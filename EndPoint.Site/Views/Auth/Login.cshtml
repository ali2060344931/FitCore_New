@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ورود</title>

    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/font-awesome.min.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/materialdesignicons.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/bootstrap.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/main.css">
</head>

<body>

    <div class="container">
        <div class="row">
            <div class="col-lg">
                <section class="page-account-box">
                    <div class="col-lg-6 col-md-8 col-xs-12 mx-auto">
                        <div class="ds-userlogin">

                            <a href="#" class="account-box-logo">
                                FitCore
                            </a>

                            <div class="account-box">

                                <div class="account-box-headline">
                                    <a href="#" class="login-ds active">
                                        <span class="title">ورود</span>
                                        <span class="sub-title">ورود به باشگاه</span>
                                    </a>

                                    <a href="~/Auth/Register" class="register-ds">
                                        <span class="title">ثبت نام</span>
                                        <span class="sub-title">ایجاد حساب</span>
                                    </a>
                                </div>

                                <div class="Login-to-account mt-4">
                                    <div class="account-box-content">

                                        <h4>ورود با شماره موبایل</h4>

                                        <div class="form-account text-right">

                                            <!-- شماره موبایل -->
                                            <div class="form-account-title">
                                                <label>شماره موبایل</label>
                                                <input type="text" class="number-email-input" id="mobile" />
                                            </div>

                                            <!-- ارسال کد -->
                                            <div class="form-row-account">
                                                <button onclick="SendOtp()" class="btn btn-primary btn-login">
                                                    ارسال کد تایید
                                                </button>
                                            </div>

                                            <hr />

                                            <!-- کد تایید -->
                                            <div class="form-account-title">
                                                <label>کد تایید</label>
                                                <input type="text" class="number-email-input" id="code" />
                                            </div>

                                            <!-- دکمه ورود مرحله اول -->
                                            <div class="form-row-account">
                                                <button onclick="VerifyOtp()" class="btn btn-success btn-login">
                                                    ورود
                                                </button>
                                            </div>


                                            <!-- بخش انتخاب باشگاه (فاز دوم لاگین) -->
                                            <div id="gymSelectionBox" style="display:none; margin-top:25px; padding-top:15px; border-top:1px solid #ccc;">

                                                <div class="form-account-title">
                                                    <label>باشگاه مورد نظر را انتخاب کنید</label>
                                                    <select id="gymSelect" class="number-email-input" style="padding:10px; width:100%;"></select>
                                                </div>

                                                <div class="form-row-account">
                                                    <button onclick="CompleteLogin()" class="btn btn-info btn-login">
                                                        ورود به پنل
                                                    </button>
                                                </div>

                                            </div>

                                            <!-- توکن مخفی -->
                                            <input type="hidden" id="loginToken" />

                                        </div>

                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </section>

            </div>
        </div>
    </div>

</body>

<!-- Scripts -->
<script src="~/SiteTemplate/assets/js/vendor/jquery-3.2.1.min.js"></script>
<script src="~/SiteTemplate/assets/js/vendor/bootstrap.js"></script>
<script src="~/SiteTemplate/assets/js/main.js"></script>

<link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
<script src="~/Sweetalert2/sweetalert2.min.js"></script>


<script>

    // -------------------------------
    // ارسال OTP
    // -------------------------------
    function SendOtp() {

    $.ajax({
    url: "/Auth/SendOtp",
    type: "POST",
    dataType: "json",
    data: {
    mobile: $("#mobile").val()
    },
    success: function (data) {

    if (data.isSuccess == true) {
    swal.fire('موفق!', data.message, 'success');
    }
    else {
    swal.fire('خطا!', data.message, 'warning');
    }
    }
    });
    }


    // -------------------------------
    // تأیید OTP (مرحله اول ورود)
    // -------------------------------
    function VerifyOtp() {

    $.ajax({
    url: "/Auth/VerifyOtp",
    type: "POST",
    dataType: "json",
    data: {
    mobile: $("#mobile").val(),
    code: $("#code").val()
    },

    success: function (data) {

    if (data.isSuccess === true) {

    // اگر نیاز به انتخاب باشگاه باشد
    if (data.needGymSelection === true) {

    $("#loginToken").val(data.loginToken);

    var gymSelect = $("#gymSelect");
    gymSelect.empty();

    $.each(data.gyms, function (i, gym) {
    gymSelect.append(new Option(gym.name, gym.id));
    });

    $("#gymSelectionBox").show();

    swal.fire('انتخاب باشگاه', 'لطفاً باشگاه مورد نظر را انتخاب کنید.', 'info');

    return;
    }

    // یک باشگاه → ورود مستقیم
    swal.fire('موفق!', data.message, 'success')
    .then(function () {
    window.location.href = "/";
    });
    }
    else {
    swal.fire('خطا!', data.message, 'warning');
    }
    }
    });
    }


    // -------------------------------
    // مرحله نهایی ورود (انتخاب باشگاه)
    // -------------------------------
    function CompleteLogin() {

    $.ajax({
    url: "/Auth/CompleteLogin",
    type: "POST",
    dataType: "json",
    data: {
    loginToken: $("#loginToken").val(),
    gymId: $("#gymSelect").val()
    },

    success: function (data) {

    if (data.isSuccess === true) {
    swal.fire('موفق!', data.message, 'success')
    .then(function () {
    window.location.href = "/";
    });
    } else {
    swal.fire('خطا!', data.message, 'warning');
    }
    }
    });
    }

</script>

</html>
