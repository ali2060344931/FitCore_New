@{
    ViewData["Title"] = "تماس با ما";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>

    body {
        background: #0f172a;
        color: white;
        font-family: Vazirmatn,sans-serif;
    }

    .section {
        padding: 90px 0;
    }

    .section-title {
        font-size: 2.2rem;
        font-weight: 800;
    }

    .section-text {
        color: #94a3b8;
    }

    .contact-card {
        background: #111827;
        border: 1px solid #1e293b;
        border-radius: 22px;
        padding: 35px;
        height: 100%;
    }

    .form-control {
        background: #020617;
        border: 1px solid #334155;
        color: white;
    }

        .form-control:focus {
            background: #020617;
            color: white;
            border-color: #2563eb;
            box-shadow: none;
        }

    .btn-main {
        background: linear-gradient(90deg,#2563eb,#06b6d4);
        border: none;
        padding: 12px 28px;
        border-radius: 12px;
        font-weight: bold;
    }

    .info-box {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
    }

    .icon-box {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        background: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .social-links {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

        .social-links a {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #020617;
            border: 1px solid #334155;
            color: white;
            font-size: 20px;
            transition: .3s;
        }

            .social-links a:hover {
                transform: translateY(-3px);
                border-color: #06b6d4;
                color: #06b6d4;
            }

    .footer {
        border-top: 1px solid #1e293b;
        color: #94a3b8;
    }

</style>

<section class="section">

    <div class="container">

        <div class="text-center mb-5">

            <h1 class="section-title">
                تماس با ما
            </h1>

            <p class="section-text mt-3">
                برای ارتباط با تیم FitCore از فرم زیر استفاده کنید.
            </p>

        </div>

        <div class="row g-4 align-items-stretch">

            <!-- فرم تماس -->

            <div class="col-lg-7">

                <div class="contact-card">

                    <form>

                        <div class="row g-3">

                            <div class="col-md-6">

                                <label class="mb-2">نام</label>

                                <input type="text"
                                       class="form-control"
                                       placeholder="نام شما">

                            </div>

                            <div class="col-md-6">

                                <label class="mb-2">ایمیل</label>

                                <input type="email"
                                       class="form-control"
                                       placeholder="example@email.com">

                            </div>

                            <div class="col-12">

                                <label class="mb-2">موضوع</label>

                                <input type="text"
                                       class="form-control"
                                       placeholder="موضوع پیام">

                            </div>

                            <div class="col-12">

                                <label class="mb-2">متن پیام</label>

<textarea class="form-control"
          rows="5"
          placeholder="پیام خود را بنویسید"></textarea>

                            </div>

                            <div class="col-12 mt-3">

                                <button class="btn btn-main">
                                    ارسال پیام
                                </button>

                            </div>

                        </div>

                    </form>

                </div>

            </div>

            <!-- اطلاعات تماس -->

            <div class="col-lg-5">

                <div class="contact-card">

                    <h4 class="mb-4">
                        اطلاعات تماس
                    </h4>

                    <div class="info-box">

                        <div class="icon-box">
                            📞
                        </div>

                        <div>

                            <div class="fw-bold">
                                شماره تماس
                            </div>

                            <div class="text-secondary">
                                09111161996 - 09021161996
                            </div>

                        </div>

                    </div>

                    <div class="info-box">

                        <div class="icon-box">
                            ✉️
                        </div>

                        <div>

                            <div class="fw-bold">
                                ایمیل
                            </div>

                            <div class="text-secondary">
                                info@fitcore.ir
                            </div>

                        </div>

                    </div>

                    <div class="info-box">

                        <div class="icon-box">
                            📍
                        </div>

                        <div>

                            <div class="fw-bold">
                                آدرس
                            </div>

                            <div class="text-secondary">
                                مازندران - بابل
                            </div>

                        </div>

                    </div>

                    <h5 class="mt-4 mb-3">
                        شبکه‌های اجتماعی
                    </h5>

                    <div class="social-links">

                        <a href="https://instagram.com/fitcore.ir" target="_blank">
                            <i class="bi bi-instagram"></i>
                        </a>

                        <a href="https://wa.me/9891111161996" target="_blank">
                            <i class="bi bi-whatsapp"></i>
                        </a>

                        <a href="https://t.me/fitcore" target="_blank">
                            <i class="bi bi-telegram"></i>
                        </a>

                        <a href="mailto:info@fitcore.ir">
                            <i class="bi bi-envelope"></i>
                        </a>

                        <a href="https://ble.ir/FitCoreBot" target="_blank">
                            <i class="bi bi-chat-dots"></i>
                        </a>

                        <a href="https://eitaa.com/fitcore" target="_blank">
                            <i class="bi bi-send"></i>
                        </a>

                    </div>

                    <div class="mt-4">

                        <a href="https://ble.ir/FitCoreBot"
                           class="btn btn-outline-light w-100">

                            ارتباط در ربات بله

                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

<footer class="footer py-4 text-center">
    © FitCore - Smart Gym Management
</footer>
