@{
    ViewData["Title"] = "FitCore | Smart Gym Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

<style>

    body {
        background: #0f172a;
        color: #e2e8f0;
        font-family: tahoma;
    }

    .navbar {
        background: #020617;
    }

    .hero {
        padding: 140px 0;
        background: radial-gradient(circle at top,#1e293b,#020617);
    }

        .hero h1 {
            font-size: 54px;
            font-weight: 800;
        }

    .gradient-text {
        background: linear-gradient(90deg,#38bdf8,#6366f1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-size: 54px;
    }

    .btn-primary {
        background: #6366f1;
        border: none;
    }

    .section {
        padding: 100px 0;
    }

    .feature-card {
        background: #020617;
        border: 1px solid #1e293b;
        padding: 35px;
        border-radius: 18px;
        transition: .4s;
    }

        .feature-card:hover {
            transform: translateY(-8px);
            border-color: #6366f1;
        }

    .stat-box {
        background: #020617;
        padding: 40px;
        border-radius: 16px;
        text-align: center;
        border: 1px solid #1e293b;
    }

        .stat-box h2 {
            font-size: 38px;
            color: #6366f1;
        }

    .bot-section {
        background: #020617;
        border-top: 1px solid #1e293b;
        border-bottom: 1px solid #1e293b;
    }

    .multi-card {
        background: #020617;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid #1e293b;
    }

    .cta {
        background: linear-gradient(135deg,#6366f1,#38bdf8);
        color: white;
        padding: 90px 0;
        text-align: center;
    }

    .footer {
        background: #020617;
        padding: 40px;
        text-align: center;
        border-top: 1px solid #1e293b;
    }


    .fc-feature-list {
        list-style: none;
        padding: 0;
        margin-top: 15px;
    }

        .fc-feature-list li {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .fc-feature-list i {
            color: #e94560;
        }



    .features-box {
        background: #111827;
        padding: 50px 30px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .features-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .features-header h2 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .features-header p {
            color: #9ca3af;
            font-size: 14px;
        }


</style>

<section class="hero">

    <div class="container text-center">

        <h1 data-aos="fade-up">

            مدیریت هوشمند باشگاه با
            <span class="gradient-text">فیتــکور FitCore </span>

        </h1>

        <p class="mt-4 lead" data-aos="fade-up">

            سیستم حرفه‌ای مدیریت باشگاه، برنامه تمرینی،
            برنامه غذایی و ارتباط با ورزشکاران

        </p>

        <div class="mt-5" data-aos="fade-up">

            <a href="/Admin/Auth/Register" class="btn btn-primary btn-lg me-3">

                شروع رایگان

            </a>

            <a href="https://ble.ir/FitCoreBot" class="btn btn-outline-light btn-lg">

                ربات بله

            </a>

        </div>

    </div>

</section>



<section class="section">

    <div class="container">

        <div class="features-box">

            <div class="features-header">
                <h2>امکانات اصلی FitCore</h2>
                <p>ابزارهای حرفه‌ای برای مدیریت باشگاه و برنامه‌های ورزشی</p>
            </div>

            <div class="row g-4">

                <div class="col-md-4" data-aos="fade-up">
                    <div class="feature-card">
                        <h4>برنامه تمرینی</h4>
                        <ul class="fc-feature-list">
                            <li><i class="fa fa-check-circle"></i> ساخت برنامه تمرینی حرفه‌ای</li>
                            <li><i class="fa fa-check-circle"></i> تعریف ست، تکرار و استراحت</li>
                            <li><i class="fa fa-check-circle"></i> زمان‌بندی روزهای تمرینی</li>
                            <li><i class="fa fa-check-circle"></i> تعیین سطح سختی حرکات</li>
                            <li><i class="fa fa-check-circle"></i> قابلیت ویرایش و بروزرسانی برنامه</li>
                            <li><i class="fa fa-check-circle"></i> ارسال درخواست برنامه تمرینی از طرف ورزشکار</li>
                            <li><i class="fa fa-check-circle"></i>PDF دریافت برنامه تمرینی با فرمت </li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up">
                    <div class="feature-card">
                        <h4>برنامه غذایی</h4>
                        <ul class="fc-feature-list">
                            <li><i class="fa fa-check-circle"></i> طراحی برنامه غذایی تخصصی</li>
                            <li><i class="fa fa-check-circle"></i> تنظیم وعده‌های غذایی</li>
                            <li><i class="fa fa-check-circle"></i> تعیین میزان کالری</li>
                            <li><i class="fa fa-check-circle"></i> تنظیم هدف افزایش یا کاهش وزن</li>
                            <li><i class="fa fa-check-circle"></i> ویرایش و مدیریت برنامه‌ها</li>
                            <li><i class="fa fa-check-circle"></i> ارسال درخواست برنامه غذایی از طرف ورزشکار</li>
                            <li><i class="fa fa-check-circle"></i>PDF دریافت برنامه غذایی با فرمت </li>

                        </ul>
                    </div>
                </div>

                <div class="col-md-4" data-aos="fade-up">
                    <div class="feature-card">
                        <h4>مدیریت اعضا</h4>
                        <ul class="fc-feature-list">
                            <li><i class="fa fa-check-circle"></i> ثبت و مدیریت اطلاعات اعضا</li>
                            <li><i class="fa fa-check-circle"></i> مشاهده تاریخچه برنامه‌ها</li>
                            <li><i class="fa fa-check-circle"></i> ثبت اندازه‌های بدنی توسط ورزشکار</li>
                            <li><i class="fa fa-check-circle"></i> پیگیری پیشرفت ورزشکاران</li>
                            <li><i class="fa fa-check-circle"></i> مدیریت کامل اعضای باشگاه</li>
                            <li><i class="fa fa-check-circle"></i> نمایش اطلاعات ورزشکاران با نمودارها</li>
                        </ul>
                    </div>
                </div>

            </div>

        </div>

    </div>

</section>



<section class="section">

    <div class="container">

        <div class="row text-center g-4">

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>10+</h2>

                    <p>باشگاه فعال</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>140+</h2>

                    <p>ورزشکار</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>1000+</h2>

                    <p>برنامه تمرینی</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>100+</h2>

                    <p>برنامه غذایی</p>

                </div>

            </div>

        </div>

    </div>

</section>



<section class="section bot-section">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-md-6">

                <h2 class="mb-4">

                    ربات بله FitCore

                </h2>

                <p>

                    بدون ورود به سایت می‌توانید
                    از طریق ربات بله با سیستم کار کنید.

                </p>

                <ul>

                    <li>ثبت نام</li>
                    <li>درخواست برنامه تمرینی</li>
                    <li>درخواست برنامه غذایی</li>
                    <li>دریافت برنامه‌ها</li>

                </ul>

                <a href="https://ble.ir/FitCoreBot" class="btn btn-primary mt-3">

                    ورود به ربات

                </a>

                <p class="mt-2">FitCoreBot</p>

            </div>


            <div class="col-md-6 text-center">

                <img src="https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=https://ble.ir/FitCoreBot">

            </div>

        </div>

    </div>

</section>



<section class="section">

    <div class="container">

        <div class="row g-4">

            <div class="col-md-6">

                <div class="multi-card h-100">

                    <h4>چند باشگاه برای یک مدیر</h4>

                    <p>
                        مدیر باشگاه می‌تواند
                        چندین باشگاه مختلف را
                        در سیستم مدیریت کند.
                    </p>

                </div>

            </div>


            <div class="col-md-6">

                <div class="multi-card h-100">

                    <h4>عضویت در چند باشگاه</h4>

                    <p>
                        ورزشکاران می‌توانند
                        در چند باشگاه مختلف عضو باشند
                        و برنامه‌های متفاوت دریافت کنند.
                    </p>

                </div>

            </div>

        </div>

    </div>

</section>



<section class="cta">

    <div class="container">

        <h2 class="mb-4">

            باشگاه خود را هوشمند مدیریت کنید

        </h2>

        <p class="mb-4">

            همین حالا در FitCore ثبت نام کنید

        </p>

        <a href="/Admin/Auth/Register" class="btn btn-light btn-lg">

            ثبت نام رایگان

        </a>

    </div>

</section>



<footer class="footer">

    <div class="container">

        <p>FitCore Smart Gym System</p>

        <p>© 2026</p>

    </div>

</footer>



<script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>

<script>

    AOS.init({
    duration:900
    });

</script>
