@{
    ViewData["Title"] = "FitCore | Smart Gym Management";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" rel="stylesheet">

<style>

    .hero,
    .section {
        max-width: 1200px; /* این مقدار را می‌توانید تغییر دهید (مثلاً 1140px یا 1320px) */
        margin-left: auto;
        margin-right: auto;
        width: 100%;
        box-sizing: border-box;
    }

    body {
        background: #0f172a;
        color: #e2e8f0;
        font-family: tahoma;
    }

    .navbar {
        background: #020617;
    }

    .hero {
        padding: 140px 0;
        background: radial-gradient(circle at top,#1e293b,#020617);
        /* border-radius برای گرد کردن گوشه‌های سکشن (اختیاری) */
        border-radius: 20px;
        margin-top: 20px; /* فاصله از بالا */
    }

        .hero h1 {
            font-size: 54px;
            font-weight: 800;
        }

    .gradient-text {
        background: linear-gradient(90deg,#38bdf8,#6366f1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-size: 54px;
    }

    .btn-primary {
        background: #6366f1;
        border: none;
    }

    .section {
        padding: 100px 0;
        /* فاصله بین سکشن‌ها */
        margin-top: 30px;
        /* اگر می‌خواهید بقیه سکشن‌ها هم گوشه‌گرد داشته باشند (اختیاری) */
        border-radius: 20px;
        overflow: hidden; /* برای اینکه محتوای داخل از گوشه‌های گرد نزن بیرون */
    }


    .feature-card {
        background: #020617;
        border: 1px solid #1e293b;
        padding: 35px;
        border-radius: 18px;
        transition: .4s;
    }

        .feature-card:hover {
            transform: translateY(-8px);
            border-color: #6366f1;
        }

    .stat-box {
        background: #020617;
        padding: 40px;
        border-radius: 16px;
        text-align: center;
        border: 1px solid #1e293b;
    }

        .stat-box h2 {
            font-size: 38px;
            color: #e52d2d;
        }

    .bot-section {
        background: #020617;
        border-top: 1px solid #1e293b;
        border-bottom: 1px solid #1e293b;
    }

    .multi-card {
        background: #020617;
        padding: 40px;
        border-radius: 16px;
        border: 1px solid #1e293b;
    }

    .cta {
        background: linear-gradient(135deg,#6366f1,#38bdf8);
        color: white;
        padding: 90px 0;
        text-align: center;
    }

    .footer {
        background: #020617;
        padding: 40px;
        text-align: center;
        border-top: 1px solid #1e293b;
    }


    .fc-feature-list {
        list-style: none;
        padding: 0;
        margin-top: 15px;
    }

        .fc-feature-list li {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 8px;
            font-size: 14px;
        }

        .fc-feature-list i {
            color: #e94560;
        }



    .features-box {
        background: #111827;
        padding: 50px 30px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .features-header {
        text-align: center;
        margin-bottom: 40px;
    }

.features-header h2 {
            font-weight: 700; /* خطا در اینجا برطرف شد */
            margin-bottom: 10px;
        }


        .features-header p {
            color: #9ca3af;
            font-size: 14px;
        }
    


</style>



<section class="hero">

    <div class="container text-center">

        <h1 data-aos="fade-up">
            <span class="d-block">مدیریت هوشمند باشگاه های بدنسازی با</span>

            <span class="gradient-text d-flex align-items-center justify-content-center gap-2">

                فیتــکور FitCore
            </span>




          @*   <span class="gradient-text d-flex align-items-center justify-content-center gap-3">

                <img src="~/AdminTemplate/app-assets/img/logos/logo_1.png"
                     asp-append-version="true"
                     alt="FitCore Logo"
                     class="fc-logo-image" />
            </span> *@


        </h1>


        <p class="mt-4 lead" data-aos="fade-up">

            سیستم حرفه‌ای مدیریت باشگاه، برنامه تمرینی،
            برنامه غذایی و ارتباط با ورزشکاران

        </p>

        <div class="mt-5" data-aos="fade-up">

            <a href="/Admin/Auth/Register" class="btn btn-primary btn-lg me-3">

                شروع رایگان

            </a>

            <a href="https://ble.ir/FitCoreBot" class="btn btn-outline-light btn-lg">

                ربات بله

            </a>

        </div>

    </div>

</section>



