@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.ViewModels.Common

@model ExerciseCreateEditViewModel

@{
    bool isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "ویرایش حرکت تمرینی" : "ثبت حرکت تمرینی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='@(isEdit ? "ویرایش حرکت تمرینی" : "ثبت حرکت تمرینی")' />

        @if (!isEdit)
        {
            @if (ViewBag.IsGlobalExercise == true)
            {
                <div class="alert alert-info">
                    <i class="fa fa-globe"></i>
                    این حرکت به‌عنوان حرکت <strong>سراسری</strong> ثبت می‌شود و
                    در بانک حرکات تمام باشگاه‌ها قابل استفاده خواهد بود.
                </div>
            }
            else
            {
                <div class="alert alert-light border">
                    <i class="fa fa-building-o"></i>
                    این حرکت فقط در بانک حرکات <strong>باشگاه شما</strong> ثبت و
                    قابل استفاده خواهد بود.
                </div>
            }
        }

        <form id="ExerciseForm">
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Name",
                             Name = "Name",
                             Value = Model.Name,
                             LabelName = Html.DisplayNameFor(m => m.Name),
                             Placeholder = "مثلاً: پرس سینه هالتر",
                             Col = 3
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "EnglishName",
                             Name = "EnglishName",
                             Value = Model.EnglishName,
                             LabelName = Html.DisplayNameFor(m => m.EnglishName),
                             Placeholder = "Bench Press",
                             Col = 3
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "PrimaryMuscleGroupId",
                             Name = "PrimaryMuscleGroupId",
                             LabelName = "گروه عضلانی اصلی",
                             Col = 2,
                             Items = ViewBag.MuscleGroups,
                             Value = Model.PrimaryMuscleGroupId.ToString()
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "EquipmentTypeId",
                             Name = "EquipmentTypeId",
                             LabelName = "نوع تجهیزات",
                             Col = 2,
                             Items = ViewBag.EquipmentTypes,
                             Value = Model.EquipmentTypeId.ToString()
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "DifficultyLevelId",
                             Name = "DifficultyLevelId",
                             LabelName = "سطح دشواری",
                             Col = 2,
                             Items = ViewBag.DifficultyLevels,
                             Value = Model.DifficultyLevelId.ToString()
                         }' />

            </div>

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "VideoUrl",
                             Name = "VideoUrl",
                             Value = Model.VideoUrl,
                             LabelName = Html.DisplayNameFor(m => m.VideoUrl),
                             Placeholder = "https://...",
                             Col = 6
                         }' />

                <div class="col-md-1 mb-3">
                    <label class="form-label font-weight-bold">فعال</label>
                    <select id="IsActive" name="IsActive" class="form-control">
                        @if (Model.IsActive)
                        {
                            <option value="true" selected>بله</option>
                            <option value="false">خیر</option>
                        }
                        else
                        {
                            <option value="true">بله</option>
                            <option value="false" selected>خیر</option>
                        }
                    </select>
                </div>

            </div>

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Description",
                             Name = "Description",
                             Value = Model.Description,
                             LabelName = Html.DisplayNameFor(m => m.Description),
                             Placeholder = "نحوه اجرای حرکت...",
                             Col = 8
                         }' />

            </div>

            <!-- آپلود تصویر حرکت -->
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label font-weight-bold">تصویر حرکت</label>

                    <div id="ImagePreviewContainer" class="mb-2 @(string.IsNullOrWhiteSpace(Model.ImagePath) ? "d-none" : "")">
                        <img id="ImagePreview"
                             src="@Model.ImagePath"
                             alt="@Model.Name"
                             style="max-width:120px;max-height:120px;border-radius:8px;object-fit:cover;" />
                    </div>

                    <input type="file" id="ExerciseImageFile" class="form-control" accept=".jpg,.jpeg,.png,.webp,.gif" />
                    <input type="hidden" id="ImagePath" name="ImagePath" value="@Model.ImagePath" />

                    <div id="ImageUploadStatus" class="mt-2"></div>

                    <small class="text-muted">
                        فرمت‌های مجاز: jpg, jpeg, png, webp, gif — حداکثر حجم: 2 مگابایت.
                        در صورت آپلود فایل جدید، تصویر قبلی جایگزین می‌شود.
                    </small>
                </div>
            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                     model='new FormButtonsViewModel
                     {
                         SubmitText = isEdit ? "ذخیره تغییرات" : "ثبت حرکت",
                         BackUrl = "/Admin/Exercise",
                         BackText = "انصراف و بازگشت"
                     }' />
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>

    <script>
        $(document).ready(function () {

            const isEdit = @(isEdit ? "true" : "false");
            let isUploadingImage = false;

            //====================================================
            // آپلود تصویر حرکت به صورت آنی (هنگام انتخاب فایل)
            //====================================================
            $("#ExerciseImageFile").on("change", function () {

                const file = this.files[0];

                if (!file) {
                    return;
                }

                // بررسی حجم فایل در سمت کلاینت (حداکثر 2 مگابایت)
                const maxSizeBytes = 2 * 1024 * 1024;

                if (file.size > maxSizeBytes) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'خطا',
                        text: 'حجم فایل نباید بیشتر از 2 مگابایت باشد'
                    });
                    $(this).val('');
                    return;
                }

                const formData = new FormData();
                formData.append('file', file);

                isUploadingImage = true;
                $("#ImageUploadStatus").html('<div class="text-muted"><i class="fa fa-spinner fa-spin"></i> در حال آپلود تصویر...</div>');

                $.ajax({
                    type: 'POST',
                    url: '/Admin/Exercise/UploadImage',
                    data: formData,
                    contentType: false,
                    processData: false,

                    success: function (response) {
                        if (response.isSuccess) {
                            $("#ImagePath").val(response.imagePath);
                            $("#ImagePreview").attr('src', response.imagePath);
                            $("#ImagePreviewContainer").removeClass('d-none');
                            $("#ImageUploadStatus").html('<div class="text-success"><i class="fa fa-check-circle"></i> تصویر با موفقیت آپلود شد</div>');
                        } else {
                            $("#ImageUploadStatus").html('<div class="text-danger"><i class="fa fa-times-circle"></i> ' + response.message + '</div>');
                            $("#ExerciseImageFile").val('');
                        }
                    },

                    error: function () {
                        $("#ImageUploadStatus").html('<div class="text-danger"><i class="fa fa-times-circle"></i> خطا در ارتباط با سرور</div>');
                        $("#ExerciseImageFile").val('');
                    },

                    complete: function () {
                        isUploadingImage = false;
                    }
                });
            });

            $("#ExerciseForm").on("submit", function (e) {
                e.preventDefault();

                // اگر آپلود تصویر هنوز در حال انجام است، اجازه ثبت فرم داده نشود
                if (isUploadingImage) {
                    Swal.fire({
                        icon: 'info',
                        title: 'لطفاً صبر کنید',
                        text: 'آپلود تصویر هنوز در حال انجام است'
                    });
                    return;
                }

                const url = isEdit
                    ? "/Admin/Exercise/Edit"
                    : "/Admin/Exercise/Create";

                const data = {
                    Id: parseInt($("#Id").val(), 10) || 0,
                    Name: $("#Name").val(),
                    EnglishName: $("#EnglishName").val(),
                    Description: $("#Description").val(),
                    PrimaryMuscleGroupId: parseInt($("#PrimaryMuscleGroupId").val(), 10) || 0,
                    EquipmentTypeId: parseInt($("#EquipmentTypeId").val(), 10) || 0,
                    DifficultyLevelId: parseInt($("#DifficultyLevelId").val(), 10) || 0,
                    VideoUrl: $("#VideoUrl").val(),
                    ImagePath: $("#ImagePath").val(),
                    IsActive: $("#IsActive").val() === "true"
                };

                $.ajax({
                    type: "POST",
                    url: url,
                    data: data,

                    success: function (response) {
                        if (response.isSuccess) {
                            Swal.fire({
                                icon: 'success',
                                title: 'موفق',
                                text: response.message,
                                timer: 1500,
                                timerProgressBar: true,
                                showConfirmButton: false
                            }).then(function () {
                                if (response.redirectUrl) {
                                    window.location.href = response.redirectUrl;
                                } else {
                                    window.location.href = "/Admin/Exercise";
                                }
                            });
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'خطا',
                                text: response.message
                            });
                        }
                    },

                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'خطا',
                            text: 'خطا در ارتباط با سرور'
                        });
                    }
                });
            });

        });
    </script>
}
