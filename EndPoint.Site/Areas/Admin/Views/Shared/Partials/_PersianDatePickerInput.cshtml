@* @model FitCore.Application.ViewModels.Common.BaseInputViewModel

@{
    var persianId = Model.Id + "_Persian";
}

<div class="col-md-@Model.Col mb-3">

    <label class="form-label fw-bold">
        @Model.LabelName
    </label>

    <input type="text"
           id="@persianId"
           class="form-control fc-persian-date"
           placeholder="@Model.Placeholder"
           value="@Model.Value"
           autocomplete="off" />

    <input type="hidden"
           id="@Model.Id"
           name="@Model.Name"
           value="@Model.Value" />

</div>

<script>

    $(document).ready(function () {

        var persianInput = $("#@persianId");
        var hiddenInput = $("#@Model.Id");

        if (persianInput.data('datepicker')) {
            return;
        }

        persianInput.persianDatepicker({

            format: 'YYYY/MM/DD',

            autoClose: true,

            initialValue: false,

            observer: true,

            calendar: {
                persian: {
                    locale: 'fa'
                }
            },

            onSelect: function () {

                hiddenInput.val(
                    persianInput.val()
                );
            }
        });

    });

</script> *@