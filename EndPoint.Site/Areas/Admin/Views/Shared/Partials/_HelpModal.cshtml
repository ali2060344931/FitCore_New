<div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content help-modal-content">

            <div class="modal-header help-modal-header">
                <div class="help-modal-title-box">
                    <div class="help-modal-icon">
                        <i class="fa fa-question-circle"></i>
                    </div>

                    <div>
                        <h5 id="helpTitle" class="modal-title help-modal-title">
                            راهنمای بخش
                        </h5>
                        <span class="help-modal-subtitle">
                            توضیحات و نکات کاربردی این قسمت
                        </span>
                    </div>
                </div>

                <button type="button"
                        class="help-modal-close"
                        data-dismiss="modal"
                        aria-label="Close">
                    <i class="fa fa-times"></i>
                </button>
            </div>

            <div class="modal-body help-modal-body">
                <div class="help-content-wrapper">
                    <div class="help-content-icon">
                        <i class="fa fa-lightbulb-o"></i>
                    </div>

                    <div id="helpContent" class="help-content-text">
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .help-modal-content {
        border: none;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 25px 70px rgba(0, 0, 0, 0.35);
        background: #ffffff;
    }

    .help-modal-header {
        background: linear-gradient(135deg, #050505, #1f2937);
        color: #ffffff;
        padding: 22px 26px;
        border-bottom: none;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .help-modal-title-box {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .help-modal-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #facc15;
        font-size: 28px;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.12);
    }

    .help-modal-title {
        color: #ffffff;
        font-size: 20px;
        font-weight: 800;
        margin: 0;
    }

    .help-modal-subtitle {
        display: block;
        margin-top: 5px;
        color: #d1d5db;
        font-size: 13px;
    }

    .help-modal-close {
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.12);
        color: #ffffff;
        font-size: 18px;
        cursor: pointer;
        transition: all 0.25s ease;
    }

        .help-modal-close:hover {
            background: #ef4444;
            color: #ffffff;
            transform: rotate(90deg);
        }

    .help-modal-body {
        padding: 28px;
        background: radial-gradient(circle at top left, rgba(250, 204, 21, 0.10), transparent 35%), linear-gradient(180deg, #ffffff, #f9fafb);
    }

    .help-content-wrapper {
        display: flex;
        gap: 18px;
        padding: 22px;
        border-radius: 18px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .help-content-icon {
        min-width: 46px;
        height: 46px;
        border-radius: 14px;
        background: #fff7ed;
        color: #f59e0b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .help-content-text {
        color: #374151;
        font-size: 15px;
        line-height: 2;
        text-align: justify;
        width: 100%;
    }

        .help-content-text p {
            margin-bottom: 12px;
        }

        .help-content-text ul {
            padding-right: 20px;
            margin-bottom: 0;
        }

        .help-content-text li {
            margin-bottom: 8px;
        }

</style>
