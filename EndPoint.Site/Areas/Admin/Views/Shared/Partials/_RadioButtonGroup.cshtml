@@model FitCore.Application.ViewModels.Common.BaseInputViewModel

<div class="col-md-@Model.Col fc-input-group">

    <label class="form-label">

        @Model.LabelName

    </label>

    <div>
        <label>@Model.LabelName</label>

        @foreach (var item in Model.Items)
        {
            <div class="form-check">
                <input type="radio"
                       name="@Model.Name"
                       value="@item.Value"
                       class="form-check-input" />

                <label class="form-check-label">
                    @item.Text
                </label>
            </div>
        }
    </div>

</div>