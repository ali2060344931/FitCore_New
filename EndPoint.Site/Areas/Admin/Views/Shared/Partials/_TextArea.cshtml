@model FitCore.Application.ViewModels.Common.BaseInputViewModel

<div class="col-md-@Model.Col fc-input-group">

    <label class="form-label">

        @Model.LabelName

    </label>

    <textarea id="@Model.Id"
              name="@Model.Name"
              class="form-control"
              rows="2"
              placeholder="@Model.Placeholder">@Model.Value</textarea>

</div>