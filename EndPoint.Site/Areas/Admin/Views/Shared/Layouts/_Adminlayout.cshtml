@using System.Security.Claims
@using FitCore.Common
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
@{
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var encryptedUserId = string.IsNullOrEmpty(userId) ? "" : SecurityUtils.EncryptId(long.Parse(userId));
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | " : "")پنل مدیریت FitCore</title>

    <link rel="shortcut icon" type="image/png" href="~/AdminTemplate/app-assets/img/ico/favicon-32.png" />

    <!-- فونت‌ها و آیکون‌ها -->
    <link rel="stylesheet" href="~/AdminTemplate/app-assets/fonts/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/AdminTemplate/app-assets/fonts/feather/style.min.css" />
    <link rel="stylesheet" href="~/AdminTemplate/app-assets/fonts/simple-line-icons/style.css" />

    <!-- کتابخانه‌های موجود -->
    <link rel="stylesheet" href="~/AdminTemplate/app-assets/vendors/css/perfect-scrollbar.min.css" />
    <link rel="stylesheet" href="~/AdminTemplate/app-assets/css/app.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/FitCorecss.css" />
    <link rel="stylesheet" href="~/css/FitCorecss_AdminLayut.css" />
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
    <link href="~/lib/select2/css/select2-bootstrap4.min.css" rel="stylesheet" />


</head>

<body>

    <!-- اورلی موبایل -->
    <div class="fc-sidebar-overlay" id="fcOverlay"></div>

    <div class="fc-layout">

        <!-- ================================
             سایدبار
        ================================ -->
        <aside class="fc-sidebar" id="fcSidebar">


            @if (User.IsSuperAdmin() || User.IsAdmin())
            {
                <!-- لوگو -->
                <a href="/admin" class="fc-sidebar-logo">
                    <div class="fc-sidebar-logo-icon">
                        <i class="fa fa-heartbeat"></i>
                    </div>
                    <div>
                        <div class="fc-sidebar-logo-text">FitCore</div>
                        <span class="fc-sidebar-logo-sub">پنل مدیریت</span>
                    </div>
                </a>
            }
            <!-- دکمه جمع شدن (دسکتاپ) -->
            <div class="fc-sidebar-footer d-none d-lg-block">
                <button class="fc-collapse-btn" id="fcCollapseBtn">
                    <i class="fa fa-angle-double-right"></i>
                    <span>جمع کردن منو</span>
                </button>
            </div>


            <!-- ناوبری -->
            <nav class="fc-nav">
                <ul style="list-style:none; padding:0; margin:0;">



                    @if (User.IsSuperAdmin() || User.IsAdmin())
                    {
                        <!-- داشبورد -->
                        <li class="fc-nav-item">
                            <a href="/admin" class="fc-nav-link" data-title="داشبورد">
                                <span class="fc-nav-icon"><i class="icon-home"></i></span>
                                <span class="fc-nav-text">داشبورد</span>
                            </a>
                        </li>
                    }
                    @if (User.IsSuperAdmin() || User.IsAdmin())
                    {
                        <!-- بخش مدیریت -->
                        <div class="fc-nav-label">مدیریت</div>

                        @if (User.IsSuperAdmin())
                        {
                            <li class="fc-nav-item has-sub" id="nav-gym">
                                <button class="fc-nav-link" data-title="باشگاه‌ها"
                                        onclick="fcToggleMenu('nav-gym')">
                                    <span class="fc-nav-icon"><i class="fa fa-building-o"></i></span>
                                    <span class="fc-nav-text">باشگاه‌ها</span>
                                    <i class="fa fa-angle-left fc-nav-arrow"></i>
                                </button>
                                <ul class="fc-nav-sub">
                                    <li>
                                        <a href="/admin/Gym/index" class="fc-nav-sub-link">
                                            <span class="fc-nav-sub-dot"></span>
                                            لیست باشگاه‌ها
                                        </a>
                                    </li>
                                    <li>
                                        <a href="/admin/Gym/Create" class="fc-nav-sub-link">
                                            <span class="fc-nav-sub-dot"></span>
                                            ثبت باشگاه جدید
                                        </a>
                                    </li>

                                </ul>
                            </li>
                        }

                        @if (User.IsAdmin())
                        {
                            <!-- بخش مدیریت — فقط برای مدیر باشگاه -->
                            @* <div class="fc-nav-label">مدیریت</div> *@

                            @if (User.IsSuperAdmin())
                            {
                                <li class="fc-nav-item has-sub" id="nav-gym">
                                    <button class="fc-nav-link" data-title="باشگاه‌ها"
                                            onclick="fcToggleMenu('nav-gym')">
                                        <span class="fc-nav-icon"><i class="fa fa-building-o"></i></span>
                                        <span class="fc-nav-text">باشگاه‌ها</span>
                                        <i class="fa fa-angle-left fc-nav-arrow"></i>
                                    </button>
                                    <ul class="fc-nav-sub">
                                        <li>
                                            <a href="/admin/Gym/index" class="fc-nav-sub-link">
                                                <span class="fc-nav-sub-dot"></span>لیست باشگاه‌ها
                                            </a>
                                        </li>
                                        <li>
                                            <a href="/admin/Gym/Create" class="fc-nav-sub-link">
                                                <span class="fc-nav-sub-dot"></span>ثبت باشگاه جدید
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }

                            <li class="fc-nav-item has-sub" id="nav-members">
                                <button class="fc-nav-link" data-title="اعضاء"
                                        onclick="fcToggleMenu('nav-members')">
                                    <span class="fc-nav-icon"><i class="icon-users"></i></span>
                                    <span class="fc-nav-text">اعضاء باشگاه</span>
                                    <i class="fa fa-angle-left fc-nav-arrow"></i>
                                </button>
                                <ul class="fc-nav-sub">
                                    <li>
                                        <a href="/admin/Members/index" class="fc-nav-sub-link">
                                            <span class="fc-nav-sub-dot"></span>لیست اعضاء
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <div class="fc-nav-label">برنامه‌ها</div>

                            <li class="fc-nav-item has-sub" id="nav-programs">
                                <button class="fc-nav-link" data-title="برنامه‌ها"
                                        onclick="fcToggleMenu('nav-programs')">
                                    <span class="fc-nav-icon"><i class="fa fa-list-alt"></i></span>
                                    <span class="fc-nav-text">برنامه‌های اعضاء</span>
                                    <i class="fa fa-angle-left fc-nav-arrow"></i>
                                </button>
                                <ul class="fc-nav-sub">
                                    <li>
                                        <a href="/admin/NutritionProgram/index" class="fc-nav-sub-link">
                                            <span class="fc-nav-sub-dot"></span>برنامه‌های غذایی
                                        </a>
                                    </li>
                                    <li>
                                        <a href="/admin/TrainingProgram/index" class="fc-nav-sub-link">
                                            <span class="fc-nav-sub-dot"></span>برنامه‌های تمرینی
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <div class="fc-nav-label">بانک اطلاعات</div>

                            <li class="fc-nav-item">
                                <a href="/admin/Food/index" class="fc-nav-link" data-title="غذاها">
                                    <span class="fc-nav-icon"><i class="fa fa-cutlery"></i></span>
                                    <span class="fc-nav-text">بانک غذاها</span>
                                </a>
                            </li>

                            <li class="fc-nav-item">
                                <a href="/admin/Exercise/index" class="fc-nav-link" data-title="حرکات">
                                    <span class="fc-nav-icon"><i class="fa fa-heartbeat"></i></span>
                                    <span class="fc-nav-text">بانک حرکات</span>
                                </a>
                            </li>


                            <li class="fc-nav-item">
                                <a href="/Admin/ProgramRequest" class="fc-nav-link" data-title="درخواست‌های برنامه"
                                   id="nav-requests-link">
                                    <span class="fc-nav-icon"><i class="fa fa-bell"></i></span>
                                    <span class="fc-nav-text">درخواست‌های برنامه</span>
                                    <span id="nav-pending-badge"
                                          style="display:none;background:#f6ad55;color:#fff;
                                        border-radius:10px;padding:1px 7px;font-size:10px;font-weight:700;margin-right:auto;">
                                    </span>
                                </a>
                            </li>


                        }
                    }
                    @if (User.IsMember() && !User.IsAdmin())
                    {
                        <div class="fc-nav-label">پرتال من</div>

                        <li class="fc-nav-item">
                            <a href="/Admin/MemberDashboard" class="fc-nav-link" data-title="داشبورد من">
                                <span class="fc-nav-icon"><i class="icon-home"></i></span>
                                <span class="fc-nav-text">داشبورد من</span>
                            </a>
                        </li>

                        <li class="fc-nav-item">
                            <a href="/Admin/MemberDashboard/MyNutritionPrograms"
                               class="fc-nav-link" data-title="برنامه غذایی">
                                <span class="fc-nav-icon"><i class="fa fa-cutlery"></i></span>
                                <span class="fc-nav-text">برنامه غذایی من</span>
                            </a>
                        </li>

                        <li class="fc-nav-item">
                            <a href="/Admin/MemberDashboard/MyTrainingPrograms"
                               class="fc-nav-link" data-title="برنامه تمرینی">
                                <span class="fc-nav-icon"><i class="fa fa-heartbeat"></i></span>
                                <span class="fc-nav-text">برنامه تمرینی من</span>
                            </a>
                        </li>

                        <div class="fc-nav-label">پروفایل</div>

                        <li class="fc-nav-item">
                            <a href="/Admin/MemberProfile/CompleteInfo"
                               class="fc-nav-link" data-title="ویرایش پروفایل">
                                <span class="fc-nav-icon"><i class="fa fa-user-circle-o"></i></span>
                                <span class="fc-nav-text">اطلاعات جسمانی</span>
                            </a>
                        </li>
                        @* / Admin / MemberProfile / BodyMeasurement / *@
                        @* /Admin/MemberProfile/BodyMeasurement/" + encryptedUserId *@

                        <li class="fc-nav-item">
                            <a href="/Admin/MemberProfile/BodyMeasurement/@encryptedUserId"
                               class="fc-nav-link" data-title="تاریخچه اندازه‌گیری">
                                <span class="fc-nav-icon"><i class="fa fa-balance-scale"></i></span>
                                <span class="fc-nav-text">تاریخچه اندازه‌گیری</span>
                            </a>
                        </li>

                        @* در بخش IsMember:  *@
                        <li class="fc-nav-item">
                            <a href="/Admin/ProgramRequest/Submit" class="fc-nav-link">
                                <span class="fc-nav-icon"><i class="fa fa-paper-plane"></i></span>
                                <span class="fc-nav-text">درخواست برنامه</span>
                            </a>
                        </li>
                        <li class="fc-nav-item">
                            <a href="/Admin/ProgramRequest/MyRequests" class="fc-nav-link">
                                <span class="fc-nav-icon"><i class="fa fa-history"></i></span>
                                <span class="fc-nav-text">درخواست‌های من</span>
                            </a>
                        </li>
                        <li class="fc-nav-item">
                            <a href="/Admin/MemberDashboard/MyTickets" class="mb-quick-btn">
                                <i class="fa fa-ticket text-primary"></i>
                                <span>تیکت‌های من</span>
                            </a>
                        </li>


                    }
                </ul>
            </nav>

            <!-- دکمه جمع شدن (دسکتاپ) -->
            @* <div class="fc-sidebar-footer d-none d-lg-block">
                <button class="fc-collapse-btn" id="fcCollapseBtn">
                    <i class="fa fa-angle-double-right"></i>
                    <span>جمع کردن منو</span>
                </button>
            </div> *@

        </aside>

        <!-- ================================
             محتوای اصلی
        ================================ -->
        <div class="fc-main" id="fcMain">

            <!-- نوار بالا -->
            <header class="fc-topbar">

                <!-- دکمه همبرگر موبایل -->
                <button class="fc-menu-toggle" id="fcMenuToggle" aria-label="منو">
                    <i class="fa fa-bars"></i>
                </button>

                <!-- عنوان صفحه -->
                <div class="fc-topbar-title">
                    @(ViewData["Title"] ?? "داشبورد")
                </div>

                <!-- آیکون‌های راست -->
                <div class="fc-topbar-actions">

                    <!-- منوی کاربر -->
                    <div class="fc-user-menu">
                        <button class="fc-user-trigger" id="fcUserTrigger">
                            <img src="~/AdminTemplate/app-assets/img/portrait/small/avatar-s-3.jpg"
                                 class="fc-user-avatar"
                                 alt="کاربر" />
                            <span class="fc-user-name">
                                @User.Identity?.Name
                            </span>
                            <i class="fa fa-angle-down" style="font-size:11px;color:var(--fc-text-muted);"></i>
                        </button>

                        <div class="fc-user-dropdown" id="fcUserDropdown">
                            <a href="#">
                                <i class="fa fa-user-o" style="width:16px;"></i>
                                پروفایل من
                            </a>
                            <a href="javascript:;">
                                <i class="fa fa-cog" style="width:16px;"></i>
                                تنظیمات
                            </a>
                            <div class="fc-user-dropdown-divider"></div>
                            <a href="/" class="danger">
                                <i class="fa fa-sign-out" style="width:16px;"></i>
                                خروج
                            </a>
                        </div>
                    </div>

                </div>

            </header>

            <!-- محتوای صفحه -->
            <main class="fc-content">
                @RenderBody()
            </main>

        </div>

    </div>
    <partial name="~/Areas/Admin/Views/Shared/Partials/_HelpModal.cshtml" />


    <div class="modal fade" id="helpModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="helpTitle"></h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body" id="helpContent"></div>
            </div>
        </div>
    </div>

    <!-- ================================
         اسکریپت‌های پایه (دقیقاً مثل قبل)
    ================================ -->
    <script src="~/AdminTemplate/app-assets/vendors/js/core/jquery-3.3.1.min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/core/popper.min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/core/bootstrap.min.js"></script>
    <script src="~/AdminTemplate/app-assets/js/persian-datepicker.min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/perfect-scrollbar.jquery.min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/prism.min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/jquery.matchHeight-min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/screenfull.min.js"></script>
    <script src="~/AdminTemplate/app-assets/vendors/js/pace/pace.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/select2/js/select2.min.js"></script>
    <script src="~/lib/select2/js/i18n/fa.js"></script>

    @RenderSection("Scripts", false)
    @RenderSection("Modals", false)

    <script>
        // ================================
        // FitCore Admin — رفتار UI
        // ================================

        // باز/بسته کردن زیرمنو
        function fcToggleMenu(id) {
        var el = document.getElementById(id);
        if (!el) return;
        var isOpen = el.classList.contains('open');

        // بستن همه زیرمنوهای دیگر
        document.querySelectorAll('.fc-nav-item.has-sub.open').forEach(function(item) {
        item.classList.remove('open');
        });

        if (!isOpen) {
        el.classList.add('open');
        }
        }

        $(document).ready(function () {

        // ---- سایدبار موبایل ----
        $('#fcMenuToggle').on('click', function () {
        $('#fcSidebar').toggleClass('mobile-open');
        $('#fcOverlay').toggleClass('show');
        });

        $('#fcOverlay').on('click', function () {
        $('#fcSidebar').removeClass('mobile-open');
        $('#fcOverlay').removeClass('show');
        });

        // ---- collapse دسکتاپ ----
        $('#fcCollapseBtn').on('click', function () {
        $('body').toggleClass('sidebar-collapsed');
        // ذخیره در localStorage
        try {
        localStorage.setItem('fc_sidebar_collapsed',
        $('body').hasClass('sidebar-collapsed') ? '1' : '0');
        } catch(e) {}
        });

        // بازیابی وضعیت collapse
        try {
        if (localStorage.getItem('fc_sidebar_collapsed') === '1') {
        $('body').addClass('sidebar-collapsed');
        }
        } catch(e) {}

        // ---- منوی کاربر ----
        $('#fcUserTrigger').on('click', function (e) {
        e.stopPropagation();
        $('#fcUserDropdown').toggleClass('show');
        });

        $(document).on('click', function () {
        $('#fcUserDropdown').removeClass('show');
        });

        // ---- فعال کردن آیتم منوی جاری ----
        var currentPath = window.location.pathname.toLowerCase();
        $('.fc-nav-link[href], .fc-nav-sub-link[href]').each(function () {
        var href = $(this).attr('href');
        if (href && href !== '#' && href !== 'javascript:;') {
        var normHref = href.replace(/^~/, '').toLowerCase();
        if (currentPath === normHref ||
        (normHref.length > 1 && currentPath.startsWith(normHref))) {
        $(this).addClass('active');
        // باز کردن والد
        var parentSub = $(this).closest('.has-sub');
        if (parentSub.length) {
        parentSub.addClass('open');
        }
        }
        }
        });

        });

        function openHelp(key) {
        $.get('/Admin/Help/Get', { key: key }, function (res) {
        $('#helpTitle').text(res.title);
        $('#helpContent').html(res.content); // پشتیبانی از HTML
        $('#helpModal').modal('show');
        });
        }

        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        tooltipTriggerList.map(function (tooltipTriggerEl) {
        return new bootstrap.Tooltip(tooltipTriggerEl)
        })



        // بارگذاری تعداد درخواست‌های در انتظار برای badge سایدبار
        if (document.getElementById('nav-pending-badge')) {
        $.get('/Admin/ProgramRequest/PendingCount', function (res) {
        if (res && res.count > 0) {
        $('#nav-pending-badge').text(res.count).show();
        }
        });
        }
    </script>

</body>
</html>
