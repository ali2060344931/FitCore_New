    <script>
        // ================================
        // FitCore Admin — رفتار UI
        // ================================

        // باز/بسته کردن زیرمنو
        function fcToggleMenu(id) {
            var el = document.getElementById(id);
            if (!el) return;
            var isOpen = el.classList.contains('open');

            // بستن همه زیرمنوهای دیگر
            document.querySelectorAll('.fc-nav-item.has-sub.open').forEach(function(item) {
                item.classList.remove('open');
            });

            if (!isOpen) {
                el.classList.add('open');
            }
        }

        $(document).ready(function () {

            // ---- سایدبار موبایل ----
            $('#fcMenuToggle').on('click', function () {
                $('#fcSidebar').toggleClass('mobile-open');
                $('#fcOverlay').toggleClass('show');
            });

            $('#fcOverlay').on('click', function () {
                $('#fcSidebar').removeClass('mobile-open');
                $('#fcOverlay').removeClass('show');
            });

            // ---- collapse دسکتاپ ----
            $('#fcCollapseBtn').on('click', function () {
                $('body').toggleClass('sidebar-collapsed');
                // ذخیره در localStorage
                try {
                    localStorage.setItem('fc_sidebar_collapsed',
                        $('body').hasClass('sidebar-collapsed') ? '1' : '0');
                } catch(e) {}
            });

            // بازیابی وضعیت collapse
            try {
                if (localStorage.getItem('fc_sidebar_collapsed') === '1') {
                    $('body').addClass('sidebar-collapsed');
                }
            } catch(e) {}

            // ---- منوی کاربر ----
            $('#fcUserTrigger').on('click', function (e) {
                e.stopPropagation();
                $('#fcUserDropdown').toggleClass('show');
            });

            $(document).on('click', function () {
                $('#fcUserDropdown').removeClass('show');
            });

            // ---- فعال کردن آیتم منوی جاری ----
            var currentPath = window.location.pathname.toLowerCase();
            $('.fc-nav-link[href], .fc-nav-sub-link[href]').each(function () {
                var href = $(this).attr('href');
                if (href && href !== '#' && href !== 'javascript:;') {
                    var normHref = href.replace(/^~/, '').toLowerCase();
                    if (currentPath === normHref ||
                        (normHref.length > 1 && currentPath.startsWith(normHref))) {
                        $(this).addClass('active');
                        // باز کردن والد
                        var parentSub = $(this).closest('.has-sub');
                        if (parentSub.length) {
                            parentSub.addClass('open');
                        }
                    }
                }
            });

        });
    </script>

