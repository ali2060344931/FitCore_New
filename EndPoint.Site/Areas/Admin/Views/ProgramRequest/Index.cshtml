@using FitCore.Application.Services.ProgramRequests
@using FitCore.Domain.Entities.ProgramRequest

@model System.Collections.Generic.List<ProgramRequestListDto>

@{
    ViewData["Title"] = "درخواست‌های برنامه";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
    int pendingCount  = ViewBag.PendingCount ?? 0;
    string curStatus  = ViewBag.CurrentStatus ?? "";
    string searchKey  = ViewBag.SearchKey ?? "";
}

<style>
    .req-status-badge {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 4px 10px; border-radius: 20px;
        font-size: 11.5px; font-weight: 600;
    }
    .req-status-badge.pending    { background:#fffbeb; color:#d97706; border:1px solid #fcd34d; }
    .req-status-badge.inprogress { background:#eff6ff; color:#2563eb; border:1px solid #93c5fd; }
    .req-status-badge.done       { background:#edfaf5; color:#059669; border:1px solid #6ee7b7; }
    .req-status-badge.rejected   { background:#fff5f5; color:#dc2626; border:1px solid #fca5a5; }

    .req-type-badge {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 3px 9px; border-radius: 6px;
        font-size: 11px; font-weight: 600;
    }
    .req-type-nutrition { background:#fffaf0; color:#c05621; border:1px solid #fbd38d; }
    .req-type-training  { background:#ebf8ff; color:#2b6cb0; border:1px solid #90cdf4; }
    .req-type-both      { background:#faf5ff; color:#6b21a8; border:1px solid #d8b4fe; }




    .req-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11.5px;
        font-weight: 600;
    }

        .req-status-badge.pending {
            background: #fffbeb;
            color: #d97706;
            border: 1px solid #fcd34d;
        }

        .req-status-badge.inprogress {
            background: #eff6ff;
            color: #2563eb;
            border: 1px solid #93c5fd;
        }

        .req-status-badge.done {
            background: #edfaf5;
            color: #059669;
            border: 1px solid #6ee7b7;
        }

        .req-status-badge.rejected {
            background: #fff5f5;
            color: #dc2626;
            border: 1px solid #fca5a5;
        }

    .req-type-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 9px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
    }

    .req-type-nutrition {
        background: #fffaf0;
        color: #c05621;
        border: 1px solid #fbd38d;
    }

    .req-type-training {
        background: #ebf8ff;
        color: #2b6cb0;
        border: 1px solid #90cdf4;
    }

    .req-type-both {
        background: #faf5ff;
        color: #6b21a8;
        border: 1px solid #d8b4fe;
    }

    /* =========================================================================
           رفع تداخل لایه‌بندی مودال با Topbar ثابت (SaaS-Level z-index Override)
           ========================================================================= */
    #updateStatusModal {
        z-index: 1200 !important; /* بالاتر از هدر با z-index 1100 */
    }

    .modal-backdrop {
        z-index: 1150 !important; /* لایه تاریک‌کننده زیر مودال و بالای هدر قرار گیرد */
    }
</style>

<div class="container-fluid mt-4">

    <!-- هدر -->
    <div class="fc-page-header mb-3">
        <div>
            <h5 class="fc-page-title mb-0">
                <i class="fa fa-bell me-2" style="color:#f6ad55;"></i>
                درخواست‌های برنامه اعضاء
            </h5>
        </div>
        @if (pendingCount > 0)
        {
            <span class="badge"
                  style="background:#fffbeb;color:#d97706;border:1.5px solid #fcd34d;
                         font-size:13px;padding:7px 14px;border-radius:10px;">
                <i class="fa fa-clock-o me-1"></i>
                @pendingCount درخواست در انتظار بررسی
            </span>
        }
    </div>

    <!-- فیلترها -->
    <div class="fc-card mb-3">
        <form method="get" asp-action="Index" asp-controller="ProgramRequest" asp-area="Admin">
            <div class="d-flex align-items-center gap-2 flex-wrap">

                <input type="text" name="searchKey" value="@searchKey"
                       class="form-control" placeholder="جستجوی نام یا موبایل عضو..."
                       style="max-width:240px;border-radius:9px;" />

                <select name="status" class="form-control" style="max-width:180px;border-radius:9px;">
                    <option value="" selected="@(curStatus == "" ? "selected" : null)">همه وضعیت‌ها</option>
                    <option value="pending"    selected="@(curStatus == "pending"    ? "selected" : null)">در انتظار بررسی</option>
                    <option value="inprogress" selected="@(curStatus == "inprogress" ? "selected" : null)">در حال آماده‌سازی</option>
                    <option value="done"       selected="@(curStatus == "done"       ? "selected" : null)">تحویل داده شد</option>
                    <option value="rejected"   selected="@(curStatus == "rejected"   ? "selected" : null)">رد شد</option>
                </select>

                <button type="submit" class="btn btn-primary"
                        style="border-radius:9px;font-size:13px;">
                    <i class="fa fa-search me-1"></i> جستجو
                </button>

                @if (!string.IsNullOrWhiteSpace(curStatus) || !string.IsNullOrWhiteSpace(searchKey))
                {
                    <a href="/Admin/ProgramRequest" class="btn btn-outline-secondary"
                       style="border-radius:9px;font-size:13px;">
                        حذف فیلتر
                    </a>
                }
            </div>
        </form>
    </div>

    <div class="fc-card">

        @if (Model == null || !Model.Any())
        {
            <div style="text-align:center;padding:50px 0;color:#a0aec0;">
                <i class="fa fa-inbox fa-3x" style="display:block;margin-bottom:12px;opacity:.35;"></i>
                هیچ درخواستی یافت نشد
            </div>
        }
        else
        {
            <!-- دسکتاپ -->
            <div class="d-none d-md-block table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>عضو</th>
                            <th>نوع درخواست</th>
                            <th>وضعیت</th>
                            <th>توضیح عضو</th>
                            <th>تاریخ ثبت</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            string badgeClass = r.Status switch
                            {
                                ProgramRequestStatus.Pending    => "pending",
                                ProgramRequestStatus.InProgress => "inprogress",
                                ProgramRequestStatus.Done       => "done",
                                _                               => "rejected"
                            };
                            string typeClass = r.RequestType switch
                            {
                                ProgramRequestType.Nutrition => "req-type-nutrition",
                                ProgramRequestType.Training  => "req-type-training",
                                _                            => "req-type-both"
                            };

                            <tr>
                                <td>
                                    <div style="font-weight:600;font-size:13px;">@r.MemberName</div>
                                    <div style="font-size:11px;color:#718096;">@r.MemberMobile</div>
                                </td>
                                <td>
                                    <span class="req-type-badge @typeClass">@r.RequestTypeLabel</span>
                                </td>
                                <td>
                                    <span class="req-status-badge @badgeClass">@r.StatusLabel</span>
                                </td>
                                <td style="max-width:200px;">
                                    <div style="font-size:12px;color:#4a5568;
                                                overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                         title="@r.MemberNote">
                                        @(r.MemberNote ?? "-")
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(r.AdminNote))
                                    {
                                        <div style="font-size:11px;color:#718096;margin-top:2px;">
                                            <i class="fa fa-reply me-1"></i>@r.AdminNote
                                        </div>
                                    }
                                </td>
                                <td style="font-size:12px;color:#718096;">
                                    @r.InsertTime.ToString("yyyy/MM/dd HH:mm")
                                </td>
                                <td>
                                    <button type="button"
                                            class="btn btn-sm"
                                            style="border-radius:8px;font-size:12px;
                                                   background:#0f1117;color:#fff;padding:5px 12px;"
                                            onclick="openUpdateModal('@r.Id','@r.StatusLabel','@r.MemberName','@r.RequestTypeLabel','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(r.AdminNote ?? ""))')">
                                        <i class="fa fa-edit me-1"></i> پاسخ / وضعیت
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- موبایل -->
            <div class="d-block d-md-none">
                @foreach (var r in Model)
                {
                    string badgeClass = r.Status switch
                    {
                        ProgramRequestStatus.Pending    => "pending",
                        ProgramRequestStatus.InProgress => "inprogress",
                        ProgramRequestStatus.Done       => "done",
                        _                               => "rejected"
                    };
                    <div style="border:1px solid #e2e8f0;border-radius:12px;padding:14px;margin-bottom:10px;">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <div style="font-weight:700;font-size:13px;">@r.MemberName</div>
                                <div style="font-size:11px;color:#718096;">@r.MemberMobile</div>
                            </div>
                            <span class="req-status-badge @badgeClass" style="font-size:10px;">@r.StatusLabel</span>
                        </div>
                        <div style="font-size:12px;color:#4a5568;margin-bottom:10px;">
                            <i class="fa fa-tag me-1"></i>@r.RequestTypeLabel
                            <span class="ms-3 text-muted">@r.InsertTime.ToString("yyyy/MM/dd")</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(r.MemberNote))
                        {
                            <div style="font-size:12px;background:#f8fafd;border-radius:7px;padding:7px 10px;margin-bottom:8px;">
                                @r.MemberNote
                            </div>
                        }
                        <button type="button"
                                class="btn btn-sm w-100"
                                style="border-radius:8px;font-size:12px;background:#0f1117;color:#fff;"
                                onclick="openUpdateModal('@r.Id','@r.StatusLabel','@r.MemberName','@r.RequestTypeLabel','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(r.AdminNote ?? ""))')">
                            <i class="fa fa-edit me-1"></i> پاسخ / تغییر وضعیت
                        </button>
                    </div>
                }
            </div>
        }

    </div>
</div>

<!-- مودال تغییر وضعیت -->
<div class="modal fade" id="updateStatusModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">
            <div class="modal-header border-0"
                 style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:16px 20px;">
                <div>
                    <h5 class="modal-title text-white mb-0" style="font-size:15px;">
                        <i class="fa fa-edit me-2" style="color:#00C896;"></i>
                        پاسخ به درخواست
                    </h5>
                    <div id="modalMemberInfo" style="font-size:12px;color:#a0aec0;margin-top:3px;"></div>
                </div>
                <button type="button" class="close text-white" data-dismiss="modal" style="opacity:.7;">&times;</button>
            </div>
            <div class="modal-body" style="padding:18px 20px;">
                <form id="updateStatusForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="modal_RequestId" name="RequestId" />

                    <div class="form-group">
                        <label style="font-size:12px;font-weight:700;color:#4a5568;">تغییر وضعیت</label>
                        <select class="form-control" name="NewStatus" id="modal_NewStatus"
                                style="border-radius:8px;">
                            <option value="1">در انتظار بررسی</option>
                            <option value="2">در حال آماده‌سازی</option>
                            <option value="3">تحویل داده شد</option>
                            <option value="4">رد شد</option>
                        </select>
                    </div>

                    <div class="form-group mb-0">
                        <label style="font-size:12px;font-weight:700;color:#4a5568;">
                            یادداشت برای عضو (اختیاری)
                        </label>
                        <textarea class="form-control" name="AdminNote" id="modal_AdminNote"
                                  rows="3" style="border-radius:8px;"
                                  placeholder="مثلاً: برنامه شما آماده شد، لطفاً بخش برنامه‌های خود را مشاهده کنید."></textarea>
                    </div>
                </form>
                <div id="updateStatusMessage" class="mt-2"></div>
            </div>
            <div class="modal-footer border-0" style="padding:12px 20px;background:#f8fafd;">
                <button type="button" class="btn btn-secondary" data-dismiss="modal"
                        style="border-radius:9px;font-size:13px;">بستن</button>
                <button type="button" id="btnUpdateStatus"
                        style="border-radius:9px;font-size:13px;padding:7px 22px;
                               background:#00C896;border:none;color:#fff;font-weight:600;">
                    <span id="btnUpdateText">ذخیره تغییرات</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script> *@

    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>


    <script>

        function openUpdateModal(id, statusLabel, memberName, requestType, adminNote) {
            $('#modal_RequestId').val(id);
            $('#modal_AdminNote').val(adminNote || '');
            $('#modalMemberInfo').text(memberName + ' — ' + requestType);
            $('#updateStatusMessage').html('');
            $('#updateStatusModal').modal('show');
        }

        $(document).on('click', '#btnUpdateStatus', function () {
            var $btn = $(this);
            $btn.prop('disabled', true);
            $('#btnUpdateText').text('در حال ذخیره...');

            $.ajax({
                url: '/Admin/ProgramRequest/UpdateStatus',
                type: 'POST',
                data: {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val(),
                    RequestId:          $('#modal_RequestId').val(),
                    NewStatus:          $('#modal_NewStatus').val(),
                    AdminNote:          $('#modal_AdminNote').val()
                },
                success: function (res) {
                    if (res.isSuccess) {
                        $('#updateStatusModal').modal('hide');
                        Swal.fire({
                            icon: 'success', title: 'ذخیره شد',
                            text: res.message,
                            timer: 1500, timerProgressBar: true,
                            showConfirmButton: false
                        }).then(function () { location.reload(); });
                    } else {
                        $('#updateStatusMessage').html(
                            '<div class="alert alert-danger" style="border-radius:8px;font-size:13px;">' +
                            res.message + '</div>');
                    }
                },
                error: function () {
                    $('#updateStatusMessage').html(
                        '<div class="alert alert-danger" style="border-radius:8px;font-size:13px;">خطا در ارتباط با سرور</div>');
                },
                complete: function () {
                    $btn.prop('disabled', false);
                    $('#btnUpdateText').text('ذخیره تغییرات');
                }
            });
        });

    </script>
}
