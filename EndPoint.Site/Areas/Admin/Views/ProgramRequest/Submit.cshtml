@{
    ViewData["Title"] = "درخواست برنامه";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4" style="max-width:640px;">

    <div class="fc-card">

        <div style="text-align:center;margin-bottom:24px;">
            <div style="width:60px;height:60px;border-radius:50%;
                        background:linear-gradient(135deg,#00C896,#0fa0d0);
                        display:inline-flex;align-items:center;justify-content:center;
                        font-size:24px;color:#fff;margin-bottom:12px;">
                <i class="fa fa-paper-plane"></i>
            </div>
            <h5 style="font-weight:700;margin-bottom:4px;">درخواست برنامه از مربی</h5>
            <p style="color:#718096;font-size:13px;margin:0;">
                درخواست خود را ارسال کنید — مربی باشگاه در اسرع وقت برنامه شما را آماده می‌کند
            </p>
        </div>

        <form id="submitRequestForm">
            @Html.AntiForgeryToken()

            <!-- نوع برنامه -->
            <div class="form-group mb-4">
                <label style="font-size:13px;font-weight:700;color:#4a5568;display:block;margin-bottom:12px;">
                    چه برنامه‌ای می‌خواهید؟ <span style="color:#e53e3e;">*</span>
                </label>

                <div class="row g-2">
                    <div class="col-4">
                        <label class="req-type-card" for="typeNutrition">
                            <input type="radio" name="requestType" id="typeNutrition" value="1" />
                            <div class="req-type-card-inner">
                                <i class="fa fa-cutlery" style="color:#f6ad55;font-size:22px;"></i>
                                <span>برنامه غذایی</span>
                            </div>
                        </label>
                    </div>
                    <div class="col-4">
                        <label class="req-type-card" for="typeTraining">
                            <input type="radio" name="requestType" id="typeTraining" value="2" />
                            <div class="req-type-card-inner">
                                <i class="fa fa-heartbeat" style="color:#63b3ed;font-size:22px;"></i>
                                <span>برنامه تمرینی</span>
                            </div>
                        </label>
                    </div>
                    <div class="col-4">
                        <label class="req-type-card" for="typeBoth">
                            <input type="radio" name="requestType" id="typeBoth" value="3" />
                            <div class="req-type-card-inner">
                                <i class="fa fa-star" style="color:#b794f4;font-size:22px;"></i>
                                <span>هر دو</span>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- توضیحات -->
            <div class="form-group mb-4">
                <label style="font-size:13px;font-weight:700;color:#4a5568;">
                    هدف / توضیحات (اختیاری)
                </label>
                <textarea name="memberNote" rows="4" class="form-control mt-1"
                          style="border-radius:10px;"
                          placeholder="مثلاً: می‌خواهم وزن کم کنم، آلرژی به لبنیات دارم، سطح مبتدی هستم..."></textarea>
            </div>

            <div id="submitRequestMessage" class="mb-3"></div>

            <button type="button" id="btnSubmitRequest"
                    class="btn w-100"
                    style="background:#00C896;color:#fff;border-radius:10px;
                           font-size:14px;font-weight:700;padding:12px;">
                <i class="fa fa-paper-plane me-2"></i>
                <span id="btnSubmitText">ارسال درخواست</span>
            </button>
        </form>

        <div style="text-align:center;margin-top:16px;">
            <a href="/Admin/ProgramRequest/MyRequests"
               style="font-size:12px;color:#718096;text-decoration:none;">
                <i class="fa fa-history me-1"></i> مشاهده درخواست‌های قبلی
            </a>
        </div>

    </div>
</div>

<style>
    .req-type-card input[type="radio"] { display: none; }

    .req-type-card-inner {
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 16px 10px;
        text-align: center;
        cursor: pointer;
        transition: all .2s;
        display: flex; flex-direction: column;
        align-items: center; gap: 8px;
        font-size: 12px; font-weight: 600;
        color: #4a5568;
        background: #f8fafd;
    }

    .req-type-card input:checked + .req-type-card-inner {
        border-color: #00C896;
        background: #edfaf5;
        color: #00C896;
    }

    .req-type-card-inner:hover {
        border-color: #00C896;
        transform: translateY(-2px);
    }
</style>

@section Scripts {
    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script>

        $(document).on('click', '#btnSubmitRequest', function () {

            var requestType = $('input[name="requestType"]:checked').val();
            if (!requestType) {
                Swal.fire({
                    icon: 'warning', title: 'انتخاب نشده',
                    text: 'لطفاً نوع برنامه مورد نظر را انتخاب کنید.'
                });
                return;
            }

            var $btn = $(this);
            $btn.prop('disabled', true);
            $('#btnSubmitText').text('در حال ارسال...');

            $.ajax({
                url:  '/Admin/ProgramRequest/Submit',
                type: 'POST',
                data: {
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val(),
                    requestType: requestType,
                    memberNote:  $('textarea[name="memberNote"]').val()
                },
                success: function (res) {
                    if (res.isSuccess) {
                        Swal.fire({
                            icon: 'success',
                            title: 'درخواست ارسال شد!',
                            text: res.message,
                            confirmButtonText: 'باشه',
                            confirmButtonColor: '#00C896'
                        }).then(function () {
                            window.location.href = '/Admin/ProgramRequest/MyRequests';
                        });
                    } else {
                        $('#submitRequestMessage').html(
                            '<div class="alert alert-warning" style="border-radius:10px;font-size:13px;">' +
                            '<i class="fa fa-exclamation-triangle me-2"></i>' + res.message + '</div>');
                    }
                },
                error: function () {
                    $('#submitRequestMessage').html(
                        '<div class="alert alert-danger" style="border-radius:10px;font-size:13px;">خطا در ارتباط با سرور</div>');
                },
                complete: function () {
                    $btn.prop('disabled', false);
                    $('#btnSubmitText').text('ارسال درخواست');
                }
            });
        });

    </script>
}
