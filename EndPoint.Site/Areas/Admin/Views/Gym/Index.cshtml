@using FitCore.Application.Services.Gyms.Commands.AddGym
@model List<GymDto>

@{
    ViewData["Title"] = "باشگاه ها";

    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var searchKey =
        Context.Request.Query["SearchKey"].ToString();

    int pageSize = 3;

    int currentPage = 1;

    if (Context.Request.Query.ContainsKey("page"))
    {
        int.TryParse(
            Context.Request.Query["page"],
            out currentPage);

        if (currentPage <= 0)
        {
            currentPage = 1;
        }
    }

    int totalItems = Model.Count();

    int totalPages =
        (int)Math.Ceiling((double)totalItems / pageSize);

    var gyms = Model
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();
}

<div class="container-fluid mt-4">

    <!-- Header -->

    <div class="fc-page-header">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"لیست باشگاه ها"' />

        <a asp-area="Admin"
           asp-controller="Gym"
           asp-action="Create"
           class="btn btn-success">

            + ثبت باشگاه جدید

        </a>

    </div>

    <!-- Search Box -->

    <partial name="~/Areas/Admin/Views/Shared/Partials/_SearchBox.cshtml"
             model="searchKey" />

    <!-- Card -->

    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardStart.cshtml" />

    <div class="mb-3">

        تعداد کل باشگاه ها :

        <strong>
            @totalItems
        </strong>

    </div>

    @if (gyms.Any())
    {
        <table class="table table-striped table-hover">

            <thead>

                <tr>

                    <th>نام باشگاه</th>

                    <th>کد باشگاه</th>

                    <th>شماره موبایل</th>

                    <th>توضیحات</th>

                    <th width="180">
                        عملیات
                    </th>

                </tr>

            </thead>

            <tbody>

                @foreach (var item in gyms)
                {
                    <tr>

                        <td>

                            <strong>
                                @item.Name
                            </strong>

                        </td>

                        <td>
                            @item.Code
                        </td>

                        <td>
                            @item.MobileNumber
                        </td>

                        <td>

                            @(string.IsNullOrWhiteSpace(item.Description)
                                ? "---"
                                : item.Description)

                        </td>

                        <td>

                            <div class="fc-action-buttons">

                                <div class="fc-action-buttons">

                                    <a asp-action="Edit"
                                       asp-route-code="@item.Code"
                                       class="btn btn-warning btn-sm">

                                        ویرایش

                                    </a>
                                    <a asp-action="CompleteGymInfo"
                                       asp-route-code="@item.Code"
                                       class="btn btn-info btn-sm">
                                        اطلاعات تکمیلی
                                    </a>

                                    <button type="button"
                                            class="btn btn-danger btn-sm"
                                            onclick="DeleteGym(@item.Id)">
                                        حذف
                                    </button>

                                </div>
                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="fc-pagination">

                @if (currentPage > 1)
                {
                    <a href="?page=@(currentPage - 1)&SearchKey=@searchKey">

                        قبلی

                    </a>
                }

                @for (int i = 1; i <= totalPages; i++)
                {
                    if (i == currentPage)
                    {
                        <span class="active">

                            @i

                        </span>
                    }
                    else
                    {
                        <a href="?page=@i&SearchKey=@searchKey">

                            @i

                        </a>
                    }
                }

                @if (currentPage < totalPages)
                {
                    <a href="?page=@(currentPage + 1)&SearchKey=@searchKey">

                        بعدی

                    </a>
                }

            </div>
        }
    }
    else
    {
        <partial name="~/Areas/Admin/Views/Shared/Partials/_EmptyState.cshtml"
                 model='"هیچ باشگاهی ثبت نشده است"' />
    }

    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardEnd.cshtml" />

</div>

@section Scripts
{
    @* <link href="~/lib/Sweetalert2/sweetalert2.min.css"
          rel="stylesheet" />

    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script> *@
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>


    <script>

        function DeleteGym(Id) {

        swal.fire({

        title: 'حذف باشگاه',

        text: "آیا از حذف باشگاه مطمئن هستید؟",

        icon: 'warning',

        showCancelButton: true,

        confirmButtonColor: '#d33',

        cancelButtonColor: '#7cacbe',

        confirmButtonText: 'بله، حذف شود',

        cancelButtonText: 'خیر'

        }).then((result) => {

        if (result.value) {

        var postData = {

        'Id': Id

        };

        $.ajax({

        contentType: 'application/x-www-form-urlencoded',

        dataType: 'json',

        type: "POST",

        url: "/Admin/Gym/Delete",

        data: postData,

        success: function (data) {

        if (data.isSuccess == true) {

        swal.fire(

        'موفق!',

        data.message,

        'success'

        ).then(function () {

        location.reload();

        });

        }
        else {

        swal.fire(

        'هشدار!',

        data.message,

        'warning'

        );

        }

        },

        error: function (request, status, error) {

        swal.fire(

        'خطا!',

        'مشکلی در ارتباط با سرور رخ داده است',

        'error'

        );

        }

        });

        }

        });

        }

    </script>
}