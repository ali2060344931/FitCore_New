@using FitCore.Application.ViewModels.Gyms
@model CreateGymDto

@{
    ViewData["Title"] = "ثبت باشگاه جدید";
    Layout = "_Adminlayout";
}

<div class="container">
    <div class="row">
        <div class="col-lg-10 mx-auto">

            <section class="page-account-box">

                <div class="account-box">

                    <div class="account-box-headline">
                        <span class="title">ثبت باشگاه جدید</span>
                    </div>

                    <div class="account-box-content p-4">

                        <form id="CreateMemberForm">

                            <div class="card-body">

                                @*                                 <div class="col-md-6 mb-3">
                                    <label></label>
                                    <input type="text" class="form-control"
                                           id="Name" placeholder="@Html.DisplayNameFor(x => x.Name)" />
                                </div>
 *@

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name"
                                           id="Name"
                                           class="form-control"
                                           placeholder="@Html.DisplayNameFor(x => x.Name)" />

                                    <span asp-validation-for="Name"
                                          class="text-danger"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Code" class="form-label"></label>
                                    <input asp-for="Code"
                                           id="Code"
                                           class="form-control"
                                           placeholder="@Html.DisplayNameFor(x => x.Code)" />

                                    <span asp-validation-for="Name"
                                          class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="MobileNumber" class="form-label"></label>
                                    <input asp-for="MobileNumber"
                                           id="MobileNumber"
                                           class="form-control"
                                           placeholder="@Html.DisplayNameFor(x => x.MobileNumber)" />

                                    <span asp-validation-for="Name"
                                          class="text-danger"></span>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label asp-for="Description" class="form-label"></label>

                                    <!-- تغییر از input به textarea -->
                                    <textarea asp-for="Description"
                                              id="Description"
                                              class="form-control"
                                              placeholder="@Html.DisplayNameFor(x => x.Description)"
                                              rows="4">
                                          </textarea>

                                    <span asp-validation-for="Description"
                                          class="text-danger"></span>
                                </div>



                                @*                                 <div class="col-md-6 mb-3">
                                    <label></label>
                                    <input type="text" class="form-control"
                                           id="Code" placeholder="@Html.DisplayNameFor(x => x.Code)" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label></label>
                                    <input type="text" class="form-control"
                                           id="MobileNumber"
                                           placeholder="@Html.DisplayNameFor(x => x.MobileNumber)" />
                                </div>

                                <div class="form-group">
                                    <label></label>
                                    <textarea class="form-control"
                                              id="Description"
                                              placeholder="@Html.DisplayNameFor(x => x.Description)"
                                              rows="2"></textarea>
                                </div>
 *@
                            </div>

                            <div class="card-footer">

                                <button type="button"
                                        onclick="CreateGym()"
                                        class="btn btn-primary">
                                    ثبت باشگاه
                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </section>

        </div>
    </div>
</div>

@section Scripts {
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <partial name="_ValidationScriptsPartial" />



    <script>

        function CreateGym() {

        var data = {

        Name: $("#Name").val(),
        Code: $("#Code").val(),
        Description: $("#Description").val(),
        MobileNumber: $("#MobileNumber").val(),

        };

        $.ajax({

        type: "POST",
        url: "/Admin/Gym/Create",
        data: data,

        success: function (data) {

        if (data.isSuccess == true) {

        swal.fire(
        'موفق!',
        data.message,
        'success'
        ).then(function () {

        window.location.href = '/Admin/Gym';
        });
        }
        else {

        swal.fire(
        'هشدار!',
        data.message,
        'warning'
        );
        }
        },

        error: function (request) {

        alert(request.responseText);
        }

        });
        }

    </script>

}