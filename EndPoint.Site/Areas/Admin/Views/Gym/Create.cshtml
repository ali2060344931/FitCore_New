@using FitCore.Application.ViewModels.Gyms
@using FitCore.Application.ViewModels.Common

@model CreateGymDto

@{
    ViewData["Title"] = "ثبت باشگاه جدید";

    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">

    <div class="fc-form-container">

        <!-- Title -->
        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"ثبت باشگاه جدید"' />

        @* <h2 class="fc-form-title">

            ثبت باشگاه جدید

        </h2> *@

        <!-- Form -->

        <form id="CreateGymForm">

            <div class="row">


                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "FullName",

                             Name = "FullName",

                             LabelName = @Html.DisplayNameFor(m => m.FullName),

                             Placeholder = @Html.DisplayNameFor(m => m.FullName),

                             Col = 6
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "MobileNumber",

                             Name = "MobileNumber",

                             LabelName = @Html.DisplayNameFor(m => m.MobileNumber),

                             Placeholder = @Html.DisplayNameFor(m => m.MobileNumber),

                             Col = 2
                         }' />


                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Name",

                             Name = "Name",

                             LabelName = @Html.DisplayNameFor(m => m.Name),

                             Placeholder = @Html.DisplayNameFor(m => m.Name),

                             Col = 6
                         }' />


<partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "Code",

             Name = "Code",

             LabelName = @Html.DisplayNameFor(m => m.Code),

             Placeholder = @Html.DisplayNameFor(m => m.Code),

             Col = 2
         }' />




<partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
         model='new BaseInputViewModel
         {
             Id = "Description",

             Name = "Description",

             LabelName = @Html.DisplayNameFor(m => m.Description),

             Placeholder = @Html.DisplayNameFor(m => m.Description),

             Col = 6
         }' />

</div>

            <!-- Buttons -->
            @* <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml" /> *@
<partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml" 
         model='new FitCore.Application.ViewModels.Common.FormButtonsViewModel 
         { 
             SubmitText = "ذخیره تغییرات", 
             BackUrl = "/Admin/Gym", 
             BackText = "انصراف و بازگشت" 
         }' />        
        
        
        
        
        
        </form>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    @* <link href="~/lib/Sweetalert2/sweetalert2.min.css"
          rel="stylesheet" />

    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script> *@
    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>


    <script>

        $("#CreateGymForm").submit(function (e) {

        e.preventDefault();

        var data = {

        FullName: $("#FullName").val(),
        Name: $("#Name").val(),

        Code: $("#Code").val(),

        MobileNumber: $("#MobileNumber").val(),

        Description: $("#Description").val()
        };

        $.ajax({

        type: "POST",

        url: "/Admin/Gym/Create",

        data: data,

        success: function (data) {

        if (data.isSuccess == true) {

        Swal.fire({

        icon: 'success',

        title: 'موفق',

        text: data.message

        }).then(() => {

        window.location.href = "/Admin/Gym";

        });
        }
        else {

        Swal.fire({

        icon: 'warning',

        title: 'هشدار',

        text: data.message

        });
        }
        },

        error: function () {

        Swal.fire({

        icon: 'error',

        title: 'خطا',

        text: 'خطایی رخ داده است'

        });
        }

        });

        });

    </script>
}