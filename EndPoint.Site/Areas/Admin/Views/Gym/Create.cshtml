@using FitCore.Application.ViewModels.Gyms
@model CreateGymDto

@{
    ViewData["Title"] = "ثبت باشگاه جدید";
    Layout = "_Adminlayout";
}

<div class="container">
    <div class="row">
        <div class="col-lg-10 mx-auto">

            <section class="page-account-box">

                <div class="account-box">

                    <div class="account-box-headline">
                        <span class="title">ثبت باشگاه جدید</span>
                    </div>

                    <div class="account-box-content p-4">

                        <form id="CreateMemberForm">

                            <div class="card-body">

@*                                 <div class="col-md-6 mb-3">
                                    <label>نام باشگاه</label>
                                    <input type="text" class="form-control"
                                           id="Name" placeholder="نام باشگاه" />
                                </div>
 *@

                                <div class="col-md-6 mb-3">

                                    <label asp-for="Name" class="form-label"></label>

                                    <input asp-for="Name"
                                           id="Name"
                                           class="form-control"
                                           placeholder="@Html.DisplayNameFor(x => x.Name)" />

                                    <span asp-validation-for="Name"
                                          class="text-danger"></span>
                                </div>




                                <div class="col-md-6 mb-3">
                                    <label>کد باشگاه</label>
                                    <input type="text" class="form-control"
                                           id="Code" placeholder="کد باشگاه" />
                                </div>

                                <div class="col-md-6 mb-3">
                                    <label>موبایل</label>
                                    <input type="text" class="form-control"
                                           id="MobileNumber"
                                           placeholder="شماره موبایل" />
                                </div>

                                <div class="form-group">
                                    <label>توضیحات</label>
                                    <textarea class="form-control"
                                              id="Description"
                                              placeholder="توضیحات راجع به باشگاه"
                                              rows="2"></textarea>
                                </div>
                                
                            </div>

                            <div class="card-footer">

                                <button type="button"
                                        onclick="CreateGym()"
                                        class="btn btn-primary">
                                    ثبت باشگاه
                                </button>

                            </div>

                        </form>

                    </div>

                </div>

            </section>

        </div>
    </div>
</div>

@section Scripts {
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <partial name="_ValidationScriptsPartial" />



    <script>

        function CreateGym() {

        var data = {

        Name: $("#Name").val(),
        Code: $("#Code").val(),
        Description: $("#Description").val(),
        MobileNumber: $("#MobileNumber").val(),

        };

        $.ajax({

        type: "POST",
        url: "/Admin/Gym/Create",
        data: data,

        success: function (data) {

        if (data.isSuccess == true) {

        swal.fire(
        'موفق!',
        data.message,
        'success'
        ).then(function () {

        window.location.href = '/Admin/Gym';
        });
        }
        else {

        swal.fire(
        'هشدار!',
        data.message,
        'warning'
        );
        }
        },

        error: function (request) {

        alert(request.responseText);
        }

        });
        }

    </script>

}