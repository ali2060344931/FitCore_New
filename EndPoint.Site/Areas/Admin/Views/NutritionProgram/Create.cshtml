@using FitCore.Application.Services.NutritionPrograms.Commands.AddNutritionProgram
@using FitCore.Application.ViewModels.Common

@model RequestAddNutritionProgramDto

@{
    ViewData["Title"] = "ثبت برنامه غذایی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"ثبت برنامه غذایی"' />

        <form id="CreateNutritionProgramForm">

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Title",
                             Name = "Title",
                             LabelName = Html.DisplayNameFor(m => m.Title),
                             Placeholder = Html.DisplayNameFor(m => m.Title),
                             Col = 6
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "ProgramTypeId",
                             Name = "ProgramTypeId",
                             LabelName = "نوع برنامه",
                             Col = 2,
                             Items = ViewBag.ProgramTypes
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "GoalTypeId",
                             Name = "GoalTypeId",
                             LabelName = "هدف برنامه",
                             Col = 2,
                             Items = ViewBag.GetGoalTypes
                         }' />
            </div>


            <div class="row">


                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "StartDate",
                             Name = "StartDate",
                             LabelName = Html.DisplayNameFor(m => m.StartDate),
                             Placeholder = "مثال: 1370/05/20",
                             Col = 2
                         }' />



                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "EndDate",
                             Name = "EndDate",
                             LabelName = Html.DisplayNameFor(m => m.EndDate),
                             Placeholder = "مثال: 1370/05/20",
                             Col = 2
                         }' />


            </div>


            @* <div class="row">

                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label font-weight-bold">
                        @Html.DisplayNameFor(m => m.StartDate)
                    </label>

                    <input type="text"
                           id="StartDate"
                           name="StartDate"
                           class="form-control"
                           readonly
                           style="background-color:#fff;cursor:pointer;" />
                </div>





                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label font-weight-bold">
                        @Html.DisplayNameFor(m => m.EndDate)
                    </label>

                    <input type="text"
                           id="EndDate"
                           name="EndDate"
                           class="form-control"
                           readonly
                           style="background-color:#fff;cursor:pointer;" />
                </div>

            </div> *@


            <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                     model='new BaseInputViewModel
                     {
                         Id = "Description",
                         Name = "Description",
                         LabelName = Html.DisplayNameFor(m => m.Description),
                         Placeholder = Html.DisplayNameFor(m => m.Description),
                         Col = 6
                     }' />


            @* <div class="row">

                <div class="col-md-12 mb-3">
                    <label asp-for="Description" class="form-label font-weight-bold">
                        توضیحات
                    </label>

                    <textarea asp-for="Description"
                              id="Description"
                              rows="5"
                              class="form-control">
                    </textarea>
                </div>

            </div> *@

            <div class="row">

                <div class="col-md-2 mb-3">
                    <label class="form-label font-weight-bold">
                        فعال
                    </label>

                    <select id="IsActive"
                            name="IsActive"
                            class="form-control">

                        <option value="true">بله</option>
                        <option value="false">خیر</option>

                    </select>
                </div>

            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                     model='new FormButtonsViewModel
                     {
                         SubmitText = "ثبت برنامه غذایی",
                         BackUrl = "/Admin/NutritionProgram",
                         BackText = "انصراف و بازگشت"
                     }' />

        </form>

    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>

        $(document).ready(function () {

            $("#StartDate").persianDatepicker({
                format: 'YYYY/MM/DD',
                autoClose: true,
                initialValue: false
            });

            $("#EndDate").persianDatepicker({
                format: 'YYYY/MM/DD',
                autoClose: true,
                initialValue: false
            });

            $("#CreateNutritionProgramForm").submit(function (e) {

                e.preventDefault();

                var data = {

                    Title: $("#Title").val(),
                    Description: $("#Description").val(),

                    ProgramTypeId:
                        parseInt($("#ProgramTypeId").val()),

                    GoalTypeId:
                        parseInt($("#GoalTypeId").val()),

                    StartDate:
                        $("#StartDate").val(),

                    EndDate:
                        $("#EndDate").val(),

                    IsActive:
                        $("#IsActive").val() === "true"
                };

                $.ajax({

                    type: "POST",

                    url: "/Admin/NutritionProgram/Create",

                    data: data,

                    success: function (response) {

                        if (response.isSuccess) {

                            Swal.fire({
                                icon: 'success',
                                title: 'موفق',
                                text: response.message
                            }).then(() => {

                                window.location.href =
                                    "/Admin/NutritionProgram";
                            });
                        }
                        else {

                            Swal.fire({
                                icon: 'warning',
                                title: 'خطا',
                                text: response.message
                            });
                        }
                    },

                    error: function () {

                        Swal.fire({
                            icon: 'error',
                            title: 'خطا',
                            text: 'خطا در ارتباط با سرور'
                        });
                    }
                });

            });

        });

    </script>
}