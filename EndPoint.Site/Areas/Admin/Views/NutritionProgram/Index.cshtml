        function sendProgramNotificationToUser(programId) {
            Swal.fire({
                title: 'اطلاع‌رسانی برنامه',
                text: 'آیا از ارسال اطلاع‌رسانی به کاربر در ربات بله مطمئن هستید؟',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'بله، ارسال شود',
                cancelButtonText: 'انصراف',
                allowOutsideClick: false
            }).then((result) => {

                // فقط این خط تغییر کرد (value به جای isConfirmed)
                if (result.value) {

                    var token = $('input[name="__RequestVerificationToken"]').val();

                    $.ajax({
                        url: '/Admin/NutritionProgramBuilder/SendNotification',
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: token,
                            programId: programId
                        },
                        success: function (response) {
                            if (response.isSuccess) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'موفق',
                                    text: response.message,
                                    confirmButtonText: 'باشه'
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'خطا',
                                    text: response.message,
                                    confirmButtonText: 'متوجه شدم'
                                });
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire({
                                icon: 'error',
                                title: 'خطای سرور',
                                text: 'درخواست با خطا مواجه شد. (شماره خطا: ' + xhr.status + ')',
                                confirmButtonText: 'بستن'
                            });
                        }
                    });
                }
            });
        }

    </script>
}