@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.Services.NutritionPrograms.Queries.GetNutritionProgram
@using FitCore.Common

<!-- برای صفحه بندی لیست -->
@model ResultGetNutritionProgramsDto
@{
    var pagingVm = new PagingPartialViewModel
    {
        RowCount = Model.RowCount,
        CurrentPage = Model.CurrentPage,
        PageSize = Model.PageSize,
        PageQueryKey = "page",

        PageSizeQueryKey = "PageSize"
    };

}
<!-- برای صفحه بندی لیست -->
@{
    ViewData["Title"] = "لیست برنامه غذایی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var searchKey = Context.Request.Query["SearchKey"].ToString();
    var isFiltered = !string.IsNullOrWhiteSpace(searchKey);
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="fc-page-header">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"لیست بــرنامه های غذایی اعضاء"' />

        @* <a asp-area="Admin"
           asp-controller="Members"
           asp-action="Create"
           class="btn btn-success">

            +  ثبت برنامه جدید تستی
        </a> *@

    </div>

    <!-- Search Box -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_SearchBox.cshtml"
             model="searchKey" />

    <!-- Card -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardStart.cshtml" />

    <div class="mb-3">

        تعداد کل برنامه :

        <strong>
            @Model.RowCount
        </strong>

        @if (isFiltered)
        {
            <span class="ms-2">
                (نتایج فیلتر: <strong>@Model.NutritionPrograms.Count</strong>)
            </span>

            <a href="/Admin/Members" class="btn btn-warning btn-sm ms-2">
                نمایش همه (@Model.RowCount)
            </a>
        }

    </div>
    @if (Model.NutritionPrograms != null && Model.NutritionPrograms.Any())
    {
        <table class="table table-striped table-hover">

            <thead>
                <tr>
                    @if(User.IsAdmin())
                    {
                        <th>نام و نام خانوادگی متقاضی</th>
                        <th>تلفن همراه</th>
                    }
                    
                    <th>هدف برنامه</th>
                    <th>نوع برنامه غذایی</th>
                    <th>تاریخ شروع</th>
                    <th>تاریخ پایان</th>
                    <th>فعـــال</th>
                    <th>تعداد روز ثبتی</th>
                    <th width="180">عملیات</th>
                </tr>
            </thead>

           
            <tbody>
                @foreach (var item in Model.NutritionPrograms)
                {
                    <tr>

                        @if (User.IsAdmin())
                        {
                            <td>
                                <i class="fa fa-user-o"></i>
                                <strong style="color:#520A0A;">@item.MemberName</strong>
                            </td>

                            <td>
                                <i class="fa fa-mobile"></i>
                                @item.MemberMobile
                            </td>

                        }

                        <td>@item.GoalType</td>
                        <td>@item.ProgramType</td>
                        <td>@item.StartDate</td>
                        <td>@item.EndDate</td>

                        <td>
                            @(item.IsActive ? "بله" : "خیر")
                        </td>

                        <td>
                            <span class="badge rounded-sm border-success">
                                @item.CountProgramBuilder
                            </span>
                        </td>

                        <td>
                            <div class="dropdown">
                                <button class="btn btn-secondary btn-sm dropdown-toggle"
                                        type="button"
                                        id="nutritionProgramActions_@item.Id"
                                        data-toggle="dropdown"
                                        data-boundary="viewport"
                                        aria-haspopup="true"
                                        aria-expanded="false">
                                    عملیات
                                </button>

                                <div class="dropdown-menu dropdown-menu-right text-right"
                                     aria-labelledby="nutritionProgramActions_@item.Id">
                                    @if (User.IsAdmin())
                                    {
                                        <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="NutritionProgramBuilder"
                                           asp-action="Index"
                                           asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                            <i class="fa fa-th-list"></i>
                                            مشاهده و ثبت برنامه غذایی
                                        </a>

                                        <a class="dropdown-item"
                                           asp-area="Admin"
                                           asp-controller="NutritionProgram"
                                           asp-action="Edit"
                                           asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                            <i class="fa fa-pencil-square-o"></i>
                                            ویرایش
                                        </a>

                                        <div class="dropdown-divider"></div>

                                        <button type="button"
                                                class="dropdown-item text-danger"
                                                onclick="NutritionProgram('@SecurityUtils.EncryptId(item.Id)')">
                                            <i class="fa fa-times"></i>
                                            حذف
                                        </button>

                                    }

                                    <a class="dropdown-item"
                                       asp-area="Admin"
                                       asp-controller="NutritionProgram"
                                       asp-action="PrintProgram"
                                       asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                        <i class="fa fa-print"></i>
                                        گزارش
                                    </a>



                                </div>
                            </div>

                            
                        </td>
                    </tr>
                }
            </tbody>

            
            

        </table>


        <partial name="~/Areas/Admin/Views/Shared/Partials/_Paging.cshtml" model="pagingVm" />
    }
    else
    {
        <partial name="~/Areas/Admin/Views/Shared/Partials/_EmptyState.cshtml"
                 model='"هیچ برنامه ای یافت نشد"' />
    }

    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardEnd.cshtml" />

</div>

@section Scripts
{
    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>
    @* <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script> *@

    <script>
        function NutritionProgram(id) {
        Swal.fire({
        title: 'حذف برنامه',
        text: "آیا از حذف برنامه مطمئن هستید؟",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#7cacbe',
        confirmButtonText: 'بله، حذف شود',
        cancelButtonText: 'خیر'
        }).then((result) => {
        if (result.value) {
        $.ajax({
        contentType: 'application/x-www-form-urlencoded',
        dataType: 'json',
        type: "POST",
        url: "/Admin/NutritionProgram/Delete",
        data: { Id: id },
        success: function (data) {
        if (data.isSuccess === true) {
        Swal.fire({
        title: 'موفق!',
        text: data.message,
        icon: 'success',
        timer: 2000,              // مدت زمان به میلی‌ثانیه (مثلاً 2 ثانیه)
        timerProgressBar: true,   // نوار پیشرفت زمان
        showConfirmButton: false  // دکمه تایید نمایش داده نشه
        }).then(() => {
        location.reload();
        });
        } else {
        Swal.fire('هشدار!', data.message, 'warning');
        }
        },
        error: function () {
        Swal.fire('خطا!', 'مشکلی در ارتباط با سرور رخ داده است', 'error');
        }
        });
        }
        });
        }
    </script>
}
