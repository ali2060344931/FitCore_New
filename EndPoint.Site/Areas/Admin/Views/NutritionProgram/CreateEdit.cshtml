@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.ViewModels.Common

@model NutritionProgramCreateEditViewModel

@{
    bool isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "ویرایش برنامه غذایی" : "ثبت برنامه غذایی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='@(isEdit ? "ویرایش برنامه غذایی" : "ثبت برنامه غذایی")' />

        <form id="NutritionProgramForm">
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />
            <input type="hidden" id="MemberId" name="MemberId" value="@Model.MemberId" />

            <div class="mb-3">
                <label class="form-label">نام و نام خانوادگی ورزشکار (متقاضی)</label>
                <div class="form-control d-inline-block bg-dark text-white border-0"
                     style="width: fit-content;">
                    @ViewBag.MemberName
                </div>
            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                     model='new BaseInputViewModel
                     {
                         Id = "Title",
                         Name = "Title",
                         Value = Model.Title,
                         LabelName = Html.DisplayNameFor(m => m.Title),
                         Placeholder = Html.DisplayNameFor(m => m.Title),
                         Col = 6
                     }' />

            <div class="row">
                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "ProgramTypeId",
                             Name = "ProgramTypeId",
                             LabelName = "نوع برنامه",
                             Col = 2,
                             Items = ViewBag.ProgramTypes,
                             Value = Model.ProgramTypeId.ToString()
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "GoalTypeId",
                             Name = "GoalTypeId",
                             LabelName = "هدف برنامه",
                             Col = 2,
                             Items = ViewBag.GetGoalTypes,
                             Value = Model.GoalTypeId.ToString()
                         }' />
            </div>

            <div class="row">
                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "StartDate",
                             Name = "StartDate",
                             Value = Model.StartDate,
                             LabelName = Html.DisplayNameFor(m => m.StartDate),
                             Placeholder = Html.DisplayNameFor(m => m.StartDate),
                             Col = 2
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "EndDate",
                             Name = "EndDate",
                             Value = Model.EndDate,
                             LabelName = Html.DisplayNameFor(m => m.EndDate),
                             Placeholder = Html.DisplayNameFor(m => m.EndDate),
                             Col = 2
                         }' />
            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                     model='new BaseInputViewModel
                     {
                         Id = "Description",
                         Name = "Description",
                         Value = Model.Description,
                         LabelName = Html.DisplayNameFor(m => m.Description),
                         Placeholder = Html.DisplayNameFor(m => m.Description),
                         Col = 6
                     }' />

            <div class="row">
                <div class="col-md-2 mb-3">
                    <label class="form-label font-weight-bold">فعال</label>
                    <select id="IsActive" name="IsActive" class="form-control">
                        @if (Model.IsActive)
                        {
                            <option value="true" selected>بله</option>
                            <option value="false">خیر</option>
                        }
                        else
                        {
                            <option value="true">بله</option>
                            <option value="false" selected>خیر</option>
                        }
                    </select>
                </div>
            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                     model='new FormButtonsViewModel
                     {
                         SubmitText = isEdit ? "ذخیره تغییرات" : "ثبت برنامه غذایی",
                         BackUrl = "/Admin/NutritionProgram",
                         BackText = "انصراف و بازگشت"
                     }' />
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {

            $("#StartDate").persianDatepicker({
                format: 'YYYY/MM/DD',
                autoClose: true,
                initialValue: false
            });

            $("#EndDate").persianDatepicker({
                format: 'YYYY/MM/DD',
                autoClose: true,
                initialValue: false
            });

            $("#NutritionProgramForm").submit(function (e) {
                e.preventDefault();

                const isEdit = @(isEdit ? "true" : "false");
                const url = isEdit ? "/Admin/NutritionProgram/Edit" : "/Admin/NutritionProgram/Create";

                var data = {
                    Id: parseInt($("#Id").val()) || 0,
                    MemberId: parseInt($("#MemberId").val()) || 0,
                    Title: $("#Title").val(),
                    Description: $("#Description").val(),
                    ProgramTypeId: parseInt($("#ProgramTypeId").val()) || 0,
                    GoalTypeId: parseInt($("#GoalTypeId").val()) || 0,
                    StartDate: $("#StartDate").val(),
                    EndDate: $("#EndDate").val(),
                    IsActive: $("#IsActive").val() === "true"
                };

                $.ajax({
                    type: "POST",
                    url: url,
                    data: data,
                    success: function (response) {
                        if (response.isSuccess) {
                            Swal.fire({
                                icon: 'success',
                                title: 'موفق',
                                text: response.message
                            }).then(() => {
                                window.location.href = "/Admin/NutritionProgram";
                            });
                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'خطا',
                                text: response.message
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'خطا',
                            text: 'خطا در ارتباط با سرور'
                        });
                    }
                });
            });
        });
    </script>
}
