@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.ViewModels.Common

@model NutritionProgramCreateEditViewModel

@{
    bool isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "ویرایش برنامه غذایی" : "ثبت برنامه غذایی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='@(isEdit ? "ویرایش برنامه غذایی" : "ثبت برنامه غذایی")' />

        <form id="NutritionProgramForm">
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />
            <input type="hidden" id="MemberId" name="MemberId" value="@Model.MemberId" />

            <div class="mb-3">
                <label class="form-label">مشخصات ورزشکار (متقاضی)</label>

                <div class="form-control d-inline-block bg-dark text-white border-0"
                     style="width: fit-content;">
                    @(ViewBag.MemberName + " - " + ViewBag.MemberMobile)
                </div>
            </div>

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "GoalTypeId",
                             Name = "GoalTypeId",
                             LabelName = "هدف برنامه",
                             Col = 2,
                             Items = ViewBag.GetGoalTypes,
                             Value = Model.GoalTypeId.ToString()
                         }' />



<partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
         model='new BaseInputViewModel
         {
             Id = "ProgramTypeId",
             Name = "ProgramTypeId",
             LabelName = "نوع برنامه",
             Col = 2,
             Items = ViewBag.ProgramTypes,
             Value = Model.ProgramTypeId.ToString()
         }' />

</div>

            <div class="row">
                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "StartDate",
                             Name = "StartDate",
                             Value = Model.StartDate,
                             LabelName = Html.DisplayNameFor(m => m.StartDate),
                             Placeholder = Html.DisplayNameFor(m => m.StartDate),
                             Col = 2
                         }' />

<partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "EndDate",
             Name = "EndDate",
             Value = Model.EndDate,
             LabelName = Html.DisplayNameFor(m => m.EndDate),
             Placeholder = Html.DisplayNameFor(m => m.EndDate),
             Col = 2
         }' />
</div>
            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Description",
                             Name = "Description",
                             Value = Model.Description,
                             LabelName = Html.DisplayNameFor(m => m.Description),
                             Placeholder = Html.DisplayNameFor(m => m.Description),
                             Col = 6
                         }' />

<div class="col-md-1 mb-3">
                    <label class="form-label font-weight-bold">فعال</label>
                    <select id="IsActive" name="IsActive" class="form-control">
                        @if (Model.IsActive)
                        {
                            <option value="true" selected>بله</option>
                            <option value="false">خیر</option>
                        }
                        else
                        {
                            <option value="true">بله</option>
                            <option value="false" selected>خیر</option>
                        }
                    </select>
                </div>
            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                     model='new FormButtonsViewModel
                     {
                         SubmitText = isEdit ? "ذخیره تغییرات" : "ثبت برنامه غذایی",
                         BackUrl = "/Admin/Members",
                         BackText = "انصراف و بازگشت"
                     }' />
</form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>

    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {

        const PROGRAM_TYPE = {
        Daily: 1,
        Weekly: 2,
        Monthly: 3
        };

        // تبدیل ارقام فارسی/عربی به انگلیسی
        function toEnglishDigits(str) {
        if (!str) return str;

        const map = {
        '۰': '0', '۱': '1', '۲': '2', '۳': '3', '۴': '4',
        '۵': '5', '۶': '6', '۷': '7', '۸': '8', '۹': '9',
        '٠': '0', '١': '1', '٢': '2', '٣': '3', '٤': '4',
        '٥': '5', '٦': '6', '٧': '7', '٨': '8', '٩': '9'
        };

        return str.replace(/[۰-۹٠-٩]/g, function (d) {
        return map[d] || d;
        });
        }

        function syncEndDate() {
        const programTypeId = parseInt($("#ProgramTypeId").val(), 10) || 0;

        let start = ($("#StartDate").val() || "").trim();
        start = toEnglishDigits(start);

        console.log("syncEndDate fired");
        console.log("ProgramTypeId:", programTypeId);
        console.log("StartDate(raw):", $("#StartDate").val());
        console.log("StartDate(en):", start);

        if (!programTypeId || !start || start.length !== 10) {
        return;
        }

        const parts = start.split('/');
        if (parts.length !== 3) {
        return;
        }

        const jy = parseInt(parts[0], 10);
        const jm = parseInt(parts[1], 10);
        const jd = parseInt(parts[2], 10);

        if (!jy || !jm || !jd) {
        return;
        }

        let p = new persianDate([jy, jm, jd]);

        if (programTypeId === PROGRAM_TYPE.Daily) {
        // روزانه: همان روز
        }
        else if (programTypeId === PROGRAM_TYPE.Weekly) {
        // هفتگی: 7 روز شامل روز شروع => +6
        p = p.add('days', 6);
        }
        else if (programTypeId === PROGRAM_TYPE.Monthly) {
        // ماهانه: شروع + 1 ماه - 1 روز
        p = p.add('months', 1).add('days', -1);
        }
        else {
        return;
        }

        const endStr = p.format('YYYY/MM/DD');
        console.log("EndDate:", endStr);

        $("#EndDate").val(endStr).trigger("change");
        }


        // const datePickerConfig = {
        // format: 'YYYY/MM/DD',
        // autoClose: true,
        // initialValue: false,
        // observer: true,
        // initialValueType: 'persian',
        // calendar: { persian: { locale: 'en' }
        // }
        // };



        // Initialize StartDate picker فقط یک بار
        $("#StartDate").persianDatepicker({
        format: 'YYYY/MM/DD',
        autoClose: true,
        initialValue: true,
        initialValueType: 'persian',
        observer: true,
        // calendar: { persian: { locale: 'en' },
        onSelect: function () {
        syncEndDate();
        }
        });

        // Initialize EndDate picker فقط یک بار
        
        $("#EndDate").persianDatepicker({
        format: 'YYYY/MM/DD',
        autoClose: true,
        initialValue: false,
        observer: true,
        initialValueType: 'persian',
        // calendar: { persian: { locale: 'en' },

        });


        // تغییر نوع برنامه
        $("#ProgramTypeId").on("change", function () {
        syncEndDate();
        });

        // تغییر تاریخ شروع
        $("#StartDate").on("change keyup blur", function () {
        syncEndDate();
        });

        // اگر فرم در حالت Edit باز شد و داده داشت
        syncEndDate();

        // فقط یک submit handler
        $("#NutritionProgramForm").on("submit", function (e) {
        e.preventDefault();

        syncEndDate();

        const isEdit = @(isEdit ? "true" : "false");
        const url = isEdit
        ? "/Admin/NutritionProgram/Edit"
        : "/Admin/NutritionProgram/Create";

        const data = {
        Id: parseInt($("#Id").val(), 10) || 0,
        MemberId: parseInt($("#MemberId").val(), 10) || 0,
        Description: $("#Description").val(),
        ProgramTypeId: parseInt($("#ProgramTypeId").val(), 10) || 0,
        GoalTypeId: parseInt($("#GoalTypeId").val(), 10) || 0,
        StartDate: toEnglishDigits($("#StartDate").val()),
        EndDate: toEnglishDigits($("#EndDate").val()),
        IsActive: $("#IsActive").val() === "true"
        };

        $.ajax({
        type: "POST",
        url: url,
        data: data,

        success: function (response) {
        if (response.isSuccess) {

        Swal.fire({
        icon: 'success',
        title: 'موفق',
        text: response.message,
        confirmButtonText: 'ادامه'
        }).then(function () {

        // فقط در حالت Create این سؤال نمایش داده شود
        if (!isEdit) {
        Swal.fire({
        title: 'ورود به فرم برنامه‌ساز',
        text: 'آیا در ادامه می‌خواهید اکنون فرم ثبت ساختار برنامه غذایی نمایش داده شود؟',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'بله، نمایش بده',
        cancelButtonText: 'خیر'
        }).then(function (result) {

        if (result.isConfirmed) {
        if (response.id && parseInt(response.id) > 0) {
        window.location.href = '/Admin/NutritionProgramBuilder/Index?programId=' + response.id;
        } else {
        Swal.fire({
        icon: 'warning',
        title: 'هشدار',
        text: 'شناسه برنامه ثبت‌شده دریافت نشد.'
        });
        }
        } else {
        if (response.redirectUrl) {
        window.location.href = response.redirectUrl;
        }
        }

        });
        } else {
        if (response.redirectUrl) {
        window.location.href = response.redirectUrl;
        }
        }

        });

        } else {
        Swal.fire({
        icon: 'warning',
        title: 'خطا',
        text: response.message
        });
        }
        },

        error: function () {
        Swal.fire({
        icon: 'error',
        title: 'خطا',
        text: 'خطا در ارتباط با سرور'
        });
        }
        });
        });

        });
    </script>

}
