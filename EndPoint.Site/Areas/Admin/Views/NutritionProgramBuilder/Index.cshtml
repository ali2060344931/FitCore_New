        var _allFoodOptions = [];

         $(document).ready(function () {
            $('#FoodId option:not(:first)').each(function () {
                _allFoodOptions.push({
                    value: $(this).val(),
                    text: $(this).text(),
                    categoryId: $(this).attr('data-category-id') || ''
                });
            });
        });

        function rebuildFoodOptions(selectedCategoryId) {
            var $foodSelect = $('#FoodId');
            var currentVal = $foodSelect.val();

            $foodSelect.find('option:not(:first)').remove();

            var filteredCount = 0;
            var optionsHtml = '';

            for (var i = 0; i < _allFoodOptions.length; i++) {
                var opt = _allFoodOptions[i];

                if (!selectedCategoryId || String(opt.categoryId) === String(selectedCategoryId)) {
                    var selected = (opt.value === currentVal) ? ' selected' : '';
                    optionsHtml += '<option value="' + opt.value + '" data-category-id="' + opt.categoryId + '"' + selected + '>' + opt.text + '</option>';
                    filteredCount++;
                }
            }

            $foodSelect.append(optionsHtml);

            if (currentVal && !$foodSelect.find('option[value="' + currentVal + '"]').length) {
                $foodSelect.val('');
            }

            $foodSelect.trigger('change');

            var $countBadge = $('#foodFilterCount');
            if (selectedCategoryId) {
                $countBadge.text(filteredCount + ' غذا');
                $countBadge.show();
                $('#btnClearFoodCategoryFilter').show();
            } else {
                $countBadge.hide();
                $('#btnClearFoodCategoryFilter').hide();
            }
        }

         $(document).on('change', '#FoodCategoryFilter', function () {
            rebuildFoodOptions($(this).val());
        });

         $(document).on('click', '#btnClearFoodCategoryFilter', function () {
            $('#FoodCategoryFilter').val('');
            rebuildFoodOptions('');
        });

         $(document).on('shown.bs.modal', '#addMealItemModal', function () {
            $('#FoodCategoryFilter').val('');
            $('#btnClearFoodCategoryFilter').hide();
            $('#foodFilterCount').hide();

            _allFoodOptions = [];
            $('#FoodId option:not(:first)').each(function () {
                _allFoodOptions.push({
                    value: $(this).val(),
                    text: $(this).text(),
                    categoryId: $(this).attr('data-category-id') || ''
                });
            });

            rebuildFoodOptions('');
        });




