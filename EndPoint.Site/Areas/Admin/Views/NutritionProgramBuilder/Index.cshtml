                                                                        onclick="openAddMealItemModal('@meal.MealId', `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`, `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.MealType ?? ""))`)">
                                                                    <i class="fa fa-plus"></i> افزودن غذا در وعده
                                                                </button>

                                                                <button type="button"
                                                                        @* class="btn btn-sm btn-warning" *@
