        var programId = $(this).data('program-id');

        Swal.fire({
        title: 'ایجاد خودکار روزهای برنامه',
        text: "آیا می‌خواهید ساختار روزهای این برنامه به صورت خودکار ایجاد شود؟",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#00C896',
        cancelButtonColor: '#d33',
        confirmButtonText: 'بله، ایجاد کن',
        cancelButtonText: 'انصراف',
        showLoaderOnConfirm: true,
        preConfirm: () => {
        // --- نقطه کلیدی: خواندن توکن از فرم مخفی ---
        var token = $('#autoGenerateDaysForm input[name="__RequestVerificationToken"]').val();

        return $.ajax({
        url: '/Admin/NutritionProgramBuilder/AutoGenerateDays',
        type: 'POST',
        data: {
        NutritionProgramId: programId  // مطمئن شوید نام پارامتر با DTO شما یکی است
        },
        headers: {
        // --- نقطه کلیدی: ارسال توکن در هدر ---
        "RequestVerificationToken": token
        }
        });
        }
        }).then((result) => {
        if (result.isConfirmed) {
        var response = result.value;

        if (response.isSuccess) {
        
            Swal.fire({
        icon: 'success',
        title: 'موفق',
        text: response.message
        }).then(() => {
        // رفرش کردن صفحه برای نمایش روزهای جدید اضافه شده
        window.location.reload();
        });
        } else {
        Swal.fire({
        icon: 'error',
        title: 'خطا',
        text: response.message
        });
        }
        }
        }).catch(error => {
        Swal.fire({
        icon: 'error',
        title: 'خطای سرور',
        text: 'در ارتباط با سرور مشکلی پیش آمد.'
        });
        });
        });



        function submitAutoGenerate() {
        // خواندن توکن از فرم
        var token = $('input[name="__RequestVerificationToken"]').val();

        // جمع آوری دیتای فرم (می‌توانید از FormData هم استفاده کنید)
        var requestData = {
        NutritionProgramId: $('#pgId').val(),
        // سایر فیلدهای مربوط به AutoGenerateNutritionDaysDto را اینجا پاس دهید
        // مثلا:
        // DaysCount: $('#daysCount').val()
        };

        $.ajax({
        url: '/Admin/NutritionProgramBuilder/AutoGenerateDays',
        type: 'POST',
        data: requestData,
        // ارسال توکن امنیتی در هدر درخواست
        headers: {
        "RequestVerificationToken": token
        },
        success: function (response) {
        if (response.isSuccess) {
        // بستن مدال
        $('#yourModalId').modal('hide');

        // نمایش پیام موفقیت
        Swal.fire('موفق', response.message, 'success').then(() => {
        // رفرش کردن صفحه برای نمایش روزهای جدید
        location.reload();
        });
        } else {
        // نمایش پیام خطا
        Swal.fire('خطا', response.message, 'error');
        }
        },
        error: function (xhr, status, error) {
        console.log(xhr.responseText); // برای دیباگ
        Swal.fire('خطای سرور', 'عملیات با مشکل مواجه شد.', 'error');
        }
        });
        }





