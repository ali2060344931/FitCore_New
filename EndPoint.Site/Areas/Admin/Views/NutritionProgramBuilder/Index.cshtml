                document.addEventListener("DOMContentLoaded", function () {

            const STORAGE_KEY = "nutrition_open_day";

            // وقتی collapse باز شد
            $('.collapse').on('shown.bs.collapse', function () {
                localStorage.setItem(STORAGE_KEY, this.id);
            });

            // وقتی collapse بسته شد
            $('.collapse').on('hidden.bs.collapse', function () {
                const openId = localStorage.getItem(STORAGE_KEY);
                if (openId === this.id) {
                    localStorage.removeItem(STORAGE_KEY);
                }
            });

            // بعد از reload بررسی کن کدام collapse باید باز شود
            const savedCollapse = localStorage.getItem(STORAGE_KEY);

            if (savedCollapse) {
                const element = document.getElementById(savedCollapse);
                if (element) {
                    $(element).collapse('show');
                }
            }

        });



                document.addEventListener("DOMContentLoaded", function () {

            const DAY_KEY = "nutrition_open_day";
            const MEAL_KEY = "nutrition_open_meal";

            // ذخیره collapse های باز
            $('.collapse').on('shown.bs.collapse', function () {

                const id = this.id;

                if (id.startsWith("collapseDay")) {
                    localStorage.setItem(DAY_KEY, id);
                }

                if (id.startsWith("collapseMeal")) {
                    localStorage.setItem(MEAL_KEY, id);
                }

            });

            // بازگردانی collapse ها بعد از reload
            const savedDay = localStorage.getItem(DAY_KEY);
            const savedMeal = localStorage.getItem(MEAL_KEY);

            if (savedDay) {
                const dayEl = document.getElementById(savedDay);
                if (dayEl) {
                    $(dayEl).collapse('show');

                    // اسکرول نرم به همان بخش
                    setTimeout(() => {
                        dayEl.scrollIntoView({ behavior: "smooth", block: "start" });
                    }, 300);
                }
            }

            if (savedMeal) {
                const mealEl = document.getElementById(savedMeal);
                if (mealEl) {
                    $(mealEl).collapse('show');

                    setTimeout(() => {
                        mealEl.scrollIntoView({ behavior: "smooth", block: "center" });
                    }, 400);
                }
            }

        });

        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
        });

                $(function () {
            $('[data-toggle="tooltip"]').tooltip({
                container: 'body'
            });
        });
    </script>
