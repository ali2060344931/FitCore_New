                                                                            <td>
                                                                                @* <a class="btn rounded-4 text-nowrap"
                                                                                   asp-controller="Food"
                                                                                   asp-action="index"
                                                                                   target="_blank"
                                                                                   rel="noopener noreferrer">
                                                                                    <i class="fa fa-plus" aria-hidden="true"></i>
                                                                                    <span class="d-none d-md-inline">بروز رسانی اطلاعات صفحه</span>
