        function loadDefaultUnit(foodId) {
        if (!foodId) {
        if ($('#UnitTypeId').hasClass('select2-hidden-accessible')) {
        $('#UnitTypeId').val('').trigger('change');
        }
        return;
        }
        $.ajax({
        url: '@Url.Action("GetFoodDefaultUnit", "NutritionProgramBuilder", new { area = "Admin" })',
        type: 'GET',
        data: { foodId: foodId },
        success: function (res) {
        if (res && res.unitId) {
        $('#UnitTypeId').val(res.unitId).trigger('change');
        }
        }
        });
        }

        $(document).on('change', '#FoodId', function () { loadDefaultUnit($(this).val()); });
        $(document).on('select2:select', '#FoodId', function () { loadDefaultUnit($(this).val()); });



