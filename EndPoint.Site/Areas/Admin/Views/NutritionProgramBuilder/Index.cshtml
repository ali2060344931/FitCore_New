                    </select>
                </div>
            </div>
        </div>
    </form>
    <div id="addMealItemMessage" class="mt-2"></div>
</div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnSaveMealItem" form="addMealItemForm"><span class="btn-text">ثبت</span></button></div>
</div>
</div>
</div>

<!-- Edit Meal Item -->
<div class="modal fade" id="editMealItemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">ویرایش غذای وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="editMealItemForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="EditMealItem_Id" name="Id" />
                    <input type="hidden" id="EditMealItem_NutritionMealId" name="NutritionMealId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>غذا</label><select class="form-control select2" id="EditMealItem_FoodId" name="FoodId">
                                <option value="">انتخاب غذا</option>@if (lookups?.Foods != null){foreach (var food in lookups.Foods){
                                <option value="@food.Id">@food.Name</option>
                            }
                        }
                    </select>

                </div>
            </div>
            <div class="col-md-3"><div class="form-group"><label>مقدار</label><input type="number" step="0.01" class="form-control" id="EditMealItem_Amount" name="Amount" /></div></div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>واحد</label><select class="form-control select2" id="EditMealItem_UnitTypeId" name="UnitTypeId">
                    <option value="">انتخاب واحد</option>@if (lookups?.Units != null){foreach (var unit in lookups.Units){
                    <option value="@unit.Id">@unit.Name</option>
                }
            }
        </select>
    </div>
</div>
</div>
</form>
<div id="editMealItemMessage" class="mt-2"></div>
</div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnEditMealItem" form="editMealItemForm"><span class="btn-text">ذخیره</span></button></div>
</div>
</div>
</div>

<!-- Delete Meal Item -->
<div class="modal fade" id="deleteMealItemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">حذف غذای وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="deleteMealItemForm">@Html.AntiForgeryToken()<input type="hidden" id="DeleteMealItem_Id" name="Id" /></form>
                <div class="alert alert-warning mb-0">آیا از حذف این آیتم مطمئن هستید؟</div>
                <div id="deleteMealItemMessage" class="mt-2"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button><button type="submit" class="btn btn-danger" id="btnDeleteMealItem" form="deleteMealItemForm"><span class="btn-text">حذف</span></button></div>
        </div>
    </div>
</div>
}


@section Scripts {
    <script>

        console.log('Meal Saved');
        var mealItemAdded = false;
        var mealAdded = false;


        $(document).ready(function () {
            if ($.fn.select2) {
                $('.select2').select2({ dir: 'rtl', width: '100%', language: 'fa' });
            }
        });

        function setButtonLoading($btn, isLoading, text) {
            if (isLoading) {
                $btn.prop('disabled', true);
                $btn.data('original-text', $btn.find('.btn-text').text());
                $btn.find('.btn-text').text(text || 'در حال ثبت...');
            } else {
                $btn.prop('disabled', false);
                $btn.find('.btn-text').text($btn.data('original-text') || 'ثبت');
            }
        }

        function showMessage(selector, type, message) {
            $(selector).html('<div class="alert alert-' + type + ' mb-0">' + message + '</div>');
        }

        function postForm(formSelector, buttonSelector, messageSelector, url, options) {
            options = options || {};

            var reloadOnSuccess = options.reloadOnSuccess !== undefined ? options.reloadOnSuccess : true;
            var onSuccess = options.onSuccess || null;

            var $form = $(formSelector);
            var $btn = $(buttonSelector);

            setButtonLoading($btn, true, 'در حال انجام...');

            $.ajax({
                url: url,
                type: 'POST',
                data: $form.serialize(),
                success: function (res) {
                    if (res && res.isSuccess) {
                        showMessage(messageSelector, 'success', res.message || 'عملیات با موفقیت انجام شد.');

                        if (typeof onSuccess === 'function') {
                            onSuccess(res, $form);
                        }

                        if (reloadOnSuccess) {
                            setTimeout(function () { location.reload(); }, 700);
                        }
                    } else {
                        showMessage(messageSelector, 'danger', (res && res.message) ? res.message : 'عملیات انجام نشد.');
                    }
                },
                error: function (xhr) {
                    showMessage(messageSelector, 'danger', 'خطا در ارتباط با سرور.');
                    console.log(xhr.responseText);
                },
                complete: function () {
                    setButtonLoading($btn, false);
                }
            });
        }

        function openEditDayModal(id, dayNumber, title) {
            $('#EditDay_Id').val(id);
            $('#EditDay_DayNumber').val(dayNumber);
            $('#EditDay_Title').val(title);
            $('#editDayMessage').html('');
            $('#editDayModal').modal('show');
        }

        function openDeleteDayModal(id) {
            $('#DeleteDay_Id').val(id);
            $('#deleteDayMessage').html('');
            $('#deleteDayModal').modal('show');
        }

        function openEditMealModal(id, dayId, mealTypeId, title) {
            $('#EditMeal_Id').val(id);
            $('#EditMeal_NutritionProgramDayId').val(dayId);
            $('#EditMeal_MealTypeId').val(mealTypeId).trigger('change');
            $('#EditMeal_Title').val(title);
            $('#editMealMessage').html('');
            $('#editMealModal').modal('show');
        }

        function openDeleteMealModal(id) {
            $('#DeleteMeal_Id').val(id);
            $('#deleteMealMessage').html('');
            $('#deleteMealModal').modal('show');
        }

        function openAddMealItemModal(mealId, dayTitle, mealTitle) {
            $('#NutritionMealId').val(mealId);
            $('#addMealItemDayTitle').text(dayTitle || '');
            $('#addMealItemMealTitle').text(mealTitle || '');
            $('#FoodId').val('').trigger('change');
            $('#Amount').val('');
            $('#UnitTypeId').val('').trigger('change');
            $('#addMealItemMessage').html('');
            $('#addMealItemModal').modal('show');
        }

        function openEditMealItemModal(id, mealId, foodId, amount, unitTypeId) {
            $('#EditMealItem_Id').val(id);
            $('#EditMealItem_NutritionMealId').val(mealId);
            $('#EditMealItem_FoodId').val(foodId).trigger('change');
            $('#EditMealItem_Amount').val(amount);
            $('#EditMealItem_UnitTypeId').val(unitTypeId).trigger('change');
            $('#editMealItemMessage').html('');
            $('#editMealItemModal').modal('show');
        }

        function openDeleteMealItemModal(id) {
            $('#DeleteMealItem_Id').val(id);
            $('#deleteMealItemMessage').html('');
            $('#deleteMealItemModal').modal('show');
        }

        $(document).on('click', '[data-target="#addMealModal"]', function () {
            $('#AddMeal_NutritionProgramDayId').val($(this).attr('data-day-id'));
            $('#addMealDayTitle').text($(this).attr('data-day-title') || '');
            $('#addMealMessage').html('');
        });

        $(document).on('submit', '#addDayForm', function (e) {
            e.preventDefault();
            postForm('#addDayForm', '#btnSaveDay', '#addDayMessage', '@Url.Action("AddDay", "NutritionProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#editDayForm', function (e) {
            e.preventDefault();
            postForm('#editDayForm', '#btnEditDay', '#editDayMessage', '@Url.Action("EditDay", "NutritionProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteDayForm', function (e) {
            e.preventDefault();
            postForm('#deleteDayForm', '#btnDeleteDay', '#deleteDayMessage', '@Url.Action("DeleteDay", "NutritionProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#addMealForm', function (e) {

            e.preventDefault();

            postForm(
                '#addMealForm',
                '#btnSaveMeal',
                '#addMealMessage',
                '@Url.Action("AddMeal", "NutritionProgramBuilder", new { area = "Admin" })',
                {
                    reloadOnSuccess: false,

                    onSuccess: function () {

                        mealAdded = true;

                        var dayId =
                            $('#AddMeal_NutritionProgramDayId').val();

                        $('#addMealForm')[0].reset();

                        $('#AddMeal_NutritionProgramDayId')
                            .val(dayId);

                        $('#AddMeal_MealTypeId').val('');

                        $('#AddMeal_Title').val('');

                        $('#AddMeal_MealTypeId').focus();
                    }
                });
        });


        $(document).on('submit', '#editMealForm', function (e) {
            e.preventDefault();
            postForm('#editMealForm', '#btnEditMeal', '#editMealMessage', '@Url.Action("EditMeal", "NutritionProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteMealForm', function (e) {
            e.preventDefault();
            postForm('#deleteMealForm', '#btnDeleteMeal', '#deleteMealMessage', '@Url.Action("DeleteMeal", "NutritionProgramBuilder", new { area = "Admin" })');
        });



        $(document).on('submit', '#addMealItemForm', function (e) {
            e.preventDefault();

            postForm(
                '#addMealItemForm',
                '#btnSaveMealItem',
                '#addMealItemMessage',
                '@Url.Action("AddMealItem", "NutritionProgramBuilder", new { area = "Admin" })',
                {
                    reloadOnSuccess: false,
                    onSuccess: function () {
                        mealItemAdded = true;

                        $('#addMealItemForm')[0].reset();
                        $('#FoodId').val('').trigger('change');
                        $('#UnitTypeId').val('').trigger('change');
                        $('#addMealItemForm input[name="MealId"]').val($('#MealId').val());
                        $('#FoodId').focus();
                    }
                }
            );
        });

        $('#addMealItemModal').on('hidden.bs.modal', function () {
            $('#addMealItemForm')[0].reset();
            $('#FoodId').val('').trigger('change');
            $('#UnitTypeId').val('').trigger('change');
            $('#addMealItemMessage').html('');

            if (mealItemAdded) {
                mealItemAdded = true;
                location.reload();
            }
        });



        $(document).on('submit', '#editMealItemForm', function (e) {
            e.preventDefault();
            postForm('#editMealItemForm', '#btnEditMealItem', '#editMealItemMessage', '@Url.Action("EditMealItem", "NutritionProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteMealItemForm', function (e) {
            e.preventDefault();
            postForm('#deleteMealItemForm', '#btnDeleteMealItem', '#deleteMealItemMessage', '@Url.Action("DeleteMealItem", "NutritionProgramBuilder", new { area = "Admin" })');
        });

        $('#addDayModal').on('hidden.bs.modal', function () {
            $('#addDayForm')[0].reset();
            $('#addDayMessage').html('');
        });

        $('#editDayModal').on('hidden.bs.modal', function () {
            $('#editDayForm')[0].reset();
            $('#editDayMessage').html('');
        });

        $('#deleteDayModal').on('hidden.bs.modal', function () {
            $('#deleteDayForm')[0].reset();
            $('#deleteDayMessage').html('');
        });


        $('#editMealModal').on('hidden.bs.modal', function () {
            $('#editMealForm')[0].reset();
            $('#editMealMessage').html('');
        });

        $('#deleteMealModal').on('hidden.bs.modal', function () {
            $('#deleteMealForm')[0].reset();
            $('#deleteMealMessage').html('');
        });

        $('#addMealItemModal').on('hidden.bs.modal', function () {
            $('#addMealItemForm')[0].reset();
            $('#NutritionMealId').val('');
            $('#FoodId').val('').trigger('change');
            $('#Amount').val('');
            $('#UnitTypeId').val('').trigger('change');
            $('#addMealItemMessage').html('');
            $('#addMealItemDayTitle').text('');
            $('#addMealItemMealTitle').text('');

            if (mealItemAdded) {
                mealItemAdded = false;
                location.reload();
            }
        });



        $('#editMealItemModal').on('hidden.bs.modal', function () {
            $('#editMealItemForm')[0].reset();
            $('#EditMealItem_FoodId').val('').trigger('change');
            $('#EditMealItem_UnitTypeId').val('').trigger('change');
            $('#editMealItemMessage').html('');
        });

        $('#deleteMealItemModal').on('hidden.bs.modal', function () {
            $('#deleteMealItemForm')[0].reset();
            $('#deleteMealItemMessage').html('');
        });

        $(document).on('click', '#btnAutoGenerateDays', function () {
            var $btn = $(this);
            var originalText = $btn.html();

            if (!confirm('آیا مطمئن هستید که روزهای برنامه به‌صورت اتوماتیک ایجاد شوند؟')) {
                return;
            }

            $btn.prop('disabled', true);
            $btn.html('<i class="fa fa-spinner fa-spin"></i> در حال ایجاد روزها...');

            $.ajax({
                url: '@Url.Action("AutoGenerateDays", "NutritionProgramBuilder", new { area = "Admin" })',
                type: 'POST',
                data: $('#autoGenerateDaysForm').serialize(),
                success: function (response) {
                    if (response && response.isSuccess) {
                        alert(response.message || 'روزها با موفقیت ایجاد شدند.');
                        location.reload();
                    } else {
                        alert((response && response.message) ? response.message : 'عملیات انجام نشد.');
                    }
                },
                error: function (xhr) {
                    console.log(xhr.responseText);
                    alert('خطا در ارتباط با سرور');
                },
                complete: function () {
                    $btn.prop('disabled', false);
                    $btn.html(originalText);
                }
            });
        });

        function loadDefaultUnit(foodId) {
            if (!foodId) {
                $('#UnitTypeId').val('').trigger('change');
                return;
            }

            $.ajax({
                url: '@Url.Action("GetFoodDefaultUnit", "NutritionProgramBuilder", new { area = "Admin" })',
                type: 'GET',
                data: { foodId: foodId },
                success: function (response) {
                    console.log("Response from server:", response);

                    if (response && response.unitId) {
                        $('#UnitTypeId').val(response.unitId).trigger('change');
                    } else {
                        $('#UnitTypeId').val('').trigger('change');
                    }
                },
                error: function (xhr) {
                    console.log("AJAX Error:", xhr.responseText);
                }
            });
        }

        $(document).on('change', '#FoodId', function () {
            var foodId = $(this).val();
            console.log("FoodId selected(change): " + foodId);
            loadDefaultUnit(foodId);
        });

        $(document).on('select2:select', '#FoodId', function () {
            var foodId = $(this).val();
            console.log("FoodId selected(select2): " + foodId);
            loadDefaultUnit(foodId);
        });

        $('#btnSaveMealItem').on('click', function (e) {
            var foodId = $('#FoodId').val();

            var isAlreadyInList = false;
            $('.meal-item-row').each(function () {
                if ($(this).data('food-id') == foodId) {
                    isAlreadyInList = true;
                }
            });

            if (isAlreadyInList) {
                e.preventDefault();
                alert('خطا: این غذا در این وعده وجود دارد!');
                return false;
            }
        });


            $(document).on('click',
        '#addMealModal .close, #addMealModal .btn-secondary',
        function () {

            if (mealAdded) {
                location.reload();
            }
        });
    </script>
}



