        function submitDeleteAllDays() {
        var $btn = $('#btnConfirmDeleteAllDays');
        var $msg = $('#deleteAllDaysMessage');
        var originalText = $btn.html();

        $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin me-1"></i> در حال حذف...');
        $msg.html('');

        var programId = $('#DeleteAllDays_ProgramId').val();

        // گرفتن توکن از داخل خود مودال
        var token = $('#deleteAllDaysForm input[name="__RequestVerificationToken"]').val();

        $.ajax({
        url: '/Admin/NutritionProgramBuilder/DeleteAllDays',
        type: 'POST',
        data: {
        __RequestVerificationToken: token,
        NutritionProgramId: programId
        },
        success: function (response) {
        if (response.isSuccess) {
        $msg.html('<div class="alert alert-success mb-0 py-2" style="font-size:12px;border-radius:8px;">' +
        '<i class="fa fa-check-circle me-1"></i> ' + response.message + '</div>');
        setTimeout(function () {
        $('#deleteAllDaysModal').modal('hide');
        location.reload();
        }, 800);
        } else {
        $msg.html('<div class="alert alert-danger mb-0 py-2" style="font-size:12px;border-radius:8px;">' +
        '<i class="fa fa-times-circle me-1"></i> ' + (response.message || 'خطایی رخ داد.') + '</div>');
        $btn.prop('disabled', false).html(originalText);
        }
        },
        error: function (xhr) {
        var errMsg = 'خطایی در ارتباط با سرور رخ داد.';
        try {
        var json = xhr.responseJSON;
        if (json && json.message) errMsg = json.message;
        } catch (ex) { }
        $msg.html('<div class="alert alert-danger mb-0 py-2" style="font-size:12px;border-radius:8px;">' +
        '<i class="fa fa-times-circle me-1"></i> ' + errMsg + '</div>');
        $btn.prop('disabled', false).html(originalText);
        }
        });
        }



