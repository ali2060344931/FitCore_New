@using System.Linq
@model EndPoint.Site.Areas.Admin.Models.NutritionProgramBuilderPageViewModel

@{
    ViewData["Title"] = "مدیریت برنامه غذایی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var program = Model?.Program;
    var lookups = Model?.Lookups;
}

<div class="content-wrapper">
    <div class="content-header row mb-4 align-items-center">
        <!-- بخش عنوان در سمت راست -->
        <div class="content-header-left col-md-6 col-12">
            <h3 class="content-header-title mb-1 fw-bold text-dark">مدیریت ساختار برنامه غذایی</h3>
            <p class="text-muted mb-0 small">
                <i class="fa fa-info-circle me-1"></i>
                ساختار برنامه: روزها ← وعده‌ها ← غذاها
            </p>
        </div>

        <!-- بخش دکمه بازگشت در سمت چپ (گوشه) -->
        <div class="content-header-right col-md-6 col-12 text-md-end text-start mt-md-0 mt-3">
            <a asp-area="Admin" asp-controller="NutritionProgram" asp-action="Index"
               class="btn btn-outline-danger btn-sm px-3 shadow-sm rounded-pill">
                <i class="fa fa-reply me-1"></i>
                بازگشت به لیست
            </a>
        </div>
    </div>


    <div class="content-body">
        @if (program == null)
        {
            <div class="alert alert-danger">اطلاعات برنامه غذایی یافت نشد.</div>
        }
        else
        {

            <!-- کارت اصلی با استایل شیک -->
            <!-- استفاده از کدهای اصلاح‌شده برای تمرکز روی مقادیر -->
            <div class="card shadow-sm border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="card-title text-primary fw-bold mb-4 border-bottom pb-2">اطلاعات برنامه غذایی</h5>

                    <div class="d-flex flex-wrap gap-3">

                        @* ساختار هر آیتم *@
                        <div class="badge bg-light text-dark border d-flex align-items-center px-4 py-3 rounded-pill shadow-sm">
                            <span class="text-muted me-2 fw-semibold" style="font-size: 1.1rem;">عضـــو: </span>
                            <span class="text-primary fw-bolder" style="font-size: 1.5rem;">@program.MemberName</span>
                        </div>

                        <div class="badge bg-light text-dark border d-flex align-items-center px-3 py-2 rounded-pill shadow-sm">
                            <span class="text-muted small me-2">هدف برنامه: </span>
                            <span class="text-primary fw-bolder fs-5">@program.GoalType</span>
                        </div>

                        <div class="badge bg-light text-dark border d-flex align-items-center px-3 py-2 rounded-pill shadow-sm">
                            <span class="text-muted small me-2">نــوع برنامه: </span>
                            <span class="text-primary fw-bolder fs-5">@program.ProgramType</span>
                        </div>

                        <div class="badge bg-light text-dark border d-flex align-items-center px-3 py-2 rounded-pill shadow-sm">
                            <span class="text-muted small me-2">تاریخ شروع: </span>
                            <span class="text-primary fw-bolder fs-5">@program.StartDate</span>
                        </div>

                        <div class="badge bg-light text-dark border d-flex align-items-center px-3 py-2 rounded-pill shadow-sm">
                            <span class="text-muted small me-2">تاریخ پایان: </span>
                            <span class="text-primary fw-bolder fs-5">@program.EndDate</span>
                        </div>

                    </div>
                </div>
            </div>

            <style>
                        /* تنظیمات اختصاصی برای زیبایی بیشتر */
                        .rounded-4 {
                            border-radius: 1rem !important;
                        }

                        /* افکت هاور برای تعاملی شدن */
                        .badge:hover {
                            background-color: #e9ecef !important;
                            transition: 0.3s;
                            cursor: default;
                        }

                        /* اطمینان از عدم بیرون زدگی در موبایل */
                        .d-flex.flex-wrap {
                            width: 100%;
                        }
            </style>



            <div class="card mb-3">
                <!-- از flex-nowrap استفاده کردیم تا چیدمان حتما در یک سطر بماند -->
                <div class="card-body d-flex justify-content-between align-items-center flex-nowrap">

                    <!-- بخش عنوان -->
                    <div class="flex-shrink-0">
                        <h5 class="mb-0">روزهای برنامه  <small class="text-muted">تعداد: @(program.Days?.Count ?? 0)</small> </h5>
                    </div>

                    <!-- فرم مخفی (بدون هیچ اثری روی چیدمان) -->
                    <form id="autoGenerateDaysForm" class="d-none">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="NutritionProgramId" value="@program?.ProgramId" />
                    </form>

                    <!-- بخش دکمه‌ها (در یک سطر) -->
                    <div class="d-flex align-items-center" style="gap: 10px;">
                        <button class="btn btn-success text-nowrap" type="button" data-toggle="modal" data-target="#addDayModal">
                            <i class="fa fa-plus"></i> <span class="d-none d-md-inline">افزودن روز جدید</span>
                        </button>

                        <button class="btn btn-outline-info text-nowrap"
                                type="button"
                                id="btnAutoGenerateDays"
                                data-program-id="@program.ProgramId">
                            <i class="fa fa-magic"></i> <span class="d-none d-md-inline">افزودن اتوماتیک</span>
                        </button>
                    </div>
                </div>
            </div>





            @if (program.Days == null || program.Days.Count == 0)
            {
                <div class="alert alert-info">هنوز هیچ روزی برای این برنامه ثبت نشده است.</div>
            }
            else
            {
                <div id="daysAccordion">
                    @for (int i = 0; i < program.Days.Count; i++)
                    {
                        var day = program.Days[i];
                        var collapseId = $"collapseDay_{day.Id}";
                        var headingId = $"headingDay_{day.Id}";

                        <div class="card mb-2">
                            <div class="card-header" id="@headingId">
                                <div class="d-flex justify-content-between align-items-center flex-wrap">
                                    <button class="btn btn-link text-left p-0 font-weight-bold" data-toggle="collapse" data-target="#@collapseId" aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="@collapseId">
                                        روز @day.DayNumber @if (!string.IsNullOrWhiteSpace(day.Title)) {
                                        <span>- @day.Title</span>
                                    }
                                </button>

                                <div class="mt-2 mt-md-0">
                                    <div class="mt-2 mt-md-0">
                                        <button type="button"
                                                class="btn btn-sm btn-primary"
                                                data-toggle="modal"
                                                data-target="#addMealModal"
                                                data-day-id="@day.Id">
                                            افزودن وعده
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-warning"
                                                onclick="openEditDayModal('@day.Id','@day.DayNumber',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                            ویرایش
                                        </button>

                                        <button type="button"
                                                class="btn btn-sm btn-danger"
                                                onclick="openDeleteDayModal('@day.Id')">
                                            حذف
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div id="@collapseId" class="collapse @(i == 0 ? "show" : "")" aria-labelledby="@headingId" data-parent="#daysAccordion">
                            <div class="card-body">
                                @if (day.Meals == null || day.Meals.Count == 0)
                                {
                                    <div class="alert alert-light border">برای این روز هنوز وعده‌ای ثبت نشده است.</div>
                                }
                                else
                                {
                                    @for (int j = 0; j < day.Meals.Count; j++)
                                    {
                                        var meal = day.Meals[j];
                                        <div class="card mb-3 border">
                                            <div class="card-header bg-light">
                                                <div class="d-flex justify-content-between align-items-center flex-wrap">
                                                    <div>
                                                        <h6 class="mb-1">@meal.Title</h6>
                                                        <small class="text-muted">نوع وعده: @(string.IsNullOrWhiteSpace(meal.MealType) ? "-" : meal.MealType)</small>
                                                    </div>
                                                    <div class="mt-2 mt-md-0">
                                                        <div class="mt-2 mt-md-0">
                                                            <button type="button"
                                                                    class="btn btn-sm btn-success"
                                                                    onclick="openAddMealItemModal('@meal.MealId')">
                                                                <i class="fa fa-plus"></i> افزودن غذا
                                                            </button>

                                                            <button type="button"
                                                                    class="btn btn-sm btn-warning"
                                                                    onclick="openEditMealModal('@meal.MealId','@day.Id','@meal.MealTypeId',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.Title ?? ""))`)">
                                                                ویرایش
                                                            </button>

                                                            <button type="button"
                                                                    class="btn btn-sm btn-danger"
                                                                    onclick="openDeleteMealModal('@meal.MealId')">
                                                                حذف
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="card-body">
                                                @if (meal.Foods == null || meal.Foods.Count == 0)
                                                {
                                                    <div class="alert alert-warning mb-0">هنوز غذایی برای این وعده ثبت نشده است.</div>
                                                }
                                                else
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-bordered table-striped table-sm">
                                                            <thead class="thead-light">
                                                                <tr>
                                                                    <th>غذا</th>
                                                                    <th>مقدار</th>
                                                                    <th>واحد</th>
                                                                    <th style="width:190px;">عملیات</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var food in meal.Foods)
                                                                {
                                                                    <tr>
                                                                        <td>@food.FoodName</td>
                                                                        <td>@food.Amount</td>
                                                                        <td>@food.Unit</td>

                                                                        <td>
                                                                            <button type="button"
                                                                                    class="btn btn-sm btn-warning"
                                                                                    onclick="openEditMealItemModal('@food.Id','@meal.MealId','@food.FoodId','@food.Amount','@food.UnitTypeId')">
                                                                                ویرایش
                                                                            </button>

                                                                            <button type="button"
                                                                                    class="btn btn-sm btn-danger"
                                                                                    onclick="openDeleteMealItemModal('@food.Id')">
                                                                                حذف
                                                                            </button>
                                                                        </td>

                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
</div>

@section Modals {
    <!-- Add Day -->
    <div class="modal fade" id="addDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">افزودن روز جدید</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <form id="addDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="NutritionProgramId" value="@program?.ProgramId" />
                        <div class="form-group"><label>شماره روز</label><input type="number" class="form-control" name="DayNumber" min="1" /></div>
                        <div class="form-group"><label>عنوان روز</label><input type="text" class="form-control" name="Title" /></div>
                    </form>
                    <div id="addDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnSaveDay" form="addDayForm"><span class="btn-text">ثبت</span></button></div>
            </div>
        </div>
    </div>

    <!-- Edit Day -->
    <div class="modal fade" id="editDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">ویرایش روز</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <form id="editDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="EditDay_Id" name="Id" />
                        <div class="form-group"><label>شماره روز</label><input type="number" class="form-control" id="EditDay_DayNumber" name="DayNumber" min="1" /></div>
                        <div class="form-group"><label>عنوان روز</label><input type="text" class="form-control" id="EditDay_Title" name="Title" /></div>
                    </form>
                    <div id="editDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnEditDay" form="editDayForm"><span class="btn-text">ذخیره</span></button></div>
            </div>
        </div>
    </div>

    <!-- Delete Day -->
    <div class="modal fade" id="deleteDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">حذف روز</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <form id="deleteDayForm">@Html.AntiForgeryToken()<input type="hidden" id="DeleteDay_Id" name="Id" /></form>
                    <div class="alert alert-warning mb-0">آیا از حذف این روز مطمئن هستید؟</div>
                    <div id="deleteDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button><button type="submit" class="btn btn-danger" id="btnDeleteDay" form="deleteDayForm"><span class="btn-text">حذف</span></button></div>
            </div>
        </div>
    </div>



    <!-- Add Meal -->
    <div class="modal fade" id="addMealModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header"><h5 class="modal-title">افزودن وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
                <div class="modal-body">
                    <form id="addMealForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="NutritionProgramDayId" id="AddMeal_NutritionProgramDayId" />
                        <div class="form-group">
                            <label>نوع وعده</label><select class="form-control" name="MealTypeId" id="AddMeal_MealTypeId" required>
                            <option value="">انتخاب کنید...</option>@foreach (var mt in lookups.MealTypes){
                            <option value="@mt.Id">@mt.Name</option>
                        }
                    </select>
                </div>
                <div class="form-group"><label>عنوان</label><input class="form-control" name="Title" id="AddMeal_Title" /></div>
            </form>
            <div id="addMealMessage" class="mt-2"></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnSaveMeal" form="addMealForm"><span class="btn-text">ثبت</span></button></div>
    </div>
</div>
</div>

<!-- Edit Meal -->
<div class="modal fade" id="editMealModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">ویرایش وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="editMealForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" id="EditMeal_Id" />
                    <input type="hidden" name="NutritionProgramDayId" id="EditMeal_NutritionProgramDayId" />
                    <div class="form-group">
                        <label>نوع وعده</label><select class="form-control" name="MealTypeId" id="EditMeal_MealTypeId" required>
                        <option value="">انتخاب کنید...</option>@foreach (var mt in lookups.MealTypes){
                        <option value="@mt.Id">@mt.Name</option>
                    }
                </select>
            </div>
            <div class="form-group"><label>عنوان</label><input class="form-control" name="Title" id="EditMeal_Title" /></div>
        </form>
        <div id="editMealMessage" class="mt-2"></div>
    </div>
    <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnEditMeal" form="editMealForm"><span class="btn-text">ذخیره</span></button></div>
</div>
</div>
</div>

<!-- Delete Meal -->
<div class="modal fade" id="deleteMealModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">حذف وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="deleteMealForm">@Html.AntiForgeryToken()<input type="hidden" id="DeleteMeal_Id" name="Id" /></form>
                <div class="alert alert-warning mb-0">آیا از حذف این وعده مطمئن هستید؟</div>
                <div id="deleteMealMessage" class="mt-2"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button><button type="submit" class="btn btn-danger" id="btnDeleteMeal" form="deleteMealForm"><span class="btn-text">حذف</span></button></div>
        </div>
    </div>
</div>




<!-- Add Meal Item -->
<div class="modal fade" id="addMealItemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">افزودن غذای جدید</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="addMealItemForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="NutritionMealId" name="NutritionMealId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>غذا</label><select class="form-control select2" id="FoodId" name="FoodId">
                                <option value="">انتخاب غذا</option>@if (lookups?.Foods != null){foreach (var food in lookups.Foods){
                                <option value="@food.Id">@food.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-3"><div class="form-group"><label>مقدار</label><input type="number" step="0.01" class="form-control" id="Amount" name="Amount" /></div></div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>واحد</label><select class="form-control select2" id="UnitTypeId" name="UnitTypeId">
                    <option value="">انتخاب واحد</option>@if (lookups?.Units != null){foreach (var unit in lookups.Units){
                    <option value="@unit.Id">@unit.Name</option>
                }
            }
        </select>
    </div>
</div>
</div>
</form>
<div id="addMealItemMessage" class="mt-2"></div>
</div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnSaveMealItem" form="addMealItemForm"><span class="btn-text">ثبت</span></button></div>
</div>
</div>
</div>

<!-- Edit Meal Item -->
<div class="modal fade" id="editMealItemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">ویرایش غذای وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="editMealItemForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="EditMealItem_Id" name="Id" />
                    <input type="hidden" id="EditMealItem_NutritionMealId" name="NutritionMealId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>غذا</label><select class="form-control select2" id="EditMealItem_FoodId" name="FoodId">
                                <option value="">انتخاب غذا</option>@if (lookups?.Foods != null){foreach (var food in lookups.Foods){
                                <option value="@food.Id">@food.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-3"><div class="form-group"><label>مقدار</label><input type="number" step="0.01" class="form-control" id="EditMealItem_Amount" name="Amount" /></div></div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>واحد</label><select class="form-control select2" id="EditMealItem_UnitTypeId" name="UnitTypeId">
                    <option value="">انتخاب واحد</option>@if (lookups?.Units != null){foreach (var unit in lookups.Units){
                    <option value="@unit.Id">@unit.Name</option>
                }
            }
        </select>
    </div>
</div>
</div>
</form>
<div id="editMealItemMessage" class="mt-2"></div>
</div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button><button type="submit" class="btn btn-primary" id="btnEditMealItem" form="editMealItemForm"><span class="btn-text">ذخیره</span></button></div>
</div>
</div>
</div>

<!-- Delete Meal Item -->
<div class="modal fade" id="deleteMealItemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-sm" role="document">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">حذف غذای وعده</h5><button type="button" class="close" data-dismiss="modal">&times;</button></div>
            <div class="modal-body">
                <form id="deleteMealItemForm">@Html.AntiForgeryToken()<input type="hidden" id="DeleteMealItem_Id" name="Id" /></form>
                <div class="alert alert-warning mb-0">آیا از حذف این آیتم مطمئن هستید؟</div>
                <div id="deleteMealItemMessage" class="mt-2"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button><button type="submit" class="btn btn-danger" id="btnDeleteMealItem" form="deleteMealItemForm"><span class="btn-text">حذف</span></button></div>
        </div>
    </div>
</div>
}




@section Scripts {
    <script>
                $(document).ready(function () {
                    if ($.fn.select2) {
                        $('.select2').select2({ dir: 'rtl', width: '100%', language: 'fa' });
                    }
                });

                function setButtonLoading($btn, isLoading, text) {
                    if (isLoading) {
                        $btn.prop('disabled', true);
                        $btn.data('original-text', $btn.find('.btn-text').text());
                        $btn.find('.btn-text').text(text || 'در حال ثبت...');
                    } else {
                        $btn.prop('disabled', false);
                        $btn.find('.btn-text').text($btn.data('original-text') || 'ثبت');
                    }
                }

                function showMessage(selector, type, message) {
                    $(selector).html('<div class="alert alert-' + type + ' mb-0">' + message + '</div>');
                }

                function postForm(formSelector, buttonSelector, messageSelector, url) {
                    var $form = $(formSelector);
                    var $btn = $(buttonSelector);
                    setButtonLoading($btn, true, 'در حال انجام...');
                    $.ajax({
                        url: url,
                        type: 'POST',
                        data: $form.serialize(),
                        success: function (res) {
                            if (res && res.isSuccess) {
                                showMessage(messageSelector, 'success', res.message || 'عملیات با موفقیت انجام شد.');
                                setTimeout(function () { location.reload(); }, 700);
                            } else {
                                showMessage(messageSelector, 'danger', (res && res.message) ? res.message : 'عملیات انجام نشد.');
                            }
                        },
                        error: function (xhr) {
                            showMessage(messageSelector, 'danger', 'خطا در ارتباط با سرور.');
                            console.log(xhr.responseText);
                        },
                        complete: function () { setButtonLoading($btn, false); }
                    });
                }

