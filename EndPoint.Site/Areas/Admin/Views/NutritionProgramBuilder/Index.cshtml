            font-weight: bold;
        }

        .info-value {
            font-weight: 500;
            text-align: right;
            word-break: break-word; /* اگر متنی طولانی بود کلمه‌ها بشکنند */
        }

        .info-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px 15px;
            margin-bottom: 15px;
        }
    </style>

    <div class="modal fade" id="memberInfoModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">
                <div class="modal-header border-0 pb-2"
                     style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:16px 20px;">
                    <h5 class="modal-title text-white mb-0" style="font-size:15px;">
                        <i class="fa fa-clipboard-list me-2" style="color:#68D391;"></i>
                        تجزیه و تحلیل اطلاعات ورزشکار
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" style="opacity:0.7;">&times;</button>
                </div>

                <div class="modal-body" style="padding:20px;">
                    @if (Model.MemberDetails != null)
                    {
                        <!-- اطلاعات پایه -->
                        <h6 class="border-bottom pb-2 mb-3 text-muted" style="font-size:14px;"><i class="fa fa-user me-2"></i>مشخصات پایه</h6>
                        <div class="info-card">
                            <div class="info-grid">
                                <span class="info-label">جنسیت:</span>
                                <span class="info-value">@( (int)Model.MemberDetails.Gender == 1 ? "مرد" : (int)Model.MemberDetails.Gender == 2 ? "زن" : "نامشخص")</span>

                                <span class="info-label">تاریخ تولد:</span>
                                <span class="info-value">@(Model.MemberDetails.BirthDate ?? "-")</span>

                                <span class="info-label">قد (سانتی‌متر):</span>
                                <span class="info-value">@(Model.MemberDetails.Height?.ToString() ?? "-")</span>

                                <span class="info-label">سطح فعالیت:</span>
                                <span class="info-value">@(Model.MemberDetails.ActivityLevel?.Name ?? "-")</span>

                                <span class="info-label">سطح تجربه:</span>
                                <span class="info-value">@(Model.MemberDetails.ExperienceLevel?.Name ?? "-")</span>

                                <span class="info-label">وضعیت عضویت:</span>
                                <span class="info-value">@Html.Raw(Model.MemberDetails.IsActive == true ? "<span class='text-success'>فعال</span>" : "<span class='text-danger'>غیرفعال</span>")</span>
                            </div>
                        </div>

                        <!-- اطلاعات پزشکی -->
                        <h6 class="border-bottom pb-2 mt-3 mb-3 text-muted" style="font-size:14px;"><i class="fa fa-notes-medical me-2"></i>سوابق پزشکی و حساسیت‌ها</h6>
                        <div class="info-card">
                            <div class="info-grid">
                                <span class="info-label">حساسیت‌های غذایی:</span>
                                <span class="info-value">@(string.IsNullOrEmpty(Model.MemberDetails.FoodAllergies) ? "ندارد" : Model.MemberDetails.FoodAllergies)</span>
                            </div>
                            <div class="info-grid">
                                <span class="info-label">بیماری‌ها:</span>
                                <span class="info-value">@(string.IsNullOrEmpty(Model.MemberDetails.MedicalConditions) ? "ندارد" : Model.MemberDetails.MedicalConditions)</span>
                            </div>
                            <div class="info-grid">
                                <span class="info-label">آسیب‌دیدگی‌ها:</span>
                                <span class="info-value">@(string.IsNullOrEmpty(Model.MemberDetails.Injuries) ? "ندارد" : Model.MemberDetails.Injuries)</span>
                            </div>
                        </div>

                        <!-- اندازه گیری های بدن -->
                        <h6 class="border-bottom pb-2 mt-3 mb-3 text-muted" style="font-size:14px;"><i class="fa fa-weight me-2"></i>سوابق اندازه‌گیری بدن</h6>
                        @if (Model.MemberDetails.memberBodyMeasurements != null && Model.MemberDetails.memberBodyMeasurements.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered table-hover text-center" style="font-size:13px;">
                                    <thead class="thead-light">
                                        <tr>
                                            <th>تاریخ ثبت</th>
                                            <th>وزن (کیلو)</th>
                                            <th>درصد چربی</th>
                                            <th>دور کمر</th>
                                            <th>دور باسن</th>
                                            <th>دور سینه</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var m in Model.MemberDetails.memberBodyMeasurements.OrderByDescending(x => x.Id))
                                        {
                                            <tr>
                                                <td class="text-nowrap">@m.RecordDate</td>
                                                <td>@(m.Weight?.ToString() ?? "-")</td>
                                                <td>@(m.BodyFatPercentage?.ToString() ?? "-")</td>
                                                <td>@(m.Waist?.ToString() ?? "-")</td>
                                                <td>@(m.Hip?.ToString() ?? "-")</td>
                                                <td>@(m.Chest?.ToString() ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light text-center mb-0" style="font-size:13px;border-radius:8px;">
                                <i class="fa fa-info-circle me-1"></i> هیچ سابقه اندازه‌گیری برای این ورزشکار ثبت نشده است.
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.MemberDetails.Description))
                        {
                            <div class="info-card mt-3">
                                <div class="info-grid">
                                    <span class="info-label">توضیحات تکمیلی:</span>
                                    <span class="info-value">@Model.MemberDetails.Description</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 text-center">اطلاعات ورزشکار در دسترس نیست.</div>
                    }
                </div>

                <div class="modal-footer border-0" style="padding:12px 20px;background:#f8fafd;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal" style="border-radius:9px;font-size:13px;">بستن</button>
                </div>
            </div>
        </div>
    </div>


}

@section Scripts {

    @* <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script> *@

    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>


    @* <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/select2/js/select2.min.js"></script> *@



    <style>
        @@keyframes fcShake {
            0%, 100% {
                transform: translateX(0)
            }

            20% {
                transform: translateX(-5px)
            }

            40% {
                transform: translateX(5px)
            }

            60% {
                transform: translateX(-4px)
            }

            80% {
                transform: translateX(4px)
            }
        }

        #btnSaveMealItem:not(:disabled):hover,
        #btnSaveMeal:not(:disabled):hover {
            background: #00a87d !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(0,200,150,0.3);
        }
    </style>

    <script>

        // ============================================================
        // توابع کمکی (مشترک)
        // ============================================================

        function setButtonLoading($btn, isLoading, iconId, textId, text) {
        if (isLoading) {
        $btn.prop('disabled', true);
        if (iconId) $('#' + iconId).removeClass('fa-plus').addClass('fa-spinner fa-spin');
        if (textId) $('#' + textId).text(text || 'در حال ثبت...');
        } else {
        $btn.prop('disabled', false);
        if (iconId) $('#' + iconId).removeClass('fa-spinner fa-spin').addClass('fa-plus');
        if (textId) $('#' + textId).text($btn.data('original-label') || 'ثبت');
        }
        }

        function showMessage(selector, type, message) {
        $(selector).html('<div class="alert alert-' + type + ' mb-0" style="border-radius:8px;font-size:13px;">' + message + '</div>');
        }

        function postForm(formSelector, buttonSelector, messageSelector, url, options) {
        options = options || {};
        var reloadOnSuccess = options.reloadOnSuccess !== undefined ? options.reloadOnSuccess : true;
        var onSuccess = options.onSuccess || null;
        var $btn = $(buttonSelector);

        $btn.prop('disabled', true);
        $btn.data('original-text', $btn.find('.btn-text').text());
        $btn.find('.btn-text').text('در حال انجام...');

        $.ajax({
        url: url,
        type: 'POST',
        data: $(formSelector).serialize(),
        success: function (res) {
        if (res && res.isSuccess) {
        showMessage(messageSelector, 'success', res.message || 'عملیات موفق');
        if (typeof onSuccess === 'function') onSuccess(res);
        if (reloadOnSuccess) setTimeout(function () { location.reload(); }, 700);
        } else {
        showMessage(messageSelector, 'danger', (res && res.message) ? res.message : 'عملیات انجام نشد.');
        }
        },
        error: function (xhr) {
        showMessage(messageSelector, 'danger', 'خطا در ارتباط با سرور.');
        },
        complete: function () {
        $btn.prop('disabled', false);
        $btn.find('.btn-text').text($btn.data('original-text') || 'ثبت');
        }
        });
        }

        // ============================================================
        // Select2
        // ============================================================

        function initSelect2(selector, modalId) {
        var $el = $(selector);
        if ($el.hasClass('select2-hidden-accessible')) $el.select2('destroy');
        var opts = {
        dir: 'rtl', width: '100%', language: 'fa',
        theme: 'bootstrap4', placeholder: 'انتخاب کنید', allowClear: true
        };
        if (modalId) opts.dropdownParent = $(modalId);
        $el.select2(opts);
        }

        $(document).ready(function () {

        // ============================================================
        // بازگردانی collapse باز بعد از reload
        // ============================================================
        const DAY_KEY  = 'nutrition_open_day';
        const MEAL_KEY = 'nutrition_open_meal';

        $('.collapse').on('shown.bs.collapse', function () {
        var id = this.id;
        if (id.startsWith('collapseDay'))  localStorage.setItem(DAY_KEY, id);
        if (id.startsWith('collapseMeal')) localStorage.setItem(MEAL_KEY, id);
        });

        var savedDay = localStorage.getItem(DAY_KEY);
        if (savedDay) {
        var dayEl = document.getElementById(savedDay);
        if (dayEl) {
        $(dayEl).collapse('show');
        setTimeout(function () { dayEl.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 300);
        }
        }

        var savedMeal = localStorage.getItem(MEAL_KEY);
        if (savedMeal) {
        var mealEl = document.getElementById(savedMeal);
        if (mealEl) {
        $(mealEl).collapse('show');
        setTimeout(function () { mealEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); }, 400);
        }
        }

        // ============================================================
        // Init Select2 در هر مودال هنگام باز شدن
        // ============================================================

        $(document).on('shown.bs.modal', '#addMealModal', function () {
        initSelect2('#AddMeal_MealTypeId', '#addMealModal');
        });

        $(document).on('shown.bs.modal', '#editMealModal', function () {
        initSelect2('#EditMeal_MealTypeId', '#editMealModal');
        var val = $('#EditMeal_MealTypeId').attr('data-current-val');
        if (val) $('#EditMeal_MealTypeId').val(val).trigger('change');
        });

        $(document).on('shown.bs.modal', '#addMealItemModal', function () {
        initSelect2('#FoodId', '#addMealItemModal');
        initSelect2('#UnitTypeId', '#addMealItemModal');
        });

        $(document).on('shown.bs.modal', '#editMealItemModal', function () {
        initSelect2('#EditMealItem_FoodId', '#editMealItemModal');
        initSelect2('#EditMealItem_UnitTypeId', '#editMealItemModal');
        var foodVal = $('#EditMealItem_FoodId').attr('data-current-val');
        var unitVal = $('#EditMealItem_UnitTypeId').attr('data-current-val');
        if (foodVal) $('#EditMealItem_FoodId').val(foodVal).trigger('change');
        if (unitVal) $('#EditMealItem_UnitTypeId').val(unitVal).trigger('change');
        });

        // ============================================================
        // tooltip
        // ============================================================
        $('[data-toggle="tooltip"]').tooltip({ container: 'body' });

        });

        // ============================================================
        // روز — بازکردن مودال‌ها
        // ============================================================

        function openEditDayModal(id, dayNumber, title) {
        $('#EditDay_Id').val(id);
        $('#EditDay_DayNumber').val(dayNumber);
        $('#EditDay_Title').text(title || '');
        $('#EditDay_Title_txt').val(title || '');
        $('#editDayMessage').html('');
        $('#editDayModal').modal('show');
        }

        function openDeleteDayModal(id, title) {
        $('#DeleteDay_Id').val(id);
        $('#DeleteDay_Title').text(title || '');
        $('#deleteDayMessage').html('');
        $('#deleteDayModal').modal('show');
        }

        // ============================================================
        // وعده — بازکردن مودال‌ها
        // ============================================================

        var _mealAdded = false;

        function openAddMealModal(dayId, dayTitle) {
        $('#AddMeal_NutritionProgramDayId').val(dayId);
        $('#addMealDayTitle').text(dayTitle || '');
        $('#AddMeal_MealTypeId').val('');
        $('#AddMeal_Title').val('');
        $('#addMealSuccessBanner').hide();
        $('#addedMealsPanel').hide();
        $('#addedMealsList').html('');
        _mealAdded = false;
        $('#addMealModal').modal('show');
        }

        function openEditMealModal(id, dayId, mealTypeId, title, dayTitle, mealType) {
        $('#EditMeal_Id').val(id);
        $('#EditMeal_NutritionProgramDayId').val(dayId);
        $('#EditMeal_MealTypeId').attr('data-current-val', mealTypeId);
        $('#EditMeal_Title').val(title || '');
        $('#EditMealmealType').text(mealType || '');
        $('#editMealMessage').html('');
        $('#editMealModal').modal('show');
        }

        function openDeleteMealModal(id, mealTitle) {
        $('#DeleteMeal_Id').val(id);
        $('#DeleteMeallTitle').text(mealTitle || '');
        $('#deleteMealMessage').html('');
        $('#deleteMealModal').modal('show');
        }

        // افزودن وعده — بدون بستن مودال
        $(document).on('click', '#btnSaveMeal', function () {

        var mealTypeId = $('#AddMeal_MealTypeId').val();
        if (!mealTypeId) {
        $('#AddMeal_MealTypeId').next('.select2-container')
        .find('.select2-selection').css('border-color', '#e53e3e');
        setTimeout(function () {
        $('#AddMeal_MealTypeId').next('.select2-container')
        .find('.select2-selection').css('border-color', '');
        }, 2000);
        return;
        }

        var $btn = $(this);
        $btn.prop('disabled', true);
        $('#btnSaveMealIcon').removeClass('fa-plus').addClass('fa-spinner fa-spin');
        $('#btnSaveMealText').text('در حال ثبت...');

        var dayId = $('#AddMeal_NutritionProgramDayId').val();
        var mealName = $('#AddMeal_MealTypeId option:selected').text();

        $.ajax({
        url: '@Url.Action("AddMeal", "NutritionProgramBuilder", new { area = "Admin" })',
        type: 'POST',
        data: $('#addMealForm').serialize(),
        success: function (res) {
        if (res && res.isSuccess) {
        _mealAdded = true;

        $('#addMealSuccessText').text('وعده «' + mealName + '» با موفقیت ثبت شد.');
        $('#addMealSuccessBanner').slideDown(200);

        $('#addedMealsList').append(
        '<span style="display:inline-flex;align-items:center;gap:5px;' +
        'background:#edfaf5;border:1px solid #00C896;color:#276749;' +
        'border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;">' +
        '<i class="fa fa-check-circle" style="color:#00C896;"></i>' + mealName + '</span>'
        );
        $('#addedMealsPanel').show();

        // ریست فرم
        $('#AddMeal_NutritionProgramDayId').val(dayId);
        if ($('#AddMeal_MealTypeId').hasClass('select2-hidden-accessible')) {
        $('#AddMeal_MealTypeId').val('').trigger('change');
        }
        $('#AddMeal_Title').val('');

        setTimeout(function () { $('#addMealSuccessBanner').slideUp(300); }, 1800);

        } else {
        var err = (res && res.message) ? res.message : 'خطا در ثبت وعده';
        var $e = $('<div style="padding:10px 20px;background:#fff5f5;' +
        'border-bottom:2px solid #fc8181;font-size:13px;color:#c53030;">' +
        '<i class="fa fa-times-circle me-2"></i>' + err + '</div>');
        $('#addMealModal .modal-body').prepend($e);
        setTimeout(function () { $e.fadeOut(400, function () { $(this).remove(); }); }, 3000);
        }
        },
        error: function () {
        showMessage('#addMealModal .modal-body', 'danger', 'خطا در ارتباط با سرور');
        },
        complete: function () {
        $btn.prop('disabled', false);
        $('#btnSaveMealIcon').removeClass('fa-spinner fa-spin').addClass('fa-plus');
        $('#btnSaveMealText').text('ثبت وعده');
        }
        });
        });

        $(document).on('hidden.bs.modal', '#addMealModal', function () {
        if (_mealAdded) { _mealAdded = false; location.reload(); }
        });

        // ============================================================
        // غذای وعده — بازکردن مودال‌ها
        // ============================================================

        var _mealItemAdded = false;

        function openAddMealItemModal(mealId, dayTitle, mealTitle) {
        $('#NutritionMealId').val(mealId);
        $('#addMealItemDayTitle').text(dayTitle || '');
        $('#addMealItemMealTitle').text(mealTitle ? ' (' + mealTitle + ')' : '');

        if ($('#FoodId').hasClass('select2-hidden-accessible')) {
        $('#FoodId').val('').trigger('change');
        }
        if ($('#UnitTypeId').hasClass('select2-hidden-accessible')) {
        $('#UnitTypeId').val('').trigger('change');
        }
        $('#Amount').val('');
        $('#MealItemDescription').val('');
        $('#addMealItemSuccessBanner').hide();
        $('#addedFoodsPanel').hide();
        $('#addedFoodsList').html('');
        _mealItemAdded = false;
        $('#addMealItemModal').modal('show');
        }

        function openEditMealItemModal(id, mealId, foodId, amount, unitTypeId, foodName, description) {
        $('#EditMealItem_Id').val(id);
        $('#EditMealItem_NutritionMealId').val(mealId);
        $('#EditMealItem_FoodId').attr('data-current-val', foodId);
        $('#EditMealItem_UnitTypeId').attr('data-current-val', unitTypeId);
        $('#EditMealItem_Amount').val(amount);
        $('#MealEditItemDescription').val(description || '');
        $('#EditFoodName').text(foodName || '');
        $('#editMealItemMessage').html('');
        $('#editMealItemModal').modal('show');
        }

        function openDeleteMealItemModal(id, foodName) {
        $('#DeleteMealItem_Id').val(id);
        $('#DeleteFoodName').text(foodName || '');
        $('#deleteMealItemMessage').html('');
        $('#deleteMealItemModal').modal('show');
        }

        // افزودن غذا — بدون بستن مودال
        $(document).on('click', '#btnSaveMealItem', function () {

        var foodId = $('#FoodId').val();
        if (!foodId) {
        var $btn2 = $(this);
        $btn2.css('animation', 'fcShake 0.4s ease');
        setTimeout(function () { $btn2.css('animation', ''); }, 500);
        return;
        }

        var $btn = $(this);
        $btn.prop('disabled', true);
        $('#btnSaveMealItemIcon').removeClass('fa-plus').addClass('fa-spinner fa-spin');
        $('#btnSaveMealItemText').text('در حال ثبت...');

        var mealId    = $('#NutritionMealId').val();
        var dayTitle  = $('#addMealItemDayTitle').text();
        var mealTitle = $('#addMealItemMealTitle').text();
        var foodName  = $('#FoodId option:selected').text();

        $('#MealItemDescription').val(($('#MealItemDescription').val() || '').trim());

        $.ajax({
        url: '@Url.Action("AddMealItem", "NutritionProgramBuilder", new { area = "Admin" })',
        type: 'POST',
        data: $('#addMealItemForm').serialize(),
        success: function (res) {
        if (res && res.isSuccess) {
        _mealItemAdded = true;

        $('#addMealItemSuccessText').text('غذای «' + foodName + '» با موفقیت ثبت شد.');
        $('#addMealItemSuccessBanner').slideDown(200);

        $('#addedFoodsList').append(
        '<span style="display:inline-flex;align-items:center;gap:5px;' +
        'background:#edfaf5;border:1px solid #00C896;color:#276749;' +
        'border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;">' +
        '<i class="fa fa-check-circle" style="color:#00C896;"></i>' + foodName + '</span>'
        );
        $('#addedFoodsPanel').show();

        // ریست
        $('#NutritionMealId').val(mealId);
        $('#addMealItemDayTitle').text(dayTitle);
        $('#addMealItemMealTitle').text(mealTitle);
        if ($('#FoodId').hasClass('select2-hidden-accessible')) {
        $('#FoodId').val('').trigger('change');
        }
        if ($('#UnitTypeId').hasClass('select2-hidden-accessible')) {
        $('#UnitTypeId').val('').trigger('change');
        }
        $('#Amount').val('');
        $('#MealItemDescription').val('');

        setTimeout(function () {
        $('#addMealItemSuccessBanner').slideUp(300);
        try { $('#FoodId').select2('open'); } catch(e) {}
        }, 1800);

        } else {
        var err = (res && res.message) ? res.message : 'خطا در ثبت غذا';
        var $e = $('<div style="padding:10px 20px;background:#fff5f5;' +
        'border-bottom:2px solid #fc8181;font-size:13px;color:#c53030;">' +
        '<i class="fa fa-times-circle me-2"></i>' + err + '</div>');
        $('#addMealItemModal .modal-body').prepend($e);
        setTimeout(function () { $e.fadeOut(400, function () { $(this).remove(); }); }, 3000);
        }
        },
        error: function () {
        var $e = $('<div style="padding:10px 20px;background:#fff5f5;' +
        'border-bottom:2px solid #fc8181;font-size:13px;color:#c53030;">' +
        '<i class="fa fa-times-circle me-2"></i>خطا در ارتباط با سرور</div>');
        $('#addMealItemModal .modal-body').prepend($e);
        setTimeout(function () { $e.fadeOut(400, function () { $(this).remove(); }); }, 3000);
        },
        complete: function () {
        $btn.prop('disabled', false);
        $('#btnSaveMealItemIcon').removeClass('fa-spinner fa-spin').addClass('fa-plus');
        $('#btnSaveMealItemText').text('ثبت غذا');
        }
        });
        });

        $(document).on('hidden.bs.modal', '#addMealItemModal', function () {
        if (_mealItemAdded) { _mealItemAdded = false; location.reload(); }
        });

        // ============================================================
        // Submit handlers (ویرایش و حذف — با reload)
        // ============================================================

        $(document).on('submit', '#addDayForm', function (e) {
        e.preventDefault();
        postForm('#addDayForm', '#btnSaveDay', '#addDayMessage',
        '@Url.Action("AddDay", "NutritionProgramBuilder", new { area = "Admin" })');
        });



        $(document).on('submit', '#editDayForm', function (e) {
        e.preventDefault();
        postForm('#editDayForm', '#btnEditDay', '#editDayMessage',
        '@Url.Action("EditDay", "NutritionProgramBuilder", new { area = "Admin" })');
        });


