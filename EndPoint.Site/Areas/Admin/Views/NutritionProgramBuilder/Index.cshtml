                <div id="deleteMealMessage" class="mt-2"></div>
            </div>
            <div class="modal-footer"><button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button><button type="submit" class="btn btn-danger" id="btnDeleteMeal" form="deleteMealForm"><span class="btn-text">حذف</span></button></div>
        </div>
    </div>
</div>

<!-- Add Meal Item -->
<div class="modal fade" id="addMealItemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            
            
            <div class="modal-header">
                <h5 class="modal-title">
                    افزودن غذا
                    <small class="text-muted d-block mt-1">
                        <span id="addMealItemDayTitle"></span>
                        <span class="mx-1">|</span>
                        <span id="addMealItemMealTitle"></span>
                    </small>
                </h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="addMealItemForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="NutritionMealId" name="NutritionMealId" />
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>غذا</label>
                                <div class="d-flex">
                                    <select class="form-control select2" id="FoodId" name="FoodId" style="width: 100%;">
                                        <option value="">انتخاب غذا</option>
