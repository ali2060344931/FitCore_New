@using System.Linq
@using FitCore.Common
@model EndPoint.Site.Areas.Admin.Models.NutritionProgramBuilderPageViewModel
@Html.AntiForgeryToken()
@functions {
    public static string ToPersianNumbers(int value)
    {
        var persianDigits = new[] { '۰', '۱', '۲', '۳', '۴', '۵', '۶', '۷', '۸', '۹' };
        var input = value.ToString();
        var result = new System.Text.StringBuilder();
        foreach (var ch in input)
        {
            if (char.IsDigit(ch))
                result.Append(persianDigits[ch - '0']);
            else
                result.Append(ch);
        }
        return result.ToString();
    }
}

@{
    ViewData["Title"] = "مدیریت برنامه غذایی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var program = Model?.Program;
    var lookups = Model?.Lookups;


    var categoryTypes = ViewBag.CategoryTypes as List<SelectListItem> ?? new List<SelectListItem>();

}

<div class="page-content-wrapper builder-wrapper">

    <div class="program-header-sticky-wrapper">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body py-3 px-3">

                <div class="program-header-row d-flex flex-column flex-lg-row
                    justify-content-between align-items-start align-items-lg-center gap-3">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="program-icon-box"><i class="fa fa-cutlery"></i></div>
                        <div class="program-main-title">مدیریت ساختار برنامه غذایی</div>
                        <span class="badge day-count-badge">
                            برای <span class="day-count-number">@(program.Days?.Count ?? 0)</span> روز
                        </span>
                        <div class="d-flex align-items-center gap-1 flex-wrap">
                            <span class="badge structure-badge">روزها</span>
                            <i class="fa fa-angle-left breadcrumb-arrow"></i>
                            <span class="badge structure-badge">وعده‌ها</span>
                            <i class="fa fa-angle-left breadcrumb-arrow"></i>
                            <span class="badge structure-badge active">غذاها</span>
                        </div>
                    </div>

                    <div class="program-meta-container d-flex align-items-center gap-2 flex-wrap">

                        <div class="program-meta-item">
                            <i class="fa-user meta-icon"></i>
                            <span class="meta-label">عضو:</span>
                            <span class="meta-value-Fullmamu">@program.MemberName</span>
                            @if (Model.MemberAge.HasValue)
                            {
                                <span class="badge px-2 py-1 rounded-pill"
                                      style="font-size:11px; background-color: #000000; color: #ffffff; border: 1px solid #333;">
                                    🎂 سن: @Model.MemberAge سال
                                </span>
                            }
                        </div>

                        <div class="program-meta-item">
                            <span class="meta-label">هدف:</span>
                            <span class="meta-value">@program.GoalType</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">نوع برنامه:</span>
                            <span class="meta-value">@program.ProgramType</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">شروع:</span>
                            <span class="meta-value">@program.StartDate</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">پایان:</span>
                            <span class="meta-value">@program.EndDate</span>
                        </div>


                    </div>
                </div>

                <div class="program-toolbar mt-3 pt-3 border-top">
                    <div class="d-flex align-items-center gap-1 flex-nowrap overflow-auto">

                        <form id="autoGenerateDaysForm" class="d-none">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="NutritionProgramId" value="@program?.ProgramId" />
                        </form>

                        <button class="btn btn-sm btn-success px-2 py-0 text-nowrap"
                                data-toggle="modal" data-target="#addDayModal">
                            <i class="fa fa-plus"></i>
                            <span class="d-none d-md-inline ms-1">افزودن روز دستی</span>
                        </button>

                        <button class="btn btn-sm btn-outline-info px-2 py-0 text-nowrap"
                                id="btnAutoGenerateDays"
                                data-program-id="@program.ProgramId">
                            <i class="fa fa-magic"></i>
                            <span class="d-none d-md-inline ms-1">افزودن روزها خودکار</span>
                        </button>


                        <button class="btn btn-sm btn-outline-danger px-2 py-0 text-nowrap"
                                type="button"
                                onclick="openDeleteAllDaysModal(@program.ProgramId)">
                            <i class="fa fa-trash"></i>
                            <span class="d-none d-md-inline ms-1">حذف همه روزها</span>
                        </button>

                        <a class="btn btn-sm btn-outline-success px-2 py-0 text-nowrap"
                           href="/Admin/Food/Create" target="_blank">
                            <i class="fa fa-plus"></i>
                            <span class="d-none d-md-inline ms-1">افزودن غذا</span>
                        </a>

                        <a class="btn btn-sm btn-outline-success px-2 py-0 text-nowrap"
                           asp-area="Admin"
                           asp-controller="NutritionProgram"
                           asp-action="PrintProgram"
                           asp-route-id="@SecurityUtils.EncryptId(@program.ProgramId)">
                            <i class="fa fa-print me-2 text-primary"></i>گزارش PDF
                        </a>

                        <!-- ارسال پیام به کاربر در ربات بله -->
                        <button class="btn btn-sm btn-outline-primary px-2 py-0 text-nowrap"
                                onclick="sendProgramNotificationToUser(@program.ProgramId)">
                            <i class="fa fa-bell"></i>
                            <span class="d-none d-md-inline ms-1">ارسال پیام برنامه جدید به کاربر</span>
                        </button>

                        <!-- اطلاعات جسمانی ورزشکار -->
                        <button class="btn btn-sm btn-outline-dark px-2 py-0 text-nowrap"
                                type="button"
                                data-toggle="modal"
                                data-target="#memberInfoModal">
                            <i class="fa fa-clipboard-list"></i>
                            <span class="d-none d-md-inline ms-1"><i class="fa fa-heart" aria-hidden="true"></i>اطلاعات جسمانی ورزشکار</span>
                        </button>

                        <button class="btn btn-sm btn-outline-secondary px-2 py-0 text-nowrap"
                                onclick="location.reload()">
                            <i class="fa fa-refresh"></i>
                        </button>


                        <a class="btn btn-sm btn-outline-secondary px-2 py-0 text-nowrap"
                           href="/Admin/NutritionProgram">
                            <i class="fa fa-reply"></i>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="content-body">
        @if (program == null)
        {
            <div class="alert alert-danger">اطلاعات برنامه غذایی یافت نشد.</div>
        }
        else
        {
            @if (program.Days == null || program.Days.Count == 0)
            {
                <div class="alert alert-info">هنوز هیچ روزی برای این برنامه ثبت نشده است.</div>
            }
            else
            {
                <div id="daysAccordion" class="nutrition-days-accordion">

                    @for (int i = 0; i < program.Days.Count; i++)
                    {
                        var day = program.Days[i];
                        var collapseId = $"collapseDay_{day.Id}";
                        var headingId = $"headingDay_{day.Id}";

                        <div class="card nutrition-day-card mb-2 border-0 shadow-sm rounded-4 overflow-hidden">

                            <div class="d-flex align-items-center flex-nowrap gap-2 day-header-box">

                                <div class="day-actions d-flex align-items-center gap-1 flex-shrink-0">

                                    <button type="button"
                                            class="btn btn-sm btn-outline-facebook rounded-pill"
                                            onclick="openAddMealModal('@day.Id','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))')">
                                        <i class="fa fa-plus"></i>
                                        <span class="d-none d-md-inline ms-1">افزودن وعده</span>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-google rounded-pill"
                                            onclick="openEditDayModal('@day.Id','@day.DayNumber',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                        <i class="fa fa-pencil-square-o"></i>
                                        <span class="d-none d-md-inline ms-1">ویرایش روز</span>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger rounded-pill"
                                            onclick="openDeleteDayModal('@day.Id',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                        <i class="fa fa-times"></i>
                                        <span class="d-none d-md-inline ms-1">حذف روز</span>
                                    </button>

                                </div>

                                <button class="btn btn-link nutrition-day-toggle text-decoration-none p-0 font-weight-bold d-flex align-items-center gap-2 text-nowrap collapsed"
                                        data-toggle="collapse"
                                        data-target="#@collapseId"
                                        aria-expanded="false"
                                        aria-controls="@collapseId">
                                    <span class="day-label">روز</span>
                                    <span class="day-number-badge">@ToPersianNumbers(day.DayNumber)</span>
                                    @if (!string.IsNullOrWhiteSpace(day.Title))
                                    {
                                        <span class="day-title-text">@day.Title</span>
                                    }
                                    @if (day.Meals != null && day.Meals.Count > 0)
                                    {
                                        <span class="badge bg-info text-white px-2 py-1 rounded-pill meal-count-badge">
                                            @ToPersianNumbers(day.Meals.Count) وعده
                                        </span>
                                    }
                                    <i class="fa fa-chevron-down text-muted day-collapse-icon"></i>
                                </button>

                            </div>

                            <div id="@collapseId" class="collapse"
                                 aria-labelledby="@headingId"
                                 data-parent="#daysAccordion">

                                <div class="card-body nutrition-day-body">

                                    @if (day.Meals == null || day.Meals.Count == 0)
                                    {
                                        <div class="text-center p-4 border rounded-4 border-dashed"
                                             style="background-color:#fef2f2;border-color:#fca5a5!important;">
                                            <div style="color:#b91c1c;">
                                                <i class="fa fa-calendar-times-o fa-2x mb-2"></i>
                                                <h6 class="fw-bold">برای این روز هیچ وعده‌ای ثبت نشده!</h6>
                                            </div>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-facebook rounded-pill mt-2"
                                                    onclick="openAddMealModal('@day.Id','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))')">
                                                <i class="fa fa-plus me-1"></i> افزودن اولین وعده
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        @for (int j = 0; j < day.Meals.Count; j++)
                                        {
                                            var meal = day.Meals[j];

                                            <div class="card nutrition-meal-card mb-3 border-0 shadow-sm rounded-4 overflow-hidden">

                                                <div class="card-header nutrition-meal-header border-0 py-2 px-3">
                                                    <div class="meal-header-row d-flex align-items-center flex-nowrap">

                                                        <div class="meal-actions d-flex align-items-center gap-1 flex-nowrap">

                                                            <button type="button"
                                                                    class="meal-btn meal-btn-add"
                                                                    onclick="openAddMealItemModal('@meal.MealId',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`,`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.MealType ?? ""))`)">
                                                                <i class="fa fa-plus me-4"></i>
                                                                @* <i class="fa fa-cutlery text-primary"></i> *@
                                                            </button>

                                                            <button type="button"
                                                                    class="meal-btn meal-btn-edit"
                                                                    onclick="openEditMealModal('@meal.MealId','@day.Id','@meal.MealTypeId',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.Title ?? ""))`,`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`,`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.MealType ?? ""))`)">
                                                                <i class="fa fa-pencil"></i>
                                                                @* <i class="fa fa-cutlery text-primary"></i> *@
                                                            </button>

                                                            <button type="button"
                                                                    class="meal-btn meal-btn-delete"
                                                                    onclick="openDeleteMealModal('@meal.MealId',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.MealType ?? ""))`)">
                                                                <i class="fa fa-trash"></i>
                                                                @* <i class="fa fa-cutlery text-primary"></i> *@
                                                            </button>

                                                        </div>

                                                        <div style="width:14px"></div>

                                                        <div class="d-flex align-items-center gap-2 flex-nowrap">
                                                            <div class="meal-icon"><i class="fa fa-cutlery"></i></div>
                                                            <div class="meal-info d-flex align-items-center gap-2 flex-nowrap">
                                                                <span class="meal-label">نوع وعده :</span>
                                                                <span class="meal-label-date">@(day.Title)</span>
                                                                <span class="meal-type-highlight">
                                                                    @(string.IsNullOrWhiteSpace(meal.MealType) ? "-" : meal.MealType)
                                                                </span>
                                                                @if (meal.Foods?.Count > 0)
                                                                {
                                                                    <span class="meal-count-badge">
                                                                        <i class="fa fa-list-ul me-1"></i>
                                                                        @ToPersianNumbers(meal.Foods.Count)
                                                                    </span>
                                                                }
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>

                                                <div class="card-body nutrition-meal-body">

                                                    @if (meal.Foods == null || meal.Foods.Count == 0)
                                                    {
                                                        <div class="text-center p-4 border rounded-4 border-dashed"
                                                             style="background-color:#fef2f2;border-color:#fca5a5!important;">
                                                            <div style="color:#b91c1c;">
                                                                <i class="fa fa-cutlery fa-2x mb-2"></i>
                                                                <h6 class="fw-bold mb-1">هنوز هیچ غذایی ثبت نشده!</h6>
                                                                <p class="mb-0 small text-muted">می‌توانید اولین غذای این وعده را ثبت کنید.</p>
                                                            </div>
                                                            <button type="button"
                                                                    class="btn btn-sm btn-outline-danger rounded-pill mt-3"
                                                                    onclick="openAddMealItemModal('@meal.MealId',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`,`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(meal.MealType ?? ""))`)">
                                                                <i class="fa fa-plus me-1"></i> افزودن اولین غذا
                                                            </button>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="table-responsive">
                                                            <table class="table table-sm align-middle nutrition-food-table">
                                                                <thead class="text-uppercase text-nowrap">
                                                                    <tr>
                                                                        <th style="width:50px;">ردیف</th>
                                                                        <th>نام/عنوان غذا</th>
                                                                        <th class="text-center">مقدار</th>
                                                                        <th>واحد</th>
                                                                        <th>توضیحات</th>
                                                                        <th class="ps-3">عملیات</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    @{
                                                                        int counter = 1;
                                                                    }
                                                                    @foreach (var food in meal.Foods)
                                                                    {
                                                                        <tr>
                                                                            <td class="text-center fw-bold text-muted">@counter</td>
                                                                            <td class="food-name-cell text-nowrap">@food.FoodName</td>
                                                                            <td class="text-center text-nowrap">
                                                                                <span class="badge bg-light text-dark border amount-badge">@food.Amount</span>
                                                                            </td>
                                                                            <td class="food-name-cell text-nowrap">@food.Unit</td>
                                                                            <td class="food-name-cell text-nowrap food-description-cell">@food.Description</td>
                                                                            <td class="text-nowrap ps-3">
                                                                                <div class="d-flex align-items-center gap-1">
                                                                                    <button type="button"
                                                                                            class="btn btn-sm btn-outline-warning btn-modern"
                                                                                            onclick="openEditMealItemModal('@food.Id','@meal.MealId','@food.FoodId','@food.Amount','@food.UnitTypeId','@food.FoodName','@food.Description')">
                                                                                        ویرایش
                                                                                    </button>
                                                                                    <button type="button"
                                                                                            class="btn btn-sm btn-outline-danger btn-modern"
                                                                                            onclick="openDeleteMealItemModal('@food.Id','@food.FoodName')">
                                                                                        حذف
                                                                                    </button>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                        counter++;
                                                                    }
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    }

                                                </div>

                                            </div>
                                        }
                                    }

                                </div>

                            </div>

                        </div>
                    }

                </div>
            }
        }
    </div>
</div>

@* ================================================================
   مودال‌ها
================================================================ *@
@section Modals {

    @* ---------- افزودن روز ---------- *@
    <div class="modal fade" id="addDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">
                <div class="modal-header border-0 pb-2"
                     style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:16px 20px;">
                    <div>
                        <h5 class="modal-title text-white mb-0" style="font-size:15px;">
                            <i class="fa fa-plus-circle me-2" style="color:#00C896;"></i>
                            افزودن روز جدید
                        </h5>
                    </div>
                    <button type="button" class="close text-white" data-dismiss="modal" style="opacity:0.7;">&times;</button>
                </div>
                <div class="modal-body" style="padding:18px 20px;">
                    <form id="addDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="NutritionProgramId" value="@program?.ProgramId" />
                        <div class="form-group">
                            <label style="font-size:12px;font-weight:700;color:#4a5568;">شماره روز</label>
                            <input type="number" class="form-control" name="DayNumber" min="1"
                                   style="border-radius:8px;" />
                        </div>
                        <div class="form-group mb-0">
                            <label style="font-size:12px;font-weight:700;color:#4a5568;">عنوان روز</label>
                            <input type="text" class="form-control" name="Title"
                                   placeholder="مثلاً: روز اول" style="border-radius:8px;" />
                        </div>
                    </form>
                    <div id="addDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer border-0" style="padding:12px 20px;background:#f8fafd;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"
                            style="border-radius:9px;font-size:13px;">
                        بستن
                    </button>
                    <button type="submit" class="btn btn-primary" id="btnSaveDay" form="addDayForm"
                            style="border-radius:9px;font-size:13px;background:#00C896;border-color:#00C896;">
                        <span class="btn-text">ثبت روز</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ---------- ویرایش روز ---------- *@
    <div class="modal fade" id="editDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">
                <div class="modal-header border-0 pb-2"
                     style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:16px 20px;">
                    <div>
                        <h5 class="modal-title text-white mb-0" style="font-size:15px;">
                            <i class="fa fa-pencil-square-o me-2" style="color:#f6ad55;"></i>
                            ویرایش روز:
                            <span id="EditDay_Title" style="color:#f6ad55;font-size:13px;"></span>
                        </h5>
                    </div>
                    <button type="button" class="close text-white" data-dismiss="modal" style="opacity:0.7;">&times;</button>
                </div>
                <div class="modal-body" style="padding:18px 20px;">
                    <form id="editDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="EditDay_Id" name="Id" />
                        <div class="form-group">
                            <label style="font-size:12px;font-weight:700;color:#4a5568;">شماره روز</label>
                            <input type="number" class="form-control" id="EditDay_DayNumber" name="DayNumber" min="1"
                                   style="border-radius:8px;" />
                        </div>
                        <div class="form-group mb-0">
                            <label style="font-size:12px;font-weight:700;color:#4a5568;">عنوان روز</label>
                            <input type="text" class="form-control" id="EditDay_Title_txt" name="Title"
                                   style="border-radius:8px;" />
                        </div>
                    </form>
                    <div id="editDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer border-0" style="padding:12px 20px;background:#f8fafd;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"
                            style="border-radius:9px;font-size:13px;">
                        بستن
                    </button>
                    <button type="submit" class="btn btn-warning" id="btnEditDay" form="editDayForm"
                            style="border-radius:9px;font-size:13px;">
                        <span class="btn-text">ذخیره تغییرات</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ---------- حذف روز ---------- *@
    <div class="modal fade" id="deleteDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">
                <div class="modal-header border-0"
                     style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:14px 18px;">
                    <h5 class="modal-title text-white mb-0" style="font-size:14px;">
                        <i class="fa fa-trash me-2" style="color:#fc8181;"></i>
                        حذف روز:
                        <span id="DeleteDay_Title" style="color:#fc8181;"></span>
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" style="opacity:0.7;">&times;</button>
                </div>
                <div class="modal-body" style="padding:16px 18px;">
                    <form id="deleteDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="DeleteDay_Id" name="Id" />
                    </form>
                    <div class="alert alert-warning mb-0" style="border-radius:8px;font-size:13px;">
                        <i class="fa fa-exclamation-triangle me-1"></i>
                        آیا از حذف این روز مطمئن هستید؟ تمام وعده‌ها و غذاهای آن نیز حذف خواهند شد.
                    </div>
                    <div id="deleteDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer border-0" style="padding:10px 18px;background:#f8fafd;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"
                            style="border-radius:9px;font-size:13px;">
                        انصراف
                    </button>
                    <button type="submit" class="btn btn-danger" id="btnDeleteDay" form="deleteDayForm"
                            style="border-radius:9px;font-size:13px;">
                        <span class="btn-text">حذف</span>
                    </button>
                </div>
            </div>
