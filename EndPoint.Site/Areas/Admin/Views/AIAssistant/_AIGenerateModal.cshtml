@*
    پارشال مشترک برای هر دو Builder
    استفاده: <partial name="~/Areas/Admin/Views/Shared/Partials/_AIGenerateModal.cshtml" />
*@

<!-- ====================================
     مودال تولید برنامه با AI
==================================== -->
<div class="modal fade" id="aiGenerateModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content border-0 shadow-lg" style="border-radius:16px;overflow:hidden;">

            <!-- هدر با گرادیان AI -->
            <div class="modal-header border-0"
                 style="background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);padding:20px 24px;">
                <div>
                    <h5 class="modal-title text-white mb-1" style="font-size:17px;font-weight:700;">
                        <span style="background:linear-gradient(135deg,#00C896,#63b3ed);
                                     -webkit-background-clip:text;-webkit-text-fill-color:transparent;
                                     font-size:20px;margin-left:6px;">✦ AI</span>
                        تولید خودکار برنامه با هوش مصنوعی
                    </h5>
                    <p style="color:#a0aec0;font-size:12px;margin:0;">
                        پروفایل عضو تحلیل می‌شود — برنامه شخصی‌سازی‌شده در چند ثانیه تولید می‌شود
                    </p>
                </div>
                <button type="button" class="close text-white" data-dismiss="modal"
                        style="opacity:.7;font-size:22px;">&times;</button>
            </div>

            <div class="modal-body" style="padding:24px;">

                <!-- تنظیمات -->
                <div class="row g-3 mb-4">

                    <div class="col-md-6">
                        <label style="font-size:12px;font-weight:700;color:#4a5568;display:block;margin-bottom:6px;">
                            <i class="fa fa-bullseye me-1" style="color:#00C896;"></i>
                            هدف اصلی برنامه
                        </label>
                        <select id="aiGoal" class="form-control" style="border-radius:9px;">
                            <option value="کاهش وزن و چربی‌سوزی">کاهش وزن و چربی‌سوزی</option>
                            <option value="افزایش حجم عضلانی">افزایش حجم عضلانی</option>
                            <option value="تناسب اندام و فیتنس عمومی">تناسب اندام و فیتنس عمومی</option>
                            <option value="افزایش قدرت و عملکرد">افزایش قدرت و عملکرد</option>
                            <option value="ریکاوری و سلامت عمومی">ریکاوری و سلامت عمومی</option>
                            <option value="آمادگی جسمانی استقامتی">آمادگی جسمانی استقامتی</option>
                        </select>
                    </div>

                    <div class="col-md-3" id="aiDaysCountWrapper">
                        <label style="font-size:12px;font-weight:700;color:#4a5568;display:block;margin-bottom:6px;">
                            <i class="fa fa-calendar me-1" style="color:#63b3ed;"></i>
                            تعداد روز برنامه
                        </label>
                        <select id="aiDaysCount" class="form-control" style="border-radius:9px;">
                            <option value="7">۷ روز (یک هفته)</option>
                            <option value="14">۱۴ روز (دو هفته)</option>
                            <option value="21">۲۱ روز (سه هفته)</option>
                            <option value="28">۲۸ روز (یک ماه)</option>
                        </select>
                    </div>

                    <div class="col-md-3" id="aiDaysPerWeekWrapper" style="display:none;">
                        <label style="font-size:12px;font-weight:700;color:#4a5568;display:block;margin-bottom:6px;">
                            <i class="fa fa-repeat me-1" style="color:#9f7aea;"></i>
                            جلسات در هفته
                        </label>
                        <select id="aiDaysPerWeek" class="form-control" style="border-radius:9px;">
                            <option value="3">۳ جلسه</option>
                            <option value="4" selected>۴ جلسه</option>
                            <option value="5">۵ جلسه</option>
                            <option value="6">۶ جلسه</option>
                        </select>
                    </div>

                </div>

                <div class="form-group mb-3">
                    <label style="font-size:12px;font-weight:700;color:#4a5568;display:block;margin-bottom:6px;">
                        <i class="fa fa-sticky-note-o me-1" style="color:#f6ad55;"></i>
                        توضیحات اضافه (اختیاری)
                    </label>
                    <textarea id="aiMemberNote" rows="2" class="form-control" style="border-radius:9px;"
                              placeholder="مثلاً: تمرین صبح‌ها انجام می‌دهم، دوست دارم برنامه متنوع باشد..."></textarea>
                </div>

                <!-- اطلاعات عضو (پیش‌نمایش) -->
                <div id="aiMemberProfilePreview" style="display:none;
                     background:#f8fafd;border:1.5px solid #e2e8f0;border-radius:10px;padding:14px 16px;margin-bottom:16px;">
                    <div style="font-size:12px;font-weight:700;color:#4a5568;margin-bottom:8px;">
                        <i class="fa fa-user me-1" style="color:#00C896;"></i>
                        اطلاعات عضو که به AI ارسال می‌شود:
                    </div>
                    <div id="aiMemberProfileContent" style="font-size:12px;color:#4a5568;line-height:1.8;"></div>
                </div>

                <!-- وضعیت در حال تولید -->
                <div id="aiLoadingState" style="display:none;text-align:center;padding:30px 0;">
                    <div style="display:inline-flex;flex-direction:column;align-items:center;gap:16px;">
                        <div style="width:60px;height:60px;border-radius:50%;
                                    background:linear-gradient(135deg,#00C896,#63b3ed);
                                    display:flex;align-items:center;justify-content:center;
                                    animation:aiPulse 1.5s ease-in-out infinite;">
                            <i class="fa fa-magic" style="color:#fff;font-size:24px;"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:14px;" id="aiLoadingText">
                                در حال تحلیل پروفایل عضو...
                            </div>
                            <div style="font-size:12px;color:#718096;margin-top:4px;">
                                این فرآیند ممکن است ۱۰ تا ۳۰ ثانیه طول بکشد
                            </div>
                        </div>
                    </div>
                </div>

                <!-- پیام خطا -->
                <div id="aiErrorMessage" style="display:none;"></div>

            </div>

            <div class="modal-footer border-0" style="padding:14px 24px;background:#f8fafd;">
                <button type="button" class="btn btn-secondary" data-dismiss="modal"
                        style="border-radius:10px;font-size:13px;">انصراف</button>
                <button type="button" id="btnGenerateAI"
                        style="border-radius:10px;font-size:13px;font-weight:700;
                               padding:9px 24px;border:none;color:#fff;
                               background:linear-gradient(135deg,#00C896,#0fa0d0);">
                    <i class="fa fa-magic me-1"></i>
                    <span id="btnGenerateAIText">تولید برنامه با AI</span>
                </button>
            </div>

        </div>
    </div>
</div>

<!-- ====================================
     مودال چت‌بات مربی مجازی
==================================== -->
<div id="aiChatWidget"
     style="position:fixed;bottom:24px;left:24px;z-index:9999;">

    <!-- دکمه باز کردن -->
    <button id="aiChatToggle"
            style="width:56px;height:56px;border-radius:50%;border:none;
                   background:linear-gradient(135deg,#00C896,#0fa0d0);
                   color:#fff;font-size:22px;cursor:pointer;
                   box-shadow:0 4px 20px rgba(0,200,150,0.4);
                   transition:transform .2s;"
            title="مربی مجازی"
            onclick="toggleAIChat()">
        <i class="fa fa-commenting-o" id="aiChatIcon"></i>
    </button>

    <!-- پنجره چت -->
    <div id="aiChatWindow"
         style="display:none;position:absolute;bottom:68px;left:0;
                width:340px;background:#fff;border-radius:16px;
                box-shadow:0 8px 40px rgba(0,0,0,0.15);
                overflow:hidden;">

        <!-- هدر -->
        <div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);
                    padding:14px 16px;display:flex;align-items:center;gap:10px;">
            <div style="width:36px;height:36px;border-radius:50%;
                        background:linear-gradient(135deg,#00C896,#63b3ed);
                        display:flex;align-items:center;justify-content:center;
                        font-size:16px;color:#fff;flex-shrink:0;">
                <i class="fa fa-magic"></i>
            </div>
            <div>
                <div style="color:#fff;font-weight:700;font-size:13px;">مربی مجازی FitCore</div>
                <div style="color:#a0aec0;font-size:11px;">هوش مصنوعی — همیشه آنلاین</div>
            </div>
            <button onclick="toggleAIChat()"
                    style="background:none;border:none;color:#a0aec0;
                           font-size:18px;margin-right:auto;cursor:pointer;">×</button>
        </div>

        <!-- پیام‌ها -->
        <div id="aiChatMessages"
             style="height:280px;overflow-y:auto;padding:12px;
                    display:flex;flex-direction:column;gap:8px;background:#f8fafd;">

            <div class="ai-msg ai-msg-bot">
                سلام! من مربی مجازی FitCore هستم 🏋️<br>
                می‌تونی هر سوالی درباره تمرین، تغذیه یا برنامه ورزشی داری ازم بپرسی.
            </div>

        </div>

        <!-- فرم ارسال -->
        <div style="padding:10px 12px;border-top:1px solid #e2e8f0;
                    display:flex;gap:8px;align-items:center;background:#fff;">
            <input type="text" id="aiChatInput"
                   placeholder="سوال خود را بنویسید..."
                   style="flex:1;border:1.5px solid #e2e8f0;border-radius:20px;
                          padding:8px 14px;font-size:12.5px;outline:none;
                          font-family:inherit;"
                   onkeydown="if(event.key==='Enter') sendAIChat()" />
            <button onclick="sendAIChat()"
                    style="width:36px;height:36px;border-radius:50%;border:none;
                           background:linear-gradient(135deg,#00C896,#0fa0d0);
                           color:#fff;cursor:pointer;flex-shrink:0;font-size:14px;">
                <i class="fa fa-paper-plane"></i>
            </button>
        </div>

    </div>
</div>

<style>
    @@keyframes aiPulse {
        0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(0,200,150,0.4); }
        50%       { transform: scale(1.05); box-shadow: 0 0 0 12px rgba(0,200,150,0); }
    }

    #aiChatToggle:hover { transform: scale(1.1); }

    .ai-msg {
        max-width: 85%;
        padding: 9px 13px;
        border-radius: 12px;
        font-size: 12.5px;
        line-height: 1.6;
        word-break: break-word;
    }

    .ai-msg-user {
        background: linear-gradient(135deg,#00C896,#0fa0d0);
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }

    .ai-msg-bot {
        background: #fff;
        color: #1a202c;
        align-self: flex-start;
        border: 1px solid #e2e8f0;
        border-bottom-left-radius: 4px;
    }

    .ai-msg-typing {
        background: #fff;
        border: 1px solid #e2e8f0;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
        color: #718096;
        font-style: italic;
    }
</style>

<script>

    // ====================================================
    // متغیرهای عمومی
    // ====================================================
    var _aiProgramType   = '';      // 'nutrition' یا 'training'
    var _aiProgramId     = 0;
    var _aiChatOpen      = false;
    var _antiForgeryToken = $('input[name="__RequestVerificationToken"]').first().val();

    // ====================================================
    // باز کردن مودال AI Generator از Builder
    // ====================================================
    function openAIGenerateModal(programType, programId, memberProfile) {
        _aiProgramType = programType;
        _aiProgramId   = programId;

        // نمایش/پنهان کردن فیلد جلسات هفتگی
        if (programType === 'training') {
            $('#aiDaysPerWeekWrapper').show();
        } else {
            $('#aiDaysPerWeekWrapper').hide();
        }

        // نمایش پروفایل عضو
        if (memberProfile) {
            var html = '';
            if (memberProfile.fullName) html += '<span class="me-3">👤 ' + memberProfile.fullName + '</span>';
            if (memberProfile.height)   html += '<span class="me-3">📏 قد: ' + memberProfile.height + ' cm</span>';
            if (memberProfile.weight)   html += '<span class="me-3">⚖️ وزن: ' + memberProfile.weight + ' kg</span>';
            if (memberProfile.activityLevel) html += '<span class="me-3">⚡ ' + memberProfile.activityLevel + '</span>';
            if (memberProfile.experienceLevel) html += '<span class="me-3">🏆 ' + memberProfile.experienceLevel + '</span>';
            if (memberProfile.foodAllergies) html += '<span class="me-3">⚠️ آلرژی: ' + memberProfile.foodAllergies + '</span>';
            if (memberProfile.injuries) html += '<span class="me-3">🩹 آسیب: ' + memberProfile.injuries + '</span>';

            if (html) {
                $('#aiMemberProfileContent').html(html);
                $('#aiMemberProfilePreview').show();
            }
        }

        $('#aiLoadingState').hide();
        $('#aiErrorMessage').hide();
        $('#btnGenerateAI').prop('disabled', false);
        $('#btnGenerateAIText').text('تولید برنامه با AI');
        $('#aiGenerateModal').modal('show');
    }

    // ====================================================
    // تولید برنامه با AI
    // ====================================================
    $(document).on('click', '#btnGenerateAI', function () {

        var goal         = $('#aiGoal').val();
        var daysCount    = parseInt($('#aiDaysCount').val(), 10);
        var daysPerWeek  = parseInt($('#aiDaysPerWeek').val(), 10);
        var memberNote   = $('#aiMemberNote').val();

        var url = _aiProgramType === 'nutrition'
            ? '/Admin/AIAssistant/GenerateNutritionProgram'
            : '/Admin/AIAssistant/GenerateTrainingProgram';

        var $btn = $(this);
        $btn.prop('disabled', true);
        $('#btnGenerateAIText').text('در حال تولید...');
        $('#aiLoadingState').show();
        $('#aiErrorMessage').hide();

        // انیمیشن متن لودینگ
        var loadingTexts = [
            'در حال تحلیل پروفایل عضو...',
            'محاسبه نیازهای تغذیه‌ای...',
            'طراحی ساختار برنامه...',
            'شخصی‌سازی بر اساس هدف...',
            'آماده‌سازی برنامه نهایی...'
        ];
        var ltIdx = 0;
        var ltInterval = setInterval(function () {
            ltIdx = (ltIdx + 1) % loadingTexts.length;
            $('#aiLoadingText').text(loadingTexts[ltIdx]);
        }, 3000);

        var postData = {
            __RequestVerificationToken: _antiForgeryToken,
            goal: goal,
            daysCount: daysCount,
            memberNote: memberNote
        };

        if (_aiProgramType === 'nutrition') {
            postData.nutritionProgramId = _aiProgramId;
        } else {
            postData.trainingProgramId = _aiProgramId;
            postData.daysPerWeek = daysPerWeek;
            postData.totalDays   = daysCount;
        }

        $.ajax({
            url:  url,
            type: 'POST',
            data: postData,

            success: function (res) {
                clearInterval(ltInterval);
                $('#aiLoadingState').hide();

                if (res.isSuccess) {
                    $('#aiGenerateModal').modal('hide');

                    // ارسال داده به Builder
                    if (_aiProgramType === 'nutrition') {
                        applyNutritionAIResult(res.data);
                    } else {
                        applyTrainingAIResult(res.data);
                    }
                } else {
                    $('#aiErrorMessage').html(
                        '<div class="alert alert-danger mb-0" style="border-radius:9px;font-size:13px;">' +
                        '<i class="fa fa-times-circle me-1"></i>' + res.message + '</div>'
                    ).show();
                    $btn.prop('disabled', false);
                    $('#btnGenerateAIText').text('تولید برنامه با AI');
                }
            },

            error: function () {
                clearInterval(ltInterval);
                $('#aiLoadingState').hide();
                $('#aiErrorMessage').html(
                    '<div class="alert alert-danger mb-0" style="border-radius:9px;font-size:13px;">' +
                    'خطا در ارتباط با سرور. لطفاً دوباره امتحان کنید.</div>'
                ).show();
                $btn.prop('disabled', false);
                $('#btnGenerateAIText').text('تولید برنامه با AI');
            }
        });
    });

    // ====================================================
    // اعمال نتیجه AI روی NutritionProgramBuilder
    // ====================================================
    function applyNutritionAIResult(data) {
        Swal.fire({
            icon:  'success',
            title: '✦ برنامه غذایی توسط AI تولید شد!',
            html:  '<div style="font-size:13px;color:#4a5568;">' + (data.summary || '') + '</div>' +
                   '<div style="margin-top:12px;background:#f8fafd;border-radius:8px;padding:10px;">' +
                   '<span style="margin:0 8px;">🔥 کالری: <strong>' + (data.totalCalories || '—') + '</strong></span>' +
                   '<span style="margin:0 8px;">💪 پروتئین: <strong>' + (data.totalProtein || '—') + 'g</strong></span>' +
                   '<span style="margin:0 8px;">🍞 کربو: <strong>' + (data.totalCarb || '—') + 'g</strong></span>' +
                   '<span style="margin:0 8px;">🥑 چربی: <strong>' + (data.totalFat || '—') + 'g</strong></span>' +
                   '</div>' +
                   '<div style="margin-top:10px;font-size:12px;color:#718096;">' +
                   data.days.length + ' روز برنامه آماده شده. صفحه reload می‌شود تا بتوانید ویرایش کنید.</div>',
            confirmButtonText: 'شروع ذخیره‌سازی',
            confirmButtonColor: '#00C896',
            allowOutsideClick: false
        }).then(function () {
            saveNutritionAIProgram(data);
        });
    }

    function saveNutritionAIProgram(data) {
        Swal.fire({
            title: 'در حال ذخیره...',
            html: 'برنامه غذایی AI در حال ذخیره‌سازی است',
            allowOutsideClick: false,
            didOpen: function () { Swal.showLoading(); }
        });

        var days = data.days || [];
        var dayIndex = 0;

        function saveNextDay() {
            if (dayIndex >= days.length) {
                Swal.close();
                Swal.fire({
                    icon: 'success', title: 'ذخیره شد!',
                    text: 'برنامه با موفقیت ذخیره شد.',
                    timer: 2000, showConfirmButton: false
                }).then(function () { location.reload(); });
                return;
            }

            var day = days[dayIndex];

            $.ajax({
                url: '/Admin/NutritionProgramBuilder/AddDay',
                type: 'POST',
                data: {
                    __RequestVerificationToken: _antiForgeryToken,
                    NutritionProgramId: _aiProgramId,
                    DayNumber: day.dayNumber,
                    Title: day.title || ('روز ' + day.dayNumber)
                },
                success: function (res) {
                    if (res && res.isSuccess && res.dayId) {
                        saveMealsForDay(res.dayId, day.meals || [], function () {
                            dayIndex++;
                            saveNextDay();
                        });
                    } else {
                        dayIndex++;
                        saveNextDay();
                    }
                },
                error: function () { dayIndex++; saveNextDay(); }
            });
        }

        saveNextDay();
    }

    function saveMealsForDay(dayId, meals, callback) {
        var mealIndex = 0;

        function saveNextMeal() {
            if (mealIndex >= meals.length) { callback(); return; }
            var meal = meals[mealIndex];

            $.ajax({
                url: '/Admin/NutritionProgramBuilder/AddMeal',
                type: 'POST',
                data: {
                    __RequestVerificationToken: _antiForgeryToken,
                    NutritionProgramDayId: dayId,
                    MealTypeId: getMealTypeId(meal.mealType),
                    Title: meal.title || meal.mealType
                },
                success: function (res) {
                    if (res && res.isSuccess && res.mealId) {
                        saveFoodsForMeal(res.mealId, meal.foods || [], function () {
                            mealIndex++;
                            saveNextMeal();
                        });
                    } else {
                        mealIndex++;
                        saveNextMeal();
                    }
                },
                error: function () { mealIndex++; saveNextMeal(); }
            });
        }

        saveNextMeal();
    }

    function saveFoodsForMeal(mealId, foods, callback) {
        var foodIndex = 0;

        function saveNextFood() {
            if (foodIndex >= foods.length) { callback(); return; }
            var food = foods[foodIndex];

            // غذاها به‌صورت توضیحات ذخیره می‌شوند — مربی بعداً از بانک غذاها انتخاب می‌کند
            $.ajax({
                url: '/Admin/NutritionProgramBuilder/AddMealItem',
                type: 'POST',
                data: {
                    __RequestVerificationToken: _antiForgeryToken,
                    NutritionMealId: mealId,
                    FoodId: 1, // پیش‌فرض — مربی بعداً ویرایش می‌کند
                    Amount: food.amount || 1,
                    UnitTypeId: 1,
                    Description: food.name + (food.note ? ' — ' + food.note : '') +
                                 ' (' + food.amount + ' ' + food.unit + ')'
                },
                complete: function () { foodIndex++; saveNextFood(); }
            });
        }

        saveNextFood();
    }

    function getMealTypeId(mealType) {
        var map = {
            'صبحانه': 1, 'میان‌وعده صبح': 2, 'ناهار': 3,
            'میان‌وعده عصر': 4, 'شام': 5, 'قبل از خواب': 6,
            'قبل از تمرین': 7, 'بعد از تمرین': 8
        };
        return map[mealType] || 1;
    }

    // ====================================================
    // اعمال نتیجه AI روی TrainingProgramBuilder
    // ====================================================
    function applyTrainingAIResult(data) {
        Swal.fire({
            icon:  'success',
            title: '✦ برنامه تمرینی توسط AI تولید شد!',
            html:  '<div style="font-size:13px;color:#4a5568;">' + (data.summary || '') + '</div>' +
                   (data.weeklyPlan ? '<div style="margin-top:8px;font-size:12px;background:#f8fafd;border-radius:8px;padding:8px;color:#4a5568;">' + data.weeklyPlan + '</div>' : '') +
                   '<div style="margin-top:10px;font-size:12px;color:#718096;">' +
                   data.days.length + ' روز برنامه آماده شده.</div>',
            confirmButtonText: 'شروع ذخیره‌سازی',
            confirmButtonColor: '#00C896',
            allowOutsideClick: false
        }).then(function () {
            saveTrainingAIProgram(data);
        });
    }

    function saveTrainingAIProgram(data) {
        Swal.fire({
            title: 'در حال ذخیره...',
            html: 'برنامه تمرینی AI در حال ذخیره‌سازی است',
            allowOutsideClick: false,
            didOpen: function () { Swal.showLoading(); }
        });

        var days = data.days || [];
        var dayIndex = 0;

        function saveNextDay() {
            if (dayIndex >= days.length) {
                Swal.close();
                Swal.fire({
                    icon: 'success', title: 'ذخیره شد!',
                    text: 'برنامه تمرینی با موفقیت ذخیره شد.',
                    timer: 2000, showConfirmButton: false
                }).then(function () { location.reload(); });
                return;
            }

            var day = days[dayIndex];

            $.ajax({
                url: '/Admin/TrainingProgramBuilder/AddDay',
                type: 'POST',
                data: {
                    __RequestVerificationToken: _antiForgeryToken,
                    TrainingProgramId: _aiProgramId,
                    DayNumber: day.dayNumber,
                    Title: day.title || ('روز ' + day.dayNumber),
                    DayTypeId: getDayTypeId(day.dayType),
                    DurationMinutes: day.durationMinutes || 60
                },
                success: function (res) {
                    if (res && res.isSuccess && res.data && res.data.id) {
                        saveExercisesForDay(res.data.id, day.exercises || [], function () {
                            dayIndex++;
                            saveNextDay();
                        });
                    } else {
                        dayIndex++;
                        saveNextDay();
                    }
                },
                error: function () { dayIndex++; saveNextDay(); }
            });
        }

        saveNextDay();
    }

    function saveExercisesForDay(dayId, exercises, callback) {
        var exIndex = 0;

        function saveNextExercise() {
            if (exIndex >= exercises.length) { callback(); return; }
            var ex = exercises[exIndex];

            // پیدا کردن ExerciseId از بانک حرکات
            findExerciseByName(ex.name, function (exerciseId) {
                if (!exerciseId) { exIndex++; saveNextExercise(); return; }

                $.ajax({
                    url: '/Admin/TrainingProgramBuilder/AddExercise',
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: _antiForgeryToken,
                        TrainingDayId: dayId,
                        ExerciseId: exerciseId,
                        Sets: ex.sets || 3,
                        Reps: ex.reps || '10-12',
                        RestSeconds: ex.restSeconds || 90,
                        CoachNote: ex.coachNote || ''
                    },
                    complete: function () { exIndex++; saveNextExercise(); }
                });
            });
        }

        saveNextExercise();
    }

    // جستجوی حرکت در بانک حرکات
    function findExerciseByName(name, callback) {
        $.ajax({
            url: '/Admin/Exercise/SearchByName',
            type: 'GET',
            data: { name: name },
            success: function (res) {
                callback(res && res.id ? res.id : null);
            },
            error: function () { callback(null); }
        });
    }

    function getDayTypeId(dayType) {
        var map = {
            'Push': 4, 'Pull': 5, 'Leg': 6,
            'سینه': 7, 'پشت': 8, 'پا': 6,
            'بالاتنه': 1, 'پایین‌تنه': 2, 'فول‌بادی': 3,
            'FullBody': 3, 'کاردیو': 10, 'استراحت': 11
        };
        return map[dayType] || 3;
    }

    // ====================================================
    // چت‌بات مربی مجازی
    // ====================================================
    function toggleAIChat() {
        _aiChatOpen = !_aiChatOpen;
        if (_aiChatOpen) {
            $('#aiChatWindow').show();
            $('#aiChatIcon').removeClass('fa-commenting-o').addClass('fa-times');
            setTimeout(function () { $('#aiChatInput').focus(); }, 100);
        } else {
            $('#aiChatWindow').hide();
            $('#aiChatIcon').removeClass('fa-times').addClass('fa-commenting-o');
        }
    }

    function sendAIChat() {
        var question = $('#aiChatInput').val().trim();
        if (!question) return;

        $('#aiChatInput').val('');

        // نمایش پیام کاربر
        $('#aiChatMessages').append(
            '<div class="ai-msg ai-msg-user">' + escapeHtml(question) + '</div>'
        );

        // نمایش تایپینگ
        var $typing = $('<div class="ai-msg ai-msg-typing">⋯</div>');
        $('#aiChatMessages').append($typing);
        scrollChat();

        $.ajax({
            url: '/Admin/AIAssistant/AskCoach',
            type: 'POST',
            data: {
                __RequestVerificationToken: _antiForgeryToken,
                question: question
            },
            success: function (res) {
                $typing.remove();
                var answer = res.isSuccess
                    ? res.answer
                    : 'متأسفم، در حال حاضر قادر به پاسخ نیستم.';

                $('#aiChatMessages').append(
                    '<div class="ai-msg ai-msg-bot">' + formatAIAnswer(answer) + '</div>'
                );
                scrollChat();
            },
            error: function () {
                $typing.remove();
                $('#aiChatMessages').append(
                    '<div class="ai-msg ai-msg-bot">خطا در ارتباط با سرور.</div>'
                );
                scrollChat();
            }
        });
    }

    function scrollChat() {
        var $msgs = $('#aiChatMessages');
        $msgs.scrollTop($msgs[0].scrollHeight);
    }

    function escapeHtml(str) {
        return $('<div>').text(str).html();
    }

    function formatAIAnswer(text) {
        return text.replace(/\n/g, '<br>');
    }

</script>
