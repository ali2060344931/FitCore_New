<div class="container-fluid" style="padding-top:16px;padding-bottom:24px;">

    @* ============ هشدار تکمیل پروفایل ============ *@
    @if (!isProfileDone)
    {
        <div class="mb-profile-alert">
            <i class="fa fa-exclamation-triangle" style="color:#f6ad55;font-size:18px;flex-shrink:0;"></i>
            <div style="flex:1;">
                <strong>پروفایل شما ناقص است</strong> — لطفاً اطلاعات جسمانی خود را تکمیل کنید.
            </div>
            <a href="/Admin/MemberProfile/CompleteInfo" class="btn btn-sm btn-warning" style="border-radius:8px;font-size:11px;white-space:nowrap;">
                <i class="fa fa-edit me-1"></i>تکمیل
            </a>
        </div>
    }

    @* ============ هدر خوش‌آمد ============ *@
    <div class="mb-header-card" style="margin-bottom:15px;">
        <div class="mb-header-top">
            <div class="mb-header-avatar">
                @(memberName.Length > 0 ? memberName[0].ToString() : "؟")
            </div>
            <div class="mb-header-info">
                <div class="mb-header-name">سلام، @memberName 👋 <help key="MD00" /></div>
                <div class="mb-header-meta">
                    <span><i class="fa fa-mobile me-1"></i>@memberMobile</span>
                    <span>@genderLabel</span>
                    @if (!string.IsNullOrWhiteSpace(member?.BirthDate))
                    {
                        <span><i class="fa fa-birthday-cake me-1"></i>  تاریخ تولد: @member.BirthDate     <i class="fa fa-calendar" aria-hidden="true"></i>  سن: @ViewBag.MemberBirthDate</span>
                    }
                </div>
            </div>
        </div>
        <div class="mb-header-tags">
            @if (member?.ActivityLevel != null)
            {
                <span class="mb-header-tag"><i class="fa fa-bolt me-1"></i>@member.ActivityLevel.Name</span>
            }
            @if (member?.ExperienceLevel != null)
            {
                <span class="mb-header-tag"><i class="fa fa-trophy me-1"></i>@member.ExperienceLevel.Name</span>
            }
            @if (member?.Height != null)
            {
                <span class="mb-header-tag"><i class="fa fa-arrows-v me-1"></i>قد: @member.Height cm</span>
            }
        </div>
    </div>

    @* ============ وضعیت عضویت ============ *@

    @if (membershipStatus != null)
    {
        string msClass = membershipStatus.Status
        switch
        {
            MembershipState.Active => "active",
            MembershipState.ExpiringSoon => "soon",
            MembershipState.Expired => "expired",
            MembershipState.NotActive => "expired",
            _ => "unknown"
        };

        string msIcon = membershipStatus.Status
        switch
        {
            MembershipState.Active => "fa-check-circle",
            MembershipState.ExpiringSoon => "fa-exclamation-circle",
            MembershipState.Expired => "fa-times-circle",
            MembershipState.NotActive => "fa-times-circle",
            _ => "fa-question-circle"
        };

        string msIconColor = membershipStatus.Status
        switch
        {
            MembershipState.Active => "#00C896",
            MembershipState.ExpiringSoon => "#f6ad55",
            MembershipState.Expired => "#fc8181",
            MembershipState.NotActive => "#fc8181",
            _ => "#a0aec0"
        };

        string msText = membershipStatus.Status
        switch
        {   
            MembershipState.Active => $"عضویت فعال — {membershipStatus.DaysLeft} روز تا پایان",
            MembershipState.ExpiringSoon => $"⚠️ تا {membershipStatus.DaysLeft} روز دیگر منقضی می‌شود",
            MembershipState.Expired => "عضویت منقضی شده — با باشگاه تماس بگیرید",
            MembershipState.NotActive => "عضویت شما توسط مدیریت باشگاه غیر فعال شد",

            _ => "اطلاعات عضویت تعریف نشده"
        };

        <div class="mb-membership-card @msClass" style="margin-bottom:15px;">
            <i class="fa @msIcon fa-2x" style="color:@msIconColor;flex-shrink:0;"></i>
            <div class="mb-membership-info">
                <div class="mb-membership-title">@msText</div>
                <div class="mb-membership-dates">
                    <span><i class="fa fa-calendar-o me-1"></i>شروع: <strong>@membershipStatus.StartDate</strong></span>
                    <span><i class="fa fa-calendar-times-o me-1"></i>پایان: <strong>@membershipStatus.EndDate</strong></span>
                </div>

                @*<div class="mb-membership-dates">
                    <span><i class="fa fa-calendar-times-o me-1"></i>سن: <strong>@ViewBag.MemberBirthDate</strong></span>
                </div>*@

            </div>


        </div>

    }

    @* ============ کارت‌های آمار ============ *@
    <div class="row g-2" style="margin-bottom:15px;">



        @if (isActivMember)
        {
            <div class="col-6 col-md-3">
                <a href="/Admin/MemberDashboard/MyNutritionPrograms" class="mb-stat" style="--c:#00C896;--cb:#edfaf5;">
                    <div class="mb-stat-icon"><i class="fa fa-cutlery"></i></div>
                    <div><div class="mb-stat-num">@(nutritionList?.Count ?? 0)</div><div class="mb-stat-lbl">برنامه غذایی</div></div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a href="/Admin/MemberDashboard/MyTrainingPrograms" class="mb-stat" style="--c:#3182ce;--cb:#ebf8ff;">
                    <div class="mb-stat-icon"><i class="fa fa-heartbeat"></i></div>
                    <div><div class="mb-stat-num">@(trainingList?.Count ?? 0)</div><div class="mb-stat-lbl">برنامه تمرینی</div></div>
                </a>
            </div>
        }

        <div class="col-6 col-md-3">
            <a href="/Admin/MemberProfile/BodyMeasurement/@encryptedId" class="mb-stat" style="--c:#9f7aea;--cb:#faf5ff;">
                <div class="mb-stat-icon"><i class="fa fa-balance-scale"></i></div>
                <div><div class="mb-stat-num">@(lastMeasurement?.Weight?.ToString("0.#") ?? "-")</div><div class="mb-stat-lbl">@(lastMeasurement != null ? "وزن (kg)" : "بدون وزن")</div></div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Admin/MemberProfile/CompleteInfo" class="mb-stat" style="--c:#f6ad55;--cb:#fffaf0;">
                <div class="mb-stat-icon"><i class="fa fa-user-circle-o"></i></div>
                <div><div class="mb-stat-num" style="font-size:14px;padding-top:2px;">@(isProfileDone ? "✓ کامل" : "ناقص")</div><div class="mb-stat-lbl">وضعیت پروفایل</div></div>
            </a>
        </div>
    </div>

    @* ============ گزارش پیشرفت جسمانی ============ *@
    @{
        var analytics = ViewBag.Analytics as FitCore.Application.Services.Member.Queries.MemberAnalyticsDto;
    }

    @if (analytics != null && (analytics.WeightHistory.Any() || analytics.Nutrition != null || analytics.Training != null))
    {
        <!-- ردیف اول: پیشرفت جسمانی + خلاصه تمرین -->
        <div class="row g-2" style="margin-bottom:15px;">

            @* کارت چپ: پیشرفت جسمانی *@
            <div class="col-md-5">
                <div class="mb-card h-100" style="border-top: 4px solid #00C896;">
                    <div class="mb-card-title" style="margin-bottom:12px;">
                        <i class="fa fa-trophy" style="color:#f6ad55;"></i>
                        میزان پیشرفت جسمانی
                        <help key="MD01" />
                    </div>

                    @if (analytics.WeightHistory.Any())
                    {
                        var weightChangeVal = analytics.WeightChange ?? 0;
                        var isWeightLoss = weightChangeVal < 0;
                        var weightColor = isWeightLoss ? "#10b981" : "#ef4444";
                        var weightIcon = isWeightLoss ? "fa-arrow-down" : "fa-arrow-up";

                        <div class="mb-change-row">
                            <div class="mb-change-label">
                                <i class="fa fa-balance-scale" style="color:#3182ce;"></i>
                                <span>وزن</span>
                            </div>
                            <div class="mb-change-values">
                                <span class="mb-change-old">@(analytics.FirstWeight ?? 0) kg</span>
                                <span class="mb-change-pill" style="color:@weightColor; background: @(isWeightLoss ? "#ecfdf5" : "#fef2f2");">
                                    <i class="fa @weightIcon"></i>@Math.Abs(weightChangeVal)
                                </span>
                                <span class="mb-change-current">@(analytics.CurrentWeight ?? 0) kg</span>
                            </div>
                        </div>

                        if (analytics.FatHistory.Any() && analytics.FirstFat.HasValue)
                        {
                            var fatChangeVal = analytics.FatChange ?? 0;
                            var isFatLoss = fatChangeVal < 0;
                            var fatColor = isFatLoss ? "#10b981" : "#ef4444";
                            var fatIcon = isFatLoss ? "fa-arrow-down" : "fa-arrow-up";

                            <div class="mb-change-row">
                                <div class="mb-change-label">
                                    <i class="fa fa-percent" style="color:#9f7aea;"></i>
                                    <span>چربی</span>
                                </div>
                                <div class="mb-change-values">
                                    <span class="mb-change-old">%@analytics.FirstFat</span>
                                    <span class="mb-change-pill" style="color:@fatColor; background: @(isFatLoss ? "#ecfdf5" : "#fef2f2");">
                                        <i class="fa @fatIcon"></i>@Math.Abs(fatChangeVal)
                                    </span>
                                    <span class="mb-change-current">%@analytics.CurrentFat</span>
                                </div>
                            </div>
                        }

                        <!-- فوتر کارت -->
                        <div class="mb-stats-footer">
                            @if (analytics.TotalWeeksPassed > 0)
                            {
                                <div class="mb-stat-footer-item">
                                    <div class="mb-stat-footer-value">@(analytics.WeeklyWeightChangeRate ?? 0) kg</div>
                                    <div class="mb-stat-footer-label">تغییرات هفتگی</div>
                                </div>
                                <div class="mb-stat-footer-divider"></div>
                            }

                            @if (analytics.WaistToHipRatio.HasValue)
                            {
                                var whrStatus = analytics.WaistToHipRatio < 0.9m ? "مطلوب" : "نیاز به اصلاح";
                                var whrColor = analytics.WaistToHipRatio < 0.9m ? "#10b981" : "#f59e0b";

                                <div class="mb-stat-footer-item">
                                    <div class="mb-stat-footer-value" style="color:@whrColor;">@analytics.WaistToHipRatio</div>
                                    <div class="mb-stat-footer-label">WHR (@whrStatus)</div>
                                </div>
                            }

                            @if (analytics.TotalWeeksPassed <= 0 && !analytics.WaistToHipRatio.HasValue)
                            {
                                <div style="text-align:center;color:var(--text-muted);font-size:11px;width:100%;">
                                    <i class="fa fa-info-circle me-1"></i>اطلاعات بیشتری برای تحلیل نیاز است
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mb-empty">
                            <i class="fa fa-info-circle"></i>
                            <div class="mb-empty-text">هنوز اندازه‌گیری ثبت نشده است</div>
                        </div>
                    }
                </div>
            </div>

            @* کارت راست: خلاصه برنامه تمرینی فعال *@
            <div class="col-md-7">
                <div class="mb-card h-100" style="border-top: 4px solid #3b82f6;">
                    <div class="mb-card-title" style="margin-bottom:12px;">
                        <i class="fa fa-heartbeat" style="color:#3b82f6;"></i>
                        خلاصه برنامه تمرینی فعال
                        <help key="MD02" />
                    </div>
                    @if (analytics.Training != null)
                    {
                        <div class="row g-2 text-center">
                            <div class="col-6 col-md-3">
                                <div class="mb-training-item" style="background:#eff6ff;">
                                    <i class="fa fa-bullseye mb-training-icon" style="color:#3b82f6;"></i>
                                    <div class="mb-training-goal" title="@analytics.Training.GoalName">@(analytics.Training.GoalName ?? "-")</div>
                                    <div class="mb-training-label">هدف</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="mb-training-item" style="background:#f0fdf4;">
                                    <div class="mb-training-value">@(analytics.Training.SessionsPerWeek ?? 0)</div>
                                    <div class="mb-training-label">جلسه / هفته</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="mb-training-item" style="background:#fefce8;">
                                    <div class="mb-training-value">@analytics.Training.TotalSets</div>
                                    <div class="mb-training-label">کل ست‌ها</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="mb-training-item" style="background:#faf5ff;">
                                    <div class="mb-training-value">@analytics.Training.TotalExercises</div>
                                    <div class="mb-training-label">تنوع حرکات</div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-empty">
                            <i class="fa fa-heartbeat"></i>
                            <div class="mb-empty-text">برنامه تمرینی فعالی وجود ندارد</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ردیف دوم: نمودارها و ماکروها -->
        <div class="row g-2" style="margin-bottom:15px;">
            <div class="col-md-4">
                <div class="mb-card h-100">
                    <div class="mb-card-title" style="margin-bottom:8px;font-size:13px;">
                        <i class="fa fa-balance-scale" style="color:#3182ce;"></i>
                        روند وزن
                        <help key="MD03" />
                    </div>
                    <div style="height:180px;position:relative;"><canvas id="weightChart"></canvas></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-card h-100">
                    <div class="mb-card-title" style="margin-bottom:8px;font-size:13px;">
                        <i class="fa fa-percent" style="color:#9f7aea;"></i>
                        درصد چربی
                        <help key="MD04" />
                    </div>
                    <div style="height:180px;position:relative;"><canvas id="fatChart"></canvas></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-card h-100">
                    <div class="mb-card-title" style="margin-bottom:8px;font-size:13px;">
                        <i class="fa fa-pie-chart" style="color:#f59e0b;"></i>
                        توزیع ماکروها
                        <help key="MD04" />
                    </div>
                    @if (analytics.Nutrition != null && analytics.Nutrition.AvgDailyCalories > 0)
                    {
                        <div style="height:130px;position:relative;"><canvas id="macroChart"></canvas></div>
                        <div class="mb-chart-legend">
                            <span class="mb-chart-legend-item"><span class="mb-chart-legend-dot" style="background:#3b82f6;"></span>پروتئین</span>
                            <span class="mb-chart-legend-item"><span class="mb-chart-legend-dot" style="background:#f59e0b;"></span>کربوهیدرات</span>
                            <span class="mb-chart-legend-item"><span class="mb-chart-legend-dot" style="background:#ef4444;"></span>چربی</span>
                        </div>
                    }
                    else
                    {
                        <div class="mb-empty" style="height:130px;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                            <i class="fa fa-cutlery"></i>
                            <div class="mb-empty-text">فاقد اطلاعات غذایی</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ردیف سوم: جزئیات رژیم -->
        @if (analytics.Nutrition != null && analytics.Nutrition.AvgDailyCalories > 0)
        {
            <div class="mb-card" style="border-right:4px solid #10b981;margin-bottom:15px;">
                <div class="d-flex justify-content-between align-items-center" style="margin-bottom:12px;flex-wrap:wrap;gap:8px;">
                    <div class="mb-card-title">
                        <i class="fa fa-cutlery" style="color:#10b981;"></i>
                        جزئیات برنامه غذایی فعال
                    </div>
                    <span class="badge rounded-pill" style="background:#ecfdf5;color:#059669;font-size:11px;">هدف: @analytics.Nutrition.GoalName</span>
                </div>
                <div class="row g-2 text-center">
                    <div class="col-6 col-md-3">
                        <div class="mb-macro-box">
                            <div class="mb-macro-value" style="color:var(--text-main);">@analytics.Nutrition.AvgDailyCalories.ToString("0")</div>
                            <div class="mb-macro-label">کالری روزانه</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mb-macro-box">
                            <div class="mb-macro-value" style="color:#3b82f6;">@analytics.Nutrition.AvgDailyProtein.ToString("0")g</div>
                            <div class="mb-macro-label">پروتئین <span class="mb-macro-percent">(@analytics.Nutrition.ProteinPercent%)</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mb-macro-box">
                            <div class="mb-macro-value" style="color:#f59e0b;">@analytics.Nutrition.AvgDailyCarbs.ToString("0")g</div>
                            <div class="mb-macro-label">کربوهیدرات <span class="mb-macro-percent">(@analytics.Nutrition.CarbsPercent%)</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="mb-macro-box">
                            <div class="mb-macro-value" style="color:#ef4444;">@analytics.Nutrition.AvgDailyFat.ToString("0")g</div>
                            <div class="mb-macro-label">چربی <span class="mb-macro-percent">(@analytics.Nutrition.FatPercent%)</span></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @* ============ برنامه‌ها ============ *@

    @if (isActivMember)
    {
        <div class="row g-2" style="margin-bottom:15px;">
            <div class="col-md-6">
                <div class="mb-card">
                    <div class="d-flex align-items-center justify-content-between" style="margin-bottom:10px;">
                        <div class="mb-card-title">
                            <i class="fa fa-cutlery" style="color:#00C896;"></i>
                            برنامه‌های غذایی
                            <help key="MD05" />
                        </div>
                        <a href="/Admin/MemberDashboard/MyNutritionPrograms" class="mb-card-link">مشاهده همه</a>
                    </div>
                    @if (nutritionList != null && nutritionList.Any())
                    {
                        @foreach (var p in nutritionList.Take(4))
                        {
                            <div class="mb-program-item">
                                <div class="mb-program-info">
                                    <div class="mb-program-title">@p.ProgramType</div>
                                    <div class="mb-program-meta">
                                        <span><i class="fa fa-calendar-o me-1"></i>@p.StartDate — @p.EndDate</span>
                                        <span class="badge" style="background:@(p.IsActive ? "#edfaf5" : "#f0f4f8");color:@(p.IsActive ? "#00C896" : "#718096");border:1px solid @(p.IsActive ? "#00C896" : "#e2e8f0");font-size:9px;border-radius:5px;">@(p.IsActive ? "فعال" : "قدیمی")</span>
                                    </div>
                                </div>
                                <a href="/Admin/MemberDashboard/PrintNutritionProgram/@SecurityUtils.EncryptId(p.Id)" target="_blank" class="mb-program-btn">
                                    <i class="fa fa-print"></i>PDF
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mb-empty">
                            <i class="fa fa-inbox"></i>
                            <div class="mb-empty-text">برنامه غذایی ثبت نشده</div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-6">
                <div class="mb-card">
                    <div class="d-flex align-items-center justify-content-between" style="margin-bottom:10px;">
                        <div class="mb-card-title">
                            <i class="fa fa-heartbeat" style="color:#3182ce;"></i>
                            برنامه‌های تمرینی
                            <help key="MD06" />
                        </div>
                        <a href="/Admin/MemberDashboard/MyTrainingPrograms" class="mb-card-link blue">مشاهده همه</a>
                    </div>
                    @if (trainingList != null && trainingList.Any())
                    {
                        @foreach (var p in trainingList.Take(4))
                        {
                            <div class="mb-program-item">
                                <div class="mb-program-info">
                                    <div class="mb-program-title" title="@p.Title">@p.Title</div>
                                    <div class="mb-program-meta">
                                        <span><i class="fa fa-tag me-1"></i>@p.TrainingProgramType</span>
                                        <span><i class="fa fa-calendar-o me-1"></i>@p.StartDate</span>
                                        <span class="badge" style="background:@(p.IsActive ? "#ebf8ff" : "#f0f4f8");color:@(p.IsActive ? "#3182ce" : "#718096");border:1px solid @(p.IsActive ? "#3182ce" : "#e2e8f0");font-size:9px;border-radius:5px;">@(p.IsActive ? "فعال" : "قدیمی")</span>
                                    </div>
                                </div>
                                <a href="/Admin/MemberDashboard/PrintTrainingProgram/@SecurityUtils.EncryptId(p.Id)" target="_blank" class="mb-program-btn blue">
                                    <i class="fa fa-print"></i>PDF
                                </a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mb-empty">
                            <i class="fa fa-inbox"></i>
                            <div class="mb-empty-text">برنامه تمرینی ثبت نشده</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    @* ============ اندازه‌گیری + اطلاعات جسمانی ============ *@
    <div class="row g-2" style="margin-bottom:15px;">
        <div class="col-md-6">
            <div class="mb-card">
                <div class="d-flex align-items-center justify-content-between" style="margin-bottom:10px;">
                    <div class="mb-card-title">
                        <i class="fa fa-balance-scale" style="color:#9f7aea;"></i>
                        آخرین اندازه‌گیری
                        <help key="MD07" />
                    </div>
                    <a href="/Admin/MemberProfile/BodyMeasurement/@encryptedId" class="mb-card-link" style="color:#9f7aea;">تاریخچه</a>
                </div>
                @if (lastMeasurement != null)
                {
                    <div style="font-size:10px;color:var(--text-light);margin-bottom:8px;">تاریخ: @lastMeasurement.RecordDate</div>
                    if (lastMeasurement.Weight.HasValue)
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl"><i class="fa fa-balance-scale"></i>وزن</span><span class="mb-measure-val">@lastMeasurement.Weight kg</span></div>
                    }
                    if (lastMeasurement.BodyFatPercentage.HasValue)
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl"><i class="fa fa-percent"></i>چربی</span><span class="mb-measure-val">@lastMeasurement.BodyFatPercentage %</span></div>
                    }
                    if (lastMeasurement.Waist.HasValue)
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl"><i class="fa fa-arrows-h"></i>کمر</span><span class="mb-measure-val">@lastMeasurement.Waist cm</span></div>
                    }
                    if (lastMeasurement.Hip.HasValue)
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">باسن</span><span class="mb-measure-val">@lastMeasurement.Hip cm</span></div>
                    }
                    if (lastMeasurement.Chest.HasValue)
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">سینه</span><span class="mb-measure-val">@lastMeasurement.Chest cm</span></div>
                    }
                    <div style="margin-top:12px;">
                        <a href="/Admin/MemberProfile/AddBodyMeasurement" class="btn btn-sm btn-outline-secondary w-100" style="border-radius:8px;font-size:11px;">
                            <i class="fa fa-plus me-1"></i>ثبت اندازه‌گیری جدید
                        </a>
                    </div>
                }
                else
                {
                    <div class="mb-empty">
                        <i class="fa fa-inbox"></i>
                        <div class="mb-empty-text" style="margin-bottom:10px;">اندازه‌گیری ثبت نشده</div>
                        <a href="/Admin/MemberProfile/AddBodyMeasurement" class="btn btn-sm" style="background:#9f7aea;color:#fff;border-radius:8px;font-size:11px;">
                            <i class="fa fa-plus me-1"></i>ثبت اولین اندازه‌گیری
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-card">
                <div class="mb-card-title" style="margin-bottom:10px;">
                    <i class="fa fa-user-circle-o" style="color:#f6ad55;"></i>
                    اطلاعات جسمانی
                    <help key="MD08" />
                </div>
                @if (member != null)
                {
                    if (!string.IsNullOrWhiteSpace(member.BirthDate))
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">تولد</span><span class="mb-measure-val" style="font-size:12px;">@member.BirthDate</span></div>
                    }
                    if (member.Height.HasValue)
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">قد</span><span class="mb-measure-val">@member.Height cm</span></div>
                    }
                    if (!string.IsNullOrWhiteSpace(member.FoodAllergies))
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">حساسیت غذایی</span><span class="mb-measure-val" style="font-size:11px;">@member.FoodAllergies</span></div>
                    }
                    if (!string.IsNullOrWhiteSpace(member.MedicalConditions))
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">شرایط پزشکی</span><span class="mb-measure-val" style="font-size:11px;">@member.MedicalConditions</span></div>
                    }
                    if (!string.IsNullOrWhiteSpace(member.Injuries))
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">آسیب‌ها</span><span class="mb-measure-val" style="font-size:11px;">@member.Injuries</span></div>
                    }
