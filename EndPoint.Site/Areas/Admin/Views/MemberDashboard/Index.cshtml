                <div style="margin-top:12px;">
                    <a href="/Admin/MemberProfile/CompleteInfo" class="btn btn-sm btn-outline-warning w-100" style="border-radius:8px;font-size:11px;">
                        <i class="fa fa-edit me-1"></i>ویرایش اطلاعات
                    </a>
                </div>
            </div>
        </div>
    </div>

    @* ============ دسترسی سریع ============ *@
    <div class="mb-card">
        <div class="mb-card-title" style="margin-bottom:12px;">
