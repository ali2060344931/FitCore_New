            </div>
            <div class="col-4 col-sm-3 col-md-2">
                <a href="/Admin/MemberProfile/AddBodyMeasurement" class="mb-quick-btn"><i class="fa fa-plus-circle" style="color:#9f7aea;"></i><span>ثبت اندازه</span></a>
