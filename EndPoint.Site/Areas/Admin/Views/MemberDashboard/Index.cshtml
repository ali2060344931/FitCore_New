                <div class="col-4 col-sm-3 col-md-2">
                    <a href="/Admin/MemberDashboard/MyTrainingPrograms" class="mb-quick-btn"><i class="fa fa-heartbeat" style="color:#3182ce;"></i><span>تمرینی</span></a>
                </div>
            }
            <div class="col-4 col-sm-3 col-md-2">
