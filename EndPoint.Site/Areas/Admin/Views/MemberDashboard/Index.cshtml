@using FitCore.Application.Services.NutritionPrograms.Queries.GetNutritionProgram
@using FitCore.Application.Services.TrainingPrograms.Queries.GetTrainingPrograms
@using FitCore.Domain.Entities.Members
@using FitCore.Common
@using EndPoint.Site.Areas.Admin.Controllers

@{
    ViewData["Title"] = "داشبورد من";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var member = ViewBag.Member as Member;
    var encryptedId = ViewBag.EncryptedUserId as string;
    var nutritionList = ViewBag.NutritionPrograms as System.Collections.Generic.List<GetNutritionProgramsDto>;
    var trainingList = ViewBag.TrainingPrograms as System.Collections.Generic.List<GetTrainingProgramsDto>;
    var lastMeasurement = ViewBag.LastMeasurement as MemberBodyMeasurement;
    var membershipStatus = ViewBag.MembershipStatus as MembershipStatusDto;

    string memberName = member?.AppUser?.FullName ?? "-";
    string memberMobile = member?.AppUser?.PhoneNumber ?? "-";
    string genderLabel = member?.Gender == Gender.Male ? "آقا" : "خانم";
    bool isProfileDone = member != null &&
                           !string.IsNullOrWhiteSpace(member.BirthDate) &&
                           member.Height != null;
}

@* ============ استایل‌ها ============ *@
<style>
    .mb-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 14px rgba(0,0,0,0.06);
        padding: 20px;
        margin-bottom: 20px;
        height: 100%;
    }

    .mb-header-card {
        background: linear-gradient(135deg, #0f1117 0%, #1a2035 100%);
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 20px;
        color: #fff;
    }

    .mb-stat {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 14px rgba(0,0,0,0.06);
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        color: inherit;
        transition: transform .2s, box-shadow .2s;
        border-right: 4px solid var(--c);
        height: 100%;
    }

        .mb-stat:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 22px rgba(0,0,0,0.1);
            color: inherit;
        }

    .mb-stat-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        background: var(--cb);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
        color: var(--c);
    }

    .mb-stat-num {
        font-size: 26px;
        font-weight: 700;
        line-height: 1;
        color: #1a202c;
    }

    .mb-stat-lbl {
        font-size: 12px;
        color: #718096;
        margin-top: 3px;
    }

    .mb-membership-card {
        border-radius: 12px;
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }

        .mb-membership-card.active {
            background: #edfaf5;
            border: 1.5px solid #00C896;
        }

        .mb-membership-card.soon {
            background: #fffbeb;
            border: 1.5px solid #f6ad55;
        }

        .mb-membership-card.expired {
            background: #fff5f5;
            border: 1.5px solid #fc8181;
        }

        .mb-membership-card.unknown {
            background: #f7fafc;
            border: 1.5px solid #e2e8f0;
        }

    .mb-program-item {
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        transition: border-color .2s;
    }

        .mb-program-item:hover {
            border-color: #00C896;
        }

        .mb-program-item:last-child {
            margin-bottom: 0;
        }

    .mb-quick-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 16px 10px;
        background: #f8fafd;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 12px;
        font-weight: 600;
        color: #4a5568;
        text-decoration: none;
        transition: all .2s;
        text-align: center;
    }

        .mb-quick-btn i {
            font-size: 22px;
        }

        .mb-quick-btn:hover {
            background: #edfaf5;
            border-color: #00C896;
            color: #00C896;
            transform: translateY(-2px);
        }

            .mb-quick-btn:hover i {
                color: #00C896;
            }

    .mb-profile-alert {
        background: #fffbeb;
        border: 1.5px solid #f6ad55;
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 13px;
    }

    .mb-measure-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 7px 0;
        border-bottom: 1px solid #f0f4f8;
        font-size: 13px;
    }

        .mb-measure-row:last-child {
            border-bottom: none;
        }

    .mb-measure-lbl {
        color: #718096;
    }

    .mb-measure-val {
        font-weight: 700;
        color: #1a202c;
    }

    @@media (max-width: 576px) {
        .mb-header-card {
            padding: 16px;
        }

        .mb-card {
            padding: 14px;
        }
    }
</style>

<div class="container-fluid mt-4">

    @* ============ هشدار تکمیل پروفایل ============ *@
    @if (!isProfileDone)
    {
        <div class="mb-profile-alert">
            <i class="fa fa-exclamation-triangle" style="color:#f6ad55;font-size:20px;flex-shrink:0;"></i>
            <div style="flex:1;">
                <strong>پروفایل شما ناقص است</strong> — برای دریافت بهترین برنامه‌های تمرینی و غذایی، لطفاً اطلاعات جسمانی خود را تکمیل کنید.
            </div>
            <a href="/Admin/MemberProfile/CompleteInfo" class="btn btn-sm btn-warning" style="border-radius:8px;font-size:12px;white-space:nowrap;">
                <i class="fa fa-edit me-1"></i> تکمیل پروفایل
            </a>
        </div>
    }

    @* ============ هدر خوش‌آمد ============ *@
    <div class="mb-header-card mb-4">
        <div class="d-flex align-items-center gap-3 flex-wrap justify-content-between">
            <div class="d-flex align-items-center gap-3">
                <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#00C896,#0fa0d0);display:flex;align-items:center;justify-content:center;font-size:22px;color:#fff;font-weight:700;flex-shrink:0;">
                    @(memberName.Length > 0 ? memberName[0].ToString() : "؟")
                </div>
                <div>
                    <div style="font-size:19px;font-weight:700;">سلام، @memberName 👋
                        <help key="MD00" />
                    </div>
                    <div style="font-size:12px;color:#a0aec0;margin-top:3px;">
                        <i class="fa fa-mobile me-1"></i>@memberMobile
                        <span class="ms-3">@genderLabel</span>
                        @if (!string.IsNullOrWhiteSpace(member?.BirthDate))
                        {
                            <span class="ms-3"><i class="fa fa-birthday-cake me-1"></i>@member.BirthDate</span>
                        }
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                @if (member?.ActivityLevel != null)
                {
                    <span style="background:rgba(255,255,255,0.1);border-radius:20px;padding:4px 12px;font-size:11px;color:#e2e8f0;"><i class="fa fa-bolt me-1"></i>@member.ActivityLevel.Name</span>
                }
                @if (member?.ExperienceLevel != null)
                {
                    <span style="background:rgba(255,255,255,0.1);border-radius:20px;padding:4px 12px;font-size:11px;color:#e2e8f0;"><i class="fa fa-trophy me-1"></i>@member.ExperienceLevel.Name</span>
                }
                @if (member?.Height != null)
                {
                    <span style="background:rgba(255,255,255,0.1);border-radius:20px;padding:4px 12px;font-size:11px;color:#e2e8f0;"><i class="fa fa-arrows-v me-1"></i>قد: @member.Height سانتی‌متر</span>
                }
            </div>
        </div>
    </div>

    @* ============ وضعیت عضویت ============ *@
    @if (membershipStatus != null)
    {
        string msClass = membershipStatus.Status switch { MembershipState.Active => "active", MembershipState.ExpiringSoon => "soon", MembershipState.Expired => "expired", _ => "unknown" };
        string msIcon = membershipStatus.Status switch { MembershipState.Active => "fa-check-circle", MembershipState.ExpiringSoon => "fa-exclamation-circle", MembershipState.Expired => "fa-times-circle", _ => "fa-question-circle" };
        string msIconColor = membershipStatus.Status switch { MembershipState.Active => "#00C896", MembershipState.ExpiringSoon => "#f6ad55", MembershipState.Expired => "#fc8181", _ => "#a0aec0" };
        string msText = membershipStatus.Status switch { MembershipState.Active => $"عضویت فعال — {membershipStatus.DaysLeft} روز تا پایان اعتبار", MembershipState.ExpiringSoon => $"⚠️ عضویت شما تا {membershipStatus.DaysLeft} روز دیگر منقضی می‌شود", MembershipState.Expired => "عضویت شما منقضی شده است — با باشگاه تماس بگیرید", _ => "اطلاعات عضویت تعریف نشده" };

        <div class="mb-membership-card @msClass mb-4">
            <i class="fa @msIcon fa-2x" style="color:@msIconColor;flex-shrink:0;"></i>
            <div style="flex:1;">
                <div style="font-weight:700;font-size:14px;">@msText</div>
                <div style="font-size:12px;color:#4a5568;margin-top:4px;">
                    <i class="fa fa-calendar-o me-1"></i>شروع: <strong>@membershipStatus.StartDate</strong>
                    <span class="ms-3"><i class="fa fa-calendar-times-o me-1"></i>پایان: <strong>@membershipStatus.EndDate</strong></span>
                </div>
            </div>
        </div>
    }

    @* ============ کارت‌های آمار ============ *@
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <a href="/Admin/MemberDashboard/MyNutritionPrograms" class="mb-stat" style="--c:#00C896;--cb:#edfaf5;">
                <div class="mb-stat-icon"><i class="fa fa-cutlery"></i></div>
                <div><div class="mb-stat-num">@(nutritionList?.Count ?? 0)</div><div class="mb-stat-lbl">برنامه غذایی</div></div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Admin/MemberDashboard/MyTrainingPrograms" class="mb-stat" style="--c:#3182ce;--cb:#ebf8ff;">
                <div class="mb-stat-icon"><i class="fa fa-heartbeat"></i></div>
                <div><div class="mb-stat-num">@(trainingList?.Count ?? 0)</div><div class="mb-stat-lbl">برنامه تمرینی</div></div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Admin/MemberProfile/BodyMeasurement/@encryptedId" class="mb-stat" style="--c:#9f7aea;--cb:#faf5ff;">
                <div class="mb-stat-icon"><i class="fa fa-balance-scale"></i></div>
                <div><div class="mb-stat-num">@(lastMeasurement?.Weight?.ToString("0.#") ?? "-")</div><div class="mb-stat-lbl">@(lastMeasurement != null ? "آخرین وزن (kg)" : "وزنی ثبت نشده")</div></div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="/Admin/MemberProfile/CompleteInfo" class="mb-stat" style="--c:#f6ad55;--cb:#fffaf0;">
                <div class="mb-stat-icon"><i class="fa fa-user-circle-o"></i></div>
                <div><div class="mb-stat-num" style="font-size:18px;padding-top:4px;">@(isProfileDone ? "✓ کامل" : "ناقص")</div><div class="mb-stat-lbl">وضعیت پروفایل</div></div>
            </a>
        </div>
    </div>

    @* ============ گزارش پیشرفت جسمانی (Advanced Analytics) ============ *@
    @{
        var analytics = ViewBag.Analytics as FitCore.Application.Services.Member.Queries.MemberAnalyticsDto;
    }

    @if (analytics != null && (analytics.WeightHistory.Any() || analytics.Nutrition != null || analytics.Training != null))
    {
        <!-- ردیف اول: پیشرفت جسمانی + خلاصه تمرین -->
        <div class="row g-3 mb-4">

            @* کارت چپ: پیشرفت جسمانی (طرح افقی جذاب) *@
            <div class="col-md-5">
                <div class="mb-card h-100" style="border-top: 4px solid #00C896;">
                    <div style="font-size:15px;font-weight:700;margin-bottom:15px;color:#1a202c;">
                        <i class="fa fa-trophy me-2" style="color:#f6ad55;"></i>
                        میزان پیشرفت جسمانی
                        <help key="MD01" />
                    </div>

                    @if (analytics.WeightHistory.Any())
                    {
                        var weightChangeVal = analytics.WeightChange ?? 0;
                        var isWeightLoss = weightChangeVal < 0;
                        var weightColor = isWeightLoss ? "#10b981" : "#ef4444";
                        var weightIcon = isWeightLoss ? "fa-arrow-down" : "fa-arrow-up";

                        <!-- ردیف وزن -->
                        <div class="d-flex align-items-center justify-content-between p-2 mb-2 rounded-2" style="background:#f8fafc;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="fa fa-balance-scale" style="color:#3182ce;"></i>
                                <span class="small text-muted">وزن</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted" style="font-size:12px;">@(analytics.FirstWeight ?? 0) kg</span>
                                <span class="fw-bold px-2 py-1 rounded-pill" style="color:@weightColor; background: @(isWeightLoss ? "#ecfdf5" : "#fef2f2"); font-size:12px; white-space:nowrap;">
                                    <i class="fa @weightIcon me-1"></i>@Math.Abs(weightChangeVal)
                                </span>
                                <span class="fw-bold" style="font-size:13px;">@(analytics.CurrentWeight ?? 0) kg</span>
                            </div>
                        </div>

                        if (analytics.FatHistory.Any() && analytics.FirstFat.HasValue)
                        {
                            var fatChangeVal = analytics.FatChange ?? 0;
                            var isFatLoss = fatChangeVal < 0;
                            var fatColor = isFatLoss ? "#10b981" : "#ef4444";
                            var fatIcon = isFatLoss ? "fa-arrow-down" : "fa-arrow-up";

                            <!-- ردیف چربی -->
                            <div class="d-flex align-items-center justify-content-between p-2 mb-3 rounded-2" style="background:#f8fafc;">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="fa fa-percent" style="color:#9f7aea;"></i>
                                    <span class="small text-muted">چربی</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-muted" style="font-size:12px;">%@analytics.FirstFat</span>
                                    <span class="fw-bold px-2 py-1 rounded-pill" style="color:@fatColor; background: @(isFatLoss ? "#ecfdf5" : "#fef2f2"); font-size:12px; white-space:nowrap;">
                                        <i class="fa @fatIcon me-1"></i>@Math.Abs(fatChangeVal)
                                    </span>
                                    <span class="fw-bold" style="font-size:13px;">%@analytics.CurrentFat</span>
                                </div>
                            </div>
                        }

                        <!-- فوتر کارت: آمار تکمیلی -->
                        <div class="border-top pt-3 mt-1" style="border-color: #e2e8f0 !important;">
                            <div class="d-flex justify-content-between align-items-center">
                                @if (analytics.TotalWeeksPassed > 0)
                                {
                                    <div class="text-center">
                                        <div class="fw-bold small text-dark">@(analytics.WeeklyWeightChangeRate ?? 0) kg</div>
                                        <div style="font-size:10px;color:#64748b;">تغییرات هفتگی</div>
                                    </div>
                                    <div style="width:1px;height:25px;background:#e2e8f0;"></div>
                                }

                                @if (analytics.WaistToHipRatio.HasValue)
                                {
                                    var whrStatus = analytics.WaistToHipRatio < 0.9m ? "مطلوب" : "نیاز به اصلاح";
                                    var whrColor = analytics.WaistToHipRatio < 0.9m ? "#10b981" : "#f59e0b";

                                    <div class="text-center">
                                        <div class="fw-bold small" style="color:@whrColor;">@analytics.WaistToHipRatio <span style="font-size:9px;">(@whrStatus)</span></div>
                                        <div style="font-size:10px;color:#64748b;">شاخص WHR</div>
                                    </div>
                                }

                                @if (analytics.TotalWeeksPassed <= 0 && !analytics.WaistToHipRatio.HasValue)
                                {
                                    <div class="text-center text-muted w-100" style="font-size:11px;">
                                        <i class="fa fa-info-circle me-1"></i>اطلاعات بیشتری برای تحلیل نیاز است
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4" style="font-size:13px;">
                            <i class="fa fa-info-circle me-1"></i>هنوز اندازه‌گیری ثبت نشده است
                        </div>
                    }
                </div>
            </div>

            @* کارت راست: خلاصه برنامه تمرینی فعال *@
            <div class="col-md-7">
                <div class="mb-card h-100" style="border-top: 4px solid #3b82f6;">
                    <div style="font-size:15px;font-weight:700;margin-bottom:15px;color:#1a202c;">
                        <i class="fa fa-heartbeat me-2" style="color:#3b82f6;"></i>
                        خلاصه برنامه تمرینی فعال
                        <help key="MD02" />
                    </div>
                    @if (analytics.Training != null)
                    {
                        <div class="row g-2 text-center">
                            <div class="col-3">
                                <div class="p-2 rounded-3" style="background:#eff6ff;">
                                    <i class="fa fa-bullseye mb-1" style="color:#3b82f6;display:block;"></i>
                                    <div class="fw-bold small text-truncate text-dark" title="@analytics.Training.GoalName">@(analytics.Training.GoalName ?? "-")</div>
                                    <div style="font-size:10px;color:#64748b;">هدف</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="p-2 rounded-3" style="background:#f0fdf4;">
                                    <div class="fw-bold fs-4 text-dark">@(analytics.Training.SessionsPerWeek ?? 0)</div>
                                    <div style="font-size:10px;color:#64748b;">جلسه / هفته</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="p-2 rounded-3" style="background:#fefce8;">
                                    <div class="fw-bold fs-4 text-dark">@analytics.Training.TotalSets</div>
                                    <div style="font-size:10px;color:#64748b;">کل ست‌ها</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="p-2 rounded-3" style="background:#faf5ff;">
                                    <div class="fw-bold fs-4 text-dark">@analytics.Training.TotalExercises</div>
                                    <div style="font-size:10px;color:#64748b;">تنوع حرکات</div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">برنامه تمرینی فعالی وجود ندارد</div>
                    }
                </div>
            </div>
        </div>

        <!-- ردیف دوم: نمودارها و ماکروها -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="mb-card h-100">
                    <div style="font-size:14px;font-weight:700;margin-bottom:10px;color:#1a202c;"><i class="fa fa-balance-scale me-2" style="color:#3182ce;"></i>
                        روند وزن
                        <help key="MD03" />
                        </div>
                    <div style="height: 200px; position: relative;"><canvas id="weightChart"></canvas></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-card h-100">
                    <div style="font-size:14px;font-weight:700;margin-bottom:10px;color:#1a202c;"><i class="fa fa-percent me-2" style="color:#9f7aea;"></i>
                        درصد چربی
                        <help key="MD04" />
                        </div>
                    <div style="height: 200px; position: relative;"><canvas id="fatChart"></canvas></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-card h-100">
                    <div style="font-size:14px;font-weight:700;margin-bottom:10px;color:#1a202c;"><i class="fa fa-pie-chart me-2" style="color:#f59e0b;"></i>
                        توزیع ماکروها
                        <help key="MD04" />
                        </div>
                    @if (analytics.Nutrition != null && analytics.Nutrition.AvgDailyCalories > 0)
                    {
                        <div style="height: 150px; position: relative;"><canvas id="macroChart"></canvas></div>
                        <div class="d-flex justify-content-around mt-2" style="font-size:11px;">
                            <span class="text-center"><span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:#3b82f6;"></span>پروتئین</span>
                            <span class="text-center"><span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:#f59e0b;"></span>کربوهیدرات</span>
                            <span class="text-center"><span class="d-inline-block rounded-circle me-1" style="width:8px;height:8px;background:#ef4444;"></span>چربی</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted h-75 d-flex flex-column align-items-center justify-content-center">
                            <i class="fa fa-cutlery fa-2x mb-2" style="opacity:0.2;"></i>
                            <div style="font-size:12px;">برنامه غذایی فعلی</div>
                            <div style="font-size:12px;">فاقد اطلاعات غذایی است</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- ردیف سوم: جزئیات دقیق رژیم -->
        @if (analytics.Nutrition != null && analytics.Nutrition.AvgDailyCalories > 0)
        {
            <div class="mb-card mb-4" style="border-left: 4px solid #10b981;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div style="font-size:15px;font-weight:700;color:#1a202c;"><i class="fa fa-cutlery me-2" style="color:#10b981;"></i>جزئیات برنامه غذایی فعال شما</div>
                    <span class="badge rounded-pill" style="background:#ecfdf5;color:#059669;font-size:12px;">هدف: @analytics.Nutrition.GoalName</span>
                </div>
                <div class="row g-3 text-center">
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-3 border">
                            <div class="fw-bold text-dark fs-4">@analytics.Nutrition.AvgDailyCalories.ToString("0")</div>
                            <div style="font-size:11px;color:#64748b;">کالری دریافتی روزانه</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-3 border">
                            <div class="fw-bold fs-4" style="color:#3b82f6;">@analytics.Nutrition.AvgDailyProtein.ToString("0")g</div>
                            <div style="font-size:11px;color:#64748b;">پروتئین <span class="text-muted">(@analytics.Nutrition.ProteinPercent%)</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-3 border">
                            <div class="fw-bold fs-4" style="color:#f59e0b;">@analytics.Nutrition.AvgDailyCarbs.ToString("0")g</div>
                            <div style="font-size:11px;color:#64748b;">کربوهیدرات <span class="text-muted">(@analytics.Nutrition.CarbsPercent%)</span></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-3 rounded-3 border">
                            <div class="fw-bold fs-4" style="color:#ef4444;">@analytics.Nutrition.AvgDailyFat.ToString("0")g</div>
                            <div style="font-size:11px;color:#64748b;">چربی <span class="text-muted">(@analytics.Nutrition.FatPercent%)</span></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @* ============ برنامه‌ها + اندازه‌گیری ============ *@
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="mb-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div style="font-size:14px;font-weight:700;"><i class="fa fa-cutlery me-2" style="color:#00C896;"></i>
                        برنامه‌های غذایی من
                        <help key="MD05" />
                        </div>
                    <a href="/Admin/MemberDashboard/MyNutritionPrograms" style="font-size:12px;color:#00C896;text-decoration:none;font-weight:600;">مشاهده همه</a>
                </div>
                @if (nutritionList != null && nutritionList.Any())
                {
                    @foreach (var p in nutritionList.Take(4))
                    {
                        <div class="mb-program-item">
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:600;">@p.ProgramType</div>
                                <div style="font-size:11px;color:#718096;margin-top:2px;">
                                    <i class="fa fa-calendar-o me-1"></i>@p.StartDate — @p.EndDate
                                    <span class="badge ms-1" style="background:@(p.IsActive ? "#edfaf5" : "#f0f4f8");color:@(p.IsActive ? "#00C896" : "#718096");border:1px solid @(p.IsActive ? "#00C896" : "#e2e8f0");font-size:10px;border-radius:5px;">@(p.IsActive ? "فعال" : "قدیمی")</span>
                                </div>
                            </div>
                            <a href="/Admin/MemberDashboard/PrintNutritionProgram/@SecurityUtils.EncryptId(p.Id)" target="_blank" class="btn btn-sm" style="background:#00C896;color:#fff;border-radius:7px;font-size:11px;padding:4px 10px;white-space:nowrap;flex-shrink:0;"><i class="fa fa-print me-1"></i>PDF</a>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:30px 0;color:#a0aec0;"><i class="fa fa-inbox fa-2x" style="display:block;margin-bottom:8px;opacity:.35;"></i>هنوز برنامه غذایی ثبت نشده</div>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div style="font-size:14px;font-weight:700;"><i class="fa fa-heartbeat me-2" style="color:#3182ce;"></i>
                        برنامه‌های تمرینی من
                        <help key="MD06" />
                        </div>
                    <a href="/Admin/MemberDashboard/MyTrainingPrograms" style="font-size:12px;color:#3182ce;text-decoration:none;font-weight:600;">مشاهده همه</a>
                </div>
                @if (trainingList != null && trainingList.Any())
                {
                    @foreach (var p in trainingList.Take(4))
                    {
                        <div class="mb-program-item">
                            <div style="flex:1;min-width:0;">
                                <div style="font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@p.Title</div>
                                <div style="font-size:11px;color:#718096;margin-top:2px;">
                                    <i class="fa fa-tag me-1"></i>@p.TrainingProgramType
                                    <span class="ms-2"><i class="fa fa-calendar-o me-1"></i>@p.StartDate</span>
                                    <span class="badge ms-1" style="background:@(p.IsActive ? "#ebf8ff" : "#f0f4f8");color:@(p.IsActive ? "#3182ce" : "#718096");border:1px solid @(p.IsActive ? "#3182ce" : "#e2e8f0");font-size:10px;border-radius:5px;">@(p.IsActive ? "فعال" : "قدیمی")</span>
                                </div>
                            </div>
                            <a href="/Admin/MemberDashboard/PrintTrainingProgram/@SecurityUtils.EncryptId(p.Id)" target="_blank" class="btn btn-sm" style="background:#3182ce;color:#fff;border-radius:7px;font-size:11px;padding:4px 10px;white-space:nowrap;flex-shrink:0;"><i class="fa fa-print me-1"></i>PDF</a>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:30px 0;color:#a0aec0;"><i class="fa fa-inbox fa-2x" style="display:block;margin-bottom:8px;opacity:.35;"></i>هنوز برنامه تمرینی ثبت نشده</div>
                }
            </div>
        </div>
    </div>

    @* ============ آخرین اندازه‌گیری + اطلاعات جسمانی ============ *@
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="mb-card">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div style="font-size:14px;font-weight:700;"><i class="fa fa-balance-scale me-2" style="color:#9f7aea;"></i>
                        آخرین اندازه‌گیری بدن
                        <help key="MD07" />
                        </div>
                    <a href="/Admin/MemberProfile/BodyMeasurement/@encryptedId" style="font-size:12px;color:#9f7aea;text-decoration:none;font-weight:600;">مشاهده تاریخچه</a>
                </div>
                @if (lastMeasurement != null)
                {
                    <div style="font-size:11px;color:#a0aec0;margin-bottom:10px;">تاریخ ثبت: @lastMeasurement.RecordDate</div>
                    if (lastMeasurement.Weight.HasValue)
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl"><i class="fa fa-balance-scale me-1"></i>وزن</span><span class="mb-measure-val">@lastMeasurement.Weight kg</span></div>
                    }
                    if (lastMeasurement.BodyFatPercentage.HasValue)
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl"><i class="fa fa-percent me-1"></i>درصد چربی</span><span class="mb-measure-val">@lastMeasurement.BodyFatPercentage %</span></div>
                    }
                    if (lastMeasurement.Waist.HasValue)
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl"><i class="fa fa-arrows-h me-1"></i>دور کمر</span><span class="mb-measure-val">@lastMeasurement.Waist cm</span></div>
                    }
                    if (lastMeasurement.Hip.HasValue)
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl">دور باسن</span><span class="mb-measure-val">@lastMeasurement.Hip cm</span></div>
                    }
                    if (lastMeasurement.Chest.HasValue)
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl">دور سینه</span><span class="mb-measure-val">@lastMeasurement.Chest cm</span></div>
                    }
                    <div class="mt-3"><a href="/Admin/MemberProfile/AddBodyMeasurement" class="btn btn-sm btn-outline-secondary w-100" style="border-radius:8px;font-size:12px;"><i class="fa fa-plus me-1"></i>ثبت اندازه‌گیری جدید</a></div>
                }
                else
                {
                    <div style="text-align:center;padding:20px 0;color:#a0aec0;">
                        <i class="fa fa-inbox fa-2x" style="display:block;margin-bottom:8px;opacity:.35;"></i>
                        <div style="font-size:13px;margin-bottom:12px;">هنوز اندازه‌گیری ثبت نشده</div>
                        <a href="/Admin/MemberProfile/AddBodyMeasurement" class="btn btn-sm" style="background:#9f7aea;color:#fff;border-radius:8px;font-size:12px;"><i class="fa fa-plus me-1"></i>ثبت اولین اندازه‌گیری</a>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-card">
                <div style="font-size:14px;font-weight:700;margin-bottom:14px;"><i class="fa fa-user-circle-o me-2" style="color:#f6ad55;"></i>
                    اطلاعات جسمانی
                    <help key="MD08" />
                    </div>
                @if (member != null)
                {
                    if (!string.IsNullOrWhiteSpace(member.BirthDate))
                    {
                        <div class="mb-measure-row"><span class="mb-measure-lbl">تاریخ تولد</span><span class="mb-measure-val">@member.BirthDate</span></div>
                    }
                    if (member.Height.HasValue)
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl">قد</span><span class="mb-measure-val">@member.Height سانتی‌متر</span></div>
                    }
                    if (!string.IsNullOrWhiteSpace(member.FoodAllergies))
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl">حساسیت غذایی</span><span class="mb-measure-val" style="font-size:12px;">@member.FoodAllergies</span></div>
                    }
                    if (!string.IsNullOrWhiteSpace(member.MedicalConditions))
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl">شرایط پزشکی</span><span class="mb-measure-val" style="font-size:12px;">@member.MedicalConditions</span></div>
                    }
                    if (!string.IsNullOrWhiteSpace(member.Injuries))
                    {

                        <div class="mb-measure-row"><span class="mb-measure-lbl">سوابق آسیب</span><span class="mb-measure-val" style="font-size:12px;">@member.Injuries</span></div>
                    }
                }
                <div class="mt-3"><a href="/Admin/MemberProfile/CompleteInfo" class="btn btn-sm btn-outline-warning w-100" style="border-radius:8px;font-size:12px;"><i class="fa fa-edit me-1"></i>ویرایش اطلاعات جسمانی</a></div>
            </div>
        </div>
    </div>

    @* ============ دسترسی سریع ============ *@
    <div class="mb-card">
        <div style="font-size:14px;font-weight:700;margin-bottom:14px;"><i class="fa fa-bolt me-2" style="color:#f6ad55;"></i>
            دسترسی سریع
            <help key="MD09" />
            </div>
        <div class="row g-2">
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/MemberDashboard/MyNutritionPrograms" class="mb-quick-btn"><i class="fa fa-cutlery" style="color:#00C896;"></i><span>برنامه غذایی</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/MemberDashboard/MyTrainingPrograms" class="mb-quick-btn"><i class="fa fa-heartbeat" style="color:#3182ce;"></i><span>برنامه تمرینی</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/MemberProfile/BodyMeasurement/@encryptedId" class="mb-quick-btn"><i class="fa fa-balance-scale" style="color:#9f7aea;"></i><span>اندازه‌گیری بدن</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/MemberProfile/AddBodyMeasurement" class="mb-quick-btn"><i class="fa fa-plus-circle" style="color:#9f7aea;"></i><span>ثبت اندازه‌گیری</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/MemberProfile/CompleteInfo" class="mb-quick-btn"><i class="fa fa-user-circle-o" style="color:#f6ad55;"></i><span>ویرایش پروفایل</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/ProgramRequest/Submit" class="mb-quick-btn"><i class="fa fa-paper-plane" style="color:#00C896;"></i><span>درخواست برنامه</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/ProgramRequest/MyRequests" class="mb-quick-btn"><i class="fa fa-history" style="color:#718096;"></i><span>درخواست‌های من</span></a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/" class="mb-quick-btn"><i class="fa fa-sign-out" style="color:#fc8181;"></i><span>خروج</span></a>
            </div>
        </div>
    </div>

</div>

@* ============ اسکریپت‌های نمودار (خارج از کانتینر اصلی) ============ *@
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        Chart.defaults.font.family = 'Vazir, Tahoma, sans-serif';
        Chart.defaults.font.size = 11;

        var wLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.WeightHistory?.Select(w => w.Label).ToList() ?? new List<string>()));
        var wData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.WeightHistory?.Select(w => w.Value).ToList() ?? new List<decimal?>()));
        var fLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.FatHistory?.Select(f => f.Label).ToList() ?? new List<string>()));
        var fData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.FatHistory?.Select(f => f.Value).ToList() ?? new List<decimal?>()));

        var macroData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                analytics?.Nutrition != null ? new List<int> { analytics.Nutrition.ProteinPercent, analytics.Nutrition.CarbsPercent, analytics.Nutrition.FatPercent } : new List<int>()));

        function createGradient(ctx, color1, color2) {
        var gradient = ctx.createLinearGradient(0, 0, 0, 200);
        gradient.addColorStop(0, color1);
        gradient.addColorStop(1, color2);
        return gradient;
        }

        var weightCtx = document.getElementById('weightChart');
        if (weightCtx && wData.length > 1) {
        new Chart(weightCtx, {
        type: 'line',
        data: { labels: wLabels, datasets: [{ label: 'وزن (کیلوگرم)', data: wData, borderColor: '#3182ce', backgroundColor: (ctx) => createGradient(ctx.chart.ctx, 'rgba(49, 130, 206, 0.25)', 'rgba(49, 130, 206, 0)'), borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 4, pointBackgroundColor: '#fff', pointBorderColor: '#3182ce' }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: false, grid: { color: '#f1f5f9' }, ticks: { precision: 1 } }, x: { grid: { display: false } } } }
        });
        }

        var fatCtx = document.getElementById('fatChart');
        if (fatCtx && fData.length > 1) {
        new Chart(fatCtx, {
        type: 'line',
        data: { labels: fLabels, datasets: [{ label: 'چربی (%)', data: fData, borderColor: '#9f7aea', backgroundColor: (ctx) => createGradient(ctx.chart.ctx, 'rgba(159, 122, 234, 0.25)', 'rgba(159, 122, 234, 0)'), borderWidth: 2.5, fill: true, tension: 0.4, pointRadius: 4, pointBackgroundColor: '#fff', pointBorderColor: '#9f7aea' }] },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: false, grid: { color: '#f1f5f9' }, ticks: { callback: v => v + '%' } }, x: { grid: { display: false } } } }
        });
        }

        var macroCtx = document.getElementById('macroChart');
        if (macroCtx && macroData.length > 0) {
        new Chart(macroCtx, {
        type: 'doughnut',
        data: { labels: ['پروتئین', 'کربوهیدرات', 'چربی'], datasets: [{ data: macroData, backgroundColor: ['#3b82f6', '#f59e0b', '#ef4444'], borderWidth: 0, hoverOffset: 6 }] },
        options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { display: false }, tooltip: { callbacks: { label: (ctx) => ctx.label + ': ' + ctx.raw + '%' } } } }
        });
        }
    </script>
}