    }

    .mb-header-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00C896, #0fa0d0);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: #fff;
        font-weight: 700;
        flex-shrink: 0;
    }

    .mb-header-info {
        flex: 1;
        min-width: 0;
    }

    .mb-header-name {
        font-size: 17px;
        font-weight: 700;
