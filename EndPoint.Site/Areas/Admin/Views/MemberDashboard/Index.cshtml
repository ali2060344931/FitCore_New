</div>

@* ============ اسکریپت‌های نمودار ============ *@
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
                        Chart.defaults.font.family = 'Vazir, Tahoma, sans-serif';
                        Chart.defaults.font.size = 10;

                        var wLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.WeightHistory?.Select(w => w.Label).ToList() ?? new List<string>()));
                        var wData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.WeightHistory?.Select(w => w.Value).ToList() ?? new List<decimal?>()));
                        var fLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.FatHistory?.Select(f => f.Label).ToList() ?? new List<string>()));
                        var fData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics?.FatHistory?.Select(f => f.Value).ToList() ?? new List<decimal?>()));

                        var macroData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            analytics?.Nutrition != null ? new List<int> { analytics.Nutrition.ProteinPercent, analytics.Nutrition.CarbsPercent, analytics.Nutrition.FatPercent } : new List<int>()));

    function createGradient(ctx, color1, color2) {
    var gradient = ctx.createLinearGradient(0, 0, 0, 180);
    gradient.addColorStop(0, color1);
    gradient.addColorStop(1, color2);
    return gradient;
    }

                        // تنظیمات مشترک نمودار خطی
                        var lineOptions = {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                        y: { beginAtZero: false, grid: { color: '#f1f5f9' }, ticks: { font: { size: 9 }, maxTicksLimit: 5 } },
                        x: { grid: { display: false }, ticks: { font: { size: 9 }, maxRotation: 0, maxTicksLimit: 4 } }
                        },
                        elements: { point: { radius: 3, hoverRadius: 5 } }
                        };

                        var weightCtx = document.getElementById('weightChart');
                        if (weightCtx && wData.length > 1) {
                        new Chart(weightCtx, {
                        type: 'line',
                        data: {
                        labels: wLabels,
                        datasets: [{
                        label: 'وزن (kg)',
                        data: wData,
                        borderColor: '#3182ce',
                        backgroundColor: function(ctx) { return createGradient(ctx.chart.ctx, 'rgba(49, 130, 206, 0.2)', 'rgba(49, 130, 206, 0)'); },
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#3182ce',
                        pointBorderWidth: 2
                        }]
                        },
                        options: lineOptions
                        });
                        }

                        var fatCtx = document.getElementById('fatChart');
                        if (fatCtx && fData.length > 1) {
                        new Chart(fatCtx, {
                        type: 'line',
                        data: {
                        labels: fLabels,
                        datasets: [{
                        label: 'چربی (%)',
                        data: fData,
                        borderColor: '#9f7aea',
                        backgroundColor: function(ctx) { return createGradient(ctx.chart.ctx, 'rgba(159, 122, 234, 0.2)', 'rgba(159, 122, 234, 0)'); },
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#fff',
                        pointBorderColor: '#9f7aea',
                        pointBorderWidth: 2
                        }]
                        },
                        options: {
                        ...lineOptions,
                        scales: {
                        ...lineOptions.scales,
                        y: { ...lineOptions.scales.y, ticks: { ...lineOptions.scales.y.ticks, callback: function(v) { return v + '%'; } } }
                        }
                        }
                        });
                        }

                        var macroCtx = document.getElementById('macroChart');
                        if (macroCtx && macroData.length > 0) {
                        new Chart(macroCtx, {
                        type: 'doughnut',
                        data: {
                        labels: ['پروتئین', 'کربوهیدرات', 'چربی'],
                        datasets: [{
                        data: macroData,
                        backgroundColor: ['#3b82f6', '#f59e0b', '#ef4444'],
                        borderWidth: 0,
                        hoverOffset: 4
                        }]
                        },
                        options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '65%',
                        plugins: {
                        legend: { display: false },
                        tooltip: {
                        callbacks: {
                        label: function(ctx) { return ctx.label + ': ' + ctx.raw + '%'; }
                        }
                        }
                        }
                        }
                        });
                        }
    </script>
}