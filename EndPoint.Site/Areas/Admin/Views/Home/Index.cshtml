@* ============================================================
   پنل سوپر ادمین
============================================================ *@
@if (ViewBag.IsSuperAdmin == true)
{
    <div class="db-root">
        <div class="db-super">
            <div class="db-super-title">
                <i class="fa fa-shield"></i>
                پنل مدیر کل
            </div>
            <div class="row g-3">
                <div class="col-6">
                    <div class="db-super-num">@ViewBag.GymCount</div>
                    <div class="db-super-label">باشگاه فعال</div>
                </div>
                <div class="col-6">
                    <div class="db-super-num">@ViewBag.TotalUsers</div>
                    <div class="db-super-label">کاربر ثبت‌شده</div>
                </div>
            </div>
        </div>
    </div>
    return;
}

@* ============================================================
   هشدار درخواست‌های در انتظار
============================================================ *@
@if (Model.PendingRequestsCount > 0)
{
    <div class="db-root" style="padding-bottom:0;">
        <div class="db-alert-pending">
            <div class="db-alert-pending-icon">
                <i class="fa fa-bell"></i>
            </div>
            <div class="db-alert-pending-body">
                <div class="db-alert-pending-title">
                    @Model.PendingRequestsCount درخواست برنامه در انتظار بررسی
                </div>
                <div class="db-alert-pending-desc">اعضا منتظر دریافت برنامه از شما هستند</div>
            </div>
            <a href="/Admin/ProgramRequest" class="db-alert-pending-btn">
                <i class="fa fa-eye"></i> مشاهده
            </a>
        </div>
    </div>
}

@* ============================================================
   هشدار اعضای بحرانی
============================================================ *@
@if (ViewBag.CriticalMembers != null && ((System.Collections.IList)ViewBag.CriticalMembers).Count > 0)
{
    <div class="db-root" style="padding-bottom:0;">
        <div class="db-critical" id="dbCritical">
            <button type="button" class="db-critical-close" onclick="document.getElementById('dbCritical').style.display='none'">&times;</button>
            <div class="db-critical-head">
                <i class="fa fa-exclamation-triangle" style="color:var(--d-orange);"></i>
                نیاز به تمدید اشتراک
            </div>
            <div class="db-critical-desc">اشتراک اعضای زیر در حال انقضا یا منقضی شده است:</div>
            <div class="db-critical-table-wrap">
                <table class="table table-sm mb-0 db-critical-table">
                    <thead>
                        <tr>
                            <th>نام عضو</th>
                            <th>موبایل</th>
                            <th>تاریخ پایان</th>
                            <th>وضعیت</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in ViewBag.CriticalMembers)
                        {
                            string statusClass = m.RemainingDays < 0 ? "badge-danger" : "badge-warning";
                            string statusText = m.RemainingDays < 0 ? "منقضی شده" : $"{m.RemainingDays} روز مانده";
                            <tr>
                                <td>@m.FullName</td>
                                <td style="direction:ltr;text-align:right;">@m.Mobile</td>
                                <td>@m.EndDate</td>
                                <td><span class="badge @statusClass" style="font-size:10px;">@statusText</span></td>
                                <td>
                                    <a asp-area="Admin"
                                       asp-controller="Members"
                                       asp-action="Edit"
                                       asp-route-id="@SecurityUtils.EncryptId(m.Id)"
                                       asp-route-isMemberID="@true"
                                       class="btn btn-xs btn-outline-primary"
                                       style="font-size:10px;padding:2px 8px;border-radius:6px;">
                                        <i class="fa fa-edit"></i> تمدید
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* ============================================================
   بدون باشگاه
============================================================ *@
@if (ViewBag.NoGym == true || Model == null)
{
    <div class="db-root">
        <div class="alert alert-warning" style="border-radius:12px;">
            باشگاهی برای این حساب کاربری تعریف نشده است.
        </div>
    </div>
    return;
}

@* ============================================================
   داشبورد اصلی
============================================================ *@
<div class="db-root" id="dashboardRoot">

    <!-- =====================================================
         هدر باشگاه
    ===================================================== -->
    <div class="db-gym-banner">
        @if (!string.IsNullOrWhiteSpace(Model.GymLogo))
        {
            <img src="@Model.GymLogo" alt="لوگو" class="db-gym-logo" style="border-radius:14px;" />
        }
        else
        {
            <div class="db-gym-logo">
                <i class="fa fa-building-o"></i>
            </div>
        }

        <div class="db-gym-info">
            <div class="db-gym-name">
                @Model.GymName
                <span class="db-help-inline">
                    <help key="H2" />
                </span>
            </div>
            <div class="db-gym-meta">
                <span><i class="fa fa-barcode"></i> کد: @Model.GymCode</span>
                @if (!string.IsNullOrWhiteSpace(Model.GymMobile))
                {
                    <span><i class="fa fa-mobile"></i> @Model.GymMobile</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.GymAddress))
                {
                    <span class="d-none d-sm-inline"><i class="fa fa-map-marker"></i> @Model.GymAddress</span>
                }

            </div>
