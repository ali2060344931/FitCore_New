@using FitCore.Application.Services.Dashboard
@using FitCore.Common

@model GymDashboardDto

@{
    ViewData["Title"] = "داشبورد";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

@if (ViewBag.IsSuperAdmin == true)
{
    <div class="container-fluid mt-4">
        <div class="fc-card" style="background:linear-gradient(135deg,#0f1117,#1a2035);color:#fff;border-radius:16px;padding:30px;">
            <h3 style="color:#00C896;">
                <i class="fa fa-shield me-2"></i>
                پنل مدیر کل

            </h3>
            <div class="row mt-3">
                <div class="col-6 col-md-3">
                    <div style="font-size:32px;font-weight:700;color:#fff;">@ViewBag.GymCount</div>
                    <div style="color:#a0aec0;font-size:13px;">باشگاه فعال</div>
                </div>
                <div class="col-6 col-md-3">
                    <div style="font-size:32px;font-weight:700;color:#fff;">@ViewBag.TotalUsers</div>
                    <div style="color:#a0aec0;font-size:13px;">کاربر ثبت‌شده</div>
                </div>
            </div>
        </div>
    </div>
    return;
}

@if (ViewBag.NoGym == true || Model == null)
{
    <div class="container-fluid mt-4">
        <div class="alert alert-warning">باشگاهی برای این حساب کاربری تعریف نشده است.</div>
    </div>
    return;
}

<div class="container-fluid mt-4" id="dashboardRoot">

    <!-- ============================
         هدر باشگاه
    ============================ -->
    <div class="dash-gym-header mb-4">
        <div class="dash-gym-header-inner">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                @if (!string.IsNullOrWhiteSpace(Model.GymLogo))
                {
                    <img src="@Model.GymLogo" alt="لوگو"
                         style="width:60px;height:60px;border-radius:14px;object-fit:cover;border:2px solid rgba(255,255,255,0.2);" />
                }
                else
                {
                    <div class="dash-gym-logo-placeholder">
                        <i class="fa fa-building-o"></i>
                    </div>
                }


                <div>
                    <div class="dash-gym-name">
                        @Model.GymName

                        <help key="H2" />

                    </div>
                    <div class="dash-gym-meta">
                        <span><i class="fa fa-barcode me-1"></i>کد: @Model.GymCode</span>
                        @if (!string.IsNullOrWhiteSpace(Model.GymMobile))
                        {
                            <span class="ms-3"><i class="fa fa-mobile me-1"></i>@Model.GymMobile</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.GymAddress))
                        {
                            <span class="ms-3 d-none d-md-inline"><i class="fa fa-map-marker me-1"></i>@Model.GymAddress</span>
                        }
                    </div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 flex-wrap mt-2 mt-md-0">
                @if (!string.IsNullOrWhiteSpace(Model.SubscriptionExpireDate))
                {
                    <span class="dash-badge dash-badge-info">
                        <i class="fa fa-calendar-check-o me-1"></i>
                        اشتراک تا: @Model.SubscriptionExpireDate
                    </span>
                }
                @if (Model.MaxMembers > 0)
                {
                    <span class="dash-badge dash-badge-purple">
                        <i class="fa fa-users me-1"></i>
                        ظرفیت: @Model.TotalMembers / @Model.MaxMembers
                    </span>
                }
                <span class="dash-badge @(Model.IsActive ? "dash-badge-green" : "dash-badge-red")">
                    @(Model.IsActive ? "فعال" : "غیرفعال")
                </span>
            </div>
        </div>
    </div>

    <!-- ============================
         کارت‌های آمار کلی
    ============================ -->
    <div class="row g-3 mb-4">

        <div class="col-6 col-md-3">
            <a href="/Admin/Members" class="dash-stat-card" style="--accent:#00C896;--light:#edfaf5;">
                <div class="dash-stat-icon" style="background:#edfaf5;">
                    <i class="fa fa-users" style="color:#00C896;"></i>
                </div>
                <div class="dash-stat-body">
                    <div class="dash-stat-num">@Model.TotalMembers</div>
                    <div class="dash-stat-label">کل اعضا</div>
                </div>
                <div class="dash-stat-trend @(Model.NewMembersThisMonth > 0 ? "up" : "")">
                    @if (Model.NewMembersThisMonth > 0)
                    {
                        <i class="fa fa-arrow-up me-1"></i>
                        <span>@Model.NewMembersThisMonth نفر این ماه</span>
                    }
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a href="/Admin/NutritionProgram" class="dash-stat-card" style="--accent:#f6ad55;--light:#fffaf0;">
                <div class="dash-stat-icon" style="background:#fffaf0;">
                    <i class="fa fa-cutlery" style="color:#f6ad55;"></i>
                </div>
                <div class="dash-stat-body">
                    <div class="dash-stat-num">@Model.TotalNutritionPrograms</div>
                    <div class="dash-stat-label">برنامه غذایی</div>
                </div>
                <div class="dash-stat-trend @(Model.ActiveNutritionPrograms > 0 ? "up" : "")">
                    <i class="fa fa-check-circle me-1" style="color:#48bb78;"></i>
                    <span>@Model.ActiveNutritionPrograms فعال</span>
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a href="/Admin/TrainingProgram" class="dash-stat-card" style="--accent:#63b3ed;--light:#ebf8ff;">
                <div class="dash-stat-icon" style="background:#ebf8ff;">
                    <i class="fa fa-heartbeat" style="color:#63b3ed;"></i>
                </div>
                <div class="dash-stat-body">
                    <div class="dash-stat-num">@Model.TotalTrainingPrograms</div>
                    <div class="dash-stat-label">برنامه تمرینی</div>
                </div>
                <div class="dash-stat-trend @(Model.ActiveTrainingPrograms > 0 ? "up" : "")">
                    <i class="fa fa-check-circle me-1" style="color:#48bb78;"></i>
                    <span>@Model.ActiveTrainingPrograms فعال</span>
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <div class="dash-stat-card" style="--accent:#b794f4;--light:#faf5ff;">
                <div class="dash-stat-icon" style="background:#faf5ff;">
                    <i class="fa fa-database" style="color:#b794f4;"></i>
                </div>
                <div class="dash-stat-body">
                    <div class="dash-stat-num">@(Model.TotalFoods + Model.TotalExercises)</div>
                    <div class="dash-stat-label">آیتم بانک اطلاعات</div>
                </div>
                <div class="dash-stat-trend">
                    <span style="color:#718096;font-size:11px;">
                        @Model.TotalFoods غذا · @Model.TotalExercises حرکت
                    </span>
                </div>
            </div>
        </div>

    </div>

    <!-- ============================
         نمودارها
    ============================ -->
    <div class="row g-3 mb-4">

        <!-- نمودار خطی — اعضا و برنامه‌ها -->
        <div class="col-md-8">
            <div class="fc-card h-100">
                <div class="dash-card-header">
                    <div class="dash-card-title">
                        <i class="fa fa-line-chart me-2" style="color:#00C896;"></i>
                        روند ۶ ماه گذشته
                    </div>
                </div>
                <canvas id="lineChart" height="120"></canvas>
            </div>
        </div>

        <!-- نمودار دونات — توزیع هدف تمرینی -->
        <div class="col-md-4">
            <div class="fc-card h-100">
                <div class="dash-card-header">
                    <div class="dash-card-title">
                        <i class="fa fa-pie-chart me-2" style="color:#63b3ed;"></i>
                        اهداف تمرینی
                    </div>
                </div>
                @if (Model.TrainingGoalTypes != null && Model.TrainingGoalTypes.Any())
                {
                    <canvas id="donutChart" height="200"></canvas>
                    <div id="donutLegend" class="mt-3"></div>
                }
                else
                {
                    <div style="text-align:center;padding:40px 0;color:#a0aec0;">
                        <i class="fa fa-info-circle fa-2x mb-2" style="display:block;"></i>
                        داده‌ای موجود نیست
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- ============================
         جداول اخیر
    ============================ -->
    <div class="row g-3 mb-4">

        <!-- اعضای اخیر -->
        <div class="col-md-7">
            <div class="fc-card">
                <div class="dash-card-header">
                    <div class="dash-card-title">
                        <i class="fa fa-user-plus me-2" style="color:#00C896;"></i>
                        آخرین اعضای ثبت‌شده
                    </div>
                    <a href="/Admin/Members" class="dash-see-all">مشاهده همه</a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size:13px;">
                        <thead>
                            <tr>
                                <th>نام و نام خانوادگی</th>
                                <th>موبایل</th>
                                <th class="text-center">برنامه غذایی</th>
                                <th class="text-center">برنامه تمرینی</th>
                                <th>تاریخ ثبت</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentMembers != null && Model.RecentMembers.Any())
                            {
                                @foreach (var m in Model.RecentMembers)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="dash-avatar">
                                                    @(m.FullName?.Length > 0 ? m.FullName[0].ToString() : "؟")
                                                </div>
                                                <span class="fw-600">@m.FullName</span>
                                            </div>
                                        </td>
                                        <td style="color:#718096;">@m.Mobile</td>
                                        <td class="text-center">
                                            <span class="dash-mini-badge @(m.NutritionCount > 0 ? "green" : "gray")">
                                                @m.NutritionCount
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <span class="dash-mini-badge @(m.TrainingCount > 0 ? "blue" : "gray")">
                                                @m.TrainingCount
                                            </span>
                                        </td>
                                        <td style="color:#718096;font-size:12px;">
                                            @m.InsertTime.ToString("yyyy/MM/dd")
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">هنوز عضوی ثبت نشده است</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- فعالیت‌های اخیر -->
        <div class="col-md-5">
            <div class="fc-card h-100">
                <div class="dash-card-header">
                    <div class="dash-card-title">
                        <i class="fa fa-clock-o me-2" style="color:#f6ad55;"></i>
                        آخرین فعالیت‌ها
                    </div>
                </div>

                <div class="dash-activity-list">

                    @if (Model.RecentNutritionPrograms != null)
                    {
                        @foreach (var p in Model.RecentNutritionPrograms)
                        {
                            <div class="dash-activity-item">
                                <div class="dash-activity-dot" style="background:#f6ad55;"></div>
                                <div class="dash-activity-body">
                                    <div style="font-size:13px;font-weight:600;">
                                        برنامه غذایی — @p.Title
                                    </div>
                                    <div style="font-size:12px;color:#718096;">
                                        <i class="fa fa-user-o me-1"></i>@p.MemberName
                                        <span class="ms-2">@p.StartDate</span>
                                    </div>
                                </div>
                                <span class="dash-badge @(p.IsActive ? "dash-badge-green" : "dash-badge-gray")"
                                      style="font-size:10px;">
                                    @(p.IsActive ? "فعال" : "قدیمی")
                                </span>
                            </div>
                        }
                    }

                    @if (Model.RecentTrainingPrograms != null)
                    {
                        @foreach (var p in Model.RecentTrainingPrograms)
                        {
                            <div class="dash-activity-item">
                                <div class="dash-activity-dot" style="background:#63b3ed;"></div>
                                <div class="dash-activity-body">
                                    <div style="font-size:13px;font-weight:600;">
                                        برنامه تمرینی — @p.Title
                                    </div>
                                    <div style="font-size:12px;color:#718096;">
                                        <i class="fa fa-user-o me-1"></i>@p.MemberName
                                        <span class="ms-2">@p.StartDate</span>
                                    </div>
                                </div>
                                <span class="dash-badge @(p.IsActive ? "dash-badge-blue" : "dash-badge-gray")"
                                      style="font-size:10px;">
                                    @(p.IsActive ? "فعال" : "قدیمی")
                                </span>
                            </div>
                        }
                    }

                    @if ((Model.RecentNutritionPrograms == null || !Model.RecentNutritionPrograms.Any()) &&
                                        (Model.RecentTrainingPrograms == null || !Model.RecentTrainingPrograms.Any()))
                    {
                        <div style="text-align:center;padding:30px;color:#a0aec0;">
                            <i class="fa fa-inbox fa-2x" style="display:block;margin-bottom:8px;opacity:0.4;"></i>
                            هنوز برنامه‌ای ثبت نشده
                        </div>
                    }

                </div>
            </div>
        </div>

    </div>

    <!-- ============================
         دسترسی سریع
    ============================ -->
    <div class="fc-card">
        <div class="dash-card-header mb-3">
            <div class="dash-card-title">
                <i class="fa fa-bolt me-2" style="color:#f6ad55;"></i>
                دسترسی سریع
            </div>
        </div>
        <div class="row g-2">
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/Members" class="dash-quick-btn">
                    <i class="fa fa-users"></i>
                    <span>اعضا</span>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/NutritionProgram" class="dash-quick-btn">
                    <i class="fa fa-cutlery"></i>
                    <span>برنامه غذایی</span>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/TrainingProgram" class="dash-quick-btn">
                    <i class="fa fa-heartbeat"></i>
                    <span>برنامه تمرینی</span>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/Food" class="dash-quick-btn">
                    <i class="fa fa-apple"></i>
                    <span>بانک غذاها</span>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/Exercise" class="dash-quick-btn">
                    <i class="fa fa-list-ul"></i>
                    <span>بانک حرکات</span>
                </a>
            </div>
            <div class="col-6 col-sm-4 col-md-2">
                <a href="/Admin/Gym" class="dash-quick-btn">
                    <i class="fa fa-building-o"></i>
                    <span>تنظیمات باشگاه</span>
                </a>
            </div>
        </div>
    </div>

</div>

<!-- ============================
     استایل
============================ -->

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        Chart.defaults.font.family = 'Vazir, Tahoma, sans-serif';
        Chart.defaults.plugins.legend.rtl = true;

        // ============================
        // داده‌های سرور
        // ============================
        var months = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                    Model.MonthlyNewMembers?.Select(m => m.Label).ToList()
                    ?? new System.Collections.Generic.List<string>()));

    var membersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyNewMembers?.Select(m => m.Value).ToList()
                ?? new System.Collections.Generic.List<int>()));

    var nutritionData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyNutritionPrograms?.Select(m => m.Value).ToList()
                ?? new System.Collections.Generic.List<int>()));

    var trainingData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.MonthlyTrainingPrograms?.Select(m => m.Value).ToList()
                ?? new System.Collections.Generic.List<int>()));

    var donutLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TrainingGoalTypes?.Select(t => t.Label).ToList()
                ?? new System.Collections.Generic.List<string>()));

    var donutData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.TrainingGoalTypes?.Select(t => t.Count).ToList()
                ?? new System.Collections.Generic.List<int>()));

    // ============================
    // نمودار خطی
    // ============================
    var lineCtx = document.getElementById('lineChart');
    if (lineCtx) {
        new Chart(lineCtx, {
            type: 'line',
            data: {
                labels: months,
                datasets: [
                    {
                        label: 'اعضای جدید',
                        data: membersData,
                        borderColor: '#00C896',
                        backgroundColor: 'rgba(0,200,150,0.08)',
                        tension: 0.4, fill: true,
                        pointBackgroundColor: '#00C896',
                        pointRadius: 5, pointHoverRadius: 7,
                        borderWidth: 2.5
                    },
                    {
                        label: 'برنامه غذایی',
                        data: nutritionData,
                        borderColor: '#f6ad55',
                        backgroundColor: 'rgba(246,173,85,0.07)',
                        tension: 0.4, fill: true,
                        pointBackgroundColor: '#f6ad55',
                        pointRadius: 5, pointHoverRadius: 7,
                        borderWidth: 2.5
                    },
                    {
                        label: 'برنامه تمرینی',
                        data: trainingData,
                        borderColor: '#63b3ed',
                        backgroundColor: 'rgba(99,179,237,0.07)',
                        tension: 0.4, fill: true,
                        pointBackgroundColor: '#63b3ed',
                        pointRadius: 5, pointHoverRadius: 7,
                        borderWidth: 2.5
                    }
                ]
            },
            options: {
                responsive: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', align: 'end' },
                    tooltip: { rtl: true }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: '#f0f4f8' } }
                }
            }
        });
    }

        // ============================
        // نمودار دونات
        // ============================
        var donutCtx = document.getElementById('donutChart');
        if (donutCtx && donutData.length > 0) {
            var colors = ['#00C896','#63b3ed','#f6ad55','#b794f4','#fc8181','#68d391'];

            new Chart(donutCtx, {
                type: 'doughnut',
                data: {
                    labels: donutLabels,
                    datasets: [{
                        data: donutData,
                        backgroundColor: colors.slice(0, donutData.length),
                        borderWidth: 2,
                        borderColor: '#fff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    cutout: '65%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { rtl: true }
                    }
                }
            });

            // legend دستی
            var legend = document.getElementById('donutLegend');
            if (legend) {
                donutLabels.forEach(function(label, i) {
                    legend.innerHTML +=
                        '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">' +
                            '<div style="width:10px;height:10px;border-radius:50%;background:' + colors[i] + ';flex-shrink:0;"></div>' +
                            '<span style="font-size:12px;color:#4a5568;flex:1;">' + label + '</span>' +
                            '<span style="font-size:12px;font-weight:700;color:#1a202c;">' + donutData[i] + '</span>' +
                        '</div>';
                });
            }
        }
    </script>
}
