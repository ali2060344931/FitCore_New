@* ============================================================
   اسکریپت‌ها
============================================================ *@
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
                        Chart.defaults.font.family = 'Vazirmatn, Vazir, Tahoma, sans-serif';
                        Chart.defaults.font.size   = 10;
                        Chart.defaults.plugins.legend.rtl = true;

                        // داده‌های سرور
                        var months = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            Model.MonthlyNewMembers?.Select(m => m.Label).ToList()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            ?? new System.Collections.Generic.List<string>()));

    var membersData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Model.MonthlyNewMembers?.Select(m => m.Value).ToList()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ?? new System.Collections.Generic.List<int>()));

    var nutritionData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Model.MonthlyNutritionPrograms?.Select(m => m.Value).ToList()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ?? new System.Collections.Generic.List<int>()));

    var trainingData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Model.MonthlyTrainingPrograms?.Select(m => m.Value).ToList()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ?? new System.Collections.Generic.List<int>()));

    var donutLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Model.TrainingGoalTypes?.Select(t => t.Label).ToList()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ?? new System.Collections.Generic.List<string>()));

    var donutData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                Model.TrainingGoalTypes?.Select(t => t.Count).ToList()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                ?? new System.Collections.Generic.List<int>()));

    // تنظیمات مشترک محورها
    var commonScales = {
        x: {
            grid: { display: false },
            ticks: { font: { size: 9 }, maxRotation: 0, maxTicksLimit: 4 }
        },
        y: {
            beginAtZero: true,
            ticks: { stepSize: 1, font: { size: 9 }, maxTicksLimit: 5 },
            grid: { color: '#f3f4f6' }
        }
    };

                        // نمودار خطی
                        var lineCtx = document.getElementById('lineChart');
                        if (lineCtx) {
                            new Chart(lineCtx, {
                                type: 'line',
                                data: {
                                    labels: months,
                                    datasets: [
                                        {
                                            label: 'اعضای جدید',
                                            data: membersData,
                                            borderColor: '#00C896',
                                            backgroundColor: 'rgba(0,200,150,0.07)',
                                            tension: 0.4, fill: true,
                                            pointBackgroundColor: '#00C896',
                                            pointRadius: 4, pointHoverRadius: 6, borderWidth: 2.5
                                        },
                                        {
                                            label: 'برنامه غذایی',
                                            data: nutritionData,
                                            borderColor: '#f59e0b',
                                            backgroundColor: 'rgba(245,158,11,0.07)',
                                            tension: 0.4, fill: true,
                                            pointBackgroundColor: '#f59e0b',
                                            pointRadius: 4, pointHoverRadius: 6, borderWidth: 2.5
                                        },
                                        {
                                            label: 'برنامه تمرینی',
                                            data: trainingData,
                                            borderColor: '#3b82f6',
                                            backgroundColor: 'rgba(59,130,246,0.07)',
                                            tension: 0.4, fill: true,
                                            pointBackgroundColor: '#3b82f6',
                                            pointRadius: 4, pointHoverRadius: 6, borderWidth: 2.5
                                        }
                                    ]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    interaction: { mode: 'index', intersect: false },
                                    plugins: {
                                        legend: {
                                            position: 'top', align: 'end',
                                            labels: { boxWidth: 10, padding: 12, font: { size: 10 } }
                                        },
                                        tooltip: { rtl: true }
                                    },
                                    scales: commonScales
                                }
                            });
                        }

                        // نمودار دونات
                        var donutCtx = document.getElementById('donutChart');
                        if (donutCtx && donutData.length > 0) {
                            var colors = ['#00C896','#3b82f6','#f59e0b','#8b5cf6','#ef4444','#10b981'];

                            new Chart(donutCtx, {
                                type: 'doughnut',
                                data: {
                                    labels: donutLabels,
                                    datasets: [{
                                        data: donutData,
                                        backgroundColor: colors.slice(0, donutData.length),
                                        borderWidth: 2,
                                        borderColor: '#fff',
                                        hoverOffset: 4
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    cutout: '62%',
                                    plugins: {
                                        legend: { display: false },
                                        tooltip: { rtl: true }
                                    }
                                }
                            });

                            var legend = document.getElementById('donutLegend');
                            if (legend) {
                                var legendHtml = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:4px 12px;">';
                                donutLabels.forEach(function(label, i) {
                                    legendHtml +=
                                        '<div style="display:flex;align-items:center;gap:6px;padding:3px 0;">' +
                                        '<div style="width:8px;height:8px;border-radius:50%;background:' + colors[i] + ';flex-shrink:0;"></div>' +
                                        '<span style="font-size:11px;color:#4b5563;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + label + '</span>' +
                                        '<span style="font-size:11px;font-weight:700;color:#111827;flex-shrink:0;">' + donutData[i] + '</span>' +
                                        '</div>';
                                });
                                legendHtml += '</div>';
                                legend.innerHTML = legendHtml;
                            }
                        }
    </script>
}
