@using System.Security.Claims
@using FitCore.Application.Contexts
@using FitCore.Common
@using FitCore.Application.Services.Members.Queries
@using Microsoft.EntityFrameworkCore
@using Swashbuckle.AspNetCore.SwaggerGen
@using System.ComponentModel.DataAnnotations
@inject IGetMemberByAppUserIdService _getMemberByAppUserIdService
@inject IDataBaseContext _db
@using FitCore.Application.Services.Dashboard



@model GymDashboardDto

@{
    ViewData["Title"] = "داشبورد";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}



@{
    bool isActivGYM = false;
    var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int difDay_ = 0;
    int difDay_abs = 0;

    long uid = 0;
    if (!string.IsNullOrEmpty(userId))
        uid = long.Parse(userId);

    var gid = _db.Users.Where(o => o.Id == uid).First().GymId;
    var qgym = _db.Gyms.Where(o => o.Id == gid).First();


    // if (User.IsAdmin())
    {
        string todayShamsi = DateConverterMlladiToShamsi.ToShamsi(DateTime.Now);

        var difDay = DateConverterMlladiToShamsi.GetDaysDifference(qgym.SubscriptionExpireDate, todayShamsi);
        if (qgym.IsActive && difDay > 0) isActivGYM = true;
        difDay_ = difDay;
        difDay_abs = Math.Abs(difDay);


    }

}


<style>
    :root {
        --d-green: #00C896;
        --d-green-bg: #edfaf5;
        --d-blue: #3b82f6;
        --d-blue-bg: #eff6ff;
        --d-orange: #f59e0b;
        --d-orange-bg: #fffbeb;
        --d-purple: #8b5cf6;
        --d-purple-bg: #f5f3ff;
        --d-red: #ef4444;
        --d-red-bg: #fef2f2;
        --d-text: #111827;
        --d-muted: #6b7280;
        --d-light: #9ca3af;
        --d-border: #e5e7eb;
        --d-surface: #f9fafb;
