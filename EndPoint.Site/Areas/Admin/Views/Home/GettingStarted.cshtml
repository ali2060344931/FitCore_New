@{
    ViewData["Title"] = "راهنمای شروع | FitCore";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_Adminlayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 30px;
        border-bottom: 1px solid #1e293b;
        margin-bottom: 20px;
    }

    .page {
        padding: 40px 0;
    }

    .step-card {
        background: #020617;
        border: 1px solid #1e293b;
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 25px;
        transition: .3s;
        color: #ffffff;
    }

        .step-card p {
            color: #e2e8f0;
        }

        .step-card h5 {
            color: #ffffff;
        }

        .step-card:hover {
            border-color: #6366f1;
            transform: translateY(-4px);
        }

    .step-number {
        width: 40px;
        height: 40px;
        background: #6366f1;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .btn-start {
        background: #6366f1;
        border: none;
    }

</style>

<div class="container page">

    <div class="text-center mb-5">

        <h2>راهنمای شروع با FitCore</h2>

        <p class="text-muted">
            در چند مرحله ساده سیستم را یاد بگیرید
        </p>

    </div>

    <div class="row">

        <div class="col-md-6">

            <div class="step-card">

                <div class="step-number">1</div>

                <h5>ایجاد باشگاه</h5>

                <p>
                    ابتدا باشگاه خود را در سیستم ثبت کنید
                    و اطلاعات کامل آن را وارد کنید.
                </p>

                <a href="/Admin/Gym/Create" class="btn btn-outline-light btn-sm">
                    ایجاد باشگاه
                </a>

            </div>

        </div>


        <div class="col-md-6">

            <div class="step-card">

                <div class="step-number">2</div>

                <h5>افزودن ورزشکار</h5>

                <p>
                    اطلاعات ورزشکاران باشگاه خود را ثبت کنید
                    و مشخصات بدنی آنها را وارد کنید.
                </p>

                <a href="/Admin/Members/CreateEdit" class="btn btn-outline-light btn-sm">
                    ثبت ورزشکار
                </a>

            </div>

        </div>


        <div class="col-md-6">

            <div class="step-card">

                <div class="step-number">3</div>

                <h5>ساخت برنامه تمرینی</h5>

                <p>
                    برای ورزشکاران برنامه تمرینی حرفه‌ای
                    با حرکات و روزهای تمرینی بسازید.
                </p>

                <a href="/Admin/TrainingProgram" class="btn btn-outline-light btn-sm">
                    مدیریت برنامه تمرینی
                </a>

            </div>

        </div>


        <div class="col-md-6">

            <div class="step-card">

                <div class="step-number">4</div>

                <h5>ساخت برنامه غذایی</h5>

                <p>
                    برنامه غذایی مناسب برای افزایش
                    یا کاهش وزن ورزشکاران طراحی کنید.
                </p>

                <a href="/Admin/NutritionProgram" class="btn btn-outline-light btn-sm">
                    مدیریت برنامه غذایی
                </a>

            </div>

        </div>

    </div>

    <div class="text-center mt-5">

        <a href="/Admin/Home/Index" class="btn btn-start btn-lg">
            ورود به داشبورد
        </a>

    </div>

</div>
