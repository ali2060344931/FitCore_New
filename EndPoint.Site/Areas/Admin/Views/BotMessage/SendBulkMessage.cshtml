@using EndPoint.Site.Areas.Admin.Models
@model SendBaleBulkMessageViewModel
@{
    ViewData["Title"] = "ارسال پیام گروهی به ربات بله";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<!-- اسکریپت SweetAlert -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    /* کانتینر اصلی با حداکثر ارتفاع ممکن و فاصله کم از بالا */
    .bulk-message-container {
    display: flex;
    flex-direction: column;
    height: 88vh; /* افزایش ارتفاع برای فضای بیشتر */
    overflow: hidden;
    margin-top: -10px; /* کم کردن فاصله از نوار ادمین */
    }

    /* بخش بالایی که ثابت می‌ماند */
    .fixed-top-section {
    flex-shrink: 0;
    background-color: #f8f9fa;
    border-bottom: 2px solid #dee2e6;
    padding-bottom: 10px;
    margin-bottom: 10px;
    border-radius: 8px;
    }

    /* بخش لیست که اسکرول می‌خورد */
    .scrollable-list-section {
    flex-grow: 1;
    overflow-y: auto;
    padding-right: 5px;
    }

    /* استایل اسکرول بار */
    .scrollable-list-section::-webkit-scrollbar {
    width: 8px;
    }

    .scrollable-list-section::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
    }

    .scrollable-list-section::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 10px;
    }

    .scrollable-list-section::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
    }

    .member-checkbox {
    width: 1.2em;
    height: 1.2em;
    cursor: pointer;
    }

    /* استایل دکمه ارسال برای اینکه جمع‌وجور شود */
    .btn-submit-compact {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1.2;
    padding: 10px 5px;
    }
</style>

<div class="container-fluid mt-1 pt-2">
    <!-- فاصله از بالا به حداقل رسید -->
    <div class="row justify-content-center">
        <div class="col-md-11">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-2">
                    <!-- پدینگ کمتر -->
                    <h6 class="mb-0"><i class="fas fa-paper-plane mr-2"></i> ارسال پیام گروهی</h6>
                    <span class="badge bg-light text-dark">متصلین: @Model.Members.Count نفر</span>
                </div>
                <div class="card-body p-2">
                    <!-- پدینگ اطراف کادر کمتر شد -->
                    @if (Model.IsSubmitted)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-2 py-2" role="alert">
                            <div class="d-flex align-items-center mb-0">
                                <div class="mr-auto">
                                    ✅ موفق: <strong>@Model.SentCount</strong> نفر
                                    @if (Model.FailedCount > 0)
                                    {
                                        <span class="text-danger"> | ❌ ناموفق: <strong>@Model.FailedCount</strong> نفر</span>
                                    }
                                </div>
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="padding: 0 10px 0 0;">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                        </div>
                    }

                    @if (!Model.Members.Any() && !Model.IsSubmitted)
                    {
                        <div class="alert alert-warning mb-0">هیچ عضو فعالی در باشگاه شما ربات بله را متصل نکرده است.</div>
                    }
                    else
                    {
                        <form id="sendMessageForm" asp-action="SendBulkMessage" method="post">
                            @Html.AntiForgeryToken()

                            <div class="bulk-message-container">

                                <!-- ========================================================== -->
                                <!-- بخش ثابت بالایی -->
                                <!-- ========================================================== -->
                                <div class="fixed-top-section p-2">

                                    <!-- کارت ۱: مخاطبان + جستجو (ترکیب شده) -->
                                    <div class="form-group mb-2 bg-white p-2 rounded border">
                                        <div class="font-weight-bold mb-2 text-dark" style="font-size: 0.95rem;">👤 مخاطبان پیام:</div>
                                        <div class="d-flex flex-wrap gap-3 mb-2">
                                            <div class="form-check form-check-inline mb-1">
                                                <input class="form-check-input filter-radio" type="radio" asp-for="FilterType" value="1" id="filterActive" checked="checked">
                                                <label class="form-check-label" for="filterActive">فقط <span class="text-success font-weight-bold">فعال</span></label>
                                            </div>
                                            <div class="form-check form-check-inline mb-1">
                                                <input class="form-check-input filter-radio" type="radio" asp-for="FilterType" value="2" id="filterExpired">
                                                <label class="form-check-label" for="filterExpired">فقط <span class="text-danger font-weight-bold">منقضی</span></label>
                                            </div>
                                            <div class="form-check form-check-inline mb-1">
                                                <input class="form-check-input filter-radio" type="radio" asp-for="FilterType" value="3" id="filterAll">
                                                <label class="form-check-label" for="filterAll">همه اعضا</label>
                                            </div>
                                        </div>

                                        <!-- جستجو و تعداد انتخاب شده ها -->
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <div class="input-group input-group-sm">
                                                    <div class="input-group-prepend"><span class="input-group-text"><i class="fas fa-search"></i></span></div>
                                                    <input type="text" id="searchInput" class="form-control" placeholder="جستجو بر اساس نام یا شماره..." />
                                                </div>
                                            </div>
                                            <div class="col-md-4 text-left pl-0">
                                                <span id="selectedCount" class="text-muted font-weight-bold" style="font-size: 0.9rem;">0 نفر انتخاب شده</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- کارت ۲: متن پیام + دکمه ارسال در یک ردیف -->
                                    <div class="form-row align-items-stretch">
                                        <div class="col-md-10 pr-0">
                                            <div class="form-group mb-0 h-100">
                                                <textarea asp-for="MessageText" class="form-control h-100" rows="2" placeholder="متن پیام خود را بنویسید..." style="resize: none; border-top-left-radius: 0;"></textarea>
                                                <span asp-validation-for="MessageText" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-md-2 pl-0">
                                            <button type="button" id="btnSubmit" class="btn btn-success btn-block h-100 btn-submit-compact">
                                                <i class="fas fa-paper-plane fa-lg"></i>
                                                <span class="mt-1 d-block" style="font-size: 0.8rem;">ارسال به</span>
                                                <b id="btnSelectedCount" class="d-block" style="font-size: 1.2rem;">0</b>
                                                <span class="d-block" style="font-size: 0.8rem;">نفر</span>
                                            </button>
                                        </div>
                                    </div>

                                </div>

                                <!-- ========================================================== -->
                                <!-- بخش لیست اعضاء (اسکرول خور با حداکثر فضا) -->
                                <!-- ========================================================== -->
                                <div class="scrollable-list-section border rounded bg-white p-2 mt-2">
                                    <table class="table table-hover table-sm mb-0" style="margin-bottom: 0;">
                                        <!-- table-sm برای فشرده شدن ردیف ها -->
                                        <thead class="thead-light" style="position: sticky; top: 0; z-index: 10;">
                                            <tr>
                                                <th style="width: 40px; padding: 8px;">
                                                    <input type="checkbox" id="selectAll" class="member-checkbox" title="انتخاب همه" />
                                                </th>
                                                <th class="text-center" style="padding: 8px;">نام و نام خانوادگی</th>
                                                <th class="text-center" style="padding: 8px;">شماره موبایل</th>
                                                <th class="text-center" style="width: 90px; padding: 8px;">وضعیت</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int i = 0; i < Model.Members.Count; i++)
                                            {
                                                var rowClass = Model.Members[i].IsExpired ? "expired-row text-danger" : "active-row";

                                                <tr class="search-row @rowClass">
                                                    <td class="text-center" style="padding: 6px;">
                                                        <input type="hidden" asp-for="@Model.Members[i].Id" />
                                                        <input type="hidden" asp-for="@Model.Members[i].BaleChatId" />
                                                        <input type="hidden" asp-for="@Model.Members[i].IsExpired" />
                                                        <input type="checkbox" asp-for="@Model.Members[i].IsSelected" class="member-checkbox" />
                                                    </td>
                                                    <td class="align-middle search-text text-center" style="padding: 6px;">@Model.Members[i].FullName</td>
                                                    <td class="align-middle search-text text-center" style="padding: 6px; direction: ltr;">@Model.Members[i].PhoneNumber</td>
                                                    <td class="align-middle search-text text-center" style="padding: 6px;">
                                                        @if (Model.Members[i].IsExpired)
                                                        {
                                                            <span class="badge badge-danger p-1" style="font-size: 0.75rem;">منقضی</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge badge-success p-1" style="font-size: 0.75rem;">فعال</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

        function updateSelectedCount() {
        var count = $('.member-checkbox:checked').length;
        $('#selectedCount').text(count + ' نفر انتخاب شده');
        $('#btnSelectedCount').text(count);
        }

        function resetSelectAll() {
        if ($('.member-checkbox:visible').length > 0 &&
        $('.member-checkbox:visible').length === $('.member-checkbox:checked:visible').length) {
        $("#selectAll").prop("checked", true);
        } else {
        $("#selectAll").prop("checked", false);
        }
        }

        function applyFilter() {
        var val = $('input[name="FilterType"]:checked').val();
        if (val == '1') { $('.active-row').show(); $('.expired-row').hide(); }
        else if (val == '2') { $('.active-row').hide(); $('.expired-row').show(); }
        else { $('.active-row').show(); $('.expired-row').show(); }

        $('.member-checkbox:hidden').prop('checked', false);
        updateSelectedCount();
        resetSelectAll();
        }

        applyFilter();
        $('.filter-radio').change(function() { applyFilter(); });

        $("#selectAll").click(function () {
        $('.member-checkbox:visible').prop('checked', this.checked);
        updateSelectedCount();
        });

        $(document).on('change', '.member-checkbox', function () {
        resetSelectAll();
        updateSelectedCount();
        });

        $('#searchInput').on("keyup", function() {
        var value = $(this).val().toLowerCase();
        applyFilter();
        $('.search-row:visible').filter(function() {
        $(this).toggle($(this).find('.search-text').text().toLowerCase().indexOf(value) > -1);
        });
        $('.member-checkbox:hidden').prop('checked', false);
        updateSelectedCount();
        resetSelectAll();
        });

        $('#btnSubmit').click(function (e) {
        e.preventDefault();
        var count = $('.member-checkbox:checked').length;
        var messageText = $('#MessageText').val().trim();

        if (count === 0) {
        Swal.fire('توجه!', 'لطفاً حداقل یک نفر را از لیست انتخاب کنید.', 'warning');
        return;
        }
        if (messageText === "") {
        Swal.fire('توجه!', 'لطفاً متن پیام را وارد کنید.', 'warning');
        return;
        }

        Swal.fire({
        title: 'آیا از ارسال پیام مطمئن هستید؟',
        html: `شما در حال ارسال پیام به <b style="color:#28a745;">${count}</b> نفر هستید.`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#28a745',
        cancelButtonColor: '#d33',
        confirmButtonText: 'بله، ارسال شود',
        cancelButtonText: 'انصراف'
        }).then((result) => {
        if (result.isConfirmed) {
        $('#btnSubmit').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i><br><small>در حال ارسال...</small>');
        $('#sendMessageForm').submit();
        }
        });
        });
        });
    </script>
}