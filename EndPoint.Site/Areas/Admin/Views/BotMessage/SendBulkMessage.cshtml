@using EndPoint.Site.Areas.Admin.Models
@model SendBaleBulkMessageViewModel
@{
    ViewData["Title"] = "ارسال پیام گروهی به ربات بله";
   
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_Adminlayout.cshtml";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">📢 ارسال پیام انتخابی به اعضاء ربات بله</h5>
                    <span class="badge bg-light text-dark">کل متصلین: @Model.Members.Count</span>
                </div>
                <div class="card-body">

                    @if (Model.IsSubmitted)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <h6 class="alert-heading">عملیات ارسال به پایان رسید</h6>
                            <p class="mb-0">
                                ✅ موفق: <strong>@Model.SentCount</strong> نفر
                                @if (Model.FailedCount > 0)
                                {
                                    <span class="text-danger"> | ❌ ناموفق: <strong>@Model.FailedCount</strong> نفر</span>
                                }
                            </p>
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                        <hr />
                    }

                    @if (!Model.Members.Any() && !Model.IsSubmitted)
                    {
                        <div class="alert alert-warning">هیچ عضو فعالی در باشگاه شما ربات بله را متصل نکرده است.</div>
                    }
                    else
                    {
                        <form id="sendMessageForm" asp-action="SendBulkMessage" method="post">
                            @Html.AntiForgeryToken()

                            <!-- رادیو باتن‌های انتخاب نوع ارسال -->
                            <div class="form-group mb-3 p-3 bg-light rounded border">
                                <label class="font-weight-bold mb-2 d-block">لطفاً مشخص کنید پیام برای چه کسانی ارسال شود:</label>

                                <div class="form-check form-check-inline">
                                    <input class="form-check-input filter-radio" type="radio" asp-for="FilterType" value="1" id="filterActive" checked="checked">
                                    <label class="form-check-label" for="filterActive">فقط اعضای <span class="text-success font-weight-bold">فعال</span></label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input filter-radio" type="radio" asp-for="FilterType" value="2" id="filterExpired">
                                    <label class="form-check-label" for="filterExpired">فقط اعضای <span class="text-danger font-weight-bold">منقضی</span></label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input filter-radio" type="radio" asp-for="FilterType" value="3" id="filterAll">
                                    <label class="form-check-label" for="filterAll">همه اعضا (بدون محدودیت)</label>
                                </div>
                            </div>

                            <!-- باکس جستجو -->
                            <div class="form-group mb-3">
                                <div class="input-group">
                                    <div class="input-group-prepend">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    </div>
                                    <input type="text" id="searchInput" class="form-control" placeholder="جستجو بر اساس نام، شماره یا وضعیت..." />
                                </div>
                                <small id="selectedCount" class="text-muted float-left" style="margin-top: 5px;">0 نفر انتخاب شده</small>
                            </div>

                            <!-- جدول لیست اعضا -->
                            <div class="table-responsive border rounded mb-3" style="max-height: 400px; overflow-y: auto;">
                                <table class="table table-hover table-striped mb-0">
                                    <thead class="thead-light sticky-top">
                                        <tr>
                                            <th style="width: 50px;">
                                                <input type="checkbox" id="selectAll" class="form-check-input" title="انتخاب همه" />
                                            </th>
                                            <th>نام و نام خانوادگی</th>
                                            <th>شماره موبایل</th>
                                            <th style="width: 100px;">وضعیت عضویت</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < Model.Members.Count; i++)
                                        {
                                            // اضافه کردن کلاس active-row یا expired-row
                                            var rowClass = Model.Members[i].IsExpired ? "expired-row" : "active-row";

                                            <tr class="search-row @rowClass">
                                                <td>
                                                    <input type="hidden" asp-for="@Model.Members[i].Id" />
                                                    <input type="hidden" asp-for="@Model.Members[i].BaleChatId" />
                                                    <input type="hidden" asp-for="@Model.Members[i].IsExpired" />
                                                    <input type="checkbox" asp-for="@Model.Members[i].IsSelected" class="form-check-input member-checkbox" />
                                                </td>
                                                <td class="search-text">@Model.Members[i].FullName</td>
                                                <td class="search-text">@Model.Members[i].PhoneNumber</td>
                                                <td class="search-text">
                                                    @if (Model.Members[i].IsExpired)
                                                    {
                                                        <span class="badge bg-danger">منقضی</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success">فعال</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <!-- کادر متن پیام -->
                            <div class="form-group mt-3">
                                <label asp-for="MessageText" class="form-label font-weight-bold">متن پیام</label>
                                <textarea asp-for="MessageText" class="form-control" rows="4" placeholder="پیام خود را اینجا بنویسید..."></textarea>
                                <span asp-validation-for="MessageText" class="text-danger"></span>
                            </div>

                            <div class="form-group text-left">
                                <button type="button" id="btnSubmit" class="btn btn-success btn-lg">
                                    <i class="fas fa-paper-plane"></i> ارسال به افراد انتخاب شده (<span id="btnSelectedCount">0</span> نفر)
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // ۱. بروزرسانی شمارنده
            function updateSelectedCount() {
                var count = $('.member-checkbox:checked').length;
                $('#selectedCount').text(count + ' نفر انتخاب شده');
                $('#btnSelectedCount').text(count);
            }

            // ریست کردن دکمه انتخاب همه
            function resetSelectAll() {
                if ($('.member-checkbox:visible').length > 0 &&
                    $('.member-checkbox:visible').length === $('.member-checkbox:checked:visible').length) {
                    $("#selectAll").prop("checked", true);
                } else {
                    $("#selectAll").prop("checked", false);
                }
            }

            // ==========================================================
            // ۲. تابع فیلتر کردن ردیف‌ها بر اساس رادیو باتن انتخاب شده
            // ==========================================================
            function applyFilter() {
                var val = $('input[name="FilterType"]:checked').val();

                if (val == '1') { // فقط فعال
                    $('.active-row').show();
                    $('.expired-row').hide();
                } else if (val == '2') { // فقط منقضی
                    $('.active-row').hide();
                    $('.expired-row').show();
                } else { // همه
                    $('.active-row').show();
                    $('.expired-row').show();
                }

                // تیک‌های ردیف‌های مخفی شده را برمی‌داریم تا اشتباهاً ارسال نشوند
                $('.member-checkbox:hidden').prop('checked', false);
                updateSelectedCount();
                resetSelectAll();
            }

            // اجرای اولیه هنگام لود صفحه (پیش‌فرض: فعال)
            applyFilter();

            // رویداد تغییر رادیو باتن‌ها
            $('.filter-radio').change(function() {
                applyFilter();
            });

            // ۳. منطق انتخاب همه
            $("#selectAll").click(function () {
                $('.member-checkbox:visible').prop('checked', this.checked);
                updateSelectedCount();
            });

            // ۴. منطق تیک تک تک
            $(document).on('change', '.member-checkbox', function () {
                resetSelectAll();
                updateSelectedCount();
            });

            // ۵. جستجو (ترکیب با فیلتر فعال/منقضی)
            $('#searchInput').on("keyup", function() {
                var value = $(this).val().toLowerCase();

                // ابتدا ردیف‌ها را بر اساس فیلتر رادیو باتن نمایش/مخفی می‌کنیم
                applyFilter();

                // سپس جستجو را روی ردیف‌های قابل مشاهده اعمال می‌کنیم
                $('.search-row:visible').filter(function() {
                    $(this).toggle($(this).find('.search-text').text().toLowerCase().indexOf(value) > -1);
                });

                // تیک‌های ردیف‌هایی که توسط جستجو مخفی شدند را برمی‌داریم
                $('.member-checkbox:hidden').prop('checked', false);

                updateSelectedCount();
                resetSelectAll();
            });

            // ۶. دکمه ارسال نهایی
            $('#btnSubmit').click(function (e) {
                e.preventDefault();
                var count = $('.member-checkbox:checked').length;
                var messageText = $('#MessageText').val().trim();

                if (count === 0) {
                    Swal.fire('توجه!', 'لطفاً حداقل یک نفر را از لیست انتخاب کنید.', 'warning');
                    return;
                }
                if (messageText === "") {
                    Swal.fire('توجه!', 'لطفاً متن پیام را وارد کنید.', 'warning');
                    return;
                }

                Swal.fire({
                    title: 'آیا از ارسال پیام مطمئن هستید؟',
                    html: `شما در حال ارسال پیام به <b style="color:#28a745;">${count}</b> نفر هستید.`,
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#28a745',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'بله، ارسال شود',
                    cancelButtonText: 'انصراف'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $('#btnSubmit').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> در حال ارسال...');
                        $('#sendMessageForm').submit();
                    }
                });
            });
        });
    </script>
}