@model List<FitCore.Application.Services.Tickets.DTOs.TicketDto>
@{
    ViewData["Title"] = "مدیریت تیکت‌های پشتیبانی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<!-- کدهای استایل و جدولی که قبلاً فرستادم دقیقاً همینجا قرار دهید -->
<style>
    .ticket-table {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        overflow: hidden;
        border: 1px solid #f1f5f9;
    }

        .ticket-table thead th {
            background: #f8fafc;
            color: #475569;
            font-weight: 600;
            font-size: 13px;
            padding: 16px;
            border-bottom: 2px solid #e2e8f0;
        }

        .ticket-table tbody td {
            padding: 16px;
            vertical-align: middle;
            font-size: 14px;
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.2s;
        }

        .ticket-table tbody tr:hover {
            background: #f8fafc;
        }

    .status-badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .status-pending {
        background: #fef3c7;
        color: #d97706;
    }

    .status-answered {
        background: #dbeafe;
        color: #2563eb;
    }

    .status-closed {
        background: #dcfce7;
        color: #16a34a;
    }

    .user-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f1f5f9;
        padding: 4px 12px 4px 4px;
        border-radius: 50px;
    }

    .user-pill-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #6366f1;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: bold;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="mb-0 text-dark fw-bold"><i class="fa fa-ticket-alt me-2 text-primary"></i> تمامی تیکت‌ها</h4>
        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fs-6">@(Model.Count()) تیکت ثبت شده</span>
    </div>

    <div class="ticket-table table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th width="30%">عنوان تیکت</th>
                    <th width="25%">ارسال کننده</th>
                    <th width="15%">باشگاه</th>
                    <th width="15%">وضعیت</th>
                    <th width="15%">تاریخ</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var ticket in Model)
                    {
                        var statusClass = ticket.Status switch
                        {
                            1 => "status-pending",  // Pending
                            2 => "status-answered", // Answered
                            3 => "status-closed",  // Closed
                            4 => "status-pending",  // Cleared
                            _ => "status-pending"
                        };

                        var statusText = ticket.Status switch
                        {
                            1 => "در انتظار",
                            2 => "پاسخ داده شده",
                            3 => "بسته شده",
                            4 => "پاک شده",
                            _ => "نامشخصوص"
                        };

                        <tr>
                            <td class="fw-bold text-dark">@ticket.Title</td>
                            <td>
                                <div class="user-pill">
                                    <div class="user-pill-avatar">@ticket.SenderName?.Substring(0, 1)</div>
                                    <span>@ticket.SenderName</span>
                                </div>
                            </td>
                            <td class="text-muted">@(ticket.GymName ?? "سیستم")</td>
                            <td><span class="status-badge @statusClass">@statusText</span></td>
                            <td class="text-muted small">@ticket.Date</td>
                            <td>
                                <a href="/Admin/SuperAdmin/TicketDetail/@ticket.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="fa fa-eye me-1"></i> بررسی
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="fa fa-inbox fa-2x d-block mb-2 opacity-25"></i>
                            هنوز تیکتیکی ثبت نشده است
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>