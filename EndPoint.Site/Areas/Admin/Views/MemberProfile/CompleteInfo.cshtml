@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @* <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script> *@

    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>


    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>

        function convertPersianToGregorian(selector) {

        var val = $(selector).val();
        if (!val) return;



        var p = new persianDate(val);
        var g = p.toCalendar('gregorian');

        var date =
        g.year + "-" +
        ("0" + g.month).slice(-2) + "-" +
        ("0" + g.day).slice(-2);

        $(selector).val(date);
        }


        $(document).ready(function () {
        // 1. مقداردهی تقویم‌های شمسی
        const datePickerConfig = {
        format: 'YYYY/MM/DD',
        autoClose: true,
        initialValue: false,
        observer: true,
        initialValueType: 'persian',
        calendar: { persian: { locale: 'en' }
        }
        };

        $("#BirthDate, #MembershipStartDate, #MembershipEndDate").persianDatepicker(datePickerConfig);

        
        
        
            // 2. هندل کردن ارسال فرم
            $("#CompleteInfoForm").on("submit", function (e) {
                e.preventDefault();

                var form = $(this);
                var btn = form.find("button[type='submit']");

                // جمع‌آوری فیلدهای متنی
                var textData = {
                    Id: $("#Id").val(),
                    FullName: $("#FullName").val(),
                    Mobile: $("#Mobile").val(),
                    Gender: parseInt($("#Gender").val()),
                    BirthDate: $("#BirthDate").val(),
                    ActivityLevelId: $("#ActivityLevelId").val(),
                    ExperienceLevelId: $("#ExperienceLevelId").val(),
                    Height: $("#Height").val(),
                    FoodAllergies: $("#FoodAllergies").val(),
                    MedicalConditions: $("#MedicalConditions").val(),
                    Injuries: $("#Injuries").val(),
                    Description: $("#Description").val()
                };

                // استفاده از FormData برای ارسال فایل همراه با متن
                var formData = new FormData();

                // اضافه کردن داده‌های متنی به FormData
                for (var key in textData) {
                    if (textData[key] !== null && textData[key] !== undefined) {
                        formData.append(key, textData[key]);
                    }
                }

                // اضافه کردن فایل‌ها به FormData
                var files = ['ProfileImageFile', 'VideoFile', 'BodyImageFile1', 'BodyImageFile2', 'BodyImageFile3'];
                files.forEach(function(fileId) {
                    var fileInput = document.getElementById(fileId);
                    if (fileInput.files && fileInput.files[0]) {
                        formData.append(fileId, fileInput.files[0]);
                    }
                });

                $.ajax({
                    url: '/Admin/MemberProfile/CompleteInfo',
                    type: 'POST',
                    data: formData,
                    contentType: false, // بسیار مهم برای FormData
                    processData: false, // بسیار مهم برای FormData
                    beforeSend: function () {
                        btn.prop("disabled", true).text("در حال آپلود و ذخیره...");
                    },
                    success: function (result) {
                        if (result.isSuccess) {
                            Swal.fire('موفق!', result.message, 'success').then(() => {
                                window.location.href = '/Admin/MemberDashboard';
                            });
                        } else {
                            Swal.fire('هشدار!', result.message, 'warning');
                        }
                    },



        error: function (xhr, status, error) {
                           // این خط خطای واقعی سرور را در کنسول مرورگر نشان می‌دهد
                           console.log("Server Error Details:", xhr.responseText);
                           Swal.fire('خطا!', 'جزئیات خطا: ' + (xhr.responseText || error), 'error');
                       },

                    complete: function () {
                        btn.prop("disabled", false).text("ذخیره اطلاعات");
                    }
                });
            });




    });

        // ....................
        function setMembershipValidityStyle(isExpired) {
        var $input = $("#MembershipValidity");

        $input.removeClass("bg-success bg-danger text-white");

        if (isExpired) {
        $input.addClass("bg-danger text-white");
        } else {
        $input.addClass("bg-success text-white");
        }
        }

        function calculateMembershipValidity() {

        var endDateValue = $("#MembershipEndDate").val();

        if (!endDateValue) {
        $("#MembershipValidity").val("");
        $("#MembershipValidity").removeClass("bg-success bg-danger text-white");
        return;
        }

        // انتظار فرمت: 1405/12/29
        var parts = endDateValue.split("/");

        if (parts.length !== 3) {
        $("#MembershipValidity").val("تاریخ نامعتبر");
        setMembershipValidityStyle(true);
        return;
        }

        var endYear = parseInt(parts[0], 10);
        var endMonth = parseInt(parts[1], 10);
        var endDay = parseInt(parts[2], 10);

        if (isNaN(endYear) || isNaN(endMonth) || isNaN(endDay)) {
        $("#MembershipValidity").val("تاریخ نامعتبر");
        setMembershipValidityStyle(true);
        return;
        }

        // ساخت درست تاریخ شمسی
        var endDate = new persianDate([endYear, endMonth, endDay]);

        // تاریخ امروز شمسی
        var today = new persianDate();

        var diffMs = endDate.valueOf() - today.valueOf();

        if (diffMs <= 0) {
        $("#MembershipValidity").val("منقضی شده");
        setMembershipValidityStyle(true);
        return;
        }

        // اختلاف تقریبی بر حسب روز
        var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

        var years = Math.floor(diffDays / 365);
        diffDays %= 365;

        var months = Math.floor(diffDays / 30);
        var days = diffDays % 30;

        var result = "";

        if (years > 0) result += years + " سال ";
        if (months > 0) result += months + " ماه ";
        if (days > 0) result += days + " روز";

        result = result.trim();

        $("#MembershipValidity").val(result || "امروز");
        setMembershipValidityStyle(false);
        }

        $(document).ready(function () {
        calculateMembershipValidity();
        });




        // -------------------
                    // تابع حذف فایل های آپلود شده
            function deleteMedia(mediaType, previewElementId) {
                Swal.fire({
                    title: 'حذف فایل',
                    text: "آیا از حذف این فایل از سرور اطمینان دارید؟",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'بله، حذف شود',
                    cancelButtonText: 'انصراف'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '/Admin/MemberProfile/DeleteMedia',
                            type: 'POST',
                            data: { mediaType: mediaType },
                            success: function (res) {
                                if (res.isSuccess) {
                                    // مخفی کردن کادر تصویر/ویدیو از روی فرم
                                    $("#" + previewElementId).fadeOut(300, function() {
                                        $(this).remove();
                                    });
                                    Swal.fire('حذف شد!', res.message, 'success');
                                } else {
                                    Swal.fire('خطا!', res.message, 'error');
                                }
                            },
                            error: function () {
                                Swal.fire('خطا!', 'مشکلی در ارتباط با سرور رخ داد', 'error');
                            }
                        });
                    }
                });
            }


    </script>
}
