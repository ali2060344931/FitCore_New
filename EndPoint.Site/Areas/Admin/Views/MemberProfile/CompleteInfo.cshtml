@using FitCore.Application.ViewModels.Common
@using FitCore.Common
@using FitCore.Common.Dto
@model FitCore.Application.Services.Members.Queries.GetMemberCompleteInfoDto

@{
    ViewData["Title"] = "تکمیل اطلاعات عضو";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">
       
        <input type="hidden"
               id="MembershipEndDate"
               value="@Model?.MembershipEndDate" />


        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"تکمیل اطلاعات پروفایل"' />

        <form id="CompleteInfoForm">
            <input type="hidden" name="Id" value="@Model?.Id" />

            <div class="row">
                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel { Id = "FullName", Name = "FullName", LabelName = Html.DisplayNameFor(m => m.FullName), Col = 3, Value = Model?.FullName, Disabled = false }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel { Id = "Mobile", Name = "Mobile", LabelName = Html.DisplayNameFor(m => m.Mobile), Col = 2, Value = Model?.Mobile, Disabled = false }' />

                <div class="col-md-1 mb-3">
                    <label asp-for="Gender" class="form-label font-weight-bold">@Html.DisplayNameFor(m => m.Gender)</label>
                    <select class="form-control" id="Gender" asp-for="Gender">
                        <option value="1">مرد</option>
                        <option value="2">زن</option>
                    </select>
                </div>

                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "BirthDate",
                             Name = "BirthDate",
                             LabelName = Html.DisplayNameFor(m => m.BirthDate),
                             Placeholder = "مثال: 1370/05/20",
                             Value = Model.BirthDate, // مقدار فعلی از دیتابیس برای فرم ویرایش
                             Col = 2,
                             Disabled = true
                         }' />


<partial name="~/Areas/Admin/Views/Shared/Partials/_DisplayDate.cshtml"
         model="Model?.MembershipStartDate"
         view-data='new ViewDataDictionary(ViewData) { { "Label", "تاریخ شروع عضویت" } }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_DisplayDate.cshtml"
                         model="Model?.MembershipEndDate"
                         view-data='new ViewDataDictionary(ViewData) { { "Label", "تاریخ پایان عضویت" } }' />


@* <div class="col-md-2 mb-3">
                    <label class="form-label font-weight-bold">مدت اعتبار عضویت</label>
                    <input type="text" id="MembershipValidity" class="form-control bg-light fw-bold" readonly />
                </div> *@

<div class="col-md-2 mb-3">
                    <label class="form-label font-weight-bold">مدت اعتبار عضویت</label>
                    <!-- کلاس text-center به اینجا اضافه شد -->
                    <input type="text" id="MembershipValidity" class="form-control bg-light fw-bold text-center" readonly />
                </div>





                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel { Id = "ActivityLevelId", Name = "ActivityLevelId", LabelName = "سطح فعالیت بدنی", Col = 3, Items = ViewBag.ActivityLevels, Value = Model?.ActivityLevelId?.ToString() }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel { Id = "ExperienceLevelId", Name = "ExperienceLevelId", LabelName = "سطح تجربه تمرینی", Col = 3, Items = ViewBag.ExperienceLevels, Value = Model?.ExperienceLevelId?.ToString() }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                         model='new BaseInputViewModel { Id = "Height", Name = "Height", LabelName = "قد (cm)", Col = 2, Value = Model?.Height.ToString() }' />
</div>

            <fieldset class="custom-groupbox mt-3">
                <legend>اطلاعات پزشکی و توضیحات</legend>
                <div class="row">
                    <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                             model='new BaseInputViewModel { Id = "FoodAllergies", Name = "FoodAllergies", LabelName = "حساسیت‌های غذایی", Col = 6, Value = Model?.FoodAllergies }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                             model='new BaseInputViewModel { Id = "MedicalConditions", Name = "MedicalConditions", LabelName = "بیماری‌ها / شرایط پزشکی", Col = 6, Value = Model?.MedicalConditions }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                             model='new BaseInputViewModel { Id = "Injuries", Name = "Injuries", LabelName = "سوابق آسیب‌دیدگی", Col = 6, Value = Model?.Injuries }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                             model='new BaseInputViewModel { Id = "Description", Name = "Description", LabelName = "توضیحات", Col = 6, Value = Model?.Description }' />

                    @*                     <partial name="~/Areas/Admin/Views/Shared/Partials/_CheckboxInput.cshtml"
                             model='new BaseInputViewModel { Id = "IsActive", Name = "IsActive", LabelName = "عضویت فعال", Col = 2, Value = Model == null || Model.IsActive ? "true" : "false" }' />
 *@
                    <div class="col-md-3">
                        @* نکته: آیدی btnSave را به پارشیال اضافه کردیم یا می‌توانید در اسکریپت به دکمه داخل فرم اشاره کنید *@
                        <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                                 model='new FormButtonsViewModel { SubmitText = "ذخیره اطلاعات", BackUrl = "/Admin", BackText = "بازگشت" }' />
                    </div>
                </div>
            </fieldset>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>
    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>

        function convertPersianToGregorian(selector) {

        var val = $(selector).val();
        if (!val) return;



        var p = new persianDate(val);
        var g = p.toCalendar('gregorian');

        var date =
        g.year + "-" +
        ("0" + g.month).slice(-2) + "-" +
        ("0" + g.day).slice(-2);

        $(selector).val(date);
        }


        $(document).ready(function () {
        // 1. مقداردهی تقویم‌های شمسی
        const datePickerConfig = {
        format: 'YYYY/MM/DD',
        autoClose: true,
        initialValue: false,
        observer: true,
        initialValueType: 'persian',
        calendar: { persian: { locale: 'en' }
        }
        };

        $("#BirthDate, #MembershipStartDate, #MembershipEndDate").persianDatepicker(datePickerConfig);

        // 2. هندل کردن ارسال فرم
        $("#CompleteInfoForm").on("submit", function (e) {
        e.preventDefault();



        var form = $(this);
        var btn = form.find("button[type='submit']");
        var formData = form.serialize();

        $.ajax({
        url: '/Admin/MemberProfile/CompleteInfo',
        type: 'POST',
        data: formData,
        beforeSend: function () {
        btn.prop("disabled", true).text("در حال ذخیره...");
        },
        success: function (result)
        {
        if (result.isSuccess) {
        Swal.fire('موفق!', result.message, 'success').then(() => {
        window.location.href = '/Admin'; // یا مسیر دلخواه
        });
        } else {
        Swal.fire('هشدار!', result.message, 'warning');
        }
        },
        error: function () {
        Swal.fire('خطا!', 'مشکلی در ارتباط با سرور رخ داده است', 'error');
        },
        complete: function () {
        btn.prop("disabled", false).text("ذخیره اطلاعات");
        }
        });
        });
        });

        // ....................
        function setMembershipValidityStyle(isExpired) {
        var $input = $("#MembershipValidity");

        $input.removeClass("bg-success bg-danger text-white");

        if (isExpired) {
        $input.addClass("bg-danger text-white");
        } else {
        $input.addClass("bg-success text-white");
        }
        }

        function calculateMembershipValidity() {

        var endDateValue = $("#MembershipEndDate").val();

        if (!endDateValue) {
        $("#MembershipValidity").val("");
        $("#MembershipValidity").removeClass("bg-success bg-danger text-white");
        return;
        }

        // انتظار فرمت: 1405/12/29
        var parts = endDateValue.split("/");

        if (parts.length !== 3) {
        $("#MembershipValidity").val("تاریخ نامعتبر");
        setMembershipValidityStyle(true);
        return;
        }

        var endYear = parseInt(parts[0], 10);
        var endMonth = parseInt(parts[1], 10);
        var endDay = parseInt(parts[2], 10);

        if (isNaN(endYear) || isNaN(endMonth) || isNaN(endDay)) {
        $("#MembershipValidity").val("تاریخ نامعتبر");
        setMembershipValidityStyle(true);
        return;
        }

        // ساخت درست تاریخ شمسی
        var endDate = new persianDate([endYear, endMonth, endDay]);

        // تاریخ امروز شمسی
        var today = new persianDate();

        var diffMs = endDate.valueOf() - today.valueOf();

        if (diffMs <= 0) {
        $("#MembershipValidity").val("منقضی شده");
        setMembershipValidityStyle(true);
        return;
        }

        // اختلاف تقریبی بر حسب روز
        var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

        var years = Math.floor(diffDays / 365);
        diffDays %= 365;

        var months = Math.floor(diffDays / 30);
        var days = diffDays % 30;

        var result = "";

        if (years > 0) result += years + " سال ";
        if (months > 0) result += months + " ماه ";
        if (days > 0) result += days + " روز";

        result = result.trim();

        $("#MembershipValidity").val(result || "امروز");
        setMembershipValidityStyle(false);
        }

        $(document).ready(function () {
        calculateMembershipValidity();
        });
    </script>
}
