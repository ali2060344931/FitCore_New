                            @if (!string.IsNullOrEmpty(Model?.BodyImageUrl1))
                            {
                                <div id="preview-BodyImage1" style="position:relative; display:inline-block; margin-top:8px;">
                                    <img src="@Model.BodyImageUrl1" class="rounded" style="max-height: 80px;" alt="عکس بدن ۱" />
                                    <button type="button" class="btn btn-danger btn-sm" style="position:absolute; top:-5px; right:-5px; border-radius:50%; padding: 2px 6px; font-size:10px; line-height:1;" onclick="deleteMedia('BodyImage1', 'preview-BodyImage1')">
