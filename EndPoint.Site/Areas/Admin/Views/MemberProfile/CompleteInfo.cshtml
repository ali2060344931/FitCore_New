                                    <button type="button" class="btn btn-danger btn-sm" style="position:absolute; top:-5px; right:-5px; border-radius:50%; padding: 2px 6px; font-size:10px; line-height:1;" onclick="deleteMedia('BodyImage3', 'preview-BodyImage3')">
