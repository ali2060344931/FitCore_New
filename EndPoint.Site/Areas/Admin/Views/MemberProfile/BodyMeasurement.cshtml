@using System.Linq
@using System.Security.Claims
@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.Services.Members.Queries
@using FitCore.Common

@model ResultGetMemberBodyMeasurementsDto

@{
    var pagingVm = new PagingPartialViewModel
    {
        RowCount = Model.RowCount,
        CurrentPage = Model.CurrentPage,
        PageSize = Model.PageSize,
        PageQueryKey = "page",
        PageSizeQueryKey = "PageSize"
    };
}
@{
    long? userId = null;

    if (ViewBag.MemberId != null)
    {
        userId = (long)ViewBag.MemberId;
    }
    else
    {
        var userIdClaim = User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (!string.IsNullOrEmpty(userIdClaim))
        {
            userId = long.Parse(userIdClaim);
        }
    }

    var encryptedMemberId = userId.HasValue
        ? userId.Value.ToString() : "";
}
@{
    ViewData["Title"] = "اندازه گیری های بدن";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var searchKey = Context.Request.Query["SearchKey"].ToString();
    var isFiltered = !string.IsNullOrWhiteSpace(searchKey);
}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="fc-page-header">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"لیست اندازه گیری های بدن  : " + @ViewBag.FullName_Mobile' />

        <a asp-area="Admin"
           asp-controller="MemberProfile"
           asp-action="AddBodyMeasurement"
           @* asp-route-memberId="@SecurityUtils.EncryptId(Convert.ToInt64( encryptedMemberId))" *@
           asp-route-id="00000"
           class="btn btn-success">

            + ثبت اندازه جدید
        </a>

    </div>

    <!-- Search -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_SearchBox.cshtml"
             model="searchKey" />

    <!-- Card -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardStart.cshtml" />

    <div class="mb-3">

        تعداد کل رکورد ها :

        <strong>
            @Model.RowCount
        </strong>

        @if (isFiltered)
        {
            <span class="ms-2">
                (نتایج فیلتر: <strong>@Model.Measurements.Count</strong>)
            </span>

            <a asp-area="Admin"
               asp-controller="Members"
               asp-action="BodyMeasurements"
               asp-route-memberId="@ViewBag.MemberId"
               class="btn btn-warning btn-sm ms-2">

                نمایش همه (@Model.RowCount)

            </a>
        }

    </div>

    @if (Model.Measurements != null && Model.Measurements.Any())
    {
        <table class="table table-striped table-hover">

            <thead>
                <tr>
                    <th>تاریخ ثبت</th>
                    <th>وزن (kg)</th>
                    <th>درصد چربی</th>
                    <th>دور کمر</th>
                    <th>دور باسن</th>
                    <th>دور سینه</th>
                    <th>عملیات</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model.Measurements)
                {
                    <tr>

                        <td>
                            <strong style="color:#0d6efd;">
                                @item.RecordDate
                            </strong>
                        </td>

                        <td>@item.Weight</td>

                        <td>@item.BodyFatPercentage</td>

                        <td>@item.Waist</td>

                        <td>@item.Hip</td>

                        <td>@item.Chest</td>

                        <td>

                            <div class="fc-action-buttons">

                                <a class="btn btn-info btn-sm"
                                   asp-area="Admin"
                                   asp-controller="MemberProfile"
                                   asp-action="EditBodyMeasurement"
                                   asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                    ویرایش
                                </a>

                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        onclick="deleteMeasurement('@SecurityUtils.EncryptId(item.Id)')">
                                    حذف
                                </button>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

        <partial name="~/Areas/Admin/Views/Shared/Partials/_Paging.cshtml"
                 model="pagingVm" />

    }
    else
    {
        <partial name="~/Areas/Admin/Views/Shared/Partials/_EmptyState.cshtml"
                 model='"هیچ رکوردی ثبت نشده است"' />
    }

    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardEnd.cshtml" />

</div>


@section Scripts
{

    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <script>

        function deleteMeasurement(id) {

        Swal.fire({
        title: 'حذف اندازه گیری',
        text: "آیا از حذف این رکورد مطمئن هستید؟",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#7cacbe',
        confirmButtonText: 'بله، حذف شود',
        cancelButtonText: 'خیر'
        }).then((result) => {

        if (result.value) {

        $.ajax({

        contentType: 'application/x-www-form-urlencoded',
        dataType: 'json',
        type: "POST",
        url: "/Admin/MemberProfile/deleteMeasurement",
        data: { Id: id },

        success: function (data) {

        if (data.isSuccess === true) {

        Swal.fire('موفق!', data.message, 'success')
        .then(function () { location.reload(); });

        }
        else {

        Swal.fire('هشدار!', data.message, 'warning');

        }

        },

        error: function () {

        Swal.fire('خطا!', 'مشکلی در ارتباط با سرور رخ داده است', 'error');

        }

        });

        }

        });

        }

    </script>

}
