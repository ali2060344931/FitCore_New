@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.ViewModels.Common

@model TrainingProgramCreateEditViewModel

@{
    bool isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "ویرایش برنامه تمرینی" : "ثبت برنامه تمرینی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='@(isEdit ? "ویرایش برنامه تمرینی" : "ثبت برنامه تمرینی")' />

        <form id="TrainingProgramForm">
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />
            <input type="hidden" id="MemberId" name="MemberId" value="@Model.MemberId" />

            <div class="mb-3">
                <label class="form-label">مشخصات ورزشکار (عضو)</label>
                <div class="form-control d-inline-block bg-dark text-white border-0"
                     style="width: fit-content;">
                    @(ViewBag.MemberName + " - " + ViewBag.MemberMobile)
                </div>
            </div>

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Title",
                             Name = "Title",
                             Value = Model.Title,
                             LabelName = Html.DisplayNameFor(m => m.Title),
                             Placeholder = "مثلاً: برنامه ۸ هفته‌ای حجم",
                             Col = 4
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "TrainingProgramTypeId",
                             Name = "TrainingProgramTypeId",
                             LabelName = "نوع برنامه تمرینی",
                             Col = 2,
                             Items = ViewBag.TrainingProgramTypes,
                             Value = Model.TrainingProgramTypeId.ToString()
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "TrainingGoalTypeId",
                             Name = "TrainingGoalTypeId",
                             LabelName = "هدف تمرینی",
                             Col = 2,
                             Items = ViewBag.TrainingGoalTypes,
                             Value = Model.TrainingGoalTypeId.ToString()
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "SessionsPerWeek",
                             Name = "SessionsPerWeek",
                             Value = Model.SessionsPerWeek?.ToString(),
                             LabelName = "تعداد جلسات در هفته",
                             Placeholder = "مثلاً: 4",
                             Col = 2
                         }' />

            </div>

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "StartDate",
                             Name = "StartDate",
                             Value = Model.StartDate,
                             LabelName = Html.DisplayNameFor(m => m.StartDate),
                             Placeholder = Html.DisplayNameFor(m => m.StartDate),
                             Col = 2
                         }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "EndDate",
                             Name = "EndDate",
                             Value = Model.EndDate,
                             LabelName = Html.DisplayNameFor(m => m.EndDate),
                             Placeholder = Html.DisplayNameFor(m => m.EndDate),
                             Col = 2
                         }' />

            </div>

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextArea.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "Description",
                             Name = "Description",
                             Value = Model.Description,
                             LabelName = Html.DisplayNameFor(m => m.Description),
                             Placeholder = Html.DisplayNameFor(m => m.Description),
                             Col = 6
                         }' />

                <div class="col-md-1 mb-3">
                    <label class="form-label font-weight-bold">فعال</label>
                    <select id="IsActive" name="IsActive" class="form-control">
                        @if (Model.IsActive)
                        {
                            <option value="true" selected>بله</option>
                            <option value="false">خیر</option>
                        }
                        else
                        {
                            <option value="true">بله</option>
                            <option value="false" selected>خیر</option>
                        }
                    </select>
                </div>

            </div>

            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                     model='new FormButtonsViewModel
                     {
                         SubmitText = isEdit ? "ذخیره تغییرات" : "ثبت برنامه تمرینی",
                         BackUrl = "/Admin/TrainingProgram",
                         BackText = "انصراف و بازگشت"
                     }' />
        </form>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>

    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {

            // تبدیل ارقام فارسی/عربی به انگلیسی
            function toEnglishDigits(str) {
                if (!str) return str;

                const map = {
                    '۰': '0', '۱': '1', '۲': '2', '۳': '3', '۴': '4',
                    '۵': '5', '۶': '6', '۷': '7', '۸': '8', '۹': '9',
                    '٠': '0', '١': '1', '٢': '2', '٣': '3', '٤': '4',
                    '٥': '5', '٦': '6', '٧': '7', '٨': '8', '٩': '9'
                };

                return str.replace(/[۰-۹٠-٩]/g, function (d) {
                    return map[d] || d;
                });
            }

            // راه‌اندازی تاریخ‌ساز شمسی
            $("#StartDate").persianDatepicker({
                format: 'YYYY/MM/DD',
                autoClose: true,
                initialValue: true,
                initialValueType: 'persian',
                observer: true
            });

            $("#EndDate").persianDatepicker({
                format: 'YYYY/MM/DD',
                autoClose: true,
                initialValue: true,
                initialValueType: 'persian',
                observer: true
            });

            const isEdit = @(isEdit ? "true" : "false");

            // ارسال فرم
            $("#TrainingProgramForm").on("submit", function (e) {
                e.preventDefault();

                const url = isEdit
                    ? "/Admin/TrainingProgram/Edit"
                    : "/Admin/TrainingProgram/Create";

                const data = {
                    Id: parseInt($("#Id").val(), 10) || 0,
                    MemberId: parseInt($("#MemberId").val(), 10) || 0,
                    Title: $("#Title").val(),
                    Description: $("#Description").val(),
                    TrainingProgramTypeId: parseInt($("#TrainingProgramTypeId").val(), 10) || 0,
                    TrainingGoalTypeId: parseInt($("#TrainingGoalTypeId").val(), 10) || 0,
                    SessionsPerWeek: $("#SessionsPerWeek").val() ? parseInt($("#SessionsPerWeek").val(), 10) : null,
                    StartDate: toEnglishDigits($("#StartDate").val()),
                    EndDate: toEnglishDigits($("#EndDate").val()),
                    IsActive: $("#IsActive").val() === "true"
                };

                $.ajax({
                    type: "POST",
                    url: url,
                    data: data,

                    success: function (response) {
                        if (response.isSuccess) {

                            Swal.fire({
                                icon: 'success',
                                title: 'موفق',
                                text: response.message,
                                confirmButtonText: 'ادامه'
                            }).then(function () {

                                // فقط در حالت ثبت جدید: انتقال به صفحه برنامه‌ساز
                                if (!isEdit && response.redirectUrl) {
                                    window.location.href = response.redirectUrl;
                                } else {
                                    window.location.href = "/Admin/TrainingProgram";
                                }

                            });

                        } else {
                            Swal.fire({
                                icon: 'warning',
                                title: 'خطا',
                                text: response.message
                            });
                        }
                    },

                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'خطا',
                            text: 'خطا در ارتباط با سرور'
                        });
                    }
                });
            });

        });
    </script>
}
