@using EndPoint.Site.Areas.Admin.Models.Foods
@using FitCore.Application.ViewModels.Common
@using FitCore.Common
@model FoodCreateEditViewModel

@{
    bool isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "ویرایش غذا" : "ثبت غذای جدید";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">
        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='(isEdit ? "ویرایش غذا" : "ثبت غذای جدید")' />

        <form id="FoodForm">
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />

            <div class="row align-items-end">
                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel { Id = "Title", Name = "Title", LabelName = "نام (عنــوان) غذا", Col = 3, Value = Model.Title }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel { Id = "CategoryTypeId", Name = "CategoryTypeId", LabelName = "دسته‌بندی(گــروه)", Col = 2, Items = ViewBag.foodCategoryTypes, Value = Model.CategoryTypeId.ToString() }' />

                <partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
                         model='new BaseInputViewModel { Id = "DefaultUnitId", Name = "DefaultUnitId", LabelName = "واحد اندازه‌گیری", Col = 2, Items = ViewBag.foodUnitTypes, Value = Model.DefaultUnitId.ToString() }' />

                <div class="col-md-3">
                    <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                             model='new FormButtonsViewModel { SubmitText = isEdit ? "ذخیره تغییرات" : "ثبت غذا", BackUrl = "/Admin/Food", BackText = "انصراف و بازگشت" }' />
                </div>
            </div>

            <fieldset class="custom-groupbox mt-3">
                <legend>اطلاعات تکمیلی</legend>
                <div class="row">
                    <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                             model='new BaseInputViewModel { Id = "EnglishTitle", Name = "EnglishTitle", LabelName = "نام (عبارت)انگلیسی", Col = 3, Value = Model.EnglishTitle }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                             model='new BaseInputViewModel { Id = "CaloriesPerUnit", Name = "CaloriesPerUnit", LabelName = "کالری", Col = 1, Value = Model.CaloriesPerUnit.ToString() }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                             model='new BaseInputViewModel { Id = "ProteinPerUnit", Name = "ProteinPerUnit", LabelName = "پروتئین", Col = 1, Value = Model.ProteinPerUnit.ToString() }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                             model='new BaseInputViewModel { Id = "CarbohydratePerUnit", Name = "CarbohydratePerUnit", LabelName = "کربوهیدرات", Col = 1, Value = Model.CarbohydratePerUnit.ToString() }' />

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
                             model='new BaseInputViewModel { Id = "FatPerUnit", Name = "FatPerUnit", LabelName = "چربی", Col = 1, Value = Model.FatPerUnit.ToString() }' />

                    <div class="col-md-1 mb-3">
                        <label class="form-label font-weight-bold">وضعیت</label>
                        <select id="IsActive" name="IsActive" class="form-control">
                            <option value="true" selected="@(Model.IsActive ? "selected" : null)">فعال</option>
                            <option value="false" selected="@(!Model.IsActive ? "selected" : null)">غیرفعال</option>
                        </select>
                    </div>
                </div>
            </fieldset>

            @* --- فیلدست جدید برای ضرایب تبدیل --- *@
            <fieldset class="custom-groupbox mt-3">
                <legend>واحدهای اندازه‌گیری جایگزین و ضرایب تبدیل</legend>
                <p class="text-muted small mb-3">
                    <i class="fa fa-info-circle"></i>
                    مقادیر بالا بر اساس واحد پیش‌فرض (مثلاً گرم) ثبت می‌شوند. اگر می‌خواهید کاربر بتواند از واحدهای دیگر (مثل پیمانه، قاشق و...) استفاده کند، اینجا ضریب تبدیل آن‌ها را وارد کنید.
                    <br>مثال: واحد پیش‌فرض «گرم» است. در اینجا واحد «پیمانه» را انتخاب کنید و بنویسید 180 (یعنی 1 پیمانه معادل 180 گرم است).
                </p>

                <button type="button" id="btnAddConversion" class="btn btn-sm btn-outline-info mb-3">
                    <i class="fa fa-plus"></i> افزودن واحد تبدیل
                </button>

                <table class="table table-sm table-bordered" id="conversionTable" style="display:none;">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 40%">واحد اندازه‌گیری</th>
                            <th style="width: 40%">ضریب تبدیل (معادل چند واحد پیش‌فرض)</th>
                            <th style="width: 20%">عملیات</th>
                        </tr>
                    </thead>
                    <tbody id="conversionTableBody">
                        <!-- ردیف‌ها به صورت داینامیک اینجا اضافه می‌شوند -->
                    </tbody>
                </table>
            </fieldset>
            @* ------------------------------------ *@
        </form>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>

    <script>
        function initSelect2(selector, options = {}) {
            const $el = $(selector);
            if (!$el.length) return;
            if ($el.hasClass('select2-hidden-accessible')) $el.select2('destroy');

            $el.select2({
                dir: 'rtl', width: '100%', language: 'fa', theme: 'bootstrap4',
                placeholder: 'انتخاب کنید', allowClear: true, ...options
            });
        }

        // تبدیل لیست ViewBag به آرایه جاوااسکریپتی برای استفاده در سطرهای داینامیک
        var unitsList = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.foodUnitTypes));

        function addConversionRow(unitId = '', factor = '') {
            let optionsHtml = '<option value="">انتخاب واحد...</option>';
            unitsList.forEach(function(item) {
                optionsHtml += `<option value="${item.Value}" ${item.Value == unitId ? 'selected' : ''}>${item.Text}</option>`;
            });

            let rowHtml = `
                <tr class="conversion-row">
                    <td>
                        <select class="form-control conv-unit" name="convUnit">
                            ${optionsHtml}
                        </select>
                    </td>
                    <td>
                        <input type="number" class="form-control conv-factor" name="convFactor" value="${factor}" step="0.01" min="0" placeholder="مثلاً 180" />
                    </td>
                    <td class="text-center">
                        <button type="button" class="btn btn-danger btn-sm btn-remove-conv">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                </tr>
            `;

            $('#conversionTableBody').append(rowHtml);
            initSelect2('#conversionTableBody tr:last .conv-unit');
            $('#conversionTable').show();
        }

        $(document).ready(function () {
            initSelect2('#CategoryTypeId');
            initSelect2('#DefaultUnitId');

            // لود کردن ضرایب موجود در حالت ویرایش
            @if (Model.Conversions != null)
            {
                    foreach (var conv in Model.Conversions)
                    {
                            @:addConversionRow('@conv.UnitTypeId', '@conv.ConversionFactor');
                    }
            }

            // رویداد دکمه افزودن
            $('#btnAddConversion').on('click', function() {
                addConversionRow();
            });

            // رویداد حذف سطر
            $(document).on('click', '.btn-remove-conv', function() {
                $(this).closest('tr').remove();
                if ($('#conversionTableBody tr').length === 0) {
                    $('#conversionTable').hide();
                }
            });

            $("#Title").focus();

            $(document).on("click", "#btnSubmit, button[type='submit'], input[type='submit']", function (e) {
                e.preventDefault();

                const isEdit = @(isEdit ? "true" : "false");
                const url = isEdit ? "/Admin/Food/Edit" : "/Admin/Food/Create";

                // جمع‌آوری ضرایب تبدیل به صورت آرایه JSON
                let conversions = [];
                $('#conversionTableBody tr').each(function() {
                    let uId = parseInt($(this).find('.conv-unit').val());
                    let fVal = parseFloat($(this).find('.conv-factor').val());
                    if (uId > 0 && fVal > 0) {
                        conversions.push({ UnitTypeId: uId, ConversionFactor: fVal });
                    }
                });

                const data = {
                    Id: parseInt($("#Id").val()) || 0,
                    Title: $("#Title").val()?.trim(),
                    EnglishTitle: $("#EnglishTitle").val()?.trim(),
                    CategoryTypeId: parseInt($("#CategoryTypeId").val()) || 0,
                    CaloriesPerUnit: parseFloat($("#CaloriesPerUnit").val()) || 0,
                    ProteinPerUnit: parseFloat($("#ProteinPerUnit").val()) || 0,
                    CarbohydratePerUnit: parseFloat($("#CarbohydratePerUnit").val()) || 0,
                    FatPerUnit: parseFloat($("#FatPerUnit").val()) || 0,
                    DefaultUnitId: parseInt($("#DefaultUnitId").val()) || 0,
                    IsActive: $("#IsActive").val() === "true",
                    Conversions: conversions // ارسال لیست ضرایب به کنترلر
                };

                $.ajax({
                    type: "POST",
                    url: url,
                    data: data,
                    success: function (response) {
                        if (response && response.isSuccess) {
                            Swal.fire({
                                icon: 'success', title: 'موفق',
                                text: response.message || 'عملیات با موفقیت انجام شد',
                                confirmButtonText: 'ادامه'
                            }).then(function () {
                                if (isEdit) {
                                    window.location.href = "/Admin/Food/index";
                                } else {
                                    window.location.reload();
                                }
                            });
                        } else {
                            Swal.fire({
                                icon: 'warning', title: 'خطا',
                                text: response?.message || 'خطا در انجام عملیات',
                                confirmButtonText: 'متوجه شدم'
                            }).then(() => {
                                $("#Title").focus().select();
                            });
                        }
                    },
                    error: function (xhr) {
                        console.log(xhr.responseText);
                        Swal.fire({
                            icon: 'error', title: 'خطای سیستمی',
                            text: 'خطا در ارتباط با سرور',
                            confirmButtonText: 'بستن'
                        });
                    }
                });
            });
        });
    </script>
}