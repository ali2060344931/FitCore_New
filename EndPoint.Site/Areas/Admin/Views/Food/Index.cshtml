@using EndPoint.Site.Areas.Admin.Models
@using FitCore.Application.Services.Foods.Queries
@using FitCore.Common
@using System.Linq

@model ResultGetFoodsDto
@* @model EndPoint.Site.Areas.Admin.Models.NutritionProgramBuilderPageViewModel *@



@{
    var pagingVm = new PagingPartialViewModel
    {
        RowCount = Model.RowCount,
        CurrentPage = Model.CurrentPage,
        PageSize = Model.PageSize,
        PageQueryKey = "page",

        PageSizeQueryKey = "PageSize"
    };

}
<!-- برای صفحه بندی لیست -->
@{
    ViewData["Title"] = "لیست غــذاها";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var searchKey = Context.Request.Query["SearchKey"].ToString();
    var isFiltered = !string.IsNullOrWhiteSpace(searchKey);

}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="fc-page-header">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"لیست غـــذاها"' />

        <a asp-area="Admin"
           asp-controller="Food"
           asp-action="Create"
           class="btn btn-success">

            + ثبت غذای جدید
        </a>

    </div>

    <!-- Search Box -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_SearchBox.cshtml"
             model="searchKey" />

    <!-- Card -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardStart.cshtml" />

    <div class="mb-3">

        تعداد کل برنامه :

        <strong>
            @Model.RowCount
        </strong>

        @if (isFiltered)
        {
            <span class="ms-2">
                (نتایج فیلتر: <strong>@Model.Foods.Count</strong>)
            </span>

            <a href="/Admin/Members" class="btn btn-warning btn-sm ms-2">
                نمایش همه (@Model.RowCount)
            </a>
        }

    </div>
    @if (Model.Foods != null && Model.Foods.Any())
    {
        <table class="table table-striped table-hover">

            <thead>
                <tr>
                    <th>عنوان غذا</th>
                    <th>عنوان انگلیسی</th>
                    <th>دسته‌بندی ماده غذایی</th>
                    <th>واحد پیش‌فرض</th>
                    <th>کالری در واحد</th>
                    <th>پروتئین در واحد</th>
                    <th>کربوهیدرات در واحد</th>
                    <th>چربی در واحد</th>
                    <th>فعال</th>
                    <th>عملیات</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Foods)
                {
                    <tr>
                        <td>
                                <strong style="color:#0d6efd;">@item.Title</strong>
                        </td>

                        
                        <td>
                            @item.EnglishTitle
                        </td>

                        <td>@item.CategoryTypeName</td>
                        
                        <td>@item.DefaultUnitName</td>

                        
                        
                        <td>@item.CaloriesPerUnit</td>


                        <td>
                            @item.ProteinPerUnit
                        </td>
                        <td>
                            @item.CaloriesPerUnit
                        </td>
                        <td>
                            @item.FatPerUnit
                        </td>


                        <td>
                            @(item.IsActive == true ? "بله" : "خیر")
                        </td>


                        <td>
                            <div class="fc-action-buttons">
                                
                                @* <a class="btn btn-primary btn-sm"
                                   asp-area="Admin"
                                   asp-controller="NutritionProgramBuilder"
                                   asp-action="Index"
                                   asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                    مشاهده فرم برنامه
                                </a> *@


                                <a class="btn btn-info btn-sm"
                                   asp-area="Admin"
                                   asp-controller="Food"
                                   asp-action="Edit"
                                   asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                    ویرایش
                                </a>


                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        onclick="foodPr('@SecurityUtils.EncryptId(item.Id)')">
                                    حذف
                                </button>

                            </div>
                        </td>
                    </tr>
                }

   
            
            
            </tbody>

        </table>
        <partial name="~/Areas/Admin/Views/Shared/Partials/_Paging.cshtml" model="pagingVm" />
    }
    else
    {
        <partial name="~/Areas/Admin/Views/Shared/Partials/_EmptyState.cshtml"
                 model='"هیچ غذایی یافت نشد"' />
    }

    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardEnd.cshtml" />

</div>

@section Scripts
{
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

