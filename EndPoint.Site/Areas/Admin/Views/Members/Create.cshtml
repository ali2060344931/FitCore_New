@* @using FitCore.Application.Services.Members.Commands.AddNewMember *@
@using FitCore.Application.Services.Members.Commands
@* @using FitCore.Domain.Entities.Members *@

@model RequestAddNewMemberDto

@{
    ViewData["Title"] = "افزودن عضو";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="content-wrapper">

    <section class="content-header">

        <div class="container-fluid">

            <div class="row mb-2">

                <div class="col-sm-6">
                    <h1>افزودن عضو جدید</h1>
                </div>

            </div>

        </div>

    </section>

    <section class="content">

        <div class="container-fluid">

            <div class="card card-primary">

                <div class="card-header">

                    <h3 class="card-title">
                        اطلاعات عضو
                    </h3>

                </div>

                <form id="CreateMemberForm">

                    <div class="card-body">

                        <div class="form-group">

                            <label>نام</label>
                            <input type="text" class="form-control" id="FirstName" />
                        </div>

                        <div class="form-group">

                            <label>نام خانوادگی</label>

                            <input type="text"
                                   class="form-control"
                                   id="LastName" />

                        </div>

                        <div class="form-group">

                            <label>موبایل</label>

                            <input type="text"
                                   class="form-control"
                                   id="Mobile" />

                        </div>

                        <div class="form-group">

                            <label>جنسیت</label>

                            <select class="form-control"
                                    id="Gender">

                                <option value="0">
                                    مرد
                                </option>

                                <option value="1">
                                    زن
                                </option>

                            </select>

                        </div>

                        <div class="form-group">

                            <label>تاریخ تولد</label>

                            <input type="date"
                                   class="form-control"
                                   id="BirthDate" />

                        </div>

                    </div>

                    <div class="card-footer">

                        <button type="button"
                                onclick="CreateMember()"
                                class="btn btn-primary">
                            ثبت عضو
                        </button>

                    </div>

                </form>

            </div>

        </div>

    </section>

</div>

@section Scripts {
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <partial name="_ValidationScriptsPartial" />



    <script>

        function CreateMember() {

        var data = {

        GymId: 2,
        FirstName: $("#FirstName").val(),
        LastName: $("#LastName").val(),
        Mobile: $("#Mobile").val(),
        Gender: parseInt($("#Gender").val()),
        BirthDate: $("#BirthDate").val()
        };

        $.ajax({

        type: "POST",
        url: "/Admin/Members/Create",
        data: data,

        success: function (data) {

        if (data.isSuccess == true) {

        swal.fire(
        'موفق!',
        data.message,
        'success'
        ).then(function () {

        window.location.href = '/Admin/Members';
        });
        }
        else {

        swal.fire(
        'هشدار!',
        data.message,
        'warning'
        );
        }
        },

        error: function (request) {

        alert(request.responseText);
        }

        });
        }

    </script>

}