@using FitCore.Application.Services.Members.Commands
@using FitCore.Application.ViewModels.Common

@model RequestAddNewMemberDto

@{
    ViewData["Title"] = "ثبت عضو جدید";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">

    <div class="fc-form-container">

        <!-- Title -->
        <h2 class="fc-form-title">
            ثبت عضو جدید
        </h2>

        <!-- Form -->
        <form id="CreateMemberForm">

            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "FirstName",
                             Name = "FirstName",
                             LabelName = @Html.DisplayNameFor(m => m.FirstName),
                             Placeholder = @Html.DisplayNameFor(m => m.FirstName),
                             Col = 6
                         }' />

<partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "LastName",
             Name = "LastName",
             LabelName = @Html.DisplayNameFor(m => m.LastName),
             Placeholder = @Html.DisplayNameFor(m => m.LastName),
             Col = 6
         }' />

<partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "Mobile",
             Name = "Mobile",
             LabelName = @Html.DisplayNameFor(m => m.Mobile),
             Placeholder = @Html.DisplayNameFor(m => m.Mobile),
             Col = 6
         }' />

<div class="col-md-6 mb-3">
                    <label asp-for="Gender">@Html.DisplayNameFor(m => m.Gender)</label>
                    <select class="form-control" id="Gender" asp-for="Gender">
                        <option value="0">مرد</option>
                        <option value="1">زن</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="BirthDate">@Html.DisplayNameFor(m => m.BirthDate)</label>
                    <!-- تغییر به text و اضافه کردن کلاس برای شناسایی -->
                    <input type="text" class="form-control date-picker-input" id="BirthDate" readonly />
                    <!-- یک فیلد مخفی برای ارسال تاریخ به سرور (در قالب میلادی یا رشته‌ای که سرور قبول می‌کند) -->
                    <input type="hidden" id="BirthDateHidden" asp-for="BirthDate" />
                </div>

            </div>

            <!-- Buttons -->
            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml" />
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- SweetAlert2 -->
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <!-- Persian Datepicker -->
    <link href="~/AdminTemplate/app-assets/css/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/AdminTemplate/app-assets/js/persian-date.min.js"></script>
    <script src="~/AdminTemplate/app-assets/js/persian-datepicker.min.js"></script>

    <script>
        $(document).ready(function() {
        // فعال‌سازی تقویم
        $(".date-picker-input").pDatepicker({
        initialValue: false,
        format: 'YYYY/MM/DD',
        altField: '#BirthDateHidden',
        altFormat: 'YYYY/MM/DD',
        observer: true,
        autoClose: true
        });

        // ارسال فرم
        $("#CreateMemberForm").submit(function (e) {
        e.preventDefault();

        // اگر فرم Validation سمت کلاینت ندارد، اینجا چک کنید
        if (!$(this).valid()) return;

        var data = {
        GymId: 2, // حتما در آینده این را از مدل یا کلیم‌ها بگیرید
        FirstName: $("#FirstName").val(),
        LastName: $("#LastName").val(),
        Mobile: $("#Mobile").val(),
        Gender: parseInt($("#Gender").val()),
        // اصلاح: خواندن مقدار از فیلد مخفی
        BirthDate: $("#BirthDateHidden").val()
        };

        $.ajax({
        type: "POST",
        url: "/Admin/Members/Create",
        data: data,
        beforeSend: function() {
        // اختیاری: غیرفعال کردن دکمه ثبت برای جلوگیری از دابل کلیک
        },
        success: function (response) {
        if (response.isSuccess) {
        Swal.fire({
        icon: 'success',
        title: 'موفق',
        text: response.message,
        confirmButtonText: 'تأیید'
        }).then(() => {
        window.location.href = "/Admin/Members";
        });
        } else {
        Swal.fire({
        icon: 'warning',
        title: 'خطا در ثبت',
        text: response.message
        });
        }
        },
        error: function () {
        Swal.fire({
        icon: 'error',
        title: 'خطا',
        text: 'خطایی در ارتباط با سرور رخ داده است'
        });
        }
        });
        });
        });
    </script>
}
