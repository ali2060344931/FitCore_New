@using FitCore.Application.Services.Member.Queries
@using FitCore.Application.ViewModels.Common

@model GetMemberByIdDto

@{
   string caption = "ویرایش اعضاء باشگاه";
    ViewData["Title"] = caption;
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <!-- Title -->
        <h2 class="fc-form-title">ویرایش اعضاء باشگاه</h2>

        <!-- Form -->
        <form id="EditMembersForm">
            <!-- فیلد مخفی برای Id -->
            <input type="hidden" id="Id" name="Id" value="@Model.Id" />

            <div class="row">
                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "FirstName",
                             Name = "FirstName",
                             Value = Model.FirstName,
                             LabelName = @Html.DisplayNameFor(m => m.FirstName),
                             Placeholder = @Html.DisplayNameFor(m => m.FirstName),
                             Col = 3
                         }' />
<partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "LastName",
             Name = "LastName",
             Value = Model.LastName,
             LabelName = @Html.DisplayNameFor(m => m.LastName),
             Placeholder = @Html.DisplayNameFor(m => m.LastName),
             Col = 3
         }' />


<partial name="~/Areas/Admin/Views/Shared/Partials/_SelectDropdown.cshtml"
         model='new BaseInputViewModel
         {
             Id = "Gender",
             Name = "Gender",
             LabelName = Html.DisplayNameFor(m => m.Gender),
             Value = ((int)Model.Gender).ToString(), // مقدار فعلی جنسیت جهت انتخاب خودکار در ویرایش
             Col = 1,
             Items = new List<SelectListItem>
{
new SelectListItem { Value = "1", Text = "مرد" },
new SelectListItem { Value = "2", Text = "زن" }
}
}' />



<partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "Mobile",
             Name = "Mobile",
             Value = Model.Mobile,
             LabelName = @Html.DisplayNameFor(m => m.Mobile),
             Placeholder = @Html.DisplayNameFor(m => m.Mobile),
             Col = 2
         }' />


<partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "BirthDate",
             Name = "BirthDate",
             LabelName = Html.DisplayNameFor(m => m.BirthDate),
             Placeholder = "مثال: 1370/05/20",
             Value = Model.BirthDate, // مقدار فعلی از دیتابیس برای فرم ویرایش
             Col = 2
         }' />




</div>

            <!-- Buttons -->



            <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                     model='new FormButtonsViewModel
                     {
                         BackUrl = "/Admin/Members",
                         BackText = "انصراف و بازگشت به لیست"
                     }' />
</form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <!-- Persian DatePicker -->
    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {

        // فعال‌سازی تقویم
        $("#BirthDate").persianDatepicker({
        format: 'YYYY/MM/DD',
        autoClose: true,
        initialValue: false,
        observer: true,
        calendar: {
        persian: {
        locale: 'fa'
        }
        }
        });

        // مدیریت ارسال فرم (دقت کنید ID فرم با HTML یکی باشد)
        $("#EditMembersForm").on("submit", function (e) {
        e.preventDefault();

        var birthDateVal = $("#BirthDate").val();
        if (!birthDateVal) {
        Swal.fire({ icon: 'warning', title: 'توجه', text: 'لطفاً تاریخ تولد را انتخاب کنید.' });
        return;
        }

        var data = {
        Id: $("#Id").val(), // ارسال آیدی برای ویرایش
        FirstName: $("#FirstName").val().trim(),
        LastName: $("#LastName").val().trim(),
        Mobile: $("#Mobile").val().trim(),
        Gender: parseInt($("#Gender").val()),
        BirthDate: birthDateVal
        };
        console.log(Id)
        $.ajax({
        type: "POST",
        url: "/Admin/Members/Edit",
        data: data,
        beforeSend: function() {
        $("button[type='submit']").prop('disabled', true).text('در حال ثبت...');
        },
        success: function (response) {
        if (response.isSuccess) {
        Swal.fire({ icon: 'success', title: 'موفقیت‌آمیز', text: response.message })
        .then(() => { window.location.href = "/Admin/Members"; });
        } else {
        Swal.fire({ icon: 'warning', title: 'خطا', text: response.message });
        $("button[type='submit']").prop('disabled', false).text('ثبت تغییرات');
        }
        },
        error: function () {
        Swal.fire({ icon: 'error', title: 'خطا', text: 'ارتباط با سرور برقرار نشد.' });
        $("button[type='submit']").prop('disabled', false).text('ثبت تغییرات');
        }
        });
        });
        });
    </script>
}
