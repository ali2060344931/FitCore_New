@using FitCore.Application.Services.Member.Queries
@using FitCore.Common
@using FitCore.Domain.Entities.Members
@model ResultGetMembersDto

@{
    ViewData["Title"] = "اعضای باشگاه";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var searchKey = Context.Request.Query["SearchKey"].ToString();
    var isFiltered = !string.IsNullOrWhiteSpace(searchKey);


}

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="fc-page-header">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='"لیست اعضای باشگاه"' />

        <a asp-area="Admin"
           asp-controller="Members"
           asp-action="Create"
           class="btn btn-success">

            + ثبت اعضاء جدید
        </a>

    </div>





    <!-- Search Box -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_SearchBox.cshtml"
             model="searchKey" />

    <!-- Card -->
    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardStart.cshtml" />

    <div class="mb-3">

        تعداد کل اعضا :

        <strong>
            @Model.RowCount
        </strong>

        @if (isFiltered)
        {
            <span class="ms-2">
                (نتایج فیلتر: <strong>@Model.Members.Count</strong>)
            </span>

            <a href="/Admin/Members" class="btn btn-warning btn-sm ms-2">
                نمایش همه (@Model.RowCount)
            </a>
        }

    </div>

    @if (Model.Members != null && Model.Members.Any())
    {
        <table class="table table-striped table-hover">

            <thead>
                <tr>
                    <th>نام و نام خانوادگی</th>
                    <th>تلفن همراه</th>
                    <th>جنسیت</th>
                    <th>تاریخ تولد</th>
                    <th>تعداد برنامه<br />غذایی ثبت شده</th>
                    <th width="180">عملیات</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Members)
                {
                    <tr>
                        <td>
                            <strong>@item.FullName</strong>
                        </td>

                        <td>@item.Mobile</td>

                        <td>
                            @(item.Gender == Gender.Male ? "مرد" : "زن")
                        </td>

                        <td>
                            @(item.BirthDate == default ? "---" : item.BirthDate)
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-success ms-1">
                                @(@item.countNutritionProg)
                            </span>

                        </td>

                        <td>
                            <div class="fc-action-buttons">
                                <a class="btn btn-primary btn-sm"
                                   asp-area="Admin"
                                   asp-controller="NutritionProgram"
                                   asp-action="Create"
                                   asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                    <i class="fa fa-th-list" aria-hidden="true"></i>
                                    ثبت برنامه غذایی
                                </a>

                                <a class="btn btn-info btn-sm"
                                   asp-area="Admin"
                                   asp-controller="Members"
                                   asp-action="Edit"
                                   asp-route-id="@SecurityUtils.EncryptId(item.Id)">
                                    ویرایش
                                </a>

                                <button type="button"
                                        class="btn btn-danger btn-sm"
                                        onclick="DeleteMember(@item.Id)">
                                    حذف
                                </button>
                            </div>

                        </td>
                    </tr>
                }
            </tbody>

        </table>

        <div class="mt-3">
            <span class="ml-3">
                تعداد نمایش داده شده :
                <strong>@Model.Rows</strong>
            </span>

            <span class="ml-3">
                کل اعضا :
                <strong>@Model.RowCount</strong>
            </span>
        </div>
    }
    else
    {
        <partial name="~/Areas/Admin/Views/Shared/Partials/_EmptyState.cshtml"
                 model='"هیچ عضوی یافت نشد"' />
    }

    <partial name="~/Areas/Admin/Views/Shared/Partials/_TableCardEnd.cshtml" />

</div>

@section Scripts
{
    <link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/Sweetalert2/sweetalert2.min.js"></script>

    <script>
        function DeleteMember(id) {
        Swal.fire({
        title: 'حذف عضو',
        text: "آیا از حذف عضو مطمئن هستید؟",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#7cacbe',
        confirmButtonText: 'بله، حذف شود',
        cancelButtonText: 'خیر'
        }).then((result) => {
        if (result.value) {
        $.ajax({
        contentType: 'application/x-www-form-urlencoded',
        dataType: 'json',
        type: "POST",
        url: "/Admin/Members/Delete",
        data: { Id: id },
        success: function (data) {
        if (data.isSuccess === true) {
        Swal.fire('موفق!', data.message, 'success')
        .then(function () { location.reload(); });
        } else {
        Swal.fire('هشدار!', data.message, 'warning');
        }
        },
        error: function () {
        Swal.fire('خطا!', 'مشکلی در ارتباط با سرور رخ داده است', 'error');
        }
        });
        }
        });
        }
    </script>
}
