@using FitCore.Application.Services.Member.Queries
@model ResultGetMembersDto

@{
    var searchKey = Context.Request.Query["SearchKey"].ToString();
    var isFiltered = !string.IsNullOrWhiteSpace(searchKey);

    ViewData["Title"] = "Members";
    Layout = "~/Areas/Admin/Views/Shared/_Adminlayout.cshtml";
}

<div class="content-wrapper">
    <div class="container-fluid">

        <section id="configuration">

            <div class="row">
                <div class="col-12">

                    <div class="card">

                        <div class="card-header">
                            <div class="card-title-wrap bar-success">
                                <h4 class="card-title">لیست اعضای باشگاه</h4>
                            </div>
                        </div>

                        <div class="card-body collapse show">

                            <div class="card-block card-dashboard">

                                <p class="card-text">لیست اعضا</p>

                                <form method="get" class="col-xl-6 col-lg-8 col-md-12 mb-1">

                                    <div class="d-flex align-items-center">

                                        <input type="text"
                                               class="form-control ml-sm-0"
                                               name="SearchKey"
                                               value="@searchKey"
                                               placeholder="جستجوی عضو..." />

                                        <button type="submit" class="btn btn-success position-relative">

                                            جستجو

                                            @if (isFiltered)
                                            {
                                                <span class="badge badge-danger">
                                                    @Model.Members.Count
                                                </span>
                                            }

                                        </button>

                                        @if (isFiltered)
                                        {
                                            <a href="/Admin/Members"
                                                   class="btn btn-warning">
                                                نمایش همه (@Model.RowCount)
                                            </a>
                                        }

                                    </div>

                                </form>


                                <div class="table-responsive">

                                    <table class="table table-striped table-bordered">

                                        <thead>

                                            <tr>
                                                <th>نام و نام خانوادگی</th>
                                                <th>تلفن همراه</th>
                                                <th>جنسیت</th>
                                                <th>تاریخ تولد</th>
                                                <th>عملیات</th>
                                            </tr>

                                        </thead>

                                        <tbody>

                                            @foreach (var item in Model.Members)
                                            {
                                                <tr>

                                                    <td>@item.FullName</td>

                                                    <td>@item.Mobile</td>

                                                    <td>@item.Gender</td>

                                                    <td>
                                                        @item.BirthDate.ToString("yyyy/MM/dd")
                                                    </td>

                                                    <td>

                                                        <button class="btn btn-info btn-sm">
                                                            ویرایش
                                                        </button>

                                                        <button class="btn btn-danger btn-sm">
                                                            حذف
                                                        </button>

                                                    </td>

                                                </tr>
                                            }

                                        </tbody>

                                    </table>

                                </div>


                                <div class="mt-3">

                                    <span class="ml-3">
                                        تعداد نمایش داده شده :
                                        <strong>@Model.Rows</strong>
                                    </span>

                                    <span class="ml-3">
                                        کل اعضا :
                                        <strong>@Model.RowCount</strong>
                                    </span>

                                </div>


                            </div>

                        </div>

                    </div>

                </div>
            </div>

        </section>

    </div>
</div>
