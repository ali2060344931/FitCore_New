@using FitCore.Application.ViewModels.Common
@model EndPoint.Site.Areas.Admin.Models.Member.MemberCreateEditViewModel

@{
    bool isEdit = Model != null && Model.Id > 0;
    ViewData["Title"] = isEdit ? "ویرایش عضو" : "ثبت عضو جدید";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

@{
    var genders = new List<SelectListItem>
    {
        new SelectListItem{ Value = "1", Text = "مرد"},
        new SelectListItem{ Value = "2", Text = "زن"}
    };
}

<div class="container-fluid mt-4">
    <div class="fc-form-container">

        <partial name="~/Areas/Admin/Views/Shared/Partials/_PageTitle.cshtml"
                 model='@(isEdit ? "ویرایش عضو" : "ثبت عضو جدید")' />

        <form id="MemberForm">

            <input type="hidden" id="Id" name="Id" value="@(isEdit ? Model.Id : 0)" />

            <!-- ✅ ردیف اول : نام + موبایل + جنسیت -->
            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_TextInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "FullName",
                             Name = "FullName",
                             Value = Model.FullName,
                             LabelName = "نام و نام خانوادگی",
                             Col = 4
                         }' />

<partial name="~/Areas/Admin/Views/Shared/Partials/_NumberInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "Mobile",
             Name = "Mobile",
             Value = Model.Mobile,
             LabelName = "موبایل",
             Col = 2
         }' />

<div class="col-md-1 mb-1">
                    <label class="form-label font-weight-bold">جنسیت</label>
                    <select class="form-control"
                            id="Gender"
                            name="Gender"
                            asp-for="Gender"
                            asp-items="genders">
                    </select>
                </div>


            </div>


            <!-- ✅ ردیف دوم : تاریخ ها -->
            <div class="row">

                <partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
                         model='new BaseInputViewModel
                         {
                             Id = "BirthDate",
                             Name = "BirthDate",
                             Value = Model.BirthDate,
                             LabelName = Html.DisplayNameFor(m => m.BirthDate),
                             Placeholder = Html.DisplayNameFor(m => m.BirthDate),
                             Col = 2
                         }' />

<partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "MembershipStartDate",
             Name = "MembershipStartDate",
             Value = Model.MembershipStartDate,
             LabelName = Html.DisplayNameFor(m => m.MembershipStartDate),
             Placeholder = Html.DisplayNameFor(m => m.MembershipStartDate),
             Col = 2
         }' />

<partial name="~/Areas/Admin/Views/Shared/Partials/_PersianDatePickerInput.cshtml"
         model='new BaseInputViewModel
         {
             Id = "MembershipEndDate",
             Name = "MembershipEndDate",
             Value = Model.MembershipEndDate,
             LabelName = Html.DisplayNameFor(m => m.MembershipEndDate),
             Placeholder = Html.DisplayNameFor(m => m.MembershipEndDate),
             Col = 2
         }' />

</div>

            <!-- ✅ اضافه شدن چک‌باکس فعال/غیرفعال -->
            <div class="col-md-2 mb-1 d-flex align-items-end">
                <div class="form-check form-switch mt-2">
                    <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive"
                    @(Model != null && Model.IsActive ? "checked" : "")>
                    @* <label class="form-check-label font-weight-bold" for="IsActive">وضعیت فعالیت</label> *@
                    <label class="form-check-label font-weight-bold" for="IsActive" style="margin-right: 12px;">وضعیت فعالیت</label>
                </div>
            </div>


            <!-- ✅ ردیف سوم : دکمه ها -->
            <div class="row">
                <div class="col-12">

                    <partial name="~/Areas/Admin/Views/Shared/Partials/_FormButtons.cshtml"
                             model='new FormButtonsViewModel
                             {
                                 SubmitText = isEdit ? "ذخیره تغییرات" : "ثبت عضو",
                                 BackUrl = "/Admin/Members",
                                 BackText = "انصراف و بازگشت"
                             }' />

</div>
            </div>

        </form>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>
    <link href="~/lib/persian-datepicker/persian-datepicker.min.css" rel="stylesheet" />
    <script src="~/lib/persian-datepicker/persian-date.min.js"></script>
    <script src="~/lib/persian-datepicker/persian-datepicker.min.js"></script>

    <script>
        $(document).ready(function () {

        const datePickerConfig = {
        format: 'YYYY/MM/DD',
        autoClose: true,
        initialValue: false,
        observer: true,
        initialValueType: 'persian',
        calendar: { persian: { locale: 'en' }
        }
        };

        $("#BirthDate, #MembershipStartDate, #MembershipEndDate").persianDatepicker(datePickerConfig);

        $("#MemberForm").on("submit", function (e) {
        e.preventDefault();

        const isEdit = @(isEdit ? "true" : "false");
        const url = isEdit ? "/Admin/Members/Edit" : "/Admin/Members/Create";

        const data = {
        Id: parseInt($("#Id").val()) || 0,
        FullName: $("#FullName").val(),
        Mobile: $("#Mobile").val(),
        Gender: parseInt($("#Gender").val()),
        BirthDate: $("#BirthDate").val(),
        MembershipStartDate: $("#MembershipStartDate").val(),
        MembershipEndDate: $("#MembershipEndDate").val(),
        // ✅ اضافه شدن مقدار چک‌باکس (دقت کنید که از is(":checked") استفاده شده تا True/False دقیق ارسال شود)
        IsActive: $("#IsActive").is(":checked")

        };

        $.ajax({
        type: "POST", url: url, data: data,
        success: function (res) {
        if (res.isSuccess) {
        Swal.fire({ icon: 'success', title: 'موفق', text: res.message }).then(() => {
        window.location.href = "/Admin/Members";
        });
        } else {
        Swal.fire({ icon: 'warning', title: 'خطا', text: res.message });
        }
        }
        });
        });
        });



    </script>
}
