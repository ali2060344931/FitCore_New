@model List<FitCore.Domain.Entities.Help.HelpContent>

@{
    ViewData["Title"] = "مدیریت راهنما";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";
}

<div class="fc-card">

    <!-- Header -->
    <div class="fc-card-header d-flex justify-content-between align-items-center">

        <div>
            <h4 class="mb-0">
                <i class="fa fa-question-circle text-info"></i>
                مدیریت راهنما
            </h4>
            <small class="text-muted">
                مدیریت متن‌های راهنمای سیستم
            </small>
        </div>

        <a class="btn btn-success"
           asp-area="Admin"
           asp-controller="Help"
           asp-action="CreateEdit">

            <i class="fa fa-plus"></i>
            افزودن راهنما

        </a>

    </div>


    <!-- Table -->
    <div class="fc-card-body">

        <div class="table-responsive">

            <table class="table table-hover align-middle">

                <thead class="thead-light">
                    <tr>
                        <th style="width:120px">کلید</th>
                        <th>عنوان</th>
                        <th style="width:120px">وضعیت</th>
                        <th style="width:200px">عملیات</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <span class="badge badge-primary">
                                        @item.HelpKey
                                    </span>
                                </td>

                                <td>
                                    <strong>@item.Title</strong>
                                </td>

                                <td>

                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-success">
                                            فعال
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">
                                            غیرفعال
                                        </span>
                                    }

                                </td>

                                <td>

                                    <a asp-action="CreateEdit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-warning">

                                        <i class="fa fa-edit"></i>
                                        ویرایش

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('آیا از حذف این راهنما مطمئن هستید؟')">

                                        <i class="fa fa-trash"></i>
                                        حذف

                                    </a>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">

                                <i class="fa fa-info-circle"></i>
                                هیچ راهنمایی ثبت نشده است

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
