@model EndPoint.Site.Areas.Admin.Models.HelpContentCreateEditViewModel
@{
    ViewData["Title"] = "لیست راهنما";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

}

<form method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="HelpKey"></label>
        <input asp-for="HelpKey" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Content"></label>
        <textarea asp-for="Content" class="form-control"></textarea>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive"></label>
    </div>

    <button type="submit" class="btn btn-primary">
        ذخیره
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        بازگشت
    </a>

</form>
