@using FitCore.Common
@model EndPoint.Site.Areas.Admin.Models.TrainingProgramBuilderPageViewModel

@functions {
    public static string ToPersianNumbers(int value)
    {
        var persianDigits = new[] { '۰', '۱', '۲', '۳', '۴', '۵', '۶', '۷', '۸', '۹' };
        var input = value.ToString();
        var result = new System.Text.StringBuilder();

        foreach (var ch in input)
        {
            if (char.IsDigit(ch))
                result.Append(persianDigits[ch - '0']);
            else
                result.Append(ch);
        }

        return result.ToString();
    }
}

@{
    ViewData["Title"] = "ساخت برنامه تمرینی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var program = Model?.Program;
    var encryptedId = ViewBag.EncryptedId as string;
}

<div class="page-content-wrapper builder-wrapper">

    <div class="program-header-sticky-wrapper">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body py-3 px-3">

                <!-- ردیف اطلاعات اصلی -->
                <div class="program-header-row d-flex flex-column flex-lg-row
                    justify-content-between align-items-start
                    align-items-lg-center gap-3">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="program-icon-box">
                            <i class="fa fa-heartbeat"></i>
                        </div>
                        <div class="program-main-title">
                            مدیریت ساختار برنامه تمرینی
                        </div>
                        <span class="badge day-count-badge">
                            برای <span class="day-count-number">@(program.Days?.Count ?? 0)</span> روز
                        </span>
                        <div class="d-flex align-items-center gap-1 flex-wrap">
                            <span class="badge structure-badge">روزها</span>
                            <i class="fa fa-angle-left breadcrumb-arrow"></i>
                            <span class="badge structure-badge active">حرکات</span>
                        </div>
                    </div>

                    <!-- متادیتای برنامه -->
                    <div class="program-meta-container d-flex align-items-center gap-2 flex-wrap">
                        <div class="program-meta-item">
                            <i class="fa fa-user meta-icon"></i>
                            <span class="meta-label">عضــو:</span>
                            <span class="meta-value-Fullmamu">@program.MemberName</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">عنوان:</span>
                            <span class="meta-value">@program.Title</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">نوع:</span>
                            <span class="meta-value">@program.TrainingProgramType</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">هدف:</span>
                            <span class="meta-value">@program.TrainingGoalType</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">شروع:</span>
                            <span class="meta-value">@program.StartDate</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">پایان:</span>
                            <span class="meta-value">@program.EndDate</span>
                        </div>
                    </div>
                </div>

                <!-- تولبار -->
                <div class="program-toolbar mt-3 pt-3 border-top">
                    <div class="d-flex align-items-center gap-1 flex-nowrap overflow-auto">

                        <button class="btn btn-sm btn-success px-2 py-0 text-nowrap"
                                data-toggle="modal"
                                data-target="#addDayModal">
                            <i class="fa fa-plus"></i>
                            <span class="d-none d-md-inline ms-1">افزودن روز تمرینی</span>
                        </button>

                        <a class="btn btn-sm btn-outline-success px-2 py-0 text-nowrap"
                           asp-area="Admin"
                           asp-controller="Exercise"
                           asp-action="Create"
                           target="_blank">
                            <i class="fa fa-plus"></i>
                            <span class="d-none d-md-inline ms-1">افزودن حرکت به بانک</span>
                        </a>

                        <button class="btn btn-sm btn-outline-secondary px-2 py-0 text-nowrap"
                                onclick="location.reload()">
                            <i class="fa fa-refresh"></i>
                        </button>

                        <a class="btn btn-sm btn-outline-secondary px-2 py-0 text-nowrap"
                           href="/Admin/TrainingProgram">
                            <i class="fa fa-reply"></i>
                        </a>
                    </div>
                </div>
                <!-- پایان تولبار -->

            </div>
        </div>
    </div>

    <div class="content-body">
        @if (program == null)
        {
            <div class="alert alert-danger">اطلاعات برنامه تمرینی یافت نشد.</div>
        }
        else
        {
            @if (program.Days == null || program.Days.Count == 0)
            {
                <div class="alert alert-info">هنوز هیچ روزی برای این برنامه ثبت نشده است.</div>
            }
            else
            {
                <div id="daysAccordion" class="nutrition-days-accordion">

                    @for (int i = 0; i < program.Days.Count; i++)
                    {
                        var day = program.Days[i];
                        var collapseId = $"collapseDay_{day.Id}";
                        var headingId = $"headingDay_{day.Id}";

                        <div class="card nutrition-day-card mb-2 border-0 shadow-sm rounded-4 overflow-hidden">

                            <!-- هدر روز -->
                            <div class="d-flex align-items-center flex-nowrap gap-2 day-header-box">

                                <div class="day-actions d-flex align-items-center gap-1 flex-shrink-0">

                                    <button type="button"
                                            class="btn btn-sm btn-outline-facebook rounded-pill"
                                            onclick="openAddExerciseModal('@day.Id', `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                        <i class="fa fa-plus"></i>
                                        <span class="d-none d-md-inline ms-1">افزودن حرکت</span>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-google rounded-pill"
                                            onclick="openEditDayModal('@day.Id','@day.DayNumber','@day.DayType','@day.DurationMinutes',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`,`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Description ?? ""))`)">
                                        <i class="fa fa-pencil-square-o"></i>
                                        <span class="d-none d-md-inline ms-1">ویرایش روز</span>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger rounded-pill"
                                            onclick="openDeleteDayModal('@day.Id',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                        <i class="fa fa-times"></i>
                                        <span class="d-none d-md-inline ms-1">حذف روز</span>
                                    </button>

                                </div>

                                <button class="btn btn-link nutrition-day-toggle text-decoration-none p-0 font-weight-bold d-flex align-items-center gap-2 text-nowrap collapsed"
                                        data-toggle="collapse"
                                        data-target="#@collapseId"
                                        aria-expanded="false"
                                        aria-controls="@collapseId">

                                    <span class="day-label">روز</span>
                                    <span class="day-number-badge">@ToPersianNumbers(day.DayNumber)</span>

                                    @if (!string.IsNullOrWhiteSpace(day.Title))
                                    {
                                        <span class="day-title-text">@day.Title</span>
                                    }

                                    <span class="badge bg-secondary text-white px-2 py-1 rounded-pill">
                                        @day.DayType
                                    </span>

                                    @if (day.DurationMinutes.HasValue)
                                    {
                                        <span class="badge bg-light text-dark border px-2 py-1 rounded-pill">
                                            <i class="fa fa-clock-o"></i>
                                            @ToPersianNumbers(day.DurationMinutes.Value) دقیقه
                                        </span>
                                    }

                                    @if (day.Exercises != null && day.Exercises.Count > 0)
                                    {
                                        <span class="badge bg-info text-white px-2 py-1 rounded-pill"
                                              data-toggle="tooltip"
                                              title="در این روز @ToPersianNumbers(day.Exercises.Count) حرکت ثبت شده است">
                                            @ToPersianNumbers(day.Exercises.Count) حرکت
                                        </span>
                                    }

                                    <i class="fa fa-chevron-down text-muted day-collapse-icon"></i>
                                </button>

                            </div>

                            <!-- بدنه روز -->
                            <div id="@collapseId"
                                 class="collapse"
                                 aria-labelledby="@headingId"
                                 data-parent="#daysAccordion">

                                <div class="card-body nutrition-day-body">

                                    @if (!string.IsNullOrWhiteSpace(day.Description))
                                    {
                                        <div class="alert alert-light border mb-3">
                                            <i class="fa fa-info-circle text-muted"></i>
                                            @day.Description
                                        </div>
                                    }

                                    @if (day.Exercises == null || day.Exercises.Count == 0)
                                    {
                                        <div class="empty-state empty-state-light border rounded-4 mb-0">
                                            <div class="text-center p-4 border rounded-4 border-dashed"
                                                 style="background-color: #fef2f2; border-color: #fca5a5 !important;">

                                                <div style="color: #b91c1c;">
                                                    <i class="fa fa-list-ul fa-2x mb-2"></i>
                                                    <h6 class="fw-bold">هنوز هیچ حرکتی برای این روز ثبت نشده!</h6>
                                                </div>

                                                <button type="button"
                                                        class="btn btn-sm btn-outline-facebook rounded-pill mt-2"
                                                        onclick="openAddExerciseModal('@day.Id', `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                                    <i class="fa fa-plus me-1"></i> افزودن اولین حرکت
                                                </button>

                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle nutrition-food-table">
                                                <thead class="text-uppercase text-nowrap">
                                                    <tr>
                                                        <th style="width: 40px;" title="جابجایی با درگ">
                                                            <i class="fa fa-arrows"></i>
                                                        </th>
                                                        <th style="width: 50px;">ردیف</th>
                                                        <th>نام حرکت</th>
                                                        <th>گروه عضلانی</th>
                                                        <th class="text-center">ست</th>
                                                        <th class="text-center">تکرار</th>
                                                        <th class="text-center">وزن (kg)</th>
                                                        <th class="text-center">استراحت (s)</th>
                                                        <th>یادداشت مربی</th>
                                                        <th class="ps-3">عملیات</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="exerciseList_@day.Id" data-day-id="@day.Id">
                                                    @{
                                                        int counter = 1;
                                                    }
                                                    @foreach (var ex in day.Exercises)
                                                    {
                                                        <tr data-item-id="@ex.Id">
                                                            <td class="text-center text-muted drag-handle" style="cursor: move;">
                                                                <i class="fa fa-bars"></i>
                                                            </td>
                                                            <td class="text-center fw-bold text-muted">@counter</td>
                                                            <td class="food-name-cell text-nowrap">@ex.ExerciseName</td>
                                                            <td class="food-name-cell text-nowrap">@ex.MuscleGroup</td>
                                                            <td class="text-center text-nowrap">
                                                                <span class="badge bg-light text-dark border amount-badge">@(ex.Sets?.ToString() ?? "-")</span>
                                                            </td>
                                                            <td class="text-center text-nowrap">@(ex.Reps ?? "-")</td>
                                                            <td class="text-center text-nowrap">@(ex.WeightKg?.ToString() ?? "-")</td>
                                                            <td class="text-center text-nowrap">@(ex.RestSeconds?.ToString() ?? "-")</td>
                                                            <td class="food-name-cell text-nowrap food-description-cell">@(ex.CoachNote ?? "-")</td>
                                                            <td class="text-nowrap ps-3">
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <button type="button" class="btn btn-sm btn-outline-warning btn-modern"
                                                                            onclick="openEditExerciseModal('@ex.Id','@day.Id','@ex.ExerciseId','@ex.Sets','@(ex.Reps ?? "")','@ex.WeightKg','@ex.RestSeconds','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(ex.CoachNote ?? ""))')">
                                                                        ویرایش
                                                                    </button>
                                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-modern"
                                                                            onclick="openDeleteExerciseModal('@ex.Id','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(ex.ExerciseName ?? ""))')">
                                                                        حذف
                                                                    </button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        counter++;
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }

                                </div>

                            </div>

                        </div>
                    }

                </div>
            }
        }
    </div>
</div>

@section Modals {

    <!-- افزودن روز تمرینی -->
    <div class="modal fade" id="addDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">افزودن روز تمرینی جدید</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="addDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TrainingProgramId" value="@program?.Id" />

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>شماره روز</label>
                                <input type="number" class="form-control" name="DayNumber" min="1" max="14" required />
                            </div>
                            <div class="form-group col-md-6">
                                <label>نوع روز</label>
                                <select class="form-control js-select2-modal" name="DayTypeId" id="AddDay_DayTypeId" required>
                                    <option value="">انتخاب کنید...</option>
                                    @foreach (var dt in Model.DayTypes)
                                    {
                                        <option value="@dt.Value">@dt.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>عنوان روز</label>
                            <input type="text" class="form-control" name="Title" placeholder="مثلاً: سینه و سه‌سر" />
                        </div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>مدت زمان (دقیقه)</label>
                                <input type="number" class="form-control" name="DurationMinutes" min="1" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>توضیحات</label>
                            <textarea class="form-control" name="Description" rows="2"></textarea>
                        </div>
                    </form>
                    <div id="addDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" id="btnSaveDay" form="addDayForm"><span class="btn-text">ثبت</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ویرایش روز تمرینی -->
    <div class="modal fade" id="editDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        ویرایش روز: <small class="swal2-textarea countdown-timer mt-1"><span id="EditDay_Title" class="countdown-text"></span></small>
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="editDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="EditDay_Id" name="Id" />

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>شماره روز</label>
                                <input type="number" class="form-control" id="EditDay_DayNumber" name="DayNumber" min="1" max="14" required />
                            </div>
                            <div class="form-group col-md-6">
                                <label>نوع روز</label>
                                <select class="form-control js-select2-modal" id="EditDay_DayTypeId" name="DayTypeId" required>
                                    <option value="">انتخاب کنید...</option>
                                    @foreach (var dt in Model.DayTypes)
                                    {
                                        <option value="@dt.Value">@dt.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>عنوان روز</label>
                            <input type="text" class="form-control" id="EditDay_Title_txt" name="Title" />
                        </div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>مدت زمان (دقیقه)</label>
                                <input type="number" class="form-control" id="EditDay_DurationMinutes" name="DurationMinutes" min="1" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>توضیحات</label>
                            <textarea class="form-control" id="EditDay_Description" name="Description" rows="2"></textarea>
                        </div>
                    </form>
                    <div id="editDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" id="btnEditDay" form="editDayForm"><span class="btn-text">ذخیره</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>

    <!-- حذف روز تمرینی -->
    <div class="modal fade" id="deleteDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        حــذف روز: <small class="swal2-textarea countdown-timer mt-1"><span id="DeleteDay_Title" class="countdown-text"></span></small>
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="deleteDayForm">@Html.AntiForgeryToken()<input type="hidden" id="DeleteDay_Id" name="trainingDayId" /></form>
                    <div class="alert alert-warning mb-0">
                        آیا از حذف این روز مطمئن هستید؟ تمام حرکات ثبت‌شده در این روز نیز حذف خواهند شد.
                    </div>
                    <div id="deleteDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger" id="btnDeleteDay" form="deleteDayForm"><span class="btn-text">حذف</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button>
                </div>
            </div>
        </div>
    </div>

    <!-- افزودن حرکت -->
    <div class="modal fade" id="addExerciseModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">

                <!-- هدر -->
                <div class="modal-header border-0 pb-2"
                     style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:16px 20px;">
                    <div>
                        <h5 class="modal-title text-white mb-0" style="font-size:15px;">
                            <i class="fa fa-plus-circle me-2" style="color:#00C896;"></i>
                            افزودن حرکت به روز:
                            <span id="addExerciseDayTitle"
                                  style="color:#00C896;font-weight:700;"></span>
                        </h5>
                        <div style="font-size:11px;color:#a0aec0;margin-top:3px;">
                            پس از هر ثبت، فرم خالی می‌شود — می‌توانید حرکت بعدی را بلافاصله وارد کنید
                        </div>
                    </div>
                    <button type="button" class="close text-white"
                            data-dismiss="modal" style="opacity:0.7;">&times;</button>
                </div>

                <div class="modal-body" style="padding:0;">

                    <!-- ناحیه پیام موفقیت (بالای فرم) -->
                    <div id="addExerciseSuccessBanner" style="display:none;
                         background:#edfaf5;border-bottom:2px solid #00C896;
                         padding:10px 20px;font-size:13px;color:#276749;">
                        <i class="fa fa-check-circle me-2" style="color:#00C896;"></i>
                        <span id="addExerciseSuccessText"></span>
                        <span style="color:#718096;font-size:12px;margin-right:8px;">
                            — می‌توانید حرکت بعدی را ثبت کنید
                        </span>
                    </div>

                    <!-- لیست حرکات ثبت‌شده در این جلسه -->
                    <div id="addedExercisesPanel" style="display:none;
                         background:#f8fafd;border-bottom:1px solid #e2e8f0;
                         padding:10px 20px;">
                        <div style="font-size:12px;font-weight:700;color:#4a5568;margin-bottom:6px;">
                            <i class="fa fa-list me-1" style="color:#00C896;"></i>
                            حرکات ثبت‌شده در این جلسه:
                        </div>
                        <div id="addedExercisesList"
                             style="display:flex;flex-wrap:wrap;gap:6px;"></div>
                    </div>

                    <!-- فرم -->
                    <div style="padding:16px 20px;">
                        <form id="addExerciseForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="TrainingDayId" id="AddExercise_TrainingDayId" />

                            <div class="form-group">
                                <label style="font-size:12px;font-weight:700;color:#4a5568;">
                                    حرکت تمرینی <span style="color:#e53e3e;">*</span>
                                </label>
                                <select class="form-control js-select2-modal"
                                        name="ExerciseId" id="AddExercise_ExerciseId" required>
                                    <option value="">جستجو و انتخاب حرکت...</option>
                                    @foreach (var ex in Model.Exercises)
                                    {
                                        <option value="@ex.Value">@ex.Text</option>
                                    }
                                </select>
                                <!-- پیام تکراری -->
                                <div id="duplicateExerciseWarning"
                                     style="display:none;margin-top:5px;padding:6px 10px;
                                            background:#fff5f5;border:1px solid #fc8181;
                                            border-radius:7px;font-size:12px;color:#c53030;">
                                    <i class="fa fa-exclamation-triangle me-1"></i>
                                    این حرکت قبلاً در این روز ثبت شده است!
                                </div>
                            </div>

                            <div class="row">
                                <div class="form-group col-6 col-md-3">
                                    <label style="font-size:12px;font-weight:700;color:#4a5568;">تعداد ست</label>
                                    <input type="number" class="form-control"
                                           name="Sets" id="AddExercise_Sets"
                                           min="1" placeholder="مثلاً: 4" />
                                </div>
                                <div class="form-group col-6 col-md-3">
                                    <label style="font-size:12px;font-weight:700;color:#4a5568;">تکرار</label>
                                    <input type="text" class="form-control"
                                           name="Reps" id="AddExercise_Reps"
                                           placeholder="مثلاً: 8-12" />
                                </div>
                                <div class="form-group col-6 col-md-3">
                                    <label style="font-size:12px;font-weight:700;color:#4a5568;">وزن (kg)</label>
                                    <input type="number" class="form-control"
                                           name="WeightKg" id="AddExercise_WeightKg"
                                           step="0.5" min="0" placeholder="اختیاری" />
                                </div>
                                <div class="form-group col-6 col-md-3">
                                    <label style="font-size:12px;font-weight:700;color:#4a5568;">استراحت (ثانیه)</label>
                                    <input type="number" class="form-control"
                                           name="RestSeconds" id="AddExercise_RestSeconds"
                                           min="0" placeholder="مثلاً: 90" />
                                </div>
                            </div>

                            <div class="form-group mb-0">
                                <label style="font-size:12px;font-weight:700;color:#4a5568;">یادداشت مربی</label>
                                <textarea class="form-control" name="CoachNote"
                                          id="AddExercise_CoachNote" rows="2"
                                          placeholder="نکات تکنیکی، تمپو، توجه ویژه..."></textarea>
                            </div>
                        </form>
                    </div>

                </div>

                <div class="modal-footer border-0"
                     style="padding:12px 20px;background:#f8fafd;">
                    <button type="button"
                            class="btn btn-secondary"
                            data-dismiss="modal"
                            style="border-radius:9px;font-size:13px;padding:7px 18px;">
                        <i class="fa fa-times me-1"></i> بستن
                    </button>
                    <button type="button"
                            id="btnSaveExercise"
                            style="border-radius:9px;font-size:13px;padding:7px 22px;
                                   background:#00C896;border:none;color:#fff;
                                   font-weight:600;min-width:120px;
                                   transition:all 0.2s;">
                        <i class="fa fa-plus me-1" id="btnSaveExerciseIcon"></i>
                        <span id="btnSaveExerciseText">ثبت حرکت</span>
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- ویرایش حرکت -->
    <div class="modal fade" id="editExerciseModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">ویرایش حرکت</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="editExerciseForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" id="EditExercise_Id" />

                        <div class="form-group">
                            <label>حرکت تمرینی</label>
                            <select class="form-control js-select2-modal" name="ExerciseId" id="EditExercise_ExerciseId" required>
                                <option value="">انتخاب کنید...</option>
                                @foreach (var ex in Model.Exercises)
                                {
                                    <option value="@ex.Value">@ex.Text</option>
                                }
                            </select>
                        </div>

                        <div class="row">
                            <div class="form-group col-md-3">
                                <label>تعداد ست</label>
                                <input type="number" class="form-control" name="Sets" id="EditExercise_Sets" min="1" />
                            </div>
                            <div class="form-group col-md-3">
                                <label>تکرار</label>
                                <input type="text" class="form-control" name="Reps" id="EditExercise_Reps" placeholder="مثلاً: 8-12" />
                            </div>
                            <div class="form-group col-md-3">
                                <label>وزن (kg)</label>
                                <input type="number" class="form-control" name="WeightKg" id="EditExercise_WeightKg" step="0.5" min="0" />
                            </div>
                            <div class="form-group col-md-3">
                                <label>استراحت (ثانیه)</label>
                                <input type="number" class="form-control" name="RestSeconds" id="EditExercise_RestSeconds" min="0" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>یادداشت مربی</label>
                            <textarea class="form-control" name="CoachNote" id="EditExercise_CoachNote" rows="2"></textarea>
                        </div>
                    </form>
                    <div id="editExerciseMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" id="btnEditExercise" form="editExerciseForm"><span class="btn-text">ذخیره</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>

    <!-- حذف حرکت -->
    <div class="modal fade" id="deleteExerciseModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-sm" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        حــذف حرکت: <small class="swal2-textarea countdown-timer mt-1"><span id="DeleteExercise_Title" class="countdown-text"></span></small>
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="deleteExerciseForm">@Html.AntiForgeryToken()<input type="hidden" id="DeleteExercise_Id" name="trainingExerciseItemId" /></form>
                    <div class="alert alert-warning mb-0">آیا از حذف این حرکت مطمئن هستید؟</div>
                    <div id="deleteExerciseMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger" id="btnDeleteExercise" form="deleteExerciseForm"><span class="btn-text">حذف</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button>
                </div>
            </div>
        </div>
    </div>

}


@section Scripts {

    <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>

    <!-- SortableJS برای جابجایی (Drag & Drop) حرکات هر روز -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>

    <script>

        //====================================================
        // توابع کمکی
        //====================================================

        function setButtonLoading($btn, isLoading, text) {
            if (isLoading) {
                $btn.prop('disabled', true);
                $btn.data('original-text', $btn.find('.btn-text').text());
                $btn.find('.btn-text').text(text || 'در حال انجام...');
            } else {
                $btn.prop('disabled', false);
                $btn.find('.btn-text').text($btn.data('original-text') || 'ثبت');
            }
        }

        function showMessage(selector, type, message) {
            $(selector).html('<div class="alert alert-' + type + ' mb-0">' + message + '</div>');
        }

        function postForm(formSelector, buttonSelector, messageSelector, url, options) {
            options = options || {};
            var reloadOnSuccess = options.reloadOnSuccess !== undefined ? options.reloadOnSuccess : true;
            var onSuccess = options.onSuccess || null;

            var $form = $(formSelector);
            var $btn = $(buttonSelector);

            setButtonLoading($btn, true, 'در حال انجام...');

            $.ajax({
                url: url,
                type: 'POST',
                data: $form.serialize(),
                success: function (res) {
                    if (res && res.isSuccess) {
                        showMessage(messageSelector, 'success', res.message || 'عملیات با موفقیت انجام شد.');
                        if (typeof onSuccess === 'function') {
                            onSuccess(res, $form);
                        }
                        if (reloadOnSuccess) {
                            setTimeout(function () { location.reload(); }, 700);
                        }
                    } else {
                        showMessage(messageSelector, 'danger', (res && res.message) ? res.message : 'عملیات انجام نشد.');
                    }
                },
                error: function (xhr) {
                    showMessage(messageSelector, 'danger', 'خطا در ارتباط با سرور.');
                    console.log(xhr.responseText);
                },
                complete: function () {
                    setButtonLoading($btn, false);
                }
            });
        }

        //====================================================
        // Select2 — راه‌اندازی در مودال‌ها
        //====================================================

        function initSelect2InModal(selector, modalSelector, currentVal) {
            var $el = $(selector);

            // در صورتی که قبلاً init شده، destroy و دوباره init
            if ($el.hasClass('select2-hidden-accessible')) {
                $el.select2('destroy');
            }

            $el.select2({
                dir: 'rtl',
                width: '100%',
                language: 'fa',
                theme: 'bootstrap4',
                placeholder: 'جستجو و انتخاب کنید...',
                allowClear: true,
                dropdownParent: $(modalSelector)
            });

            // اعمال مقدار انتخابی (برای حالت ویرایش)
            if (currentVal) {
                $el.val(currentVal).trigger('change');
            }
        }

        //====================================================
        // روز تمرینی — مودال افزودن
        //====================================================

        function openEditDayModal(id, dayNumber, dayTypeId, durationMinutes, title, description) {
            $('#EditDay_Id').val(id);
            $('#EditDay_DayNumber').val(dayNumber);
            $('#EditDay_DurationMinutes').val(durationMinutes && durationMinutes !== 'undefined' ? durationMinutes : '');
            $('#EditDay_Title').text(title || '');
            $('#EditDay_Title_txt').val(title || '');
            $('#EditDay_Description').val(description || '');

            // ذخیره مقدار نوع روز برای اعمال بعد از init
            $('#EditDay_DayTypeId').attr('data-current-val', dayTypeId);

            $('#editDayMessage').html('');
            $('#editDayModal').modal('show');
        }

        function openDeleteDayModal(id, title) {
            $('#DeleteDay_Id').val(id);
            $('#DeleteDay_Title').text(title || '');
            $('#deleteDayMessage').html('');
            $('#deleteDayModal').modal('show');
        }

        //====================================================
        // حرکات تمرینی — مودال‌های افزودن/ویرایش/حذف
        //====================================================

        // شناسه‌های حرکاتی که در این جلسه به این روز اضافه شده‌اند
        // کلید: dayId → Set از exerciseId های ثبت‌شده
        var _sessionAddedExercises = {};

        function openAddExerciseModal(dayId, dayTitle) {
            $('#AddExercise_TrainingDayId').val(dayId);
            $('#addExerciseDayTitle').text(dayTitle || '');

            // ریست فرم
            resetAddExerciseForm();

            // ریست پیام‌ها
            $('#addExerciseSuccessBanner').hide();
            $('#addedExercisesPanel').hide();
            $('#addedExercisesList').html('');

            // ریست لیست session برای این روز
            _sessionAddedExercises[dayId] = new Set();

            $('#addExerciseModal').modal('show');
        }

        function resetAddExerciseForm() {
            var dayId = $('#AddExercise_TrainingDayId').val();

            // ریست Select2
            if ($('#AddExercise_ExerciseId').hasClass('select2-hidden-accessible')) {
                $('#AddExercise_ExerciseId').val('').trigger('change');
            } else {
                $('#AddExercise_ExerciseId').val('');
            }

            // ریست فیلدها
            $('#AddExercise_Sets').val('');
            $('#AddExercise_Reps').val('');
            $('#AddExercise_WeightKg').val('');
            $('#AddExercise_RestSeconds').val('');
            $('#AddExercise_CoachNote').val('');

            // ریست پیام تکراری
            $('#duplicateExerciseWarning').hide();

            // TrainingDayId باید بماند
            $('#AddExercise_TrainingDayId').val(dayId);

            // focus روی کمبوباکس
            setTimeout(function () {
                try { $('#AddExercise_ExerciseId').select2('open'); } catch(e) {}
            }, 350);
        }

        // بررسی تکراری بودن حرکت هنگام انتخاب از Select2
        $(document).on('change', '#AddExercise_ExerciseId', function () {
            var exerciseId = $(this).val();
            var dayId = $('#AddExercise_TrainingDayId').val();

            if (!exerciseId || !dayId) {
                $('#duplicateExerciseWarning').hide();
                return;
            }

            var added = _sessionAddedExercises[dayId];
            if (added && added.has(String(exerciseId))) {
                $('#duplicateExerciseWarning').show();
            } else {
                $('#duplicateExerciseWarning').hide();
            }
        });

        // ثبت حرکت — بدون بستن مودال
        $(document).on('click', '#btnSaveExercise', function () {

            var exerciseId = $('#AddExercise_ExerciseId').val();
            var dayId      = $('#AddExercise_TrainingDayId').val();

            // validation — حرکت الزامی
            if (!exerciseId) {
                $('#AddExercise_ExerciseId').closest('.form-group')
                    .find('label').css('color', '#e53e3e');
                if ($('#AddExercise_ExerciseId').hasClass('select2-hidden-accessible')) {
                    $('#AddExercise_ExerciseId').next('.select2-container')
                        .find('.select2-selection')
                        .css('border-color', '#e53e3e');
                }
                setTimeout(function () {
                    $('label[for="AddExercise_ExerciseId"]').css('color', '');
                    $('#AddExercise_ExerciseId').next('.select2-container')
                        .find('.select2-selection').css('border-color', '');
                }, 2000);
                return;
            }

            // بررسی تکراری
            var added = _sessionAddedExercises[dayId] || new Set();
            if (added.has(String(exerciseId))) {
                $('#duplicateExerciseWarning').show();
                // لرزش دکمه
                var $btn = $('#btnSaveExercise');
                $btn.css('animation', 'fcShake 0.4s ease');
                setTimeout(function () { $btn.css('animation', ''); }, 500);
                return;
            }

            // غیرفعال کردن دکمه
            var $btn = $('#btnSaveExercise');
            $btn.prop('disabled', true);
            $('#btnSaveExerciseText').text('در حال ثبت...');
            $('#btnSaveExerciseIcon').removeClass('fa-plus').addClass('fa-spinner fa-spin');

            // نام حرکت انتخاب‌شده
            var exerciseName = $('#AddExercise_ExerciseId option:selected').text();

            $.ajax({
                url: '@Url.Action("AddExercise", "TrainingProgramBuilder", new { area = "Admin" })',
                type: 'POST',
                data: $('#addExerciseForm').serialize(),

                success: function (res) {

                    if (res && res.isSuccess) {

                        // ثبت در لیست session
                        if (!_sessionAddedExercises[dayId]) {
                            _sessionAddedExercises[dayId] = new Set();
                        }
                        _sessionAddedExercises[dayId].add(String(exerciseId));

                        // نمایش بنر موفقیت
                        $('#addExerciseSuccessText').text('حرکت «' + exerciseName + '» با موفقیت ثبت شد.');
                        $('#addExerciseSuccessBanner').slideDown(200);

                        // نمایش تگ در لیست session
                        var tagHtml =
                            '<span style="display:inline-flex;align-items:center;gap:5px;' +
                            'background:#edfaf5;border:1px solid #00C896;color:#276749;' +
                            'border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;">' +
                            '<i class="fa fa-check-circle" style="color:#00C896;"></i>' +
                            exerciseName + '</span>';

                        $('#addedExercisesList').append(tagHtml);
                        $('#addedExercisesPanel').show();

                        // ریست فرم برای ثبت بعدی
                        setTimeout(function () {
                            resetAddExerciseForm();
                            $('#addExerciseSuccessBanner').slideUp(300);
                        }, 1800);

                    } else {
                        // خطا — نمایش در بنر قرمز
                        $('#addExerciseSuccessBanner').hide();
                        var errMsg = (res && res.message) ? res.message : 'خطا در ثبت حرکت';

                        var $errBanner = $('<div id="addExerciseTempError" ' +
                            'style="padding:10px 20px;background:#fff5f5;border-bottom:2px solid #fc8181;' +
                            'font-size:13px;color:#c53030;">' +
                            '<i class="fa fa-times-circle me-2"></i>' + errMsg + '</div>');

                        $('#addExerciseModal .modal-body').prepend($errBanner);

                        setTimeout(function () {
                            $('#addExerciseTempError').fadeOut(400, function () { $(this).remove(); });
                        }, 3000);
                    }
                },

                error: function () {
                    var $errBanner = $('<div id="addExerciseTempError" ' +
                        'style="padding:10px 20px;background:#fff5f5;border-bottom:2px solid #fc8181;' +
                        'font-size:13px;color:#c53030;">' +
                        '<i class="fa fa-times-circle me-2"></i>خطا در ارتباط با سرور</div>');
                    $('#addExerciseModal .modal-body').prepend($errBanner);
                    setTimeout(function () {
                        $('#addExerciseTempError').fadeOut(400, function () { $(this).remove(); });
                    }, 3000);
                },

                complete: function () {
                    $btn.prop('disabled', false);
                    $('#btnSaveExerciseText').text('ثبت حرکت');
                    $('#btnSaveExerciseIcon')
                        .removeClass('fa-spinner fa-spin')
                        .addClass('fa-plus');
                }
            });
        });

        // وقتی مودال بسته می‌شود، صفحه reload شود
        // تا جدول حرکات به‌روز شود
        $(document).on('hidden.bs.modal', '#addExerciseModal', function () {
            var dayId = $('#AddExercise_TrainingDayId').val();
            var added = _sessionAddedExercises[dayId];
            if (added && added.size > 0) {
                location.reload();
            }
        });

        function openEditExerciseModal(id, dayId, exerciseId, sets, reps, weightKg, restSeconds, coachNote) {
            $('#EditExercise_Id').val(id);
            $('#EditExercise_Sets').val(sets !== 'undefined' ? sets : '');
            $('#EditExercise_Reps').val(reps || '');
            $('#EditExercise_WeightKg').val(weightKg !== 'undefined' ? weightKg : '');
            $('#EditExercise_RestSeconds').val(restSeconds !== 'undefined' ? restSeconds : '');
            $('#EditExercise_CoachNote').val(coachNote || '');

            // ذخیره مقدار حرکت برای اعمال بعد از init
            $('#EditExercise_ExerciseId').attr('data-current-val', exerciseId);

            $('#editExerciseMessage').html('');
            $('#editExerciseModal').modal('show');
        }

        function openDeleteExerciseModal(id, exerciseName) {
            $('#DeleteExercise_Id').val(id);
            $('#DeleteExercise_Title').text(exerciseName || '');
            $('#deleteExerciseMessage').html('');
            $('#deleteExerciseModal').modal('show');
        }

        //====================================================
        // Submit handler ها
        //====================================================

        $(document).on('submit', '#addDayForm', function (e) {
            e.preventDefault();
            postForm('#addDayForm', '#btnSaveDay', '#addDayMessage', '@Url.Action("AddDay", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#editDayForm', function (e) {
            e.preventDefault();
            postForm('#editDayForm', '#btnEditDay', '#editDayMessage', '@Url.Action("EditDay", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteDayForm', function (e) {
            e.preventDefault();
            postForm('#deleteDayForm', '#btnDeleteDay', '#deleteDayMessage', '@Url.Action("DeleteDay", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#addExerciseForm', function (e) {
            e.preventDefault();
            // این فرم دیگر با submit ارسال نمی‌شود — از btnSaveExercise click handler استفاده می‌شود
        });

        $(document).on('submit', '#editExerciseForm', function (e) {
            e.preventDefault();
            postForm('#editExerciseForm', '#btnEditExercise', '#editExerciseMessage', '@Url.Action("EditExercise", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteExerciseForm', function (e) {
            e.preventDefault();
            postForm('#deleteExerciseForm', '#btnDeleteExercise', '#deleteExerciseMessage', '@Url.Action("DeleteExercise", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        //====================================================
        // Select2 — رویداد باز شدن هر مودال
        //====================================================

        $(document).ready(function () {

            // مودال افزودن روز
            $('#addDayModal').on('shown.bs.modal', function () {
                initSelect2InModal('#AddDay_DayTypeId', '#addDayModal', null);
            });

            // مودال ویرایش روز
            $('#editDayModal').on('shown.bs.modal', function () {
                var val = $('#EditDay_DayTypeId').attr('data-current-val');
                initSelect2InModal('#EditDay_DayTypeId', '#editDayModal', val);
            });

            // مودال افزودن حرکت
            $('#addExerciseModal').on('shown.bs.modal', function () {
                initSelect2InModal('#AddExercise_ExerciseId', '#addExerciseModal', null);
            });

            // مودال ویرایش حرکت
            $('#editExerciseModal').on('shown.bs.modal', function () {
                var val = $('#EditExercise_ExerciseId').attr('data-current-val');
                initSelect2InModal('#EditExercise_ExerciseId', '#editExerciseModal', val);
            });

        });

        //====================================================
        // Drag & Drop ترتیب حرکات هر روز
        //====================================================

        $(document).ready(function () {

            document.querySelectorAll('[id^="exerciseList_"]').forEach(function (tbody) {

                new Sortable(tbody, {
                    handle: '.drag-handle',
                    animation: 150,
                    onEnd: function (evt) {

                        var items = [];
                        tbody.querySelectorAll('tr[data-item-id]').forEach(function (row, index) {
                            items.push({
                                Id: parseInt(row.getAttribute('data-item-id'), 10),
                                SortOrder: index + 1
                            });
                        });

                        $.ajax({
                            url: '@Url.Action("ReorderExercises", "TrainingProgramBuilder", new { area = "Admin" })',
                            type: 'POST',
                            contentType: 'application/json',
                            headers: {
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            },
                            data: JSON.stringify(items),
                            success: function (res) {
                                if (!res.isSuccess) {
                                    Swal.fire('هشدار', res.message || 'خطا در ذخیره ترتیب', 'warning');
                                }
                            },
                            error: function () {
                                Swal.fire('خطا', 'خطا در ارتباط با سرور', 'error');
                            }
                        });

                        tbody.querySelectorAll('tr[data-item-id]').forEach(function (row, index) {
                            row.querySelector('td:nth-child(2)').innerText = (index + 1);
                        });
                    }
                });

            });

        });

    </script>

    <style>
        /* انیمیشن لرزش دکمه برای خطای تکراری */
        @@keyframes fcShake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            40%       { transform: translateX(6px); }
            60%       { transform: translateX(-4px); }
            80%       { transform: translateX(4px); }
        }

        /* hover دکمه ثبت */
        #btnSaveExercise:not(:disabled):hover {
            background: #00a87d !important;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(0,200,150,0.35);
        }

        #btnSaveExercise:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
    </style>
}
