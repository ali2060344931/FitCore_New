                        }
                        <div class="exercise-muscle-filter-bar mb-3 p-3 rounded-3"
                             style="background:linear-gradient(135deg,#ebf8ff,#f0fff4);border:1px solid #bee3f8;">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <div style="font-size:13px;font-weight:700;color:#2b6cb0;white-space:nowrap;">
                                    <i class="fa fa-filter me-1"></i> فیلتر عضله:
                                </div>
