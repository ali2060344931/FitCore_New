                    </div>



                </div>

                <!-- تولبار -->
                <div class="program-toolbar mt-3 pt-3 border-top">
                    <div class="d-flex align-items-center gap-1 flex-nowrap overflow-auto">

                        <button class="btn btn-sm btn-success px-2 py-0 text-nowrap"
                                data-toggle="modal"
                                data-target="#addDayModal">
                            <i class="fa fa-plus"></i>
                            <span class="d-none d-md-inline ms-1">افزودن روز تمرینی</span>
                        </button>

                        <a class="btn btn-sm btn-outline-success px-2 py-0 text-nowrap"
                           asp-area="Admin"
                           asp-controller="Exercise"
                           asp-action="Create"
                           target="_blank">
                            <i class="fa fa-plus"></i>
                            <span class="d-none d-md-inline ms-1">افزودن حرکت به بانک</span>
                        </a>


                        <button class="btn btn-sm btn-outline-danger px-2 py-0 text-nowrap"
                                type="button"
                                onclick="openDeleteAllTrainingDaysModal(@program?.Id)">
                            <i class="fa fa-trash"></i>
                            <span class="d-none d-md-inline ms-1">حذف همه روزها</span>
                        </button>




                        <a class="btn btn-sm btn-outline-success px-2 py-0 text-nowrap"
                           asp-area="Admin"
                           asp-controller="TrainingProgram"
                           asp-action="PrintProgram"
                           asp-route-id="@SecurityUtils.EncryptId(@program.Id)">
                            <i class="fa fa-print me-2 text-primary"></i>گزارش PDF
                        </a>



                        <!-- ارسال پیام به کاربر در ربات بله -->
                        <button class="btn btn-sm btn-outline-primary px-2 py-0 text-nowrap"
                            @(program?.BaleChatId == null ? "disabled" : "")
                                onclick="sendProgramNotificationToUser(@program?.Id)">
                            <i class="fa fa-bell"></i>
                            <span class="d-none d-md-inline ms-1">ارسال پیام برنامه جدید به کاربر</span>
                        </button>

                        <!-- اطلاعات جسمانی ورزشکار -->
                        <button class="btn btn-sm btn-outline-dark px-2 py-0 text-nowrap"
                                type="button"
                                data-toggle="modal"
                                data-target="#memberInfoModal">
                            <i class="fa fa-clipboard-list"></i>
                            <span class="d-none d-md-inline ms-1"><i class="fa fa-heart" aria-hidden="true"></i>اطلاعات جسمانی ورزشکار</span>
                        </button>



                        <button class="btn btn-sm btn-outline-secondary px-2 py-0 text-nowrap"
                                onclick="location.reload()">
                            <i class="fa fa-refresh"></i>
                        </button>

                        <a class="btn btn-sm btn-outline-secondary px-2 py-0 text-nowrap"
                           href="/Admin/TrainingProgram">
                            <i class="fa fa-reply"></i>
                        </a>
                    </div>
                </div>
                <!-- پایان تولبار -->

            </div>
        </div>
    </div>

    <div class="content-body">
        @if (program == null)
        {
            <div class="alert alert-danger">اطلاعات برنامه تمرینی یافت نشد.</div>
        }
        else
        {
            @if (program.Days == null || program.Days.Count == 0)
            {
                <div class="alert alert-info">هنوز هیچ روزی برای این برنامه ثبت نشده است.</div>
            }
            else
            {
                <div id="daysAccordion" class="nutrition-days-accordion">

                    @for (int i = 0; i < program.Days.Count; i++)
                    {
                        var day = program.Days[i];
                        var collapseId = $"collapseDay_{day.Id}";
                        var headingId = $"headingDay_{day.Id}";

                        <div class="card nutrition-day-card mb-2 border-0 shadow-sm rounded-4 overflow-hidden">

                            <!-- هدر روز -->
                            <div class="d-flex align-items-center flex-nowrap gap-2 day-header-box">

                                <div class="day-actions d-flex align-items-center gap-1 flex-shrink-0">

                                    <button type="button"
                                            class="btn btn-sm btn-outline-facebook rounded-pill"
                                            onclick="openAddExerciseModal('@day.Id', `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                        <i class="fa fa-plus"></i>
                                        <span class="d-none d-md-inline ms-1">افزودن حرکت</span>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-google rounded-pill"
                                            onclick="openEditDayModal('@day.Id','@day.DayNumber','@day.DayType','@day.DurationMinutes',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`,`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Description ?? ""))`)">
                                        <i class="fa fa-pencil-square-o"></i>
                                        <span class="d-none d-md-inline ms-1">ویرایش روز</span>
                                    </button>

                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger rounded-pill"
                                            onclick="openDeleteDayModal('@day.Id',`@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                        <i class="fa fa-times"></i>
                                        <span class="d-none d-md-inline ms-1">حذف روز</span>
                                    </button>

                                </div>

                                <button class="btn btn-link nutrition-day-toggle text-decoration-none p-0 font-weight-bold d-flex align-items-center gap-2 text-nowrap collapsed"
                                        data-toggle="collapse"
                                        data-target="#@collapseId"
                                        aria-expanded="false"
                                        aria-controls="@collapseId">

                                    <span class="day-label">روز</span>
                                    <span class="day-number-badge">@ToPersianNumbers(day.DayNumber)</span>

                                    @if (!string.IsNullOrWhiteSpace(day.Title))
                                    {
                                        <span class="day-title-text">@day.Title</span>
                                    }

                                    <span class="badge bg-secondary text-white px-2 py-1 rounded-pill">
                                        @day.DayType
                                    </span>

                                    @if (day.DurationMinutes.HasValue)
                                    {
                                        <span class="badge bg-light text-dark border px-2 py-1 rounded-pill">
                                            <i class="fa fa-clock-o"></i>
                                            @ToPersianNumbers(day.DurationMinutes.Value) دقیقه
                                        </span>
                                    }

                                    @if (day.Exercises != null && day.Exercises.Count > 0)
                                    {
                                        <span class="badge bg-info text-white px-2 py-1 rounded-pill"
                                              data-toggle="tooltip"
                                              title="در این روز @ToPersianNumbers(day.Exercises.Count) حرکت ثبت شده است">
                                            @ToPersianNumbers(day.Exercises.Count) حرکت
                                        </span>
                                    }

                                    <i class="fa fa-chevron-down text-muted day-collapse-icon"></i>
                                </button>

                            </div>

                            <!-- بدنه روز -->
                            <div id="@collapseId"
                                 class="collapse"
                                 aria-labelledby="@headingId"
                                 data-parent="#daysAccordion">

                                <div class="card-body nutrition-day-body">

                                    @if (!string.IsNullOrWhiteSpace(day.Description))
                                    {
                                        <div class="alert alert-light border mb-3">
                                            <i class="fa fa-info-circle text-muted"></i>
                                            @day.Description
                                        </div>
                                    }

                                    @if (day.Exercises == null || day.Exercises.Count == 0)
                                    {
                                        <div class="empty-state empty-state-light border rounded-4 mb-0">
                                            <div class="text-center p-4 border rounded-4 border-dashed"
                                                 style="background-color: #fef2f2; border-color: #fca5a5 !important;">

                                                <div style="color: #b91c1c;">
                                                    <i class="fa fa-list-ul fa-2x mb-2"></i>
                                                    <h6 class="fw-bold">هنوز هیچ حرکتی برای این روز ثبت نشده!</h6>
                                                </div>

                                                <button type="button"
                                                        class="btn btn-sm btn-outline-facebook rounded-pill mt-2"
                                                        onclick="openAddExerciseModal('@day.Id', `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(day.Title ?? ""))`)">
                                                    <i class="fa fa-plus me-1"></i> افزودن اولین حرکت
                                                </button>

                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle nutrition-food-table">
                                                <thead class="text-uppercase text-nowrap">
                                                    <tr>
                                                        <th style="width: 40px;" title="جابجایی با درگ">
                                                            <i class="fa fa-arrows"></i>
                                                        </th>
                                                        <th style="width: 50px;">ردیف</th>
                                                        <th>نام حرکت</th>
                                                        <th>گروه عضلانی</th>
                                                        <th>ابزار/دستگاه</th>
                                                        <th class="text-center">ست</th>
                                                        <th class="text-center">تکرار</th>
                                                        <th class="text-center">وزن (kg)</th>
                                                        <th class="text-center">استراحت (s)</th>
                                                        <th>یادداشت مربی</th>
                                                        <th class="ps-3">عملیات</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="exerciseList_@day.Id" data-day-id="@day.Id">
                                                    @{
                                                        int counter = 1;
                                                    }
                                                    @foreach (var ex in day.Exercises)
                                                    {
                                                        <tr data-item-id="@ex.Id" data-exercise-id="@ex.ExerciseId">
                                                            <td class="text-center text-muted drag-handle" style="cursor: move;">
                                                                <i class="fa fa-bars"></i>
                                                            </td>
                                                            <td class="text-center fw-bold text-muted">@counter</td>
                                                            <td class="food-name-cell text-nowrap">@ex.ExerciseName</td>
                                                            <td class="food-name-cell text-nowrap">@ex.MuscleGroup</td>
                                                            <td class="food-name-cell text-nowrap">@(ex.EquipmentType ?? "-")</td>
                                                            <td class="text-center text-nowrap">
                                                                <span class="badge bg-light text-dark border amount-badge">@(ex.Sets?.ToString() ?? "-")</span>
                                                            </td>
                                                            <td class="text-center text-nowrap">@(ex.Reps ?? "-")</td>
                                                            <td class="text-center text-nowrap">@(ex.WeightKg?.ToString() ?? "-")</td>
                                                            <td class="text-center text-nowrap">@(ex.RestSeconds?.ToString() ?? "-")</td>
                                                            <td class="food-name-cell text-nowrap food-description-cell">@(ex.CoachNote ?? "-")</td>
                                                            <td class="text-nowrap ps-3">
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <button type="button" class="btn btn-sm btn-outline-warning btn-modern"
                                                                            onclick="openEditExerciseModal('@ex.Id','@day.Id','@ex.ExerciseId','@ex.Sets','@(ex.Reps ?? "")','@ex.WeightKg','@ex.RestSeconds','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(ex.CoachNote ?? ""))')">
                                                                        ویرایش
                                                                    </button>
                                                                    <button type="button" class="btn btn-sm btn-outline-danger btn-modern"
                                                                            onclick="openDeleteExerciseModal('@ex.Id','@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(ex.ExerciseName ?? ""))')">
                                                                        حذف
                                                                    </button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        counter++;
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }

                                </div>

                            </div>

                        </div>
                    }

                </div>
            }
        }
    </div>
</div>

@section Modals {

    <!-- افزودن روز تمرینی -->
    <div class="modal fade" id="addDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">افزودن روز تمرینی جدید</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="addDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TrainingProgramId" value="@program?.Id" />

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>شماره روز</label>
                                <input type="number" class="form-control" name="DayNumber" min="1" max="14" required />
                            </div>
                            <div class="form-group col-md-6">
                                <label>نوع روز</label>
                                <select class="form-control js-select2-modal" name="DayTypeId" id="AddDay_DayTypeId" required>
                                    <option value="">انتخاب کنید...</option>
                                    @foreach (var dt in Model.DayTypes)
                                    {
                                        <option value="@dt.Value">@dt.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>عنوان روز</label>
                            <input type="text" class="form-control" name="Title" placeholder="مثلاً: سینه و سه‌سر" />
                        </div>

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>مدت زمان (دقیقه)</label>
                                <input type="number" class="form-control" name="DurationMinutes" min="1" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label>توضیحات</label>
                            <textarea class="form-control" name="Description" rows="2"></textarea>
                        </div>
                    </form>
                    <div id="addDayMessage" class="mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary" id="btnSaveDay" form="addDayForm"><span class="btn-text">ثبت</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">بستن</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ویرایش روز تمرینی -->
    <div class="modal fade" id="editDayModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        ویرایش روز: <small class="swal2-textarea countdown-timer mt-1"><span id="EditDay_Title" class="countdown-text"></span></small>
                    </h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form id="editDayForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="EditDay_Id" name="Id" />

                        <div class="row">
                            <div class="form-group col-md-6">
                                <label>شماره روز</label>
                                <input type="number" class="form-control" id="EditDay_DayNumber" name="DayNumber" min="1" max="14" required />
                            </div>
                            <div class="form-group col-md-6">
                                <label>نوع روز</label>
                                <select class="form-control js-select2-modal" id="EditDay_DayTypeId" name="DayTypeId" required>
                                    <option value="">انتخاب کنید...</option>
                                    @foreach (var dt in Model.DayTypes)
                                    {
                                        <option value="@dt.Value">@dt.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>عنوان روز</label>
                            <input type="text" class="form-control" id="EditDay_Title_txt" name="Title" />
                        </div>

                        <div class="row">
