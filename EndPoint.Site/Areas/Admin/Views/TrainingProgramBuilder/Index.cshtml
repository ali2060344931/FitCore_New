@using FitCore.Common
@model EndPoint.Site.Areas.Admin.Models.TrainingProgramBuilderPageViewModel

@functions {
    public static string ToPersianNumbers(int value)
    {
        var persianDigits = new[] { '۰', '۱', '۲', '۳', '۴', '۵', '۶', '۷', '۸', '۹' };
        var input = value.ToString();
        var result = new System.Text.StringBuilder();

        foreach (var ch in input)
        {
            if (char.IsDigit(ch))
                result.Append(persianDigits[ch - '0']);
            else
                result.Append(ch);
        }

        return result.ToString();
    }
}

@{
    ViewData["Title"] = "ساخت برنامه تمرینی";
    Layout = "~/Areas/Admin/Views/Shared/Layouts/_AdminLayout.cshtml";

    var program = Model?.Program;
    var encryptedId = ViewBag.EncryptedId as string;
}

@{
    string memberImgUrl = ViewBag.MemberProfileImage as string;

    string frontImg = ViewBag.FrontImage as string;
    string sideImg = ViewBag.SideImage as string;
    string backImg = ViewBag.BackImage as string;
}


<style>

    @@keyframes fcShake {
        0%, 100% {
            transform: translateX(0);
        }

        20% {
            transform: translateX(-6px);
        }

        40% {
            transform: translateX(6px);
        }

        60% {
            transform: translateX(-4px);
        }

        80% {
            transform: translateX(4px);
        }
    }

    /* hover دکمه ثبت */
    #btnSaveExercise:not(:disabled):hover {
        background: #00a87d !important;
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(0,200,150,0.35);
    }

    #btnSaveExercise:disabled {
        opacity: 0.7;
        cursor: not-allowed;
    }










    .image-modal {
        display: none; /* به صورت پیش فرض مخفی است */
        position: fixed;
        z-index: 9999; /* برای اینکه روی بقیه اجزا باشد */
        padding-top: 100px;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        overflow: auto;
        background-color: rgba(0, 0, 0, 0.8); /* پس زمینه تیره شیشه ای */
    }

    .modal-image {
        margin: auto;
        display: block;
        max-width: 80%;
        max-height: 80vh;
        border-radius: 8px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    }

    /* استایل دکمه بستن (چون سایت شما فارسی است دکمه را چپ چین کردم) */
    .modal-close {
        position: absolute;
        top: 20px;
        left: 30px;
        color: #f1f1f1;
        font-size: 40px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .modal-close:hover,
        .modal-close:focus {
            color: #bbb;
            text-decoration: none;
        }


    .body-photo {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        background-position: center;
        background-size: cover;
        border: 2px solid #e2e8f0;
        cursor: pointer;
        transition: .25s;
        flex-shrink: 0;
    }

        .body-photo:hover {
            transform: scale(1.15);
            border-color: #00C896;
            box-shadow: 0 0 10px rgba(0,200,150,.35);
        }

</style>




<div class="page-content-wrapper builder-wrapper">

    <div class="program-header-sticky-wrapper">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body py-3 px-3">

                <!-- ردیف اطلاعات اصلی -->
