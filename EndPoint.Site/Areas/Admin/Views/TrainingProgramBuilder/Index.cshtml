                <div class="modal-footer">
                    <button type="submit" class="btn btn-danger" id="btnDeleteExercise" form="deleteExerciseForm"><span class="btn-text">حذف</span></button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">انصراف</button>
