        @* ---------- استایل مودال اطلاعات جسمانی ---------- *@
    <style>
        .modal-backdrop.show { z-index: 10550 !important; }
        .modal.show { z-index: 10600 !important; }
        
        .info-grid {
            display: grid;
            grid-template-columns: 140px 1fr;
            gap: 8px 15px;
            font-size: 13px;
            align-items: baseline;
        }
        .info-label {
            color: #64748b;
            font-weight: bold;
        }
        .info-value {
            font-weight: 500;
            text-align: right;
            word-break: break-word;
        }
        .info-card {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px 15px;
            margin-bottom: 15px;
        }
    </style>

    @* ---------- مودال اطلاعات جسمانی ورزشکار ---------- *@
    <div class="modal fade" id="memberInfoModal" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content border-0 shadow" style="border-radius:14px;overflow:hidden;">
                <div class="modal-header border-0 pb-2"
                     style="background:linear-gradient(135deg,#0f1117,#1a2035);padding:16px 20px;">
                    <h5 class="modal-title text-white mb-0" style="font-size:15px;">
                        <i class="fa fa-clipboard-list me-2" style="color:#68D391;"></i>
                        تجزیه و تحلیل اطلاعات ورزشکار
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" style="opacity:0.7;">&times;</button>
                </div>
                
                <div class="modal-body" style="padding:20px;">
                    @if (Model.MemberDetails != null)
                    {
                        <!-- اطلاعات پایه -->
                        <h6 class="border-bottom pb-2 mb-3 text-muted" style="font-size:14px;"><i class="fa fa-user me-2"></i>مشخصات پایه</h6>
                        <div class="info-card">
                            <div class="info-grid">
                                <span class="info-label">جنسیت:</span>
                                <span class="info-value">@((int)Model.MemberDetails.Gender == 1 ? "مرد" : (int)Model.MemberDetails.Gender == 2 ? "زن" : "نامشخص")</span>
                                
                                <span class="info-label">تاریخ تولد:</span>
                                <span class="info-value">@(Model.MemberDetails.BirthDate ?? "-")</span>
                                
                                <span class="info-label">قد (سانتی‌متر):</span>
                                <span class="info-value">@(Model.MemberDetails.Height?.ToString() ?? "-")</span>
                                
                                <span class="info-label">سطح فعالیت:</span>
                                <span class="info-value">@(Model.MemberDetails.ActivityLevel?.Name ?? "-")</span>
                                
                                <span class="info-label">سطح تجربه:</span>
                                <span class="info-value">@(Model.MemberDetails.ExperienceLevel?.Name ?? "-")</span>
                                
                                <span class="info-label">وضعیت عضویت:</span>
                                <span class="info-value">@Html.Raw(Model.MemberDetails.IsActive == true ? "<span class='text-success'>فعال</span>" : "<span class='text-danger'>غیرفعال</span>")</span>
                            </div>
                        </div>

                        <!-- اطلاعات پزشکی -->
                        <h6 class="border-bottom pb-2 mt-3 mb-3 text-muted" style="font-size:14px;"><i class="fa fa-notes-medical me-2"></i>سوابق پزشکی و حساسیت‌ها</h6>
                        <div class="info-card">
                            <div class="info-grid">
                                <span class="info-label">حساسیت‌های غذایی:</span>
                                <span class="info-value">@(string.IsNullOrEmpty(Model.MemberDetails.FoodAllergies) ? "ندارد" : Model.MemberDetails.FoodAllergies)</span>
                            </div>
                            <div class="info-grid">
                                <span class="info-label">بیماری‌ها:</span>
                                <span class="info-value">@(string.IsNullOrEmpty(Model.MemberDetails.MedicalConditions) ? "ندارد" : Model.MemberDetails.MedicalConditions)</span>
                            </div>
                            <div class="info-grid">
                                <span class="info-label">آسیب‌دیدگی‌ها:</span>
                                <span class="info-value">@(string.IsNullOrEmpty(Model.MemberDetails.Injuries) ? "ندارد" : Model.MemberDetails.Injuries)</span>
                            </div>
                        </div>

                        <!-- اندازه گیری های بدن -->
                        <h6 class="border-bottom pb-2 mt-3 mb-3 text-muted" style="font-size:14px;"><i class="fa fa-weight me-2"></i>سوابق اندازه‌گیری بدن</h6>
                        @if (Model.MemberDetails.memberBodyMeasurements != null && Model.MemberDetails.memberBodyMeasurements.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-bordered table-hover text-center" style="font-size:13px;">
                                    <thead class="thead-light">
                                        <tr>
                                            <th>تاریخ ثبت</th>
                                            <th>وزن (کیلو)</th>
                                            <th>درصد چربی</th>
                                            <th>دور کمر</th>
                                            <th>دور باسن</th>
                                            <th>دور سینه</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var m in Model.MemberDetails.memberBodyMeasurements.OrderByDescending(x => x.Id))
                                        {
                                            <tr>
                                                <td class="text-nowrap">@m.RecordDate</td>
                                                <td>@(m.Weight?.ToString() ?? "-")</td>
                                                <td>@(m.BodyFatPercentage?.ToString() ?? "-")</td>
                                                <td>@(m.Waist?.ToString() ?? "-")</td>
                                                <td>@(m.Hip?.ToString() ?? "-")</td>
                                                <td>@(m.Chest?.ToString() ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-light text-center mb-0" style="font-size:13px;border-radius:8px;">
                                <i class="fa fa-info-circle me-1"></i> هیچ سابقه اندازه‌گیری برای این ورزشکار ثبت نشده است.
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.MemberDetails.Description))
                        {
                            <div class="info-card mt-3">
                                <div class="info-grid">
                                    <span class="info-label">توضیحات تکمیلی:</span>
                                    <span class="info-value">@Model.MemberDetails.Description</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0 text-center">اطلاعات ورزشکار در دسترس نیست.</div>
                    }
                </div>

                <div class="modal-footer border-0" style="padding:12px 20px;background:#f8fafd;">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal" style="border-radius:9px;font-size:13px;">بستن</button>
                </div>
            </div>
        </div>
    </div>




    <!-- پنجره پاپ آپ تصویر (خارج از تمامی div های دیگر باشد) -->
    <div id="imageModal" class="image-modal" onclick="closeImageModal(event)">
        <span class="modal-close" onclick="closeImageModal()">&times;</span>
        <img class="modal-image" id="modalImg" src="" alt="تصویر پرسنلی">
    </div>



}






@section Scripts {

    @* <link href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script> *@

    <!-- SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.css">

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.14.5/dist/sweetalert2.min.js"></script>



    <!-- SortableJS برای جابجایی (Drag & Drop) حرکات هر روز -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>

    <script>

        //====================================================
        // توابع کمکی
        //====================================================

        function setButtonLoading($btn, isLoading, text) {
            if (isLoading) {
                $btn.prop('disabled', true);
                $btn.data('original-text', $btn.find('.btn-text').text());
                $btn.find('.btn-text').text(text || 'در حال انجام...');
            } else {
                $btn.prop('disabled', false);
                $btn.find('.btn-text').text($btn.data('original-text') || 'ثبت');
            }
        }

        function showMessage(selector, type, message) {
            $(selector).html('<div class="alert alert-' + type + ' mb-0">' + message + '</div>');
        }

        function postForm(formSelector, buttonSelector, messageSelector, url, options) {
            options = options || {};
            var reloadOnSuccess = options.reloadOnSuccess !== undefined ? options.reloadOnSuccess : true;
            var onSuccess = options.onSuccess || null;

            var $form = $(formSelector);
            var $btn = $(buttonSelector);

            setButtonLoading($btn, true, 'در حال انجام...');

            $.ajax({
                url: url,
                type: 'POST',
                data: $form.serialize(),
                success: function (res) {
                    if (res && res.isSuccess) {
                        showMessage(messageSelector, 'success', res.message || 'عملیات با موفقیت انجام شد.');
                        if (typeof onSuccess === 'function') {
                            onSuccess(res, $form);
                        }
                        if (reloadOnSuccess) {
                            setTimeout(function () { location.reload(); }, 700);
                        }
                    } else {
                        showMessage(messageSelector, 'danger', (res && res.message) ? res.message : 'عملیات انجام نشد.');
                    }
                },
                error: function (xhr) {
                    showMessage(messageSelector, 'danger', 'خطا در ارتباط با سرور.');
                    console.log(xhr.responseText);
                },
                complete: function () {
                    setButtonLoading($btn, false);
                }
            });
        }

        //====================================================
        // Select2 — راه‌اندازی در مودال‌ها
        //====================================================

        function initSelect2InModal(selector, modalSelector, currentVal) {
            var $el = $(selector);

            // در صورتی که قبلاً init شده، destroy و دوباره init
            if ($el.hasClass('select2-hidden-accessible')) {
                $el.select2('destroy');
            }

            $el.select2({
                dir: 'rtl',
                width: '100%',
                language: 'fa',
                theme: 'bootstrap4',
                placeholder: 'جستجو و انتخاب کنید...',
                allowClear: true,
                dropdownParent: $(modalSelector)
            });

            // اعمال مقدار انتخابی (برای حالت ویرایش)
            if (currentVal) {
                $el.val(currentVal).trigger('change');
            }
        }

        //====================================================
        // روز تمرینی — مودال افزودن
        //====================================================

        function openEditDayModal(id, dayNumber, dayTypeId, durationMinutes, title, description) {
            $('#EditDay_Id').val(id);
            $('#EditDay_DayNumber').val(dayNumber);
            $('#EditDay_DurationMinutes').val(durationMinutes && durationMinutes !== 'undefined' ? durationMinutes : '');
            $('#EditDay_Title').text(title || '');
            $('#EditDay_Title_txt').val(title || '');
            $('#EditDay_Description').val(description || '');

            // ذخیره مقدار نوع روز برای اعمال بعد از init
            $('#EditDay_DayTypeId').attr('data-current-val', dayTypeId);

            $('#editDayMessage').html('');
            $('#editDayModal').modal('show');
        }

        function openDeleteDayModal(id, title) {
            $('#DeleteDay_Id').val(id);
            $('#DeleteDay_Title').text(title || '');
            $('#deleteDayMessage').html('');
            $('#deleteDayModal').modal('show');
        }

        //====================================================
        // حرکات تمرینی — مودال‌های افزودن/ویرایش/حذف
        //====================================================

        // شناسه‌های حرکاتی که در این جلسه به این روز اضافه شده‌اند
        // کلید: dayId → Set از exerciseId های ثبت‌شده
        var _sessionAddedExercises = {};

        function openAddExerciseModal(dayId, dayTitle) {
            $('#AddExercise_TrainingDayId').val(dayId);
            $('#addExerciseDayTitle').text(dayTitle || '');

            // ریست فرم
            resetAddExerciseForm();

            // ریست پیام‌ها
            $('#addExerciseSuccessBanner').hide();
            $('#addedExercisesPanel').hide();
            $('#addedExercisesList').html('');

            //====================================
            // خواندن حرکات از قبل موجود در این روز از DOM
            // (هم از دیتابیس + هم از همین session)
            //====================================
            var existingSet = new Set();

            $('#exerciseList_' + dayId + ' tr[data-exercise-id]').each(function () {
                var eid = $(this).attr('data-exercise-id');
                if (eid) existingSet.add(String(eid));
            });

            _sessionAddedExercises[dayId] = existingSet;

            $('#addExerciseModal').modal('show');
        }

        function resetAddExerciseForm() {
            var dayId = $('#AddExercise_TrainingDayId').val();

            // ریست Select2
            if ($('#AddExercise_ExerciseId').hasClass('select2-hidden-accessible')) {
                $('#AddExercise_ExerciseId').val('').trigger('change');
            } else {
                $('#AddExercise_ExerciseId').val('');
            }

            // ریست فیلدها
            $('#AddExercise_Sets').val('');
            $('#AddExercise_Reps').val('');
            $('#AddExercise_WeightKg').val('');
            $('#AddExercise_RestSeconds').val('');
            $('#AddExercise_CoachNote').val('');

            // ریست پیام تکراری
            $('#duplicateExerciseWarning').hide();

            // TrainingDayId باید بماند
            $('#AddExercise_TrainingDayId').val(dayId);

            // focus روی کمبوباکس
            setTimeout(function () {
                try { $('#AddExercise_ExerciseId').select2('open'); } catch(e) {}
            }, 350);
        }

        // بررسی تکراری بودن حرکت هنگام انتخاب از Select2
        $(document).on('change', '#AddExercise_ExerciseId', function () {
            var exerciseId = $(this).val();
            var dayId = $('#AddExercise_TrainingDayId').val();

            if (!exerciseId || !dayId) {
                $('#duplicateExerciseWarning').hide();
                return;
            }

            var added = _sessionAddedExercises[dayId];
            if (added && added.has(String(exerciseId))) {
                $('#duplicateExerciseWarning').show();
            } else {
                $('#duplicateExerciseWarning').hide();
            }
        });

        // ثبت حرکت — بدون بستن مودال
        $(document).on('click', '#btnSaveExercise', function () {

            var exerciseId = $('#AddExercise_ExerciseId').val();
            var dayId      = $('#AddExercise_TrainingDayId').val();

            // validation — حرکت الزامی
            if (!exerciseId) {
                $('#AddExercise_ExerciseId').closest('.form-group')
                    .find('label').css('color', '#e53e3e');
                if ($('#AddExercise_ExerciseId').hasClass('select2-hidden-accessible')) {
                    $('#AddExercise_ExerciseId').next('.select2-container')
                        .find('.select2-selection')
                        .css('border-color', '#e53e3e');
                }
                setTimeout(function () {
                    $('label[for="AddExercise_ExerciseId"]').css('color', '');
                    $('#AddExercise_ExerciseId').next('.select2-container')
                        .find('.select2-selection').css('border-color', '');
                }, 2000);
                return;
            }

            // بررسی تکراری
            var added = _sessionAddedExercises[dayId] || new Set();
            if (added.has(String(exerciseId))) {
                $('#duplicateExerciseWarning').show();
                // لرزش دکمه
                var $btn = $('#btnSaveExercise');
                $btn.css('animation', 'fcShake 0.4s ease');
                setTimeout(function () { $btn.css('animation', ''); }, 500);
                return;
            }

            // غیرفعال کردن دکمه
            var $btn = $('#btnSaveExercise');
            $btn.prop('disabled', true);
            $('#btnSaveExerciseText').text('در حال ثبت...');
            $('#btnSaveExerciseIcon').removeClass('fa-plus').addClass('fa-spinner fa-spin');

            // نام حرکت انتخاب‌شده
            var exerciseName = $('#AddExercise_ExerciseId option:selected').text();

            $.ajax({
                url: '@Url.Action("AddExercise", "TrainingProgramBuilder", new { area = "Admin" })',
                type: 'POST',
                data: $('#addExerciseForm').serialize(),

                success: function (res) {

                    if (res && res.isSuccess) {

                        // ثبت در لیست session
                        if (!_sessionAddedExercises[dayId]) {
                            _sessionAddedExercises[dayId] = new Set();
                        }
                        _sessionAddedExercises[dayId].add(String(exerciseId));

                        // اضافه کردن سطر مجازی به DOM برای بررسی تکراری بعدی
                        // (بدون نیاز به reload)
                        var $tbody = $('#exerciseList_' + dayId);
                        if ($tbody.length) {
                            $tbody.append(
                                '<tr data-item-id="new_' + exerciseId +
                                '" data-exercise-id="' + exerciseId +
                                '" class="fc-ghost-row" style="display:none;"></tr>'
                            );
                        }

                        // نمایش بنر موفقیت
                        $('#addExerciseSuccessText').text('حرکت «' + exerciseName + '» با موفقیت ثبت شد.');
                        $('#addExerciseSuccessBanner').slideDown(200);

                        // نمایش تگ در لیست session
                        var tagHtml =
                            '<span style="display:inline-flex;align-items:center;gap:5px;' +
                            'background:#edfaf5;border:1px solid #00C896;color:#276749;' +
                            'border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;">' +
                            '<i class="fa fa-check-circle" style="color:#00C896;"></i>' +
                            exerciseName + '</span>';

                        $('#addedExercisesList').append(tagHtml);
                        $('#addedExercisesPanel').show();

                        // ریست فرم برای ثبت بعدی
                        setTimeout(function () {
                            resetAddExerciseForm();
                            $('#addExerciseSuccessBanner').slideUp(300);
                        }, 1800);

                    } else {
                        // خطا — نمایش در بنر قرمز
                        $('#addExerciseSuccessBanner').hide();
                        var errMsg = (res && res.message) ? res.message : 'خطا در ثبت حرکت';

                        var $errBanner = $('<div id="addExerciseTempError" ' +
                            'style="padding:10px 20px;background:#fff5f5;border-bottom:2px solid #fc8181;' +
                            'font-size:13px;color:#c53030;">' +
                            '<i class="fa fa-times-circle me-2"></i>' + errMsg + '</div>');

                        $('#addExerciseModal .modal-body').prepend($errBanner);

                        setTimeout(function () {
                            $('#addExerciseTempError').fadeOut(400, function () { $(this).remove(); });
                        }, 3000);
                    }
                },

                error: function () {
                    var $errBanner = $('<div id="addExerciseTempError" ' +
                        'style="padding:10px 20px;background:#fff5f5;border-bottom:2px solid #fc8181;' +
                        'font-size:13px;color:#c53030;">' +
                        '<i class="fa fa-times-circle me-2"></i>خطا در ارتباط با سرور</div>');
                    $('#addExerciseModal .modal-body').prepend($errBanner);
                    setTimeout(function () {
                        $('#addExerciseTempError').fadeOut(400, function () { $(this).remove(); });
                    }, 3000);
                },

                complete: function () {
                    $btn.prop('disabled', false);
                    $('#btnSaveExerciseText').text('ثبت حرکت');
                    $('#btnSaveExerciseIcon')
                        .removeClass('fa-spinner fa-spin')
                        .addClass('fa-plus');
                }
            });
        });

        // وقتی مودال بسته می‌شود، صفحه reload شود
        // تا جدول حرکات به‌روز شود
        $(document).on('hidden.bs.modal', '#addExerciseModal', function () {
            var dayId = $('#AddExercise_TrainingDayId').val();
            var added = _sessionAddedExercises[dayId];
            if (added && added.size > 0) {
                location.reload();
            }
        });

        function openEditExerciseModal(id, dayId, exerciseId, sets, reps, weightKg, restSeconds, coachNote) {
            $('#EditExercise_Id').val(id);
            $('#EditExercise_Sets').val(sets !== 'undefined' ? sets : '');
            $('#EditExercise_Reps').val(reps || '');
            $('#EditExercise_WeightKg').val(weightKg !== 'undefined' ? weightKg : '');
            $('#EditExercise_RestSeconds').val(restSeconds !== 'undefined' ? restSeconds : '');
            $('#EditExercise_CoachNote').val(coachNote || '');

            // ذخیره مقدار حرکت برای اعمال بعد از init
            $('#EditExercise_ExerciseId').attr('data-current-val', exerciseId);

            $('#editExerciseMessage').html('');
            $('#editExerciseModal').modal('show');
        }

        function openDeleteExerciseModal(id, exerciseName) {
            $('#DeleteExercise_Id').val(id);
            $('#DeleteExercise_Title').text(exerciseName || '');
            $('#deleteExerciseMessage').html('');
            $('#deleteExerciseModal').modal('show');
        }

        //====================================================
        // Submit handler ها
        //====================================================

        $(document).on('submit', '#addDayForm', function (e) {
            e.preventDefault();
            postForm('#addDayForm', '#btnSaveDay', '#addDayMessage', '@Url.Action("AddDay", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#editDayForm', function (e) {
            e.preventDefault();
            postForm('#editDayForm', '#btnEditDay', '#editDayMessage', '@Url.Action("EditDay", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteDayForm', function (e) {
            e.preventDefault();
            postForm('#deleteDayForm', '#btnDeleteDay', '#deleteDayMessage', '@Url.Action("DeleteDay", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#addExerciseForm', function (e) {
            e.preventDefault();
            // این فرم دیگر با submit ارسال نمی‌شود — از btnSaveExercise click handler استفاده می‌شود
        });

        $(document).on('submit', '#editExerciseForm', function (e) {
            e.preventDefault();
            postForm('#editExerciseForm', '#btnEditExercise', '#editExerciseMessage', '@Url.Action("EditExercise", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        $(document).on('submit', '#deleteExerciseForm', function (e) {
            e.preventDefault();
            postForm('#deleteExerciseForm', '#btnDeleteExercise', '#deleteExerciseMessage', '@Url.Action("DeleteExercise", "TrainingProgramBuilder", new { area = "Admin" })');
        });

        //====================================================
        // Select2 — رویداد باز شدن هر مودال
        //====================================================

        $(document).ready(function () {

            // مودال افزودن روز
            $('#addDayModal').on('shown.bs.modal', function () {
                initSelect2InModal('#AddDay_DayTypeId', '#addDayModal', null);
            });

            // مودال ویرایش روز
            $('#editDayModal').on('shown.bs.modal', function () {
                var val = $('#EditDay_DayTypeId').attr('data-current-val');
                initSelect2InModal('#EditDay_DayTypeId', '#editDayModal', val);
            });

            // مودال افزودن حرکت
            $('#addExerciseModal').on('shown.bs.modal', function () {
                initSelect2InModal('#AddExercise_ExerciseId', '#addExerciseModal', null);
            });

            // مودال ویرایش حرکت
            $('#editExerciseModal').on('shown.bs.modal', function () {
                var val = $('#EditExercise_ExerciseId').attr('data-current-val');
                initSelect2InModal('#EditExercise_ExerciseId', '#editExerciseModal', val);
            });

        });

        //====================================================
        // Drag & Drop ترتیب حرکات هر روز
        //====================================================

        $(document).ready(function () {

            document.querySelectorAll('[id^="exerciseList_"]').forEach(function (tbody) {

                new Sortable(tbody, {
                    handle: '.drag-handle',
                    animation: 150,
                    onEnd: function (evt) {

                        var items = [];
                        tbody.querySelectorAll('tr[data-item-id]').forEach(function (row, index) {
                            items.push({
                                Id: parseInt(row.getAttribute('data-item-id'), 10),
                                SortOrder: index + 1
                            });
                        });

                        $.ajax({
                            url: '@Url.Action("ReorderExercises", "TrainingProgramBuilder", new { area = "Admin" })',
                            type: 'POST',
                            contentType: 'application/json',
                            headers: {
                                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                            },
                            data: JSON.stringify(items),
                            success: function (res) {
                                if (!res.isSuccess) {
                                    Swal.fire('هشدار', res.message || 'خطا در ذخیره ترتیب', 'warning');
                                }
                            },
                            error: function () {
                                Swal.fire('خطا', 'خطا در ارتباط با سرور', 'error');
                            }
                        });

                        tbody.querySelectorAll('tr[data-item-id]').forEach(function (row, index) {
                            row.querySelector('td:nth-child(2)').innerText = (index + 1);
                        });
                    }
                });

            });

        });



                // ===================== حذف همه روزهای تمرینی =====================

        function openDeleteAllTrainingDaysModal(programId) {
            document.getElementById('DeleteAllTrainingDays_ProgramId').value = programId;
            document.getElementById('deleteAllTrainingDaysMessage').innerHTML = '';
            $('#deleteAllTrainingDaysModal').modal('show');
        }

        function submitDeleteAllTrainingDays() {
            var $btn = $('#btnConfirmDeleteAllTrainingDays');
            var $msg = $('#deleteAllTrainingDaysMessage');
            var originalText = $btn.html();

            $btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin me-1"></i> در حال حذف...');
            $msg.html('');

            var programId = $('#DeleteAllTrainingDays_ProgramId').val();
            var token = $('#deleteAllTrainingDaysForm input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '/Admin/TrainingProgramBuilder/DeleteAllDays',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    TrainingProgramId: programId
                },
                success: function (response) {
                    if (response.isSuccess) {
                        $msg.html('<div class="alert alert-success mb-0 py-2" style="font-size:12px;border-radius:8px;">' +
                            '<i class="fa fa-check-circle me-1"></i> ' + response.message + '</div>');
                        setTimeout(function () {
                            $('#deleteAllTrainingDaysModal').modal('hide');
                            location.reload();
                        }, 800);
                    } else {
                        $msg.html('<div class="alert alert-danger mb-0 py-2" style="font-size:12px;border-radius:8px;">' +
                            '<i class="fa fa-times-circle me-1"></i> ' + (response.message || 'خطایی رخ داد.') + '</div>');
                        $btn.prop('disabled', false).html(originalText);
                    }
                },
                error: function (xhr) {
                    var errMsg = 'خطایی در ارتباط با سرور رخ داد.';
                    try {
                        var json = xhr.responseJSON;
                        if (json && json.message) errMsg = json.message;
                    } catch (ex) { }
                    $msg.html('<div class="alert alert-danger mb-0 py-2" style="font-size:12px;border-radius:8px;">' +
                        '<i class="fa fa-times-circle me-1"></i> ' + errMsg + '</div>');
                    $btn.prop('disabled', false).html(originalText);
                }
            });
        }


        function sendProgramNotificationToUser(programId) {

            // ۱. نمایش پنجره تایید با SweetAlert
            Swal.fire({
                title: 'ارسال اطلاع‌رسانی',
                text: "آیا از ارسال اطلاع‌رسانی به کاربر در ربات بله مطمئن هستید؟",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#00C896',
                cancelButtonColor: '#d33',
                confirmButtonText: 'بله، ارسال شود',
                cancelButtonText: 'انصراف'
            }).then((result) => {

                // ۲. اگر کاربر روی دکمه تایید کلیک کرد
                if (result.isConfirmed) {

                    // گرفتن توکن امنیتی
                    var token = $('input[name="__RequestVerificationToken"]').val();

                    // ۳. شروع درخواست AJAX
                    $.ajax({
                        url: '/Admin/TrainingProgramBuilder/SendNotification', // آدرس دقیق شما
                        type: 'POST',
                        data: {
                            __RequestVerificationToken: token,
                            programId: programId
                        },
                        success: function (response) {
                            if (response.isSuccess) {
                                Swal.fire({
                                    title: 'موفق!',
                                    text: response.message,
                                    icon: 'success',
                                    confirmButtonColor: '#00C896'
                                });
                            } else {
                                Swal.fire({
                                    title: 'انجام نشد!',
                                    text: response.message,
                                    icon: 'warning',
                                    confirmButtonColor: '#f6ad55'
                                });
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire({
                                title: 'خطای سرور!',
                                text: 'درخواست با خطا مواجه شد. (شماره خطا: ' + xhr.status + ')',
                                icon: 'error',
                                confirmButtonColor: '#d33'
                            });
                        }
                    });
                }
            });
        }







        // ============================================================
        // فیلتر گروه عضلانی در مودال افزودن حرکت
        // ============================================================
        var _allExerciseOptions = [];

         $(document).ready(function () {
            // جمع‌آوری تمام آپشن‌های حرکت همراه با MuscleGroupId
            $('#AddExercise_ExerciseId option:not(:first)').each(function () {
                _allExerciseOptions.push({
                    value: $(this).val(),
                    text: $(this).text(),
                    muscleId: $(this).attr('data-muscle-id') || ''
                });
            });
        });

        // بازسازی لیست حرکات بر اساس فیلتر
        function rebuildExerciseOptions(selectedMuscleId) {
            var $exerciseSelect = $('#AddExercise_ExerciseId');
            var currentVal = $exerciseSelect.val();

            // حذف همه آپشن‌ها به جز placeholder اول
            $exerciseSelect.find('option:not(:first)').remove();

            var filteredCount = 0;
            var optionsHtml = '';

            for (var i = 0; i < _allExerciseOptions.length; i++) {
                var opt = _allExerciseOptions[i];

                // اگر فیلتری انتخاب نشده یا عضله مطابقت دارد
                if (!selectedMuscleId || String(opt.muscleId) === String(selectedMuscleId)) {
                    var selected = (opt.value === currentVal) ? ' selected' : '';
                    optionsHtml += '<option value="' + opt.value + '" data-muscle-id="' + opt.muscleId + '"' + selected + '>' + opt.text + '</option>';
                    filteredCount++;
                }
            }

            $exerciseSelect.append(optionsHtml);

            // اگر مقدار قبلی در لیست فیلترشده نبود، ریست کن
            if (currentVal && !$exerciseSelect.find('option[value="' + currentVal + '"]').length) {
                $exerciseSelect.val('');
            }

            // آپدیت select2
            $exerciseSelect.trigger('change');

            // نمایش تعداد نتایج
            var $countBadge = $('#exerciseFilterCount');
            if (selectedMuscleId) {
                $countBadge.text(filteredCount + ' حرکت');
                $countBadge.show();
                $('#btnClearMuscleGroupFilter').show();
            } else {
                $countBadge.hide();
                $('#btnClearMuscleGroupFilter').hide();
            }
        }

        // تغییر فیلتر گروه عضلانی
         $(document).on('change', '#MuscleGroupFilter', function () {
            rebuildExerciseOptions($(this).val());
        });

        // دکمه حذف فیلتر
         $(document).on('click', '#btnClearMuscleGroupFilter', function () {
            $('#MuscleGroupFilter').val('');
            rebuildExerciseOptions('');
        });

        // ریست کامل فیلتر هنگام باز شدن مودال
         $(document).on('shown.bs.modal', '#addExerciseModal', function () {
            $('#MuscleGroupFilter').val('');
            $('#btnClearMuscleGroupFilter').hide();
            $('#exerciseFilterCount').hide();

            // بازسازی مجدد آرایه
            _allExerciseOptions = [];
            $('#AddExercise_ExerciseId option:not(:first)').each(function () {
                _allExerciseOptions.push({
                    value: $(this).val(),
                    text: $(this).text(),
                    muscleId: $(this).attr('data-muscle-id') || ''
                });
            });

            rebuildExerciseOptions('');
        });



                function openImageModal(src) {
