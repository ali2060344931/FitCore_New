                    justify-content-between align-items-start
                    align-items-lg-center gap-3">

                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <div class="program-icon-box">
                            <i class="fa fa-heartbeat"></i>
                        </div>
                        <div class="program-main-title">
                            مدیریت ساختار برنامه تمرینی
                        </div>
                        <span class="badge day-count-badge">
                            برای <span class="day-count-number">@(program.Days?.Count ?? 0)</span> روز
                        </span>
                        <div class="d-flex align-items-center gap-1 flex-wrap">
                            <span class="badge structure-badge">روزها</span>
                            <i class="fa fa-angle-left breadcrumb-arrow"></i>
                            <span class="badge structure-badge active">حرکات</span>
                        </div>
                    </div>

                    <!-- متادیتای برنامه -->
                    <div class="program-meta-container d-flex align-items-center gap-2 flex-wrap">


                        <div class="program-meta-item">
                            @if (!string.IsNullOrEmpty(memberImgUrl))
                            {
                                <!-- نمایش عکس پرسنلی اگر وجود داشت -->
                                @* <div style="width: 32px; height: 32px; border-radius: 50%; background: url('@memberImgUrl') center/cover no-repeat; border: 2px solid #e2e8f0; flex-shrink: 0;"></div> *@
                                <div style="width: 32px; height: 32px; border-radius: 50%; background: url('@memberImgUrl') center/cover no-repeat; border: 2px solid #e2e8f0; flex-shrink: 0; cursor: pointer;" onclick="openImageModal('@memberImgUrl')"></div>
                            }
                            else
                            {
                                <!-- نمایش آیکون پیش‌فرض اگر عکسی نبود -->
                                <i class="fa-user meta-icon"></i>
                            }
                            <span class="meta-label">عضو:</span>
                            <span class="meta-value-Fullmamu">@program.MemberName</span>
                            @if (Model.MemberAge.HasValue)
                            {
                                <span class="badge px-2 py-1 rounded-pill"
                                      style="font-size:11px; background-color: #000000; color: #ffffff; border: 1px solid #333;">
                                    🎂 سن: @Model.MemberAge سال
                                </span>
                            }
                        </div>




                        @* <div class="program-meta-item">
                            <i class="fa-user meta-icon"></i>
                            <span class="meta-label">عضو:</span>
                            <span class="meta-value-Fullmamu">@program.MemberName</span>
                            @if (Model.MemberAge.HasValue)
                            {
                                <span class="badge px-2 py-1 rounded-pill"
                                      style="font-size:11px; background-color: #000000; color: #ffffff; border: 1px solid #333;">
                                    🎂 سن: @Model.MemberAge سال
                                </span>
                            }
                        </div>  *@





                        <div class="program-meta-item">
                            <span class="meta-label">عنوان:</span>
                            <span class="meta-value">@program.Title</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">نوع:</span>
                            <span class="meta-value">@program.TrainingProgramType</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">هدف:</span>
                            <span class="meta-value">@program.TrainingGoalType</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">شروع:</span>
                            <span class="meta-value">@program.StartDate</span>
                        </div>
                        <div class="program-meta-item">
                            <span class="meta-label">پایان:</span>
                            <span class="meta-value">@program.EndDate</span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2">

                        @if (!string.IsNullOrEmpty(frontImg))
                        {
                            <div class="body-photo"
                                 title="نمای روبرو"
                                 style="background-image:url('@frontImg')"
                                 onclick="openImageModal('@frontImg')">
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(sideImg))
                        {
                            <div class="body-photo"
                                 title="نمای پهلو"
                                 style="background-image:url('@sideImg')"
                                 onclick="openImageModal('@sideImg')">
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(backImg))
                        {
                            <div class="body-photo"
                                 title="نمای پشت"
                                 style="background-image:url('@backImg')"
                                 onclick="openImageModal('@backImg')">
                            </div>
