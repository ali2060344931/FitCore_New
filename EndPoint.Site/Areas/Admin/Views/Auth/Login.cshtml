@{
    ViewData["Title"] = "ورود";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ورود | FitCore</title>
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/font-awesome.min.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/materialdesignicons.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/bootstrap.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/main.css">
    <link rel="stylesheet" href="~/css/FitCorecss.css">
    <link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-8 col-xs-12 mx-auto">
                <section class="page-account-box">
                    <div class="ds-userlogin">
                        <a href="#" class="account-box-logo">FitCore</a>
                        <div class="account-box">
                            <div class="account-box-headline">
                                <a href="#" class="login-ds active"><span class="title">ورود</span></a>
                                <a href="~/admin/Auth/Register" class="register-ds"><span class="title">ثبت نام</span></a>
                            </div>

                            <div class="account-box-content">
                                <!-- مرحله 1: دریافت شماره موبایل -->
                                <div id="stepMobile">
                                    <h4>ورود به حساب کاربری</h4>
                                    <div class="form-account-title"><label>شماره موبایل</label></div>
                                    <input type="text" id="mobile" class="number-email-input" placeholder="09xxxxxxxxx">

                                    <div class="row mt-3">
                                        <div class="col-6">
                                            <button onclick="SendOtp()" class="btn btn-primary btn-login w-100">ارسال کد تایید</button>
                                        </div>
                                        <div class="col-6">
                                            <button onclick="showPasswordSection()" class="btn btn-outline-primary btn-login w-100">ورود با رمز</button>
                                        </div>
                                    </div>
                                </div>

                                <!-- مرحله 2 (الف): ورود با رمز عبور -->
                                <div id="stepPassword" style="display:none;">
                                    <h4>ورود با رمز عبور</h4>
                                    <p>شماره موبایل: <b class="user-mobile-label"></b></p>
                                    <div class="form-account-title"><label>رمز عبور</label></div>
                                    <input type="password" id="loginPassword" class="number-email-input">
                                    <button onclick="LoginWithPassword()" class="btn btn-primary btn-login w-100 mt-3">تایید و ورود</button>
                                    <button onclick="EditMobile()" class="btn btn-link w-100 mt-2">تغییر شماره موبایل</button>
                                </div>

                                <!-- مرحله 2 (ب): ورود با کد تایید (OTP) -->
                                <div id="stepVerify" style="display:none;">
                                    <h4>تایید کد ارسال شده</h4>
                                    <p>کد تایید برای شماره <b class="user-mobile-label"></b> ارسال شد.</p>
                                    <div class="form-account-title"><label>کد ۵ رقمی</label></div>
                                    <input type="text" id="code" class="number-email-input text-center" style="letter-spacing: 10px;" placeholder="-----">
                                    <button onclick="VerifyOtp()" class="btn btn-success btn-login w-100 mt-3">بررسی کد</button>
                                    <button onclick="EditMobile()" class="btn btn-link w-100 mt-2">تغییر شماره یا روش ورود</button>
                                </div>

                                <!-- مرحله 3: انتخاب باشگاه (فقط برای کاربران چند باشگاهی) -->
                                <div id="gymSelectionBox" style="display:none;">
                                    <h4>انتخاب باشگاه</h4>
                                    <p>شما در چند باشگاه عضو هستید، یکی را انتخاب کنید:</p>
                                    <div class="form-account-title"><label>لیست باشگاه‌ها</label></div>
                                    <select id="gymSelect" class="form-control mb-3"></select>
                                    <input type="hidden" id="hdnLoginToken" />
                                    <button onclick="CompleteLogin()" class="btn btn-info btn-login w-100">ورود نهایی</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <script src="~/SiteTemplate/assets/js/vendor/jquery-3.2.1.min.js"></script>
    <script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>

    <script>
        // متغیر کمکی برای نگهداری موبایل در تمام مراحل
        function getMobile() { return $("#mobile").val(); }

        function showPasswordSection() {
            var m = getMobile();
            if (!m) { Swal.fire('خطا', 'لطفا ابتدا شماره موبایل را وارد کنید', 'warning'); return; }
            $(".user-mobile-label").text(m);
            $("#stepMobile").hide();
            $("#stepPassword").show();
        }

        function EditMobile() {
            $("#stepPassword, #stepVerify, #gymSelectionBox").hide();
            $("#stepMobile").show();
        }

        // ۱. ارسال OTP
        function SendOtp() {
            var mobile = getMobile();
            if (!mobile) { Swal.fire('خطا', 'شماره موبایل الزامی است', 'error'); return; }

            $.post("/Admin/Auth/SendOtpLogin", { mobile: mobile }, function (res) {
                if (res.isSuccess) {
                    $(".user-mobile-label").text(mobile);
                    $("#stepMobile").hide();
                    $("#stepVerify").show();
                } else { Swal.fire('خطا', res.message, 'error'); }
            });
        }

        // ۲. تایید OTP
        function VerifyOtp() {
            $.post("/Admin/Auth/VerifyOtp", { mobile: getMobile(), code: $("#code").val() }, function (res) {
                if (res.isSuccess) {
                    processLoginResponse(res);
                } else { Swal.fire('خطا', res.message, 'error'); }
            });
        }

        // ۳. ورود با پسورد (نیاز به اکشن در بک‌اند دارد)
        function LoginWithPassword() {
            $.post("/Admin/Auth/LoginWithPassword", { Mobile: getMobile(), Password: $("#loginPassword").val() }, function (res) {
                if (res.isSuccess) {
                    processLoginResponse(res);
                } else { Swal.fire('خطا', res.message, 'error'); }
            });
        }

        // تابع مشترک برای مدیریت پاسخ لاگین (باشگاه یا ریدایرکت)
        function processLoginResponse(res) {
            if (res.needGymSelection) {
                $("#stepVerify, #stepPassword").hide();
                $("#gymSelectionBox").show();
                $("#hdnLoginToken").val(res.loginToken); // توکن را برای مرحله آخر ذخیره می‌کنیم
                $("#gymSelect").empty();
                res.gyms.forEach(g => {
                    $("#gymSelect").append(new Option(g.name, g.id));
                });
            } else {
                window.location.href = "/Admin/Home/Index";
            }
        }

        // ۴. انتخاب نهایی باشگاه
        function CompleteLogin() {
            var dto = {
                LoginToken: $("#hdnLoginToken").val(),
                GymId: $("#gymSelect").val()
            };
            $.post("/Admin/Auth/CompleteLogin", dto, function (res) {
                if (res.isSuccess) {
                    window.location.href = "/Admin/Home/Index";
                } else { Swal.fire('خطا', res.message, 'error'); }
            });
        }
    </script>
</body>
</html>
