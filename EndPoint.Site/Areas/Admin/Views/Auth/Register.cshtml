@using FitCore.Application.Services.Auth
@model RegisterUserViewModel

@{
    ViewData["Title"] = "Register";
    Layout = null; // اگر این صفحه نیاز به Layout اصلی ندارد، این خط صحیح است.
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ثبت نام</title>
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/font-awesome.min.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/materialdesignicons.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/bootstrap.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/main.css">
    <link rel="stylesheet" href="~/css/FitCorecss.css">
</head>
<body>
    <div class="container">
        <div class="row">
            <div class="col-lg">
                <section class="page-account-box">
                    <div class="col-lg-6 col-md-8 col-xs-12 mx-auto">
                        <div class="ds-userlogin">
                            <a href="#" class="account-box-logo">FitCore</a>
                            <div class="account-box">
                                <div class="account-box-headline">
                                    <a href="~/admin/Auth/Login" class="login-ds"><span class="title">ورود</span><span class="sub-title">ورود به حساب</span></a>
                                    <a href="#" class="register-ds active"><span class="title">ثبت نام</span><span class="sub-title">ایجاد حساب</span></a>
                                </div>
                                <div class="Login-to-account mt-4">
                                    <div class="account-box-content">
                                        <h4>ثبت نام کاربر جدید</h4>
                                        <div class="form-account text-right">

                                            <div id="registrationForm">
                                                <div class="form-account-title">
                                                    <label>نام و نام خانوادگی</label>
                                                    <input type="text" class="number-email-input" id="fullname" dir="rtl" style="text-align:right;" />
                                                </div>
                                                <div class="form-account-title">
                                                    <label>شماره موبایل</label>
                                                    <input type="text" class="number-email-input" id="mobile" inputmode="numeric" />
                                                </div>
                                                @* <div class="form-account-title">
                                                    <label>رمز عبور</label>
                                                    <input type="text" class="number-email-input" id="Password" inputmode="numeric" />
                                                </div>
                                                <div class="form-account-title">
                                                    <label>تکرار رمز عبور</label>
                                                    <input type="text" class="number-email-input" id="RePassword" inputmode="numeric" />
                                                </div> *@


                                                <partial name="~/Areas/Admin/Views/Shared/Partials/_PasswordInput.cshtml"
                                                         model='new BaseInputViewModel { Id = "Password", Name = "Password", LabelName = "رمز عبور", Col = 6, Value = Model.Password }' />

                                                <partial name="~/Areas/Admin/Views/Shared/Partials/_PasswordInput.cshtml"
                                                         model='new BaseInputViewModel { Id = "RePassword", Name = "RePassword", LabelName = "تکرار رمز عبور", Col = 6, Value = Model.RePassword }' />


                                                @* <div class="row">
                                                    <div class="col-md-6">
                                                        @await Html.PartialAsync("Partials/_PasswordInput", new {
                                                        Label = "رمز عبور",
                                                                                                                Name = "Password",
                                                                                                                Placeholder = "حداقل ۶ کاراکتر"
                                                                                                                })
                                                    </div>
                                                    <div class="col-md-6">
                                                        @await Html.PartialAsync("Partials/_PasswordInput", new {
                                                                                                                Label = "تکرار رمز عبور",
                                                                                                                Name = "RePassword",
                                                                                                                Placeholder = "رمز عبور را دوباره وارد کنید"
                                                                                                                })
                                                    </div> *@
                                                </div>
                                                <div class="form-account-title">
                                                    <label>انتخاب باشگاه</label>
                                                    <select id="gymId" class="number-email-input">
                                                        <option value="">-- انتخاب کنید --</option>
                                                        @foreach (var gym in Model.Gyms)
                                                        {
                                                            <option value="@gym.Value">@gym.Text</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="form-row-account"><button id="btnSendOtp" onclick="SendOtp()" class="btn btn-primary btn-login">ارسال کد تایید</button></div>
                                            </div>

                                            <div id="otpSection" style="display:none;">
                                                <hr />
                                                <div class="form-account-title"><label>کد تایید</label><input type="text" class="number-email-input" id="code" inputmode="numeric" /></div>
                                                <div class="form-row-account"><button id="btnRegister" onclick="RegisterUser()" class="btn btn-success btn-login">ثبت نام</button></div>
                                                <div class="helper-row">
                                                    <span id="resendInfo"></span>
                                                    <a id="btnResend" class="muted" onclick="ResendOtp()" style="display:none;">ارسال مجدد کد</a>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</body>

<script src="~/SiteTemplate/assets/js/vendor/jquery-3.2.1.min.js"></script>
<script src="~/SiteTemplate/assets/js/vendor/bootstrap.js"></script>
<link href="~/lib/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
<script src="~/lib/Sweetalert2/sweetalert2.min.js"></script>
</html>

<script>
    var resendTimerId = null;
    var timerSeconds = 60; // زمان اولیه برای شمارش معکوس

    // تابع برای مدیریت وضعیت بارگذاری دکمه
    function setBtnLoading(id, loading, text) {
    var $btn = $("#" + id);
    // ذخیره متن اصلی دکمه اگر قبلاً ذخیره نشده باشد
    if (!$btn.data("orig")) {
    $btn.data("orig", $btn.text());
    }
    $btn.prop("disabled", loading).text(loading ? (text || "در حال انجام...") : $btn.data("orig"));
    }

    // تابع برای ارسال کد تایید
    function SendOtp() {
    var mobile = $("#mobile").val();
    var fullname = $("#fullname").val();
    var gymId = $("#gymId").val();

    // اعتبارسنجی نام
    if (!fullname || fullname.trim().length < 3) {
    swal.fire('خطا!', 'لطفاً نام و نام خانوادگی معتبر وارد کنید.', 'warning');
    return;
    }

    // اعتبارسنجی انتخاب باشگاه
    if (!gymId) {
    swal.fire('خطا!', 'لطفاً یک باشگاه انتخاب کنید.', 'warning');
    return;
    }

    // اعتبارسنجی موبایل
    if (!/^09\d{9}$/.test(mobile)) {
    swal.fire('خطا!', 'شماره موبایل وارد نشده یا نامعتبر است.', 'warning');
    return;
    }

    setBtnLoading("btnSendOtp", true, "در حال ارسال...");

    $.post("/admin/Auth/SendOtpReg", {
    FullName: fullname,
    mobile: mobile,
    gymId: gymId
    }, function (data) {
    setBtnLoading("btnSendOtp", false); // بازگرداندن دکمه به حالت عادی

    if (data.isSuccess) {
    swal.fire('موفق!', data.message, 'success');
    $("#registrationForm").hide(); // پنهان کردن فرم ثبت نام
    $("#otpSection").show();       // نمایش بخش کد تایید
    startTimer();                  // شروع شمارش معکوس
    } else {
    swal.fire('خطا!', data.message, 'warning');
    }
    }).fail(function() { // اضافه کردن مدیریت خطا برای درخواست AJAX
    setBtnLoading("btnSendOtp", false);
    swal.fire('خطا!', 'خطایی در ارسال درخواست رخ داد. لطفاً دوباره تلاش کنید.', 'error');
    });
    }

    // تابع برای شروع شمارش معکوس
    function startTimer() {
    timerSeconds = 60; // بازنشانی زمان شمارش معکوس
    $("#btnResend").hide(); // مخفی کردن دکمه ارسال مجدد
    $("#resendInfo").text("ارسال مجدد تا " + timerSeconds + " ثانیه"); // نمایش پیام اولیه

    // پاکسازی تایمر قبلی اگر وجود دارد
    if (resendTimerId) {
    clearInterval(resendTimerId);
    }

    resendTimerId = setInterval(function () {
    timerSeconds--;
    if (timerSeconds >= 0) {
    $("#resendInfo").text("ارسال مجدد تا " + timerSeconds + " ثانیه");
    } else {
    clearInterval(resendTimerId); // توقف تایمر
    $("#resendInfo").text("");    // پاک کردن پیام شمارش معکوس
    $("#btnResend").show();       // نمایش دکمه ارسال مجدد
    }
    }, 1000); // اجرای هر 1000 میلی‌ثانیه (1 ثانیه)
    }

    // تابع برای ارسال مجدد کد تایید
    function ResendOtp() {
    // با کلیک بر روی ارسال مجدد، تابع SendOtp دوباره فراخوانی می‌شود
    // این تابع خودش اعتبارسنجی‌ها و ارسال مجدد را انجام می‌دهد
    // و همچنین تایمر را دوباره شروع می‌کند.
    SendOtp();
    }

    // تابع برای ثبت نام نهایی کاربر
    function RegisterUser() {
    var code = $("#code").val();
    var mobile = $("#mobile").val(); // نیاز به موبایل برای ارسال به سرور
    var password = $("#password").val(); // دریافت پسورد

    // اعتبارسنجی کد تایید
    if (!code || code.trim().length === 0) {
    swal.fire('خطا!', 'لطفاً کد تایید را وارد کنید.', 'warning');
    return;
    }

    setBtnLoading("btnRegister", true, "در حال ثبت...");
    $.post("/admin/Auth/RegisterUser", {
    fullName: $("#fullname").val(), // نام و نام خانوادگی همچنان لازم است
    mobile: mobile,
    code: code,
     password: password, // ارسال پسورد
    gymId: $("#gymId").val() // شناسه باشگاه نیز لازم است
    }, function (data) {
    if (data.isSuccess) {
    swal.fire('موفق!', data.message, 'success').then(() => {
    // پس از موفقیت، کاربر به صفحه اصلی هدایت می‌شود
    window.location.href = "/";
    });
    } else {
    swal.fire('خطا!', data.message, 'warning');
    setBtnLoading("btnRegister", false); // بازگرداندن دکمه به حالت عادی در صورت خطا
    }
    }).fail(function() { // مدیریت خطا برای درخواست AJAX
    setBtnLoading("btnRegister", false);
    swal.fire('خطا!', 'خطایی در ثبت نام رخ داد. لطفاً دوباره تلاش کنید.', 'error');
    });
    }

    // اختیاری: اگر می‌خواهید وقتی صفحه لود می‌شود، دکمه ارسال کد غیرفعال باشد تا زمانی که اطلاعات وارد شوند،
    // می‌توانید منطقی به این بخش اضافه کنید. فعلاً فرض بر این است که دکمه فعال است.



</script>
