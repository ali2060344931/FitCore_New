@using FitCore.Application.Services.Auth
@model RegisterUserViewModel

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ثبت نام</title>
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/font-awesome.min.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/materialdesignicons.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/vendor/bootstrap.css">
    <link rel="stylesheet" href="~/SiteTemplate/assets/css/main.css">
    <style>
            .btn[disabled] {
                opacity: .65;
                cursor: not-allowed;
            }

            .helper-row {
                margin-top: 8px;
                font-size: 12px;
                color: #666;
            }

            .muted {
                color: #777;
                cursor: pointer;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="row">
            <div class="col-lg">
                <section class="page-account-box">
                    <div class="col-lg-6 col-md-8 col-xs-12 mx-auto">
                        <div class="ds-userlogin">
                            <a href="#" class="account-box-logo">FitCore</a>
                            <div class="account-box">
                                <div class="account-box-headline">
                                    <a href="~/admin/Auth/Login" class="login-ds"><span class="title">ورود</span><span class="sub-title">ورود به حساب</span></a>
                                    <a href="#" class="register-ds active"><span class="title">ثبت نام</span><span class="sub-title">ایجاد حساب</span></a>
                                </div>
                                <div class="Login-to-account mt-4">
                                    <div class="account-box-content">
                                        <h4>ثبت نام کاربر جدید</h4>
                                        <div class="form-account text-right">

                                            <div id="registrationForm">
                                                <div class="form-account-title">
                                                    <label>نام و نام خانوادگی</label>
                                                    <input type="text" class="number-email-input" id="fullname" dir="rtl"  style="text-align:right;" />

                                                </div>
                                                <div class="form-account-title">
                                                    <label>شماره موبایل</label><input type="text" class="number-email-input" id="mobile" inputmode="numeric" />
                                                </div>
                                                <div class="form-account-title">
                                                    <label>انتخاب باشگاه</label><select id="gymId" class="number-email-input">
                                                    <option value="">-- انتخاب کنید --</option>@foreach (var gym in Model.Gyms){
                                                    <option value="@gym.Value">@gym.Text</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="form-row-account"><button id="btnSendOtp" onclick="SendOtp()" class="btn btn-primary btn-login">ارسال کد تایید</button></div>
                                    </div>

                                    <div id="otpSection" style="display:none;">
                                        <hr />
                                        <div class="form-account-title"><label>کد تایید</label><input type="text" class="number-email-input" id="code" inputmode="numeric" /></div>
                                        <div class="form-row-account"><button id="btnRegister" onclick="RegisterUser()" class="btn btn-success btn-login">ثبت نام</button></div>
                                        <div class="helper-row"><span id="resendInfo"></span> <a id="btnResend" class="muted" onclick="ResendOtp()" style="display:none;">ارسال مجدد کد</a></div>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>
</div>
</body>

<script src="~/SiteTemplate/assets/js/vendor/jquery-3.2.1.min.js"></script>
<script src="~/SiteTemplate/assets/js/vendor/bootstrap.js"></script>
<link href="~/Sweetalert2/sweetalert2.min.css" rel="stylesheet" />
<script src="~/Sweetalert2/sweetalert2.min.js"></script>


<script>
    var resendTimerId = null;

    function setBtnLoading(id, loading, text) {
    var $btn = $("#" + id);
    $btn.prop("disabled", loading).text(loading ? (text || "در حال انجام...") : $btn.data("orig"));
    if (!loading && !$btn.data("orig")) $btn.data("orig", $btn.text());
    }



    function SendOtp() {

    var mobile = $("#mobile").val();
    var fullname = $("#fullname").val();
    var gymId = $("#gymId").val();

    // اعتبارسنجی نام
    if (!fullname || fullname.trim().length < 3) {
    swal.fire('خطا!', 'لطفاً نام و نام خانوادگی معتبر وارد کنید.', 'warning');
    return;
    }

    // اعتبارسنجی انتخاب باشگاه
    if (!gymId) {
    swal.fire('خطا!', 'لطفاً یک باشگاه انتخاب کنید.', 'warning');
    return;
    }

    // اعتبارسنجی موبایل
    if (!/^09\d{9}$/.test(mobile)) {
    swal.fire('خطا!', 'شماره موبایل وارد نشده یا نامعتبر است.', 'warning');
    return;
    }

    setBtnLoading("btnSendOtp", true, "در حال ارسال...");

    $.post("/admin/Auth/SendOtpReg", {
    FullName: fullname,
    mobile: mobile,
    gymId: gymId
    }, function (data) {

    setBtnLoading("btnSendOtp", false);

    if (data.isSuccess) {
    swal.fire('موفق!', data.message, 'success');
    $("#registrationForm").hide();
    $("#otpSection").show();
    startTimer();
    } else {
    swal.fire('خطا!', data.message, 'warning');
    }
    });
    }

    function startTimer() {
    var sec = 60;
    $("#btnResend").hide();
    resendTimerId = setInterval(function () {
    $("#resendInfo").text("ارسال مجدد تا " + sec + " ثانیه");
    if (--sec < 0) {
    clearInterval(resendTimerId);
    $("#resendInfo").text("");
    $("#btnResend").show();
    }
    }, 1000);
    }

    function ResendOtp() { SendOtp(); }

    function RegisterUser() {
    setBtnLoading("btnRegister", true, "در حال ثبت...");
    $.post("/admin/Auth/RegisterUser", {
    fullName: $("#fullname").val(),
    mobile: $("#mobile").val(),
    code: $("#code").val(),
    gymId: $("#gymId").val()
    }, function (data) {
    if (data.isSuccess) {
    swal.fire('موفق!', data.message, 'success').then(() => window.location.href = "/");
    } else {
    swal.fire('خطا!', data.message, 'warning');
    setBtnLoading("btnRegister", false);
    }
    });
    }
</script>
</html>
